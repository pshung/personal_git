# Default mmap size used by every e2e fixture and demo. Exposed via
# --mmap-size for unusual workloads.
_DEFAULT_MMAP_SIZE = 128 * 1024 * 1024


def _load_checkpoint_module():
    """Lazy-add tools/ to sys.path and return orchestrator.checkpoint.

    Kept lazy so an unrelated subcommand (e.g. `./hsim list`) does not
    pay the ctypes layout check at module load time.
    """
    tools_dir = str(REPO_ROOT / "tools")
    if tools_dir not in sys.path:
        sys.path.insert(0, tools_dir)
    from orchestrator import checkpoint
    return checkpoint


def cmd_archive(args: argparse.Namespace) -> int:
    state = Path(args.state)
    mmap_file = Path(args.mmap)
    if not state.is_file():
        print(f"hsim: state file not found: {args.state}", file=sys.stderr)
        return 2
    if not mmap_file.is_file():
        print(f"hsim: mmap file not found: {args.mmap}", file=sys.stderr)
        return 2

    snap = Path(args.output)
    if args.dry_run:
        print(
            f"archive: state={state} mmap={mmap_file} elf={args.elf} "
            f"mmap_size={args.mmap_size} -> {snap}"
        )
        return 0

    # In-process import: hsim and orchestrator are both Python, so a
    # `python3 -c` subprocess wrapper (as the bash demos use) just adds
    # interpreter startup latency and obscures tracebacks.
    checkpoint = _load_checkpoint_module()
    try:
        checkpoint.write_archive(
            snap,
            state_path=state,
            mmap_path=mmap_file,
            mmap_size=args.mmap_size,
            elf_path=args.elf,
            source_step_index=0,
        )
    except Exception as exc:
        print(f"hsim: write_archive failed: {exc}", file=sys.stderr)
        return 1

    print(f"archive: {snap}/{{state.bin,mem,meta.json}}")
    return 0


def cmd_replay(args: argparse.Namespace) -> int:
    snap = Path(args.snap)
    if not snap.is_dir():
        print(f"hsim: snapshot directory not found: {args.snap}",
              file=sys.stderr)
        return 2

    artifacts = _resolve_artifacts()
    for label, path in artifacts.items():
        if not path.is_file():
            print(f"hsim: {label} not built -- run ./hsim build",
                  file=sys.stderr)
            return 2

    argv = [
        sys.executable, "-m", "orchestrator.main", "replay-checkpoint",
        str(snap),
        "--resume-with", args.resume_with,
        "--project-root", str(REPO_ROOT),
    ]
    if args.dry_run:
        print(f"exec: {shlex.join(argv)}")
        return 0

    env = os.environ.copy()
    existing_pp = env.get("PYTHONPATH", "")
    tools_dir = str(REPO_ROOT / "tools")
    env["PYTHONPATH"] = (
