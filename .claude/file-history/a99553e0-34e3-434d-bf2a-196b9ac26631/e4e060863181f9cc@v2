def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="hsim",
        description="End-user driver for the Andes hybrid simulator (QEMU + vsim).",
    )
    sub = parser.add_subparsers(dest="cmd", metavar="<cmd>")
    sub.required = True

    p_list = sub.add_parser(
        "list",
        help="list available fixtures, demos, or trigger modes",
    )
    p_list.add_argument(
        "target",
        choices=("fixtures", "demos", "modes"),
        help="what to list",
    )
    p_list.set_defaults(func=cmd_list)

    p_build = sub.add_parser(
        "build",
        help="build artifacts (qemu, vsim, plugin, simpoint, ELF fixtures)",
    )
    p_build.add_argument(
        "--what",
        choices=("all", "qemu", "vsim", "plugin", "simpoint", "fixtures"),
        default="all",
        help="which target to build (default: all)",
    )
    p_build.add_argument(
        "--dry-run",
        action="store_true",
        help="print the underlying commands without executing",
    )
    p_build.set_defaults(func=cmd_build)

    p_run = sub.add_parser(
        "run",
        help="run one ELF through the QEMU -> vsim -> QEMU round-trip",
    )
    p_run.add_argument(
        "elf",
        help="path to a RISC-V ELF (relative or absolute)",
    )
    p_run.add_argument(
        "--mode",
        choices=("csr", "pc", "icount", "slice"),
        required=True,
        help=(
            "trigger mode: csr (csrwi 0x7C0,{0,1}) or pc (ELF symbols) "
            "use tests/e2e.sh; icount and slice spawn QEMU+vsim directly "
            "for CSR-less workloads"
        ),
    )
    p_run.add_argument(
        "-v", "--verbose",
        action="store_true",
        help="print resolved env and command before launching",
    )
    p_run.add_argument(
        "--qemu-icount", dest="qemu_icount", type=int, default=10000,
        help=(
            "QEMU plugin icount target (default: 10000; --mode icount uses "
            "this as the drain target, --mode slice uses it as the safety "
            "upper bound)"
        ),
    )
    p_run.add_argument(
        "--vsim-icount", dest="vsim_icount", type=int, default=5000,
        help=(
            "vsim --hybrid-icount drain target (default: 5000; "
            "--mode icount and --mode slice only)"
        ),
    )
    p_run.add_argument(
        "--slice", dest="slice", type=int, default=1000,
        help="insns per slice (default: 1000; --mode slice only)",
    )
    p_run.add_argument(
        "--slice-at", dest="slice_at", type=int, default=1,
        help="0-based slice index to drain at (default: 1; --mode slice only)",
    )
    p_run.add_argument(
        "--mmap-size", dest="mmap_size", type=_parse_mmap_size,
        default=_DEFAULT_MMAP_SIZE,
        help=(
            f"shared mmap size (default: 128M; accepts SPEC like 8G, 512M, "
            f"1024). Honored for --mode icount/slice; csr/pc use tests/e2e.sh "
            f"which has its own 128 MiB default. Set HSIM_MMAP_DIR=/path to "
            f"redirect the backing file off /dev/shm."
        ),
    )
    p_run.set_defaults(func=cmd_run)

    p_test = sub.add_parser(
        "test",
        help="run the e2e test suite (wraps scripts/run_e2e.sh)",
    )
    p_test.add_argument(
        "--filter",
        default=None,
        help="regex; only run tests whose name matches",
    )
    p_test.add_argument(
        "--mode",
        choices=("csr", "pc", "both"),
        default="both",
        help="trigger mode for round-trip fixtures (default: both)",
    )
    p_test.add_argument(
        "--jobs",
        type=int,
        default=_DEFAULT_JOBS,
        help=f"parallel job slots (default: {_DEFAULT_JOBS})",
    )
    p_test.add_argument(
        "--dry-run",
        action="store_true",
        help="print resolved env and command without executing",
    )
    p_test.set_defaults(func=cmd_test)

    p_doctor = sub.add_parser(
        "doctor",
        help="env-health diagnoser (artifacts, submodules, toolchain, runtime)",
        description=(
            "Run a read-only env-health diagnose: artifacts, submodules, "
            "toolchain, runtime. Exit 0 if no FAIL row; 1 otherwise."
        ),
    )
    p_doctor.set_defaults(func=cmd_doctor)

    demo_list = ", ".join(f"{tid}={short}" for tid, short in _DEMO_ORDER)
    p_demo = sub.add_parser(
        "demo",
        help="run a milestone demo by T-id or short name (T1..T7)",
        description=(
            "Run one demo from tests/demos/demo_*.sh. Selector accepts "
            f"T-id (T1..T7), short name, or `demo_<short>`. Mapping: {demo_list}. "
            "Pass per-run env overrides after `--`, e.g. "
            "`./hsim demo T7 -- SLICE=400 MAXK=4`."
        ),
    )
    p_demo.add_argument(
        "selector",
        nargs="?",
        help="demo selector: T1..T7 or short name (e.g. csr_oneshot)",
    )
    p_demo.add_argument(
        "--dry-run",
        action="store_true",
        help="print the resolved env + command without executing",
    )
    p_demo.set_defaults(func=cmd_demo)
    # `extras` is populated by main() after splitting argv on the first `--`,
    # so argparse never sees the passthrough KEY=VAL tail. This avoids the
    # argparse.REMAINDER gotcha that swallows `--dry-run` typed after the
    # selector.

    p_profile = sub.add_parser(
        "profile",
        help="M4: QEMU + plugin BBV profile pass (writes a SimPoint .bb file)",
        description=(
            "Run one QEMU+plugin profile pass: drain at the icount limit "
            "while emitting one BBV row per `--slice` retired instructions. "
            "Output is a SimPoint-compatible .bb file ready for "
            "`./hsim cluster`."
        ),
    )
    p_profile.add_argument(
        "elf",
        help="path to a RISC-V ELF (relative or absolute)",
    )
    p_profile.add_argument(
        "--slice", dest="slice", type=int, default=1000,
        help="retired insns per BBV row (default: 1000)",
    )
    p_profile.add_argument(
        "--icount", type=int, default=10000,
        help="total retired insns before drain (default: 10000)",
    )
    p_profile.add_argument(
        "-o", "--output", required=True,
        help="BBV output file (e.g. /tmp/profile.bb)",
    )
    p_profile.add_argument(
        "--dry-run", action="store_true",
        help="print the resolved QEMU command without executing",
    )
    p_profile.add_argument(
        "--mmap-size", dest="mmap_size", type=_parse_mmap_size,
        default=_DEFAULT_MMAP_SIZE,
        help=(
            f"shared mmap size (default: 128M; accepts SPEC like 8G, 512M, "
            f"1024). Set HSIM_MMAP_DIR=/path to redirect off /dev/shm."
        ),
    )
    p_profile.set_defaults(func=cmd_profile)

    p_cluster = sub.add_parser(
        "cluster",
        help="M4: run SimPoint on a BBV file to pick representative phases",
        description=(
            "Cluster a BBV (.bb) file with tools/simpoint/bin/simpoint. "
            "Writes one slice-index per cluster to --simpts and one "
            "weight per cluster to --weights."
        ),
    )
    p_cluster.add_argument(
        "bbv",
        help="path to a BBV (.bb) file produced by `./hsim profile`",
    )
    p_cluster.add_argument(
        "--max-k", dest="max_k", type=int, default=2,
        help="SimPoint -maxK (default: 2; tiny BBVs need conservative K)",
    )
    p_cluster.add_argument(
        "--simpts", required=True,
        help="output: slice-index per cluster",
    )
    p_cluster.add_argument(
        "--weights", required=True,
        help="output: weight per cluster (sums to ~1.0)",
    )
    p_cluster.add_argument(
        "--dry-run", action="store_true",
        help="print the resolved simpoint command without executing",
    )
    p_cluster.set_defaults(func=cmd_cluster)

    p_archive = sub.add_parser(
        "archive",
        help="M6: archive a drained state into snap/N (state.bin + mem + meta.json)",
        description=(
            "Bundle a drained QEMU/vsim state file plus its /dev/shm mmap "
            "into a portable snapshot directory. Counterpart to `./hsim replay`. "
            "The state file must satisfy the v1 ABI (magic + version + size); "
            "synthesise one with `./hsim run` or `./hsim profile`."
        ),
    )
    p_archive.add_argument(
        "--state", required=True,
        help="path to a hybrid_state_v1 .bin file (from a prior drain)",
    )
    p_archive.add_argument(
        "--mmap", required=True,
        help="path to the /dev/shm mmap file used during the drain",
    )
    p_archive.add_argument(
        "--elf", required=True,
        help="ELF path stored in meta.json (e.g. tests/fixtures/rt_c_v_regs.elf)",
    )
    p_archive.add_argument(
        "--mmap-size", dest="mmap_size", type=_parse_mmap_size,
        default=_DEFAULT_MMAP_SIZE,
        help=(
            f"mmap size for the meta.json record (default: 128M; accepts "
            f"SPEC like 8G, 512M, 1024)"
        ),
    )
    p_archive.add_argument(
        "-o", "--output", required=True,
        help="snapshot directory (will be created if absent)",
    )
    p_archive.add_argument(
        "--dry-run", action="store_true",
        help="print resolved write_archive args without writing",
    )
    p_archive.set_defaults(func=cmd_archive)

    p_replay = sub.add_parser(
        "replay",
        help="M7: replay a snap/N archive (resume with vsim or qemu)",
        description=(
            "Hydrate a snapshot directory and resume the chosen model. "
            "vsim resumes from state.bin and drains on its CSR-exit trigger; "
            "qemu resumes via gdbstub and continues to workload completion."
        ),
    )
    p_replay.add_argument(
        "snap",
        help="path to a snap/N directory written by `./hsim archive`",
    )
    p_replay.add_argument(
        "--resume-with", dest="resume_with",
        choices=("vsim", "qemu"), default="vsim",
        help="model to resume the archive with (default: vsim)",
    )
    p_replay.add_argument(
        "--dry-run", action="store_true",
        help="print the resolved orchestrator command without executing",
    )
    p_replay.set_defaults(func=cmd_replay)

    p_estimate = sub.add_parser(
        "estimate",
        help="SimPoint cycle estimator: profile + cluster + per-phase mcycle delta",
        description=(
            "End-to-end SimPoint cycle estimator. Runs an M4 BBV profile "
            "pass, clusters the result with SimPoint, drains QEMU + vsim "
            "for each cluster representative slice, and aggregates a "
            "weighted CPI to produce an estimated cycle count: "
            "estimated_cycles = N_total * sum_i(w_i * CPI_i). Composes "
            "F9 (profile + cluster) and F11 (slice mode) end to end."
        ),
    )
    p_estimate.add_argument(
        "elf",
        help="path to a RISC-V ELF (relative or absolute)",
    )
    p_estimate.add_argument(
        "--slice", dest="slice", type=int, default=1000,
        help="insns per BBV row / per slice (default: 1000)",
    )
    p_estimate.add_argument(
        "--icount", type=int, default=0,
        help=(
            "total retired insns for the M4 profile pass "
            "(default: 0 means run to program exit and read minstret "
            "from the plugin atexit drain; pass a positive N to cap "
            "the profile pass at N insns and use N as the multiplier)"
        ),
    )
    p_estimate.add_argument(
        "--max-k", dest="max_k", type=int, default=2,
        help="SimPoint -maxK (default: 2; tiny BBVs need conservative K)",
    )
    p_estimate.add_argument(
        "--vsim-icount", dest="vsim_icount", type=int, default=0,
        help=(
            "vsim --hybrid-icount per phase (default: 0 -> use --slice "
            "for SimPoint-correct CPI math)"
        ),
    )
    p_estimate.add_argument(
        "--mmap-size", dest="mmap_size", type=_parse_mmap_size,
        default=_DEFAULT_MMAP_SIZE,
        help=(
            f"shared mmap size for the profile + per-phase drain pairs "
            f"(default: 128M; accepts SPEC like 8G, 512M, 1024). "
            f"Set HSIM_MMAP_DIR=/path to redirect off /dev/shm."
        ),
    )
    p_estimate.set_defaults(func=cmd_estimate)

    return parser


def main(argv: list[str]) -> int:
    if "--" in argv:
        idx = argv.index("--")
        head, tail = argv[:idx], argv[idx + 1:]
    else:
        head, tail = argv, []
    parser = build_parser()
    args = parser.parse_args(head)
    args.extras = tail
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
