# AX45MPV — RV64, Vector 1.0, 45-series, VLEN=1024

[cpu]
name = ax45mpv

[toolchain]
compiler = /local/nick/SW_Release_cp/ast530/nds64le-elf-newlib-v5d/bin/riscv64-elf-gcc
extra_cflags = -mext-vector -mtune=andes-45-series -DNDS_VEC_RVV_VERSION=1000

[sim]
wrapper = project/ax45mpv/riscv-qemu-wrapper-v1024_d1024_b512
target = QEMU

[qemu]
binary = /local/nick/qemu_andes/build/qemu-system-riscv64
cpu = andes-ax45mpv,vext_spec=v1.0,vlen=1024
vec_cfg = zve64d

[board]
ice_host = sw-boards.andestech.com
ice_port = 1116
