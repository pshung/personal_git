#!/usr/bin/env bash
# Modelzoo Ranker — train a tile configuration ranker on modelzoo benchmark data.
#
# Usage:
#   bash script/modelzoo_ranker/run.sh dataset_modelzoo/
#   bash script/modelzoo_ranker/run.sh -o tmp/my_experiment dataset_modelzoo/
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${SCRIPT_DIR}/.."

OUTPUT_DIR=""
EXTRA_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -o|--output-dir)
            OUTPUT_DIR="$2"
            shift 2
            ;;
        *)
            EXTRA_ARGS+=("$1")
            shift
            ;;
    esac
done

if [[ ${#EXTRA_ARGS[@]} -eq 0 ]]; then
    echo "Usage: $0 [-o output_dir] <dataset_dir> [extra args...]"
    exit 1
fi

DATASET_DIR="${EXTRA_ARGS[0]}"
EXTRA_ARGS=("${EXTRA_ARGS[@]:1}")

if [[ -z "$OUTPUT_DIR" ]]; then
    OUTPUT_DIR="../tmp/modelzoo_ranker"
fi

echo "=== Modelzoo Ranker ==="
echo "  Dataset:  $DATASET_DIR"
echo "  Output:   $OUTPUT_DIR"
echo ""

python3 -m modelzoo_ranker.train "$DATASET_DIR" -o "$OUTPUT_DIR" "${EXTRA_ARGS[@]}"

echo ""
echo "=== Done ==="
