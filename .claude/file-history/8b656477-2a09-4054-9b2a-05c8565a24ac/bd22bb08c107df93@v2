"""Tests for modelzoo_ranker.data.dataset — PyTorch Dataset and collate."""
import torch
from torch.utils.data import DataLoader

from modelzoo_ranker.data.loader import load_all_models
from modelzoo_ranker.data.split import assign_splits
from modelzoo_ranker.data.features import FEATURE_A_DIM, FEATURE_B_DIM
from modelzoo_ranker.data.dataset import RankingDataset, collate_ranking_groups


class TestRankingDataset:
    def test_ranking_dataset_getitem(self, dataset_dir):
        """Dataset items have correct tensor shapes and types."""
        groups = load_all_models(dataset_dir)
        groups = assign_splits(groups, val_models=['ModelA'], test_models=['ModelB'])
        ds = RankingDataset(groups, split='train')

        item = ds[0]
        assert item['feature_a'].shape == (FEATURE_A_DIM,)
        assert item['feature_a'].dtype == torch.float32
        assert item['feature_b'].ndim == 2
        assert item['feature_b'].shape[1] == FEATURE_B_DIM
        assert item['feature_b'].dtype == torch.float32
        assert item['cycles'].ndim == 1
        assert item['cycles'].dtype == torch.float64
        assert isinstance(item['size'], int)
        assert item['size'] == item['feature_b'].shape[0]

    def test_ranking_dataset_split_filter(self, dataset_dir):
        """Dataset only returns groups from the specified split."""
        groups = load_all_models(dataset_dir)
        groups = assign_splits(groups, val_models=['ModelA'], test_models=['ModelB'])

        train_ds = RankingDataset(groups, split='train')
        val_ds = RankingDataset(groups, split='val')
        test_ds = RankingDataset(groups, split='test')

        # ModelA has 2 groups (matmul + generic) -> val
        assert len(val_ds) == 2
        # ModelB has 1 group (conv, pooling singleton filtered) -> test
        assert len(test_ds) == 1
        # ModelC + ModelD -> train (1 + 1 groups)
        assert len(train_ds) == 2


class TestCollate:
    def test_collate_pads_and_masks(self, dataset_dir):
        """Collate zero-pads to max group size and creates correct mask."""
        groups = load_all_models(dataset_dir)
        groups = assign_splits(groups)
        ds = RankingDataset(groups)

        batch = collate_ranking_groups([ds[0], ds[1]])
        assert batch['feature_a'].shape == (2, FEATURE_A_DIM)
        assert batch['feature_b'].ndim == 3
        assert batch['feature_b'].shape[0] == 2
        assert batch['feature_b'].shape[2] == FEATURE_B_DIM
        assert batch['mask'].shape == batch['cycles'].shape
        assert batch['mask'].dtype == torch.bool
        # Mask sum should equal total real configs
        assert batch['mask'].sum().item() == batch['sizes'].sum().item()

    def test_dataloader_integration(self, dataset_dir):
        """DataLoader with collate iterates without error."""
        groups = load_all_models(dataset_dir)
        groups = assign_splits(groups)
        ds = RankingDataset(groups)

        loader = DataLoader(ds, batch_size=2, collate_fn=collate_ranking_groups)
        for batch in loader:
            assert 'feature_a' in batch
            assert 'feature_b' in batch
            assert 'mask' in batch
            assert 'cycles' in batch
            assert 'sizes' in batch
