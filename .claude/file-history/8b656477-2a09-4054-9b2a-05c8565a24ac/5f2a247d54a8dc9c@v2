"""Tests for modelzoo_ranker.data.loader — CSV parsing and ranking group construction."""
import json

from modelzoo_ranker.data.loader import load_model_csv, build_ranking_groups


class TestLoadModelCSV:
    def test_parse_csv_row(self, model_a_csv):
        """Each row is parsed into a typed dict with correct fields."""
        rows = load_model_csv(model_a_csv)
        row = rows[0]
        assert row['dispatch'] == 'module_main_dispatch_0'
        assert row['op_name'] == 'linalg.matmul-1'
        assert row['shape'] == [64, 32, 16]
        assert row['config_index'] == 100
        assert isinstance(row['lowering_config'], list)
        assert len(row['lowering_config']) == 6  # 6-level matmul
        assert row['cycles'] == 5000.0
        assert row['status'] == 'OK'

    def test_filter_ok_only(self, model_a_csv):
        """Only OK rows are returned; FAIL rows are excluded."""
        rows = load_model_csv(model_a_csv)
        statuses = {r['status'] for r in rows}
        assert statuses == {'OK'}
        # Model A has 5 OK rows (3 matmul + 2 generic) and 1 FAIL
        assert len(rows) == 5

    def test_load_model_csv_shapes(self, model_c_csv):
        """1D shapes are parsed correctly."""
        rows = load_model_csv(model_c_csv)
        assert rows[0]['shape'] == [150528]
        assert len(rows[0]['lowering_config']) == 4  # 4-level generic


class TestBuildRankingGroups:
    def test_build_ranking_groups(self, model_a_csv):
        """Groups are keyed by dispatch, sorted by cycles ascending."""
        rows = load_model_csv(model_a_csv)
        groups = build_ranking_groups(rows, model_name='ModelA')
        # 2 dispatches: dispatch_0 (matmul, 3 OK) and dispatch_1 (generic, 2 OK)
        assert len(groups) == 2
        matmul_group = [g for g in groups if g['op_name'] == 'linalg.matmul-1'][0]
        assert len(matmul_group['configs']) == 3
        # Sorted ascending by cycles
        cycles = [c['cycles'] for c in matmul_group['configs']]
        assert cycles == sorted(cycles)
        assert matmul_group['model'] == 'ModelA'

    def test_singleton_groups_filtered(self, model_b_csv):
        """Groups with fewer than 2 configs are excluded."""
        rows = load_model_csv(model_b_csv)
        groups = build_ranking_groups(rows, model_name='ModelB')
        # conv dispatch has 2 configs (kept), pooling has 1 (filtered)
        assert len(groups) == 1
        assert groups[0]['op_name'] == 'linalg.conv_2d_nhwc_hwcf-0'

    def test_group_shape_and_dispatch(self, model_a_csv):
        """Each group carries shape and dispatch metadata."""
        rows = load_model_csv(model_a_csv)
        groups = build_ranking_groups(rows, model_name='ModelA')
        for g in groups:
            assert 'shape' in g
            assert 'dispatch' in g
            assert 'op_name' in g
            assert isinstance(g['shape'], list)
