"""Tests for modelzoo_ranker.training.trainer — training loop."""
import torch
from torch.utils.data import DataLoader

from modelzoo_ranker.data.loader import load_all_models
from modelzoo_ranker.data.split import assign_splits
from modelzoo_ranker.data.dataset import RankingDataset, collate_ranking_groups
from modelzoo_ranker.model.ranker import ModelzooRanker
from modelzoo_ranker.training.trainer import train


class TestTrainer:
    def _make_loaders(self, dataset_dir):
        """Helper to create train/val DataLoaders from fixture data."""
        groups = load_all_models(dataset_dir)
        groups = assign_splits(groups, val_models=['ModelA'], test_models=['ModelB'])
        train_ds = RankingDataset(groups, split='train')
        val_ds = RankingDataset(groups, split='val')
        train_loader = DataLoader(train_ds, batch_size=4,
                                  collate_fn=collate_ranking_groups)
        val_loader = DataLoader(val_ds, batch_size=4,
                                collate_fn=collate_ranking_groups)
        return train_loader, val_loader

    def test_train_one_epoch(self, dataset_dir):
        """Training returns history with train_loss after 1 epoch."""
        train_loader, val_loader = self._make_loaders(dataset_dir)
        model = ModelzooRanker()
        history = train(model, train_loader, val_loader,
                        max_epochs=1, patience=5, top_k=2)
        assert 'train_loss' in history
        assert len(history['train_loss']) == 1
        assert history['epochs_run'] == 1

    def test_train_loss_decreases(self, dataset_dir):
        """Loss should generally decrease over several epochs."""
        train_loader, val_loader = self._make_loaders(dataset_dir)
        model = ModelzooRanker()
        history = train(model, train_loader, val_loader,
                        max_epochs=20, patience=50, top_k=2)
        losses = history['train_loss']
        # First loss should be > last loss (training should improve)
        assert losses[-1] < losses[0]

    def test_early_stopping(self, dataset_dir):
        """Training stops early when patience is exhausted."""
        train_loader, val_loader = self._make_loaders(dataset_dir)
        model = ModelzooRanker()
        history = train(model, train_loader, val_loader,
                        max_epochs=500, patience=3, top_k=2)
        # Should stop well before 500 epochs
        assert history['epochs_run'] < 500
        assert 'best_epoch' in history
