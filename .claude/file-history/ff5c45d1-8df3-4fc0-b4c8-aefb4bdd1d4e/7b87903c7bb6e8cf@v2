import json

filepath = '/home/nick/work/AIAutoIREE/AutoIREE_zoo/models/MobileNet_v3_int8/MobileNet-v3-Large-Quantized/record/2025-10-22-16-13-57-mobilenetV3_int8/history.log'

results = []
with open(filepath) as f:
    for i, line in enumerate(f):
        r = json.loads(line.strip())
        dispatch = r['input'][2]
        if dispatch != 'module_main_dispatch_0':
            continue
        cfgs = r['config']['configs']
        if len(cfgs) < 2:
            print(f'Line {i+1}: only {len(cfgs)} configs: {cfgs}')
            continue
        a0 = cfgs[0][3][0]
        a1 = cfgs[1][3][0]
        lv0 = [a0[0], a1[0]]
        lv1 = [a0[1], a1[1]]
        lv2 = [0, 0]
        lv3 = [a0[2], a1[2]]
        tile_str = f'[{lv0}, {lv1}, {lv2}, {lv3}]'

        cycles = r['result'][0][0]
        err = r['result'][1]
        success = err == 0 and cycles < 1e9

        results.append((tile_str, cycles, success, r['config']['index']))

results.sort(key=lambda x: (not x[2], x[1]))

print(f'Total configs tried for dispatch_0: {len(results)}')
print(f'Successful: {sum(1 for r in results if r[2])}')
print(f'Failed: {sum(1 for r in results if not r[2])}')
print()
print(f'{"idx":>5} {"lowering_config":60} {"cycles":>12} {"status"}')
print('-' * 95)
for tile_str, cycles, success, idx in results:
    status = 'OK' if success else 'FAIL'
    cyc_str = f'{int(cycles):,}' if cycles < 1e9 else 'timeout'
    print(f'{idx:>5} {tile_str:60} {cyc_str:>12} {status}')
