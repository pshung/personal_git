[project]
name = "auto-iree"
version = "0.1.0"
description = "iree auto-tuner"
authors = [{name = "Nick Hung", email = "nick@andestech.com"}]
readme = "README.md"
requires-python = ">=3.11"
package-mode = "false"

[tool.poetry.dependencies]
numpy = "^1.26.4"
decorator = "^5.1.1"
pytest = "^8.2.2"
psutil = "^5.9.8"
#attrs = "^23.2.0"
#tornado = "^6.4.1"
cloudpickle = "^3.0.0"
requests = "^2.32.3"
pre-commit = "^3.7.1"
colorama = "^0.4.6"
#uuid = "^1.30"
#flake8 = "^7.1.0"
autopep8 = "^2.3.1"
autoflake = "^2.3.1"
toml = "^0.10.2"
pydantic = "^2.8.2"
types-toml = "^0.10.8.20240310"
tqdm = "^4.67.1"


[tool.pytest.ini_options]
pythonpath = ["python"]

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"
