// CSR-less spin fixture for F5 plugin icount-trigger e2e test.
// Linked at 0x00100000 (test.ld) so it runs under -machine
// andes_ae350 (DRAM at 0x00000000..0x7FFFFFFF). No csrwi 0x7C0
// trigger means the icount path is the only way out -- timeout
// otherwise.

.section .text
.globl _start
_start:
    li      a0, 0
1:  addi    a0, a0, 1
    j       1b
