/* Trap glue shared by all C-level round-trip fixtures.
 *
 * crt0.S invokes init_mtvec() as a constructor; trap.S's m_trap_entry
 * tail-calls handle_trap on every exception or interrupt. libgloss_vh
 * routes syscalls through the RISC-V semihosting magic triple, not
 * through `ecall`, so there's no syscall-dispatch table here. Any trap
 * is treated as a fatal error: print a diagnostic and exit.
 */

#ifdef __cplusplus
extern "C"
{
#endif

#include <stdint.h>
#include <stdio.h>

#define WRITE_ERROR(format, ...) \
  fprintf(stderr, "\033[31m[ERROR] " format "\033[0m\n", ##__VA_ARGS__)

__attribute__((used, noreturn)) void _exit(int exit_status);

void exception_handler(void)
{
  uint32_t mcause, mdcause, mepc, mtval;

  asm volatile("csrr %0, mcause" : "=r"(mcause));
  asm volatile("csrr %0, mdcause" : "=r"(mdcause));
  asm volatile("csrr %0, mepc" : "=r"(mepc));
  asm volatile("csrr %0, mtval" : "=r"(mtval));

  WRITE_ERROR("Trap occurred!");
  WRITE_ERROR("mcause: 0x%x", mcause);
  WRITE_ERROR("mdcause: 0x%x", mdcause);
  WRITE_ERROR("mepc: 0x%x", mepc);
  WRITE_ERROR("mtval: 0x%x", mtval);

  if ((mcause & 0x80000000) == 0) {
    WRITE_ERROR("Exception code: %d", mcause);
  } else {
    WRITE_ERROR("Interrupt occurred! Cause: %d", mcause & 0x7FFFFFFF);
  }

  _exit(mcause);
}

void handle_trap(unsigned long cause, void* tf)
{
  (void) cause;
  (void) tf;
  exception_handler();
}

extern void m_trap_entry(void);

__attribute__((constructor)) void init_mtvec(void)
{
  uintptr_t handler_address = (uintptr_t) &m_trap_entry;
  asm volatile("csrw mtvec, %0" : : "r"(handler_address));
}

#ifdef __cplusplus
}
#endif
