/* V regfile handoff scaffolding for Tier-2 C-level RVV fixtures.
 *
 * The functions below save / restore the entire 32-V-register file
 * (bit-identically) through the shared V_SCRATCH region. They are the
 * runtime side of the "save all / reload all" transport pattern: by
 * round-tripping all 32 V regs at each handoff boundary, the compiler's
 * tracking of which physical V reg holds which intrinsic-typed C
 * variable remains valid across the boundary - so test fixtures can
 * write pure RVV intrinsic code and never reference a physical V
 * register number.
 *
 * Usage:
 *
 *     enter_vsim();             // QEMU1 drain trigger
 *     v_regfile_reload_all();   // restore V regfile from V_SCRATCH
 *     ... intrinsic kernel ...
 *     v_regfile_dump_all();     // dump V regfile to V_SCRATCH
 *     exit_vsim();              // vsim drain trigger
 *
 * Why two declarations in a header and bodies in a .c file
 *   Bodies live in v_regfile_xfer.c (separate translation unit) so the
 *   compiler treats each call as opaque - it cannot inspect the body
 *   and decide to reorder vector compute across the call. This is the
 *   robust way to make the round-trip act as a true compiler barrier
 *   for V instructions. (asm volatile + memory clobber stops memory-op
 *   reordering but not pure V compute reordering.)
 *
 * VLEN / address contract
 *   VLEN=512 -> vlenb=64. V_SCRATCH = 0x80FF0000 (matches
 *   hybrid::kVScratchGpa in v_regfile_xfer.hpp). v<N> lives at
 *   V_SCRATCH + N*64.
 */

#ifndef RT_V_REGFILE_XFER_H
#define RT_V_REGFILE_XFER_H

void v_regfile_reload_all(void);
void v_regfile_dump_all(void);

#endif /* RT_V_REGFILE_XFER_H */
