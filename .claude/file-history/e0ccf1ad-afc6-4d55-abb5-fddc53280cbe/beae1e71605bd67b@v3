/* Tier-2 C-level fixture: newlib vfprintf format-specifier coverage.
 *
 * All printf output emits in QEMU2 (phase 3) via libgloss_vh's
 * semihosting _write. Phase 2 (vsim) is syscall-free by rule.
 *
 * Covered: signed int, hex, string, char, pointer, width/zero-pad/
 * left-align, octal, unsigned, long. No floating-point format
 * specifiers: %f drags soft-float / iprintf and is unnecessary here.
 */
#include "runtime/rt_c_helpers.h"
#include <stdio.h>

int main(void)
{
  enter_vsim();
  /* Phase 2: vsim. No syscalls. */
  exit_vsim();

  printf("dec=%d hex=%lx str=%s chr=%c ptr=%p pad=[%5d]\n",
         -42, 0xDEADBEEFCAFEUL, "vsim", 'Z', (void*) 0x80000000UL, 7);
  printf("widths: %08x %-10s|\n", 0x1234, "x");
  printf("octal=%o uns=%u neg=%ld\n", 0755, 4000000000U, -1L);
  fflush(stdout);
  return 0;
}
