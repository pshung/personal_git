# less: render .md files with glow, pass everything else to real less
function less() {
  local md_found=0 args=()
  for arg in "$@"; do
    if [[ "$arg" == *.md ]]; then
      md_found=1
    fi
    args+=("$arg")
  done
  if (( md_found )); then
    glow -n -t "${args[@]}"
  else
    command less "${args[@]}"
  fi
}


