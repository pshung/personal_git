/*
 * test-sincos.c -- Accuracy test for sincos() and sincosf()
 */
#define _GNU_SOURCE
#include "test-common.h"
#include "golden-values.h"

/* sincos/sincosf may not be declared in all math.h; provide fallback decls */
extern void sincos(double, double *, double *);
extern void sincosf(float, float *, float *);

static void test_sincos_golden(void)
{
    for (unsigned i = 0; i < GOLDEN_SIN_COUNT; i++) {
        double s, c;
        char buf[64];
        snprintf(buf, sizeof(buf), "%.17g", golden_sin[i].input);
        sincos(golden_sin[i].input, &s, &c);
        CHECK_DOUBLE("sincos:sin", s, buf,
                     golden_sin[i].expected, golden_sin[i].max_ulp);
    }
    for (unsigned i = 0; i < GOLDEN_COS_COUNT; i++) {
        double s, c;
        char buf[64];
        snprintf(buf, sizeof(buf), "%.17g", golden_cos[i].input);
        sincos(golden_cos[i].input, &s, &c);
        CHECK_DOUBLE("sincos:cos", c, buf,
                     golden_cos[i].expected, golden_cos[i].max_ulp);
    }
}

static void test_sincos_special(void)
{
    double s, c;

    sincos(0.0, &s, &c);
    CHECK_DOUBLE("sincos:sin", s, "0.0", 0.0, 0);
    CHECK_DOUBLE("sincos:cos", c, "0.0", 1.0, 0);

    sincos(-0.0, &s, &c);
    CHECK_DOUBLE("sincos:sin", s, "-0.0", -0.0, 0);
    CHECK_DOUBLE("sincos:cos", c, "-0.0", 1.0, 0);

    sincos(INFINITY, &s, &c);
    CHECK_DOUBLE_NAN("sincos:sin", s, "Inf");
    CHECK_DOUBLE_NAN("sincos:cos", c, "Inf");

    sincos(NAN, &s, &c);
    CHECK_DOUBLE_NAN("sincos:sin", s, "NaN");
    CHECK_DOUBLE_NAN("sincos:cos", c, "NaN");
}

static void test_sincosf_golden(void)
{
    for (unsigned i = 0; i < GOLDEN_SINF_COUNT; i++) {
        float s, c;
        char buf[64];
        snprintf(buf, sizeof(buf), "%.9g", (double)golden_sinf[i].input);
        sincosf(golden_sinf[i].input, &s, &c);
        CHECK_FLOAT("sincosf:sin", s, buf,
                    golden_sinf[i].expected, golden_sinf[i].max_ulp);
    }
    for (unsigned i = 0; i < GOLDEN_COSF_COUNT; i++) {
        float s, c;
        char buf[64];
        snprintf(buf, sizeof(buf), "%.9g", (double)golden_cosf[i].input);
        sincosf(golden_cosf[i].input, &s, &c);
        CHECK_FLOAT("sincosf:cos", c, buf,
                    golden_cosf[i].expected, golden_cosf[i].max_ulp);
    }
}

static void test_sincosf_special(void)
{
    float s, c;

    sincosf(0.0f, &s, &c);
    CHECK_FLOAT("sincosf:sin", s, "0.0f", 0.0f, 0);
    CHECK_FLOAT("sincosf:cos", c, "0.0f", 1.0f, 0);

    sincosf(INFINITY, &s, &c);
    CHECK_FLOAT_NAN("sincosf:sin", s, "Inf");
    CHECK_FLOAT_NAN("sincosf:cos", c, "Inf");

    sincosf(NAN, &s, &c);
    CHECK_FLOAT_NAN("sincosf:sin", s, "NaN");
    CHECK_FLOAT_NAN("sincosf:cos", c, "NaN");
}

int main(void)
{
    printf("=== sincos/sincosf accuracy test ===\n");

    test_sincos_golden();
    test_sincos_special();
    test_sincosf_golden();
    test_sincosf_special();

    TEST_SUMMARY("sincos/sincosf");
}
