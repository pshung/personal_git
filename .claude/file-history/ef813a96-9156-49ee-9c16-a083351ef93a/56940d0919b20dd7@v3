/*
 * test-pow.c -- powf() (only float override on riscv64)
 */
#include "test-common.h"

int main(void)
{
    /* basic */
    P_F2(powf, 2.0f, 0.0f);
    P_F2(powf, 2.0f, 1.0f);
    P_F2(powf, 2.0f, 10.0f);
    P_F2(powf, 2.0f, -1.0f);
    P_F2(powf, 10.0f, 3.0f);
    P_F2(powf, 0.5f, 2.0f);
    P_F2(powf, 1.0f, 100.0f);
    P_F2(powf, 4.0f, 0.5f);
    P_F2(powf, 27.0f, 0.333333343f); /* ~1/3 */
    P_F2(powf, 0.1f, 0.1f);
    P_F2(powf, 100.0f, -0.5f);

    /* special: x^0 = 1 */
    P_F2(powf, 0.0f, 0.0f);
    P_F2(powf, INFINITY, 0.0f);
    P_F2(powf, NAN, 0.0f);

    /* 1^y = 1 */
    P_F2(powf, 1.0f, INFINITY);
    P_F2(powf, 1.0f, NAN);
    P_F2(powf, 1.0f, -100.0f);

    /* inf */
    P_F2(powf, INFINITY, 2.0f);
    P_F2(powf, INFINITY, -2.0f);
    P_F2(powf, -1.0f, INFINITY);
    P_F2(powf, -1.0f, -INFINITY);

    /* zero */
    P_F2(powf, 0.0f, 3.0f);
    P_F2(powf, 0.0f, -1.0f);

    return 0;
}
