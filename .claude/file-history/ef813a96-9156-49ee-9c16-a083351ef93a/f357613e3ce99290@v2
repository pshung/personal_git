/*
 * test-cos.c -- Accuracy test for cos() and cosf()
 */
#include "test-common.h"
#include "golden-values.h"

static void test_cos_golden(void)
{
    for (unsigned i = 0; i < GOLDEN_COS_COUNT; i++) {
        char buf[64];
        snprintf(buf, sizeof(buf), "%.17g", golden_cos[i].input);
        CHECK_DOUBLE("cos", cos(golden_cos[i].input), buf,
                     golden_cos[i].expected, golden_cos[i].max_ulp);
    }
}

static void test_cos_special(void)
{
    /* cos(+0) = 1 */
    CHECK_DOUBLE("cos", cos(0.0), "0.0", 1.0, 0);
    /* cos(-0) = 1 */
    CHECK_DOUBLE("cos", cos(-0.0), "-0.0", 1.0, 0);
    /* cos(Inf) = NaN */
    CHECK_DOUBLE_NAN("cos", cos(INFINITY), "Inf");
    CHECK_DOUBLE_NAN("cos", cos(-INFINITY), "-Inf");
    CHECK_DOUBLE_NAN("cos", cos(NAN), "NaN");
}

static void test_cosf_golden(void)
{
    for (unsigned i = 0; i < GOLDEN_COSF_COUNT; i++) {
        char buf[64];
        snprintf(buf, sizeof(buf), "%.9g", (double)golden_cosf[i].input);
        CHECK_FLOAT("cosf", cosf(golden_cosf[i].input), buf,
                    golden_cosf[i].expected, golden_cosf[i].max_ulp);
    }
}

static void test_cosf_special(void)
{
    CHECK_FLOAT("cosf", cosf(0.0f), "0.0f", 1.0f, 0);
    CHECK_FLOAT("cosf", cosf(-0.0f), "-0.0f", 1.0f, 0);
    CHECK_FLOAT_NAN("cosf", cosf(INFINITY), "Inf");
    CHECK_FLOAT_NAN("cosf", cosf(-INFINITY), "-Inf");
    CHECK_FLOAT_NAN("cosf", cosf(NAN), "NaN");
}

int main(void)
{
    printf("=== cos/cosf accuracy test ===\n");

    test_cos_golden();
    test_cos_special();
    test_cosf_golden();
    test_cosf_special();

    TEST_SUMMARY("cos/cosf");
}
