/*
 * test-cos.c -- cos() and cosf()
 */
#include "test-common.h"

static const double din[] = {
    0.0, -0.0, 1e-300, -1e-300, 5e-324, 1e-15, -1e-15,
    0.5235987755982989, 0.7853981633974483, 1.0471975511965976,
    1.5707963267948966, 3.141592653589793, 4.71238898038469, 6.283185307179586,
    -0.5235987755982989, -0.7853981633974483, -1.0471975511965976,
    -1.5707963267948966, -3.141592653589793,
    0.1, 0.5, 1.0, 2.0, 3.0, -0.1, -0.5, -1.0, -2.0, -3.0,
    10.0, 100.0, 1000.0, 1e10, 1e20, -10.0, -100.0, -1000.0,
    1.5707963267948965, 1.5707963267948968,
    3.1415926535897931, 3.1415926535897936,
};
#define DIN_COUNT (sizeof(din)/sizeof(din[0]))

static const float fin[] = {
    0.0f, -0.0f, 1e-38f, -1e-38f, 1.4e-45f, 1e-7f, -1e-7f,
    0.52359878f, 0.78539816f, 1.04719755f, 1.57079633f,
    3.14159265f, 4.71238898f, 6.28318531f,
    -0.78539816f, -1.57079633f, -3.14159265f,
    0.1f, 0.5f, 1.0f, 2.0f, 3.0f, -0.1f, -0.5f, -1.0f, -2.0f, -3.0f,
    10.0f, 100.0f, 1000.0f, 1e10f, -10.0f, -100.0f,
};
#define FIN_COUNT (sizeof(fin)/sizeof(fin[0]))

int main(void)
{
    unsigned i;
    for (i = 0; i < DIN_COUNT; i++)
        P_D1(cos, din[i]);
    P_D1(cos, INFINITY);
    P_D1(cos, -INFINITY);
    P_D1(cos, NAN);

    for (i = 0; i < FIN_COUNT; i++)
        P_F1(cosf, fin[i]);
    P_F1(cosf, INFINITY);
    P_F1(cosf, -INFINITY);
    P_F1(cosf, NAN);

    return 0;
}
