/*
 * test-fma.c -- fma() and fmaf()
 */
#include "test-common.h"

int main(void)
{
    P_D3(fma, 1.0, 1.0, 1.0);
    P_D3(fma, 2.0, 3.0, 4.0);
    P_D3(fma, -1.0, 1.0, 1.0);
    P_D3(fma, 1e300, 1e300, 0.0);  /* overflow */
    P_D3(fma, 1e-300, 1e-300, 0.0); /* tiny product */
    P_D3(fma, 1.0 + 1e-15, 1.0 - 1e-15, 0.0); /* cancellation */
    P_D3(fma, 0.0, 0.0, 0.0);
    P_D3(fma, 1.0, 0.0, 1.0);
    P_D3(fma, 3.14, 1.0, 0.0);
    P_D3(fma, 3.14, 0.0, 2.72);
    P_D3(fma, NAN, 1.0, 1.0);
    P_D3(fma, 1.0, NAN, 1.0);
    P_D3(fma, 1.0, 1.0, NAN);
    P_D3(fma, 0.0, INFINITY, NAN);

    P_F3(fmaf, 1.0f, 1.0f, 1.0f);
    P_F3(fmaf, 2.0f, 3.0f, 4.0f);
    P_F3(fmaf, -1.0f, 1.0f, 1.0f);
    P_F3(fmaf, 1e38f, 1e-2f, 0.0f);
    P_F3(fmaf, 0.0f, 0.0f, 0.0f);
    P_F3(fmaf, 1.0f, 0.0f, 1.0f);
    P_F3(fmaf, 3.14f, 1.0f, 0.0f);
    P_F3(fmaf, NAN, 1.0f, 1.0f);

    return 0;
}
