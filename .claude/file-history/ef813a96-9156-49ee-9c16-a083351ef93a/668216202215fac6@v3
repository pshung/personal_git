/*
 * test-copysign.c -- copysign() and copysignf()
 */
#include "test-common.h"

int main(void)
{
    P_D2(copysign, 1.0, 1.0);
    P_D2(copysign, 1.0, -1.0);
    P_D2(copysign, -1.0, 1.0);
    P_D2(copysign, -1.0, -1.0);
    P_D2(copysign, 0.0, -1.0);
    P_D2(copysign, -0.0, 1.0);
    P_D2(copysign, INFINITY, -1.0);
    P_D2(copysign, -INFINITY, 1.0);
    P_D2(copysign, 3.14, -0.0);
    P_D2(copysign, NAN, -1.0);
    P_D2(copysign, NAN, 1.0);

    P_F2(copysignf, 1.0f, 1.0f);
    P_F2(copysignf, 1.0f, -1.0f);
    P_F2(copysignf, -1.0f, 1.0f);
    P_F2(copysignf, 0.0f, -1.0f);
    P_F2(copysignf, -0.0f, 1.0f);
    P_F2(copysignf, INFINITY, -1.0f);
    P_F2(copysignf, NAN, -1.0f);
    P_F2(copysignf, NAN, 1.0f);

    return 0;
}
