/*
 * test-exp.c -- expf() (only float override on riscv64)
 */
#include "test-common.h"

static const float fin[] = {
    0.0f, -0.0f,
    1.0f, -1.0f, 0.5f, -0.5f, 2.0f, -2.0f,
    10.0f, -10.0f,
    0.6931472f, /* ln(2) */
    -87.0f, 88.0f, /* near underflow/overflow */
    -80.0f, 50.0f,
    0.001f, -0.001f, 1e-7f,
};
#define FIN_COUNT (sizeof(fin)/sizeof(fin[0]))

int main(void)
{
    unsigned i;
    for (i = 0; i < FIN_COUNT; i++)
        P_F1(expf, fin[i]);
    P_F1(expf, INFINITY);
    P_F1(expf, -INFINITY);
    P_F1(expf, NAN);
    /* overflow / underflow */
    P_F1(expf, 89.0f);
    P_F1(expf, -104.0f);

    return 0;
}
