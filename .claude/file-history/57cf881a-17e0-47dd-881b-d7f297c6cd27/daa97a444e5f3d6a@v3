        Q1_TCG --> Q1_PLUGIN
    end

    subgraph VSIM["vsim (cycle-accurate, KHz)"]
        V_PIPE["RTL pipeline<br/>(Verilator + SystemC)"]
        V_DM["JTAG DM driver (in-process)<br/>Abstract Cmds + Program Buffer"]
        V_TRIG["CsrTrigger<br/>CSR mode: csrwi 0x7C0,1 (or runtime form)<br/>PC mode: --hybrid-exit-pc"]
        V_CTRL["HandoffController<br/>passthrough(snapshot) +<br/>fresh GPR/PC/V-CSR drain"]
        V_DM -.GPR/FPR/CSR + vsetvl.-> V_PIPE
        V_PIPE -.retire signals.-> V_TRIG
        V_TRIG --> V_CTRL
        V_CTRL --> V_DM
    end

    subgraph QEMU2["QEMU 2 (functional, MHz)"]
        Q2_GDB["gdbstub -gdb tcp::PORT -S"]
