    subgraph DISK["Shared backing files"]
        SHM[("/dev/shm RAM<br/>(mmap shared)<br/>+ V scratch<br/>at 0x80FF0000")]
        STATE_Q["state_qemu.bin<br/>hybrid_state_v1"]
        STATE_V["state_vsim.bin<br/>hybrid_state_v1"]
    end

    subgraph QEMU1["QEMU 1 (functional, MHz)"]
