/* Self-test for --kanata-loop-* gate
 * Loop runs 100 iterations.
 * loop_start and loop_end are exposed as global symbols so we can read their
 * PCs from objdump and feed them to --kanata-loop-start / --kanata-loop-end.
 */
    .section .text.init
    .globl _start
    .globl loop_start
    .globl loop_end

_start:
    li   sp, 0x40000          /* set up stack somewhere in RAM */
    li   t0, 100              /* iteration counter */
    li   t1, 0                /* accumulator */

    .align 4
loop_start:
    addi t1, t1, 1
    addi t1, t1, 1
    addi t1, t1, 1
    addi t1, t1, 1
loop_end:
    addi t0, t0, -1
    bnez t0, loop_start

    /* exit: write SimCommand::PASSED (0x01234568) to SIM_CONTROL_BASE */
    li   t2, 0xE0080000
    li   t3, 0x01234568
    sw   t3, 0(t2)
1:  j 1b
