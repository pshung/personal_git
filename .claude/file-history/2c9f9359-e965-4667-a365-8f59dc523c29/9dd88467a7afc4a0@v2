    const long align_byte = sizeof(long);

    // two col buffer
    int32_t buf_size = 2 * in_tensor_ch * ker_dim_x * sizeof(int8_t);
    buf_size += align_byte - 1;     //extra size for aligning

    // buffer for extra contribution
    buf_size += out_tensor_ch * sizeof(int32_t);
    buf_size += align_byte - 1;     //extra size for aligning

    return buf_size;
#elif defined(ENA_DSP_ISA)
    (void)in_tensor_ch;
    (void)in_tensor_batch;
    (void)pad_x;
    (void)stride_x;
    (void)out_tensor_dim_x;
    (void)dilation_x;
    const long align_byte = sizeof(long);

    // two col buffer
    int32_t buf_size = 2 * in_tensor_ch * ker_dim_x * sizeof(int8_t);
    buf_size += align_byte - 1;     //extra size for aligning

    // buffer for the unpacked weight
    buf_size += out_tensor_ch * in_tensor_ch * ker_dim_x;
    buf_size += align_byte - 1;     //extra size for aligning

    // buffer for weight contribution
    buf_size += out_tensor_ch * sizeof(int32_t);
    buf_size += align_byte - 1;     //extra size for aligning

    return buf_size;
#else
    (void)in_tensor_dim_x;
