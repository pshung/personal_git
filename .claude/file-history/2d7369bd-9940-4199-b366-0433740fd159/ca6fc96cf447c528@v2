#!/usr/bin/env bash
# cc-log.sh - Human/LLM-readable Claude Code behavior logger
# Called by hooks with: cc-log.sh <log_name>
# Receives hook event JSON via stdin
# Appends plain text to ~/.claude/logs/<log_name>.log
#
# Only logs: SessionStart, SessionEnd, UserPromptSubmit, Stop,
# Bash tool use (Pre/Post/Failure), Agent tool use (Pre), SubagentStart/Stop

LOG_NAME="${1:-$(date +%Y-%m-%d)}"
LOG_DIR="$HOME/.claude/logs"
LOG_FILE="$LOG_DIR/$LOG_NAME.log"

mkdir -p "$LOG_DIR"

INPUT="$(cat)" || true
[ -z "$INPUT" ] && exit 0

EVENT=$(echo "$INPUT" | jq -r '.hook_event_name // empty' 2>/dev/null) || true
[ -z "$EVENT" ] && exit 0

trunc() {
  local s="$1" n="${2:-300}"
  if [ "${#s}" -gt "$n" ]; then
    printf '%s...' "${s:0:$n}"
  else
    printf '%s' "$s"
  fi
}

extract() {
  echo "$INPUT" | jq -r "$1 // empty" 2>/dev/null || true
}

agent_prefix() {
  local aid="$1"
  [ -n "$aid" ] && printf '[agent:%s] ' "${aid:0:10}" || true
}

case "$EVENT" in
  SessionStart)
    SID=$(extract '.session_id')
    MODEL=$(extract '.model')
    CWD=$(extract '.cwd')
    {
      echo ""
      echo "== session=${SID:0:10} | model=$MODEL | cwd=$CWD =="
    } >> "$LOG_FILE"
    ;;

  SessionEnd)
    echo "== SessionEnd ==" >> "$LOG_FILE"
    ;;

  UserPromptSubmit)
    PROMPT=$(extract '.prompt')
    {
      echo ""
      echo "> $PROMPT"
    } >> "$LOG_FILE"
    ;;

  PreToolUse)
    TOOL=$(extract '.tool_name')
    AID=$(extract '.agent_id')
    case "$TOOL" in
      Bash)
        CMD=$(extract '.tool_input.command')
        DESC=$(extract '.tool_input.description')
        {
          echo ""
          echo "$(agent_prefix "$AID")PreToolUse Bash | cmd: $(trunc "$CMD" 200)"
          [ -n "$DESC" ] && echo "  desc: $DESC"
        } >> "$LOG_FILE"
        ;;
      Agent)
        ADESC=$(extract '.tool_input.description')
        ATYPE=$(extract '.tool_input.subagent_type')
        APROMPT=$(extract '.tool_input.prompt')
        [ -z "$ATYPE" ] && ATYPE="general-purpose"
        {
          echo ""
          echo "Agent | desc=\"$ADESC\" | type=$ATYPE"
          [ -n "$APROMPT" ] && echo "  prompt: $APROMPT"
        } >> "$LOG_FILE"
        ;;
      Skill)
        SNAME=$(extract '.tool_input.skill')
        SARGS=$(extract '.tool_input.args')
        {
          echo ""
          echo "Skill | name=$SNAME"
          [ -n "$SARGS" ] && echo "  args: $SARGS"
        } >> "$LOG_FILE"
        ;;
    esac
    ;;

  PostToolUse)
    TOOL=$(extract '.tool_name')
    [ "$TOOL" != "Bash" ] && exit 0
    AID=$(extract '.agent_id')
    CMD=$(extract '.tool_input.command')
    DESC=$(extract '.tool_input.description')
    STDOUT=$(extract '.tool_response.stdout')
    STDERR=$(extract '.tool_response.stderr')
    {
      echo ""
      echo "$(agent_prefix "$AID")PostToolUse Bash | cmd: $(trunc "$CMD" 200)"
      [ -n "$DESC" ] && echo "  desc: $DESC"
      [ -n "$STDOUT" ] && echo "  stdout: $(trunc "$STDOUT")"
      [ -n "$STDERR" ] && echo "  stderr: $(trunc "$STDERR")"
    } >> "$LOG_FILE"
    ;;

  PostToolUseFailure)
    TOOL=$(extract '.tool_name')
    [ "$TOOL" != "Bash" ] && exit 0
    AID=$(extract '.agent_id')
    CMD=$(extract '.tool_input.command')
    DESC=$(extract '.tool_input.description')
    STDERR=$(extract '.tool_response.stderr // .tool_response')
    {
      echo ""
      echo "$(agent_prefix "$AID")PostToolUseFailure Bash | cmd: $(trunc "$CMD" 200)"
      [ -n "$DESC" ] && echo "  desc: $DESC"
      [ -n "$STDERR" ] && echo "  stderr: $(trunc "$STDERR" 500)"
    } >> "$LOG_FILE"
    ;;

  SubagentStart)
    AID=$(extract '.agent_id')
    ATYPE=$(extract '.agent_type')
    echo "SubagentStart | id=${AID:0:10} | type=$ATYPE" >> "$LOG_FILE"
    ;;

  SubagentStop)
    AID=$(extract '.agent_id')
    echo "SubagentStop | id=${AID:0:10}" >> "$LOG_FILE"
    ;;

  Stop)
    {
      echo ""
      echo "Stop"
    } >> "$LOG_FILE"
    ;;
esac

exit 0
