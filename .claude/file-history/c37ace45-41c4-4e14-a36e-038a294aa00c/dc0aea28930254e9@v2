    "linalg.fill-0": {
        "instruction_seq": "",
        "default": "[[32, 24], [1, 8], [0, 0], [0, 0]]",
        "iteration_space": "[3136, 24]",
        "iteration_type": "['parallel', 'parallel']",
        "rank / tilingLevels": "[2, 4]",
        "Parallel dimensions": "[0, 1]",
        "Reduction dimensions": "[]",
    },
    "linalg.generic-1": {
        "instruction_seq": "arith.mulf-arith.addf-linalg.yield",
        "default": "[[32, 24, 0], [1, 8, 0], [0, 0, 32], [0, 0, 0]]",
        "iteration_space": "[3136, 24, 144]",
        "iteration_type": "['parallel', 'parallel', 'reduction']",
        "rank / tilingLevels": "[3, 4]",
        "Parallel dimensions": "[0, 1]",
        "Reduction dimensions": "[2]",
    },
    "linalg.generic-2": {
        "instruction_seq": "arith.addf-arith.maximumf-linalg.yield",
        "default": "[[32, 24], [1, 8], [0, 0], [0, 0]]",
        "iteration_space": "[3136, 24]",
        "iteration_type": "['parallel', 'parallel']",
