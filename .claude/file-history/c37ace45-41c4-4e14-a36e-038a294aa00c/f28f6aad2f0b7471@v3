#!/usr/bin/env bash
# Run AI-tune on all 19 AutoIREE_zoo models (skip MobileBert_int8).
# FPGA board is a single shared resource — models run sequentially.
#
# Usage:
#   bash tmp/run_ai_tune_all.sh           # run all 19
#   bash tmp/run_ai_tune_all.sh Bird      # run specific model(s)
set -euo pipefail

AUTOIREE_DIR="/home/nick/work/AutoIREE_plus_AI"
ZOO_DIR="/local/nick/AutoIREE_zoo/models"
PLATFORM="config/AX45_1024.toml"
LOG_DIR="/home/nick/work/ai_iree/tmp/ai_tune_logs"

export PYTHONPATH="$AUTOIREE_DIR/python${PYTHONPATH:+:$PYTHONPATH}"

# Model name → MLIR filename mapping
declare -A MLIR_MAP=(
  [Bird]="bird.mlir"
  [CartoonGAN]="cartoongan.tosa.mlir"
  [DeepLab_int8]="deeplab-edgetpu-argmax-m.mlir"
  [DenseNet]="densenet.mlir"
  [MobileNet_v1]="mobilenet.mlir"
  [MobileNet_v1_int8]="mobilenet.mlir"
  [MobileNet_v3]="mobilenetV3.mlir"
  [MobileNet_v3_int8]="MobileNet-v3-Large-Quantized.mlir"
  [Mobile_Vit]="Mobile_Vit.mlir"
  [PoseNet]="posenet_f32.mlir"
  [ResNet-50]="resnet-50.mlir"
  [ResNet-50_int8]="ResNet50Quantized.mlir"
  [Simple-Bev]="Simple-Bev.mlir"
  [SqueezeNet]="squeezenet.mlir"
  [Ultra_Fast_Lane_Detection]="UFLD_TUSIMPLE.mlir"
  [YamNet]="YamNet.mlir"
  [YOLOv11n]="yolov11n.tosa.mlir"
  [YOLOv5n]="yolov5n.tosa.mlir"
  [YOLOv8n]="yolov8n.tosa.mlir"
)

# Ordered list (skip MobileBert_int8 — 579 dispatches)
ALL_MODELS=(
  Bird CartoonGAN DeepLab_int8 DenseNet
  MobileNet_v1 MobileNet_v1_int8 MobileNet_v3 MobileNet_v3_int8
  Mobile_Vit PoseNet "ResNet-50" "ResNet-50_int8"
  Simple-Bev SqueezeNet Ultra_Fast_Lane_Detection YamNet
  YOLOv11n YOLOv5n YOLOv8n
)

# Allow running specific models via CLI args
if [[ $# -gt 0 ]]; then
  MODELS=("$@")
else
  MODELS=("${ALL_MODELS[@]}")
fi

mkdir -p "$LOG_DIR"

TOTAL=${#MODELS[@]}
PASS=0
FAIL=0
SKIP=0

echo "=== AI-tune batch run: ${TOTAL} models ==="
echo "Started: $(date)"
echo ""

cd "$AUTOIREE_DIR"

for i in "${!MODELS[@]}"; do
  MODEL="${MODELS[$i]}"
  IDX=$((i + 1))
  MLIR_FILE="${MLIR_MAP[$MODEL]:-}"

  if [[ -z "$MLIR_FILE" ]]; then
    echo "[$IDX/$TOTAL] SKIP $MODEL — unknown MLIR file"
    SKIP=$((SKIP + 1))
    continue
  fi

  MLIR_PATH="$ZOO_DIR/$MODEL/$MLIR_FILE"
  if [[ ! -f "$MLIR_PATH" ]]; then
    echo "[$IDX/$TOTAL] SKIP $MODEL — $MLIR_PATH not found"
    SKIP=$((SKIP + 1))
    continue
  fi

  LOG_FILE="$LOG_DIR/${MODEL}.log"
  echo "[$IDX/$TOTAL] START $MODEL ($(date '+%H:%M:%S'))"

  if python3 iree_tuner.py "$MLIR_PATH" --ai-tune -p "$PLATFORM" \
       2>&1 | tee "$LOG_FILE"; then
    echo "[$IDX/$TOTAL] DONE  $MODEL ($(date '+%H:%M:%S'))"
    PASS=$((PASS + 1))
  else
    echo "[$IDX/$TOTAL] FAIL  $MODEL ($(date '+%H:%M:%S')) — see $LOG_FILE"
    FAIL=$((FAIL + 1))
  fi
  echo ""
done

echo "=== Summary ==="
echo "Pass: $PASS  Fail: $FAIL  Skip: $SKIP  Total: $TOTAL"
echo "Finished: $(date)"
