/*
 * nextafter() test harness — prints (x_hex, y_hex, output_hex) triples.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x, double y)
{
    double r = nextafter(x, y);
    printf("%016llx %016llx %016llx\n", (unsigned long long)d2u(x), (unsigned long long)d2u(y), (unsigned long long)d2u(r));
}

static void emit_u(uint64_t x_bits, uint64_t y_bits)
{
    emit(u2d(x_bits), u2d(y_bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0, 1.0);
    emit(-0.0, 1.0);
    emit(1.0, 0.0);
    emit(1.0, 1.0);
    emit_u(0x7ff8000000000000ULL, 0x3ff0000000000000ULL);  /* NaN, 1.0 */
    emit_u(0x3ff0000000000000ULL, 0x7ff8000000000000ULL);  /* 1.0, NaN */
    emit_u(0x7ff0000000000000ULL, 0x3ff0000000000000ULL);  /* +Inf, 1.0 */
}

/* Test moving away from zero */
static void test_away_from_zero(void)
{
    emit(1.0, 2.0);   /* toward 2.0 */
    emit(1.0, 0.0);   /* toward 0.0 */
    emit(-1.0, -2.0); /* toward -2.0 */
    emit(-1.0, 0.0);  /* toward 0.0 */
}

/* Test near zero */
static void test_near_zero(void)
{
    emit(0.0, 0.5);
    emit(0.0, -0.5);
    emit(-0.0, 0.5);
    emit(-0.0, -0.5);
}

/* Test boundaries */
static void test_boundaries(void)
{
    emit(DBL_MAX, INFINITY);
    emit(DBL_MAX, 0.0);
    emit(DBL_MIN, 0.0);
    emit(DBL_MIN, 1.0);
}

/* Test repeated steps */
static void test_repeated(void)
{
    double x = 1.0;
    for (int i = 0; i < 5; i++) {
        x = nextafter(x, 2.0);
        emit(x, 2.0);
    }
}

int main(void)
{
    test_special();
    test_away_from_zero();
    test_near_zero();
    test_boundaries();
    test_repeated();
    return 0;
}
