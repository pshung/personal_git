/*
 * log1p() test harness — prints (input_hex, output_hex) pairs.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x)
{
    double r = log1p(x);
    printf("%016llx %016llx\n", (unsigned long long)d2u(x), (unsigned long long)d2u(r));
}

static void emit_u(uint64_t bits)
{
    emit(u2d(bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0);
    emit(-0.0);
    emit_u(0x7ff8000000000000ULL);  /* qNaN */
    emit_u(0x7ff0000000000000ULL);  /* +Inf */
    emit_u(0xfff0000000000000ULL);  /* -Inf */
}

/* Test near zero (critical for precision) */
static void test_near_zero(void)
{
    double vals[] = { 1.0e-20, 1.0e-15, 1.0e-10, 1.0e-5, 1.0e-3, 1.0e-2 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++) {
        emit(vals[i]);
        emit(-vals[i]);
    }
}

/* Test known values */
static void test_known(void)
{
    emit(-0.5);   /* log(0.5) */
    emit(0.0);    /* log(1) */
    emit(1.0);    /* log(2) */
    emit(2.718281828 - 1.0); /* log(e) */
}

/* Test normal range */
static void test_normal(void)
{
    double vals[] = { 0.5, 2.0, 5.0, 10.0, 100.0 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++)
        emit(vals[i]);
}

/* Test boundary */
static void test_boundary(void)
{
    emit(-1.0);   /* log(0) */
    emit(-0.99999);
    emit(-0.5);
}

int main(void)
{
    test_special();
    test_near_zero();
    test_known();
    test_normal();
    test_boundary();
    return 0;
}
