/*
 * fmin() test harness — prints (x_hex, y_hex, output_hex) triples.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x, double y)
{
    double r = fmin(x, y);
    printf("%016llx %016llx %016llx\n", (unsigned long long)d2u(x), (unsigned long long)d2u(y), (unsigned long long)d2u(r));
}

static void emit_u(uint64_t x_bits, uint64_t y_bits)
{
    emit(u2d(x_bits), u2d(y_bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0, 0.0);
    emit(-0.0, 0.0);
    emit(0.0, -0.0);
    emit(-0.0, -0.0);
    emit_u(0x7ff8000000000000ULL, 0x3ff0000000000000ULL);  /* NaN, 1.0 */
    emit_u(0x3ff0000000000000ULL, 0x7ff8000000000000ULL);  /* 1.0, NaN */
    emit_u(0x7ff0000000000000ULL, 0x3ff0000000000000ULL);  /* +Inf, 1.0 */
    emit_u(0xfff0000000000000ULL, 0x3ff0000000000000ULL);  /* -Inf, 1.0 */
}

/* Test equal values */
static void test_equal(void)
{
    emit(1.0, 1.0);
    emit(-1.0, -1.0);
    emit(0.5, 0.5);
}

/* Test various pairs */
static void test_pairs(void)
{
    emit(1.0, 2.0);
    emit(2.0, 1.0);
    emit(-1.0, -2.0);
    emit(-2.0, -1.0);
    emit(-1.0, 1.0);
    emit(-2.0, 2.0);
}

/* Test tiny values */
static void test_tiny(void)
{
    emit(DBL_MIN, 0.0);
    emit(-DBL_MIN, 0.0);
    emit(1.0e-300, 1.0e-200);
}

/* Test large values */
static void test_large(void)
{
    emit(1.0e100, 1.0e50);
    emit(1.0e300, 1.0e200);
    emit(DBL_MAX, 1.0);
}

int main(void)
{
    test_special();
    test_equal();
    test_pairs();
    test_tiny();
    test_large();
    return 0;
}
