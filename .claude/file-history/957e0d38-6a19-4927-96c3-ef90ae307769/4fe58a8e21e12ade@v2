/*
 * remquo() test harness — prints (x_hex, y_hex, rem_hex, quo) quads.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x, double y)
{
    int quo;
    double rem = remquo(x, y, &quo);
    printf("%016llx %016llx %016llx %d\n", (unsigned long long)d2u(x), (unsigned long long)d2u(y), (unsigned long long)d2u(rem), quo);
}

static void emit_u(uint64_t x_bits, uint64_t y_bits)
{
    emit(u2d(x_bits), u2d(y_bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0, 1.0);
    emit(-0.0, 1.0);
    emit(1.0, 0.0);
    emit_u(0x7ff8000000000000ULL, 0x3ff0000000000000ULL);  /* NaN, 1.0 */
    emit_u(0x3ff0000000000000ULL, 0x7ff8000000000000ULL);  /* 1.0, NaN */
    emit_u(0x7ff0000000000000ULL, 0x3ff0000000000000ULL);  /* +Inf, 1.0 */
}

/* Test basic cases */
static void test_basic(void)
{
    emit(5.0, 2.0);
    emit(5.5, 2.5);
    emit(-5.0, 2.0);
    emit(5.0, -2.0);
    emit(-5.0, -2.0);
}

/* Test small operands */
static void test_small(void)
{
    emit(0.1, 0.3);
    emit(1.0e-100, 1.0e-50);
    emit(1.0e-20, 1.0e-10);
    emit(DBL_MIN, 1.0);
}

/* Test various divisors */
static void test_divisors(void)
{
    emit(10.0, 3.0);
    emit(22.0, 7.0);
    emit(100.0, 30.0);
    emit(7.0, 2.5);
}

/* Test large values */
static void test_large(void)
{
    emit(1.0e100, 1.0e50);
    emit(1.0e200, 1.0e100);
    emit(DBL_MAX, 1.0e100);
}

int main(void)
{
    test_special();
    test_basic();
    test_small();
    test_divisors();
    test_large();
    return 0;
}
