/*
 * ldexp() test harness — prints (mantissa_hex, exponent, output_hex) triples.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x, int exp)
{
    double r = ldexp(x, exp);
    printf("%016llx %d %016llx\n", (unsigned long long)d2u(x), exp, (unsigned long long)d2u(r));
}

static void emit_u(uint64_t bits, int exp)
{
    emit(u2d(bits), exp);
}

/* Test special values */
static void test_special(void)
{
    emit(0.0, 0);
    emit(-0.0, 0);
    emit(0.0, 10);
    emit_u(0x7ff8000000000000ULL, 0);  /* qNaN */
    emit_u(0x7ff0000000000000ULL, 0);  /* +Inf */
    emit_u(0xfff0000000000000ULL, 0);  /* -Inf */
}

/* Test basic powers of 2 */
static void test_powers_of_2(void)
{
    emit(1.0, 0);
    emit(1.0, 1);
    emit(1.0, 2);
    emit(1.0, 10);
    emit(1.0, -1);
    emit(1.0, -2);
    emit(1.0, -10);
}

/* Test 0.5 */
static void test_half(void)
{
    emit(0.5, 0);
    emit(0.5, 1);
    emit(0.5, 2);
    emit(0.5, -1);
}

/* Test normal values */
static void test_normal(void)
{
    emit(1.5, 0);
    emit(1.5, 1);
    emit(1.5, 10);
    emit(1.5, -10);
    emit(-1.5, 5);
    emit(2.0, 100);
}

/* Test tiny values */
static void test_tiny(void)
{
    emit(DBL_MIN, 0);
    emit(DBL_MIN, 1);
    emit(1.0e-200, 100);
}

/* Test overflow/underflow */
static void test_overflow(void)
{
    emit(1.0, 1023);
    emit(1.0, 1024);  /* overflow */
    emit(1.0, -1074);
    emit(1.0, -1075);  /* underflow */
}

int main(void)
{
    test_special();
    test_powers_of_2();
    test_half();
    test_normal();
    test_tiny();
    test_overflow();
    return 0;
}
