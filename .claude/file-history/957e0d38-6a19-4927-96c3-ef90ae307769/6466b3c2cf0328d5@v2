/*
 * hypot() test harness — prints (x_hex, y_hex, output_hex) triples.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x, double y)
{
    double r = hypot(x, y);
    printf("%016llx %016llx %016llx\n", (unsigned long long)d2u(x), (unsigned long long)d2u(y), (unsigned long long)d2u(r));
}

static void emit_u(uint64_t x_bits, uint64_t y_bits)
{
    emit(u2d(x_bits), u2d(y_bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0, 0.0);
    emit(0.0, 1.0);
    emit(1.0, 0.0);
    emit_u(0x7ff8000000000000ULL, 0x3ff0000000000000ULL);  /* NaN, 1.0 */
    emit_u(0x3ff0000000000000ULL, 0x7ff8000000000000ULL);  /* 1.0, NaN */
    emit_u(0x7ff0000000000000ULL, 0x3ff0000000000000ULL);  /* +Inf, 1.0 */
    emit(1.0, INFINITY);
    emit_u(0xfff0000000000000ULL, 0x3ff0000000000000ULL);  /* -Inf, 1.0 */
}

/* Test Pythagorean triples */
static void test_pythagorean(void)
{
    emit(3.0, 4.0);    /* 5.0 */
    emit(5.0, 12.0);   /* 13.0 */
    emit(8.0, 15.0);   /* 17.0 */
    emit(7.0, 24.0);   /* 25.0 */
    emit(20.0, 21.0);  /* 29.0 */
}

/* Test equal arguments */
static void test_equal(void)
{
    emit(1.0, 1.0);
    emit(2.0, 2.0);
    emit(10.0, 10.0);
    emit(-1.0, 1.0);
    emit(-2.0, 2.0);
}

/* Test small values */
static void test_small(void)
{
    emit(1.0e-100, 1.0e-100);
    emit(1.0e-20, 1.0e-20);
    emit(DBL_MIN, DBL_MIN);
    emit(1.0e-100, 1.0e-50);
}

/* Test large values */
static void test_large(void)
{
    emit(1e100, 1e100);
    emit(1e150, 1e150);
    emit(1e300, 1e300);
}

int main(void)
{
    test_special();
    test_pythagorean();
    test_equal();
    test_small();
    test_large();
    return 0;
}
