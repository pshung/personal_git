/*
 * fmod() test harness — prints (x_hex, y_hex, output_hex) triples.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x, double y)
{
    double r = fmod(x, y);
    printf("%016llx %016llx %016llx\n", (unsigned long long)d2u(x), (unsigned long long)d2u(y), (unsigned long long)d2u(r));
}

static void emit_u(uint64_t x_bits, uint64_t y_bits)
{
    emit(u2d(x_bits), u2d(y_bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0, 1.0);
    emit(-0.0, 1.0);
    emit(1.0, 0.0);
    emit_u(0x7ff8000000000000ULL, 0x3ff0000000000000ULL);  /* NaN, 1.0 */
    emit_u(0x3ff0000000000000ULL, 0x7ff8000000000000ULL);  /* 1.0, NaN */
    emit_u(0x7ff0000000000000ULL, 0x3ff0000000000000ULL);  /* +Inf, 1.0 */
    emit(1.0, INFINITY);
}

/* Test normal cases */
static void test_normal(void)
{
    emit(5.0, 2.0);
    emit(5.5, 2.5);
    emit(-5.0, 2.0);
    emit(5.0, -2.0);
    emit(-5.0, -2.0);
    emit(1.5, 0.5);
    emit(3.0, 2.0);
}

/* Test small operands */
static void test_small(void)
{
    emit(0.1, 0.3);
    emit(1.0e-100, 1.0e-50);
    emit(1.0e-20, 1.0e-10);
    emit(DBL_MIN, 1.0);
}

/* Test large operands */
static void test_large(void)
{
    emit(1e100, 1e50);
    emit(1e200, 1e100);
    emit(DBL_MAX, 1e100);
}

/* Test various ratios */
static void test_ratios(void)
{
    emit(10.0, 3.0);
    emit(7.0, 2.5);
    emit(22.0, 7.0);
    emit(100.0, 30.0);
}

int main(void)
{
    test_special();
    test_normal();
    test_small();
    test_large();
    test_ratios();
    return 0;
}
