/*
 * lrint() test harness — prints (input_hex, output_long) pairs.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <limits.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x)
{
    long r = lrint(x);
    printf("%016llx %016lx\n", (unsigned long long)d2u(x), (unsigned long)r);
}

static void emit_u(uint64_t bits)
{
    emit(u2d(bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0);
    emit(-0.0);
    emit_u(0x7ff8000000000000ULL);  /* qNaN */
    emit_u(0x7ff0000000000000ULL);  /* +Inf */
    emit_u(0xfff0000000000000ULL);  /* -Inf */
}

/* Test small integers */
static void test_small_integers(void)
{
    double vals[] = { -5.0, -1.0, 0.0, 1.0, 5.0 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++)
        emit(vals[i]);
}

/* Test half-way cases */
static void test_halfway(void)
{
    emit(0.5);
    emit(1.5);
    emit(2.5);
    emit(-0.5);
    emit(-1.5);
    emit(-2.5);
}

/* Test fractional values */
static void test_fractional(void)
{
    double vals[] = { -5.9, -5.1, -0.9, -0.1, 0.1, 0.9, 5.1, 5.9 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++)
        emit(vals[i]);
}

/* Test near LONG_MAX/LONG_MIN */
static void test_boundary(void)
{
    emit((double)(LONG_MAX - 1));
    emit((double)LONG_MAX);
    emit((double)(LONG_MIN + 1));
    emit((double)LONG_MIN);
}

/* Test overflow */
static void test_overflow(void)
{
    emit(1.0e20);
    emit(-1.0e20);
    emit(DBL_MAX);
    emit(-DBL_MAX);
}

int main(void)
{
    test_special();
    test_small_integers();
    test_halfway();
    test_fractional();
    test_boundary();
    test_overflow();
    return 0;
}
