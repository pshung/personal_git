/*
 * sqrt() test harness — prints (input_hex, output_hex) pairs.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x)
{
    double r = sqrt(x);
    printf("%016llx %016llx\n", (unsigned long long)d2u(x), (unsigned long long)d2u(r));
}

static void emit_u(uint64_t bits)
{
    emit(u2d(bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0);
    emit(-0.0);
    emit_u(0x7ff8000000000000ULL);  /* qNaN */
    emit_u(0x7ff0000000000000ULL);  /* +Inf */
}

/* Test negative numbers */
static void test_negative(void)
{
    emit(-1.0);
    emit_u(0xbff0000000000000ULL);  /* -1.0 */
}

/* Test perfect squares */
static void test_perfect_squares(void)
{
    double vals[] = { 1.0, 4.0, 9.0, 16.0, 25.0, 100.0, 10000.0 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++)
        emit(vals[i]);
}

/* Test tiny values */
static void test_tiny(void)
{
    emit_u(0x0000000000000001ULL);
    emit_u(0x000fffffffffffff ULL);  /* max subnormal */
    emit(DBL_MIN);
    emit(1.0e-200);
    emit(1.0e-300);
}

/* Test normal range */
static void test_normal(void)
{
    double vals[] = { 0.5, 2.0, 3.0, 10.0, 100.0, 1000.0 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++)
        emit(vals[i]);
}

/* Test large values */
static void test_large(void)
{
    emit(1.0e100);
    emit(1.0e200);
    emit(1.0e300);
    emit(DBL_MAX);
}

int main(void)
{
    test_special();
    test_negative();
    test_perfect_squares();
    test_tiny();
    test_normal();
    test_large();
    return 0;
}
