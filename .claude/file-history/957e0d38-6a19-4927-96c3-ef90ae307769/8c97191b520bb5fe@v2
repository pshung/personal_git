/*
 * round() test harness — prints (input_hex, output_hex) pairs.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x)
{
    double r = round(x);
    printf("%016llx %016llx\n", (unsigned long long)d2u(x), (unsigned long long)d2u(r));
}

static void emit_u(uint64_t bits)
{
    emit(u2d(bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0);
    emit(-0.0);
    emit_u(0x7ff8000000000000ULL);  /* qNaN */
    emit_u(0x7ff0000000000000ULL);  /* +Inf */
    emit_u(0xfff0000000000000ULL);  /* -Inf */
}

/* Test integers */
static void test_integers(void)
{
    double vals[] = { -5.0, -1.0, 0.0, 1.0, 5.0 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++)
        emit(vals[i]);
}

/* Test half-way cases (round to even) */
static void test_halfway(void)
{
    emit(0.5);     /* rounds to 0 */
    emit(1.5);     /* rounds to 2 */
    emit(2.5);     /* rounds to 2 */
    emit(3.5);     /* rounds to 4 */
    emit(-0.5);    /* rounds to 0 */
    emit(-1.5);    /* rounds to -2 */
    emit(-2.5);    /* rounds to -2 */
}

/* Test fractional values */
static void test_fractional(void)
{
    double vals[] = { -5.9, -5.4, -5.1, -0.9, -0.4, -0.1, 0.1, 0.4, 0.9, 5.1, 5.4, 5.9 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++)
        emit(vals[i]);
}

/* Test near halfway */
static void test_near_halfway(void)
{
    emit(0.5000000000000001);
    emit(0.4999999999999999);
    emit(1.5000000000000001);
    emit(1.4999999999999999);
}

/* Test tiny values */
static void test_tiny(void)
{
    emit(1.0e-200);
    emit(-1.0e-200);
    emit(DBL_MIN);
    emit(-DBL_MIN);
}

/* Test large values */
static void test_large(void)
{
    emit(1.0e100);
    emit(-1.0e100);
    emit(1.0e300);
    emit(-1.0e300);
    emit(DBL_MAX);
    emit(-DBL_MAX);
}

int main(void)
{
    test_special();
    test_integers();
    test_halfway();
    test_fractional();
    test_near_halfway();
    test_tiny();
    test_large();
    return 0;
}
