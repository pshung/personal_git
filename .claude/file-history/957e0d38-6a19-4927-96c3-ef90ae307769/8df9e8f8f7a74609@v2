/*
 * atanh() test harness — prints (input_hex, output_hex) pairs.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x)
{
    double r = atanh(x);
    printf("%016llx %016llx\n", (unsigned long long)d2u(x), (unsigned long long)d2u(r));
}

static void emit_u(uint64_t bits)
{
    emit(u2d(bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0);
    emit(-0.0);
    emit_u(0x7ff8000000000000ULL);  /* qNaN */
}

/* Test bounds */
static void test_bounds(void)
{
    emit(-1.0);
    emit(1.0);
}

/* Test domain error */
static void test_domain_error(void)
{
    emit_u(0x3ff0000000000001ULL);  /* 1.0 + eps */
    emit_u(0xbff0000000000001ULL);  /* -1.0 - eps */
    emit(2.0);
    emit(-2.0);
}

/* Test normal range */
static void test_normal(void)
{
    double vals[] = { -0.99, -0.5, 0.0, 0.5, 0.99 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++)
        emit(vals[i]);
}

/* Test values close to bounds */
static void test_near_bounds(void)
{
    emit(0.9999);
    emit(-0.9999);
    emit(0.99999);
    emit(-0.99999);
}

int main(void)
{
    test_special();
    test_bounds();
    test_domain_error();
    test_normal();
    test_near_bounds();
    return 0;
}
