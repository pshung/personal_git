/*
 * lgamma() test harness — prints (input_hex, output_hex) pairs.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x)
{
    double r = lgamma(x);
    printf("%016llx %016llx\n", (unsigned long long)d2u(x), (unsigned long long)d2u(r));
}

static void emit_u(uint64_t bits)
{
    emit(u2d(bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0);
    emit(-0.0);
    emit_u(0x7ff8000000000000ULL);  /* qNaN */
    emit_u(0x7ff0000000000000ULL);  /* +Inf */
    emit_u(0xfff0000000000000ULL);  /* -Inf */
}

/* Test integers */
static void test_integers(void)
{
    emit(1.0);
    emit(2.0);
    emit(3.0);
    emit(4.0);
    emit(5.0);
    emit(10.0);
}

/* Test half-integers */
static void test_half_integers(void)
{
    emit(0.5);
    emit(1.5);
    emit(2.5);
    emit(3.5);
}

/* Test negative values (poles at non-positive integers) */
static void test_negative(void)
{
    emit(-0.5);
    emit(-1.5);
    emit(-2.5);
}

/* Test small values */
static void test_small(void)
{
    emit(0.1);
    emit(0.01);
    emit(1.0e-10);
}

/* Test large values */
static void test_large(void)
{
    emit(100.0);
    emit(1000.0);
    emit(1.0e10);
}

int main(void)
{
    test_special();
    test_integers();
    test_half_integers();
    test_negative();
    test_small();
    test_large();
    return 0;
}
