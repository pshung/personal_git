/*
 * frexp() test harness — prints (input_hex, mantissa_hex, exponent) triples.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(double x)
{
    int exp;
    double mantissa = frexp(x, &exp);
    printf("%016llx %016llx %d\n", (unsigned long long)d2u(x), (unsigned long long)d2u(mantissa), exp);
}

static void emit_u(uint64_t bits)
{
    emit(u2d(bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0);
    emit(-0.0);
    emit_u(0x7ff8000000000000ULL);  /* qNaN */
    emit_u(0x7ff0000000000000ULL);  /* +Inf */
    emit_u(0xfff0000000000000ULL);  /* -Inf */
}

/* Test powers of 2 */
static void test_powers_of_2(void)
{
    emit(1.0);
    emit(2.0);
    emit(4.0);
    emit(0.5);
    emit(0.25);
    emit(1024.0);
    emit(-1.0);
    emit(-2.0);
}

/* Test normal values */
static void test_normal(void)
{
    double vals[] = { 1.5, 2.5, 3.14159, 10.0, 100.0, -1.5, -2.5, -3.14159 };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++)
        emit(vals[i]);
}

/* Test tiny values */
static void test_tiny(void)
{
    emit(DBL_MIN);
    emit(-DBL_MIN);
    emit(1.0e-200);
    emit(-1.0e-200);
}

/* Test large values */
static void test_large(void)
{
    emit(1.0e100);
    emit(-1.0e100);
    emit(DBL_MAX);
    emit(-DBL_MAX);
}

int main(void)
{
    test_special();
    test_powers_of_2();
    test_normal();
    test_tiny();
    test_large();
    return 0;
}
