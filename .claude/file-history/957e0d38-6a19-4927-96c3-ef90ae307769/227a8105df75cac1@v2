/*
 * jn() test harness — prints (n, x_hex, output_hex) triples.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint64_t d2u(double d)
{
    union { double d; uint64_t u; } x;
    x.d = d;
    return x.u;
}

static inline double u2d(uint64_t u)
{
    union { double d; uint64_t u; } x;
    x.u = u;
    return x.d;
}

static void emit(int n, double x)
{
    double r = jn(n, x);
    printf("%d %016llx %016llx\n", n, (unsigned long long)d2u(x), (unsigned long long)d2u(r));
}

static void emit_u(int n, uint64_t bits)
{
    emit(n, u2d(bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0, 0.0);
    emit(1, 0.0);
    emit(2, 0.0);
    emit(0, -0.0);
    emit_u(0, 0x7ff8000000000000ULL);  /* qNaN */
    emit_u(1, 0x7ff0000000000000ULL);  /* +Inf */
}

/* Test order 0 (J0) */
static void test_order_0(void)
{
    emit(0, 0.5);
    emit(0, 1.0);
    emit(0, 5.0);
    emit(0, 10.0);
    emit(0, -5.0);
}

/* Test order 1 (J1) */
static void test_order_1(void)
{
    emit(1, 0.5);
    emit(1, 1.0);
    emit(1, 5.0);
    emit(1, 10.0);
    emit(1, -5.0);
}

/* Test order 2 */
static void test_order_2(void)
{
    emit(2, 0.5);
    emit(2, 1.0);
    emit(2, 5.0);
    emit(2, 10.0);
    emit(2, -5.0);
}

/* Test higher orders */
static void test_higher_orders(void)
{
    emit(3, 5.0);
    emit(5, 5.0);
    emit(10, 5.0);
    emit(-1, 5.0);
    emit(-2, 5.0);
}

/* Test large arguments */
static void test_large(void)
{
    emit(0, 100.0);
    emit(1, 100.0);
    emit(2, 100.0);
}

int main(void)
{
    test_special();
    test_order_0();
    test_order_1();
    test_order_2();
    test_higher_orders();
    test_large();
    return 0;
}
