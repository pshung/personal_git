/*
 * asinhf() test harness — prints (input_hex, output_hex) pairs.
 */

#include <math.h>
#include <stdint.h>
#include <stdio.h>
#include <float.h>

static inline uint32_t f2u(float f)
{
    union { float f; uint32_t u; } x;
    x.f = f;
    return x.u;
}

static inline float u2f(uint32_t u)
{
    union { float f; uint32_t u; } x;
    x.u = u;
    return x.f;
}

static void emit(float x)
{
    float r = asinhf(x);
    printf("%08lx %08lx\n", (unsigned long)f2u(x), (unsigned long)f2u(r));
}

static void emit_u(uint32_t bits)
{
    emit(u2f(bits));
}

/* Test special values */
static void test_special(void)
{
    emit(0.0f);
    emit(-0.0f);
    emit_u(0x7fc00000u);  /* qNaN */
    emit_u(0x7f800000u);  /* +Inf */
    emit_u(0xff800000u);  /* -Inf */
}

/* Test tiny values */
static void test_tiny(void)
{
    emit_u(0x00000001u);
    emit_u(0x80000001u);
    emit(FLT_MIN);
    emit(-FLT_MIN);
    emit(1.0e-20f);
    emit(-1.0e-20f);
}

/* Test normal range */
static void test_normal(void)
{
    float vals[] = { 0.1f, 0.5f, 1.0f, 2.0f, 5.0f, 10.0f, 100.0f };
    int n = sizeof(vals) / sizeof(vals[0]);
    for (int i = 0; i < n; i++) {
        emit(vals[i]);
        emit(-vals[i]);
    }
}

/* Test large values */
static void test_large(void)
{
    emit(1e10f);
    emit(-1e10f);
    emit(1e20f);
    emit(-1e20f);
    emit(FLT_MAX);
    emit(-FLT_MAX);
}

int main(void)
{
    test_special();
    test_tiny();
    test_normal();
    test_large();
    return 0;
}
