/*
 * test-fabs.c -- Accuracy test for fabs() and fabsf()
 */
#include "test-common.h"

int main(void)
{
    printf("=== fabs/fabsf accuracy test ===\n");

    /* Double: exact results expected (0 ULP) */
    CHECK_DOUBLE("fabs", fabs(0.0), "0.0", 0.0, 0);
    CHECK_DOUBLE("fabs", fabs(-0.0), "-0.0", 0.0, 0);
    CHECK_DOUBLE("fabs", fabs(1.0), "1.0", 1.0, 0);
    CHECK_DOUBLE("fabs", fabs(-1.0), "-1.0", 1.0, 0);
    CHECK_DOUBLE("fabs", fabs(3.14), "3.14", 3.14, 0);
    CHECK_DOUBLE("fabs", fabs(-3.14), "-3.14", 3.14, 0);
    CHECK_DOUBLE("fabs", fabs(1e300), "1e300", 1e300, 0);
    CHECK_DOUBLE("fabs", fabs(-1e300), "-1e300", 1e300, 0);
    CHECK_DOUBLE("fabs", fabs(5e-324), "5e-324", 5e-324, 0);
    CHECK_DOUBLE("fabs", fabs(-5e-324), "-5e-324", 5e-324, 0);
    CHECK_DOUBLE_INF("fabs", fabs(INFINITY), "Inf", +1);
    CHECK_DOUBLE_INF("fabs", fabs(-INFINITY), "-Inf", +1);
    /* fabs(NaN) = NaN (with sign bit cleared, but still NaN) */
    CHECK_DOUBLE_NAN("fabs", fabs(NAN), "NaN");

    /* Float */
    CHECK_FLOAT("fabsf", fabsf(0.0f), "0.0f", 0.0f, 0);
    CHECK_FLOAT("fabsf", fabsf(-0.0f), "-0.0f", 0.0f, 0);
    CHECK_FLOAT("fabsf", fabsf(1.0f), "1.0f", 1.0f, 0);
    CHECK_FLOAT("fabsf", fabsf(-1.0f), "-1.0f", 1.0f, 0);
    CHECK_FLOAT("fabsf", fabsf(3.14f), "3.14f", 3.14f, 0);
    CHECK_FLOAT("fabsf", fabsf(-3.14f), "-3.14f", 3.14f, 0);
    CHECK_FLOAT("fabsf", fabsf(1e38f), "1e38f", 1e38f, 0);
    CHECK_FLOAT("fabsf", fabsf(-1e38f), "-1e38f", 1e38f, 0);
    CHECK_FLOAT("fabsf", fabsf(1.4e-45f), "1.4e-45f", 1.4e-45f, 0);
    CHECK_FLOAT("fabsf", fabsf(-1.4e-45f), "-1.4e-45f", 1.4e-45f, 0);
    CHECK_FLOAT_INF("fabsf", fabsf(INFINITY), "Inf", +1);
    CHECK_FLOAT_INF("fabsf", fabsf(-INFINITY), "-Inf", +1);
    CHECK_FLOAT_NAN("fabsf", fabsf(NAN), "NaN");

    TEST_SUMMARY("fabs/fabsf");
}
