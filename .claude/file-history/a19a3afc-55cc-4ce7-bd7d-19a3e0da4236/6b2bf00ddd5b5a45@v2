/*
 * test-log.c -- Accuracy test for logf()
 *
 * Only logf is overridden on riscv64.
 */
#include "test-common.h"
#include "golden-values.h"

static void test_logf_golden(void)
{
    for (unsigned i = 0; i < GOLDEN_LOGF_COUNT; i++) {
        char buf[64];
        snprintf(buf, sizeof(buf), "%.9g", (double)golden_logf[i].input);
        CHECK_FLOAT("logf", logf(golden_logf[i].input), buf,
                    golden_logf[i].expected, golden_logf[i].max_ulp);
    }
}

static void test_logf_special(void)
{
    /* log(1) = 0 */
    CHECK_FLOAT("logf", logf(1.0f), "1.0f", 0.0f, 0);
    /* log(0) = -Inf */
    CHECK_FLOAT_INF("logf", logf(0.0f), "0.0f", -1);
    /* log(-0) = -Inf */
    CHECK_FLOAT_INF("logf", logf(-0.0f), "-0.0f", -1);
    /* log(+Inf) = +Inf */
    CHECK_FLOAT_INF("logf", logf(INFINITY), "Inf", +1);
    /* log(-1) = NaN */
    CHECK_FLOAT_NAN("logf", logf(-1.0f), "-1.0f");
    /* log(NaN) = NaN */
    CHECK_FLOAT_NAN("logf", logf(NAN), "NaN");
}

int main(void)
{
    printf("=== logf accuracy test ===\n");

    test_logf_golden();
    test_logf_special();

    TEST_SUMMARY("logf");
}
