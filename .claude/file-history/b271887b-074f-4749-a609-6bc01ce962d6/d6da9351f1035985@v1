    stride_x = 3;
    stride_y = 2;
    in_tensor_dim_x = 56;
    in_tensor_dim_y = 34;
    in_tensor_ch = 1031;
    out_tensor_ch = 2050;
    out_tensor_dim_x = 19;
    out_tensor_dim_y = 17;
    is_bias_null = false;
    retStatus |= test("8b_in1.bin", "8b_in2.bin", "32b_in1.bin",
