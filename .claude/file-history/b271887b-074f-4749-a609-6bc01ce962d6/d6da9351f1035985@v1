    int32_t out_offset, in_offset, act_min, act_max;
    uint32_t retStatus=NDS_SUCCESS;
    bool is_bias_null;

    pad_x = 0;
    pad_y = 0;
    out_offset = 5;
    in_offset = 3;
    act_min = 0xffffff81;
    act_max = 0x0000007e;

