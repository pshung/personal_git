/* Provide __clzsi2 for RV32 assembly files running on RV64 target.
 * libgcc on RV64 only provides __clzdi2 (64-bit), but the Andes
 * softfloat assembly helpers call __clzsi2 (32-bit). */
int __clzsi2(unsigned int x)
{
    if (x == 0)
        return 32;
    int n = 0;
    if (x <= 0x0000FFFF) { n += 16; x <<= 16; }
    if (x <= 0x00FFFFFF) { n +=  8; x <<=  8; }
    if (x <= 0x0FFFFFFF) { n +=  4; x <<=  4; }
    if (x <= 0x3FFFFFFF) { n +=  2; x <<=  2; }
    if (x <= 0x7FFFFFFF) { n +=  1; }
    return n;
}
