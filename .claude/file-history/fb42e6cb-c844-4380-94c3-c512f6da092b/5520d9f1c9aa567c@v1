#pragma once

namespace pipeview {

/// Abstract per-cycle pipeline viewer.
/// Implementations (e.g. Kanata) record pipeline events each cycle and
/// write to their own output format.
template<typename CPU>
class PipelineViewer
{
public:
  virtual ~PipelineViewer() = default;

  /// Called once per cycle after sc_start.
  virtual void on_cycle() = 0;

  /// Flush and close the viewer output.
  virtual void close() = 0;
};

} // namespace pipeview
