/* Slim harness for vsim Kanata loop-window verification.
 * No fread, no golden, no verify. Buffer big enough for a few outer-loop
 * iterations of riscv_nn_relu_s8 (each processes maxvl_per_loop = VLMAX*4
 * bytes; with VLEN=1024 that's 512 B/iter, so 4096 B yields 8 iterations). */
#include <stdint.h>
#include "riscv_nn_activation.h"
#include "test_util.h"

#define BUF_SIZE 4096
static int8_t buf[BUF_SIZE];

int main(void)
{
    enable_fs_and_vs();
    for (int i = 0; i < BUF_SIZE; ++i)
        buf[i] = (int8_t)((i & 0xFF) - 64);
    riscv_nn_relu_s8(buf, BUF_SIZE);
    return 0;
}
