// SimPoint Basic Block Vector (BBV) emission for the hybrid_handoff QEMU
// TCG plugin. One .bb row per `slice` retired insns; row format:
//   T:<bbid>:<count> :<bbid>:<count> ... \n
// where bbid is 1-based and count is the dynamic instruction count
// attributed to that basic block within the current slice. The format
// is consumed verbatim by tools/simpoint/bin/simpoint (SimPoint 3.2
// FVParser).
//
// Single-hart only - matches the broader hybrid plan-validation
// contract (hart_id != 0 rejected by orchestrator).

#pragma once

#include <stdint.h>

typedef struct BbvEmit BbvEmit;

// Opens `path` for writing (truncate). Returns NULL on error.
BbvEmit *bbv_emit_new(const char *path, uint64_t slice_target);

// Translation-time: assign or look up the 1-based bb_id for `pc`. Repeat
// calls with the same PC return the same id. O(1) hash lookup.
uint64_t bbv_emit_assign_id(BbvEmit *e, uint64_t pc);

// Per-insn tick. Attributes one insn to `bb_id`. On every slice_target-th
// tick, writes a row and resets per-BB counts.
void bbv_emit_tick(BbvEmit *e, uint64_t bb_id);

// Closes the file. The last partial slice (if any) is dropped, matching
// standard SimPoint emitter behavior.
void bbv_emit_close(BbvEmit *e);
