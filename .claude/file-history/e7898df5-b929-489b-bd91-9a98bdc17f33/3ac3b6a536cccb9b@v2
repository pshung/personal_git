"""Unit tests for MmapOwner: RAII /dev/shm fd holder used by the F8 N-way runner.

Covers:
  - allocate(): creates a file under /dev/shm sized to `mem_size`, unlinks on exit.
  - attach(): wraps an existing path without taking ownership of its lifecycle.
  - invalid size is rejected.
"""
from __future__ import annotations

import os
from pathlib import Path

import pytest

from orchestrator.mmap_owner import MmapOwner


def test_allocate_creates_file_at_requested_size() -> None:
    size = 4 * 1024 * 1024
    with MmapOwner.allocate(size) as owner:
        assert owner.path.exists()
        assert owner.path.parent == Path("/dev/shm")
        assert os.path.getsize(owner.path) == size
        path_held = owner.path
    # NamedTemporaryFile(delete=True) unlinks on close.
    assert not path_held.exists()


def test_allocate_rejects_zero_or_negative_size() -> None:
    for bad in (0, -1):
        with pytest.raises(ValueError):
            MmapOwner.allocate(bad)


def test_attach_leaves_file_untouched_on_exit(tmp_path: Path) -> None:
    target = tmp_path / "external-mmap"
    size = 1024
    with open(target, "wb") as fp:
        os.ftruncate(fp.fileno(), size)
    with MmapOwner.attach(target, size) as owner:
        assert owner.path == target
        assert owner.size == size
    # attach() must not delete - caller owns the lifecycle.
    assert target.exists()


def test_attach_raises_when_path_missing(tmp_path: Path) -> None:
    with pytest.raises(FileNotFoundError):
        MmapOwner.attach(tmp_path / "nope", 1024)
