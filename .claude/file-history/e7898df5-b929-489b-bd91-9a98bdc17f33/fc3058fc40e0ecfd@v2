"""F2 RED: `orchestrator dry-run <plan>` prints one line per planned spawn.

Dry-run is the F2 deliverable: confirm that the plan parses, then exit.
No process is spawned. The output is intentionally informal (humans
read it during plan authoring); the assertions below pin only the
load-bearing fields so future formatting changes do not flap the test.
"""
from __future__ import annotations

from pathlib import Path

from orchestrator.main import main


_EXAMPLE = Path(__file__).resolve().parents[1] / "examples" / "csr_oneshot.yaml"


def test_dry_run_prints_three_spawns(capsys) -> None:
    rc = main(["dry-run", str(_EXAMPLE)])
    out = capsys.readouterr().out

    assert rc == 0
    spawn_lines = [line for line in out.splitlines() if "step " in line]
    assert len(spawn_lines) == 3
    assert "model=qemu" in spawn_lines[0]
    assert "trigger=csr" in spawn_lines[0]
    assert "model=vsim" in spawn_lines[1]
    assert "trigger=csr" in spawn_lines[1]
    assert "model=qemu" in spawn_lines[2]
    assert "trigger=end_of_program" in spawn_lines[2]
