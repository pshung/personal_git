function = "sinf"
name     = "d9_horner"
description = "degree-9 sin / degree-10 cos, unrolled Horner, Sollya minimax coefficients"

[target]
isa  = "rv32im"
abi  = "ilp32"
core = "andes-n25"
xlen = 32

[latency]
mul                  = 1
mulhu                = 4
mulhsu               = 4
load_use             = 2
alu                  = 1
branch_taken_penalty = 2
mispredict_penalty   = 3
mul_pipelined        = true

[accuracy]
target_ulp  = 1.0
eval_domain = [-0.7853981633974483, 0.7853981633974483]
rounding    = "round_nearest_even"

[size_budget]
extra_text_bytes   = 256
extra_rodata_bytes = 16

[reduction]
strategy                = "bit_serial"
small_arg_threshold_exp = -126
huge_arg_policy         = "return_nan"
pi_over_2_words         = 2

[kernel]
sin_degree            = 9
cos_degree            = 10
evaluation            = "horner"
unroll                = true
fixed_point_format    = "Q1.31"
use_mulhsu_for_signed = false

[verify]
special_inputs  = [0.0, -0.0]
max_allowed_ulp = 1.0

[bench]
enabled              = true
target               = "fpga"
representative_input = 1.0
iterations           = 100
