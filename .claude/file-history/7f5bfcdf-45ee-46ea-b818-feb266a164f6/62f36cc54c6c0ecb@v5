# AX45MPV — RV64, Vector 1.0, 45-series, VLEN=1024

[cpu]
name = ax45mpv

[toolchain]
compiler = riscv64-elf-gcc
extra_cflags = -mext-vector -mtune=andes-45-series -DNDS_VEC_RVV_VERSION=1000

[sim]
wrapper = project/ax45mpv/riscv-qemu-wrapper-v512_d512_b512
target = QEMU

[qemu]
vec_cfg = zve64d

[board]
ice_host = sw-boards.andestech.com
ice_port = 1116
