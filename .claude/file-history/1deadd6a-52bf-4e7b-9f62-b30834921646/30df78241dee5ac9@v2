"""End-to-end integration test for modelzoo_ranker CLI."""
import json
import os

from modelzoo_ranker.train import train_and_evaluate


class TestCLIEndToEnd:
    def test_cli_end_to_end(self, dataset_dir, tmp_path):
        """Full pipeline: load -> split -> train -> evaluate -> save."""
        output_dir = str(tmp_path / 'output')

        history, test_metrics = train_and_evaluate(
            dataset_dir, output_dir,
            max_epochs=5, batch_size=4, patience=10, top_k=2,
            val_models=['ModelA'], test_models=['ModelB'],
            seed=42,
        )

        # Check history
        assert 'train_loss' in history
        assert len(history['train_loss']) == 5
        assert 'best_epoch' in history

        # Check test metrics include top-k error
        assert 'opa' in test_metrics
        assert 'top1_error' in test_metrics
        assert 'top3_error' in test_metrics
        assert 'top5_error' in test_metrics
        assert all(isinstance(v, float) for v in test_metrics.values())

        # Check output files
        assert os.path.isfile(os.path.join(output_dir, 'model.pt'))
        assert os.path.isfile(os.path.join(output_dir, 'training_history.json'))
        assert os.path.isfile(os.path.join(output_dir, 'test_metrics.json'))
        assert os.path.isfile(os.path.join(output_dir, 'split_config.json'))
        assert os.path.isfile(os.path.join(output_dir, 'dataset_summary.txt'))

        # Check split_config content
        with open(os.path.join(output_dir, 'split_config.json')) as f:
            split_cfg = json.load(f)
        assert split_cfg['val_models'] == ['ModelA']
        assert split_cfg['test_models'] == ['ModelB']

        # Check test_metrics.json has top-k error
        with open(os.path.join(output_dir, 'test_metrics.json')) as f:
            saved_metrics = json.load(f)
        assert 'top1_error' in saved_metrics
