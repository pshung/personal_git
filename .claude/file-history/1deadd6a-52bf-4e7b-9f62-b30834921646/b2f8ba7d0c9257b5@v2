class TestLoadTileConfig:
    def test_load_single_op_dispatch(self, zoo_dir):
        """Load a single-op tile_config.json and get parsed dict."""
        tc = load_tile_config(zoo_dir, "Bird", "module_main_dispatch_0")
        assert tc is not None
        assert "linalg.generic-0" in tc
        assert tc["linalg.generic-0"]["instruction_seq"] == "arith.mulf-arith.subf-linalg.yield"

    def test_load_multi_op_dispatch(self, zoo_dir):
        """Load a multi-op tile_config.json with 3 ops."""
        tc = load_tile_config(zoo_dir, "Bird", "module_main_dispatch_1")
        assert tc is not None
        assert len(tc) == 3
        assert "linalg.matmul-1" in tc

    def test_load_missing_returns_none(self, zoo_dir):
        """Missing tile_config file returns None."""
        tc = load_tile_config(zoo_dir, "Bird", "module_main_dispatch_99")
        assert tc is None

    def test_load_unknown_model_returns_none(self, zoo_dir):
        """Unknown model name returns None."""
        tc = load_tile_config(zoo_dir, "UnknownModel", "module_main_dispatch_0")
        assert tc is None


class TestLoadAllTileConfigs:
    def test_load_all(self, zoo_dir):
        """Load all tile_configs for a model."""
        configs = load_all_tile_configs(zoo_dir, "Bird")
        assert len(configs) == 2
        assert "module_main_dispatch_0" in configs
        assert "module_main_dispatch_1" in configs

    def test_load_all_unknown_model(self, zoo_dir):
        """Unknown model returns empty dict."""
        configs = load_all_tile_configs(zoo_dir, "UnknownModel")
        assert configs == {}
