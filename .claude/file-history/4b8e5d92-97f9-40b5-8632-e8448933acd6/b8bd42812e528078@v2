    code: "execv(qemu_binary,\n  '-cpu', 'andes-ax45mpv,vlen=512',\n  '-bios', 'none', '-nographic',\n  '-object', 'memory-backend-file,id=mem,share=on,mem-path=...,size=...',\n  '-machine', 'andes_ae350,memory-backend=mem',\n  '-gdb', 'tcp::PORT', '-S', NULL);",
    files: "hybrid_vsim/src/hybrid/qemu_handback.hpp (spawn_qemu)"
  },
  {
    name: "10. replay",
    title: "Restore via gdbstub P-packets and continue",
    live: ["vsim", "q2"],
    what: "Connect to <code>tcp::PORT</code>, fetch <code>target.xml</code> + every xi:include annex via <code>qXfer:features:read</code>, build name to packet-number map. Then send a P-packet for every register the stub advertises. Finally send <code>vc</code> (continue).",
    why: "Numbered P-packets aren't portable across QEMU CSR feature versions - feature XML can change which CSRs are advertised. Looking up by name keeps the handback resilient.",
    code: "auto reg_map = discover_reg_map(sess);\nfor (i = 1..31)  sess.send_command(P{i, state.gpr[i]});\n                  sess.send_command(P{32, state.pc});\ntry_write_named_u64(sess, reg_map, 'mstatus', state.mstatus);\n...\nfor (i = 0..31) try_write_named_bytes(sess, reg_map,\n                  'v'+i, &state.vreg[i*64], state.vlenb);\nsess.cont();",
    files: "hybrid_vsim/src/hybrid/qemu_handback.hpp (apply_state, discover_reg_map)"
  },
  {
    name: "11. finish",
    title: "QEMU 2 runs to completion; exit code propagates",
    live: ["q2"],
    what: "vsim's parent process <code>waitpid()</code>s on QEMU2. WIFEXITED -> exit code; WIFSIGNALED -> 128+signum. That value is returned all the way up to <code>run_e2e.sh</code>.",
    why: "Every phase is allowed to fail independently and surfaces its own exit code so e2e logs pinpoint which phase broke. ChildExitedDuringConnect catches the case where QEMU2 dies before its gdbstub becomes reachable (typically a bad <code>--qemu-binary</code> path).",
    code: "int wstat;\nwaitpid(pid, &wstat, 0);\nreturn WIFEXITED(wstat)   ? WEXITSTATUS(wstat)\n     : WIFSIGNALED(wstat) ? 128 + WTERMSIG(wstat)\n     : -1;",
    files: "hybrid_vsim/src/hybrid/qemu_handback.hpp (run_qemu_handback), run_e2e.sh"
  }
];

let curStep = 0;
const stepBtnsEl = document.getElementById('stepBtns');
const walkInfoEl = document.getElementById('walkInfo');
steps.forEach((s, i) => {
  const b = document.createElement('button');
  b.className = 'step-btn';
  b.textContent = s.name;
  b.onclick = () => goStep(i);
  stepBtnsEl.appendChild(b);
});

function goStep(i) {
  curStep = Math.max(0, Math.min(steps.length - 1, i));
  const s = steps[curStep];

  // step buttons
  document.querySelectorAll('.step-btn').forEach((b, idx) => {
    b.classList.toggle('active', idx === curStep);
  });
  document.getElementById('prevBtn').disabled = (curStep === 0);
  document.getElementById('nextBtn').disabled = (curStep === steps.length - 1);

  // stage
  const live = new Set(s.live || []);
  const liveArrows = new Set(s.arrows || []);
  document.querySelectorAll('.stage-actor').forEach(a => {
    a.classList.toggle('live', live.has(a.dataset.actor));
  });
  document.querySelectorAll('.stage-arrow').forEach(a => {
    a.classList.toggle('live', liveArrows.has(a.dataset.actor));
    a.textContent = liveArrows.has(a.dataset.actor) ? 'v' : '|';
  });

  // info
  walkInfoEl.innerHTML = `
    <h3>${s.title}</h3>
    <div class="what"><b>What happens</b>${s.what}</div>
    <div class="why"><b>Why this way</b>${s.why}</div>
    <pre>${escapeHtml(s.code)}</pre>
    <div class="files">${s.files}</div>
  `;
}
function escapeHtml(t) {
  return t.replace(/[&<>]/g, c => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;' }[c]));
}
document.getElementById('prevBtn').onclick = () => goStep(curStep - 1);
document.getElementById('nextBtn').onclick = () => goStep(curStep + 1);
goStep(0);

// Default: select QEMU1 in the top diagram so the detail panel is populated
document.querySelector('.node[data-id="qemu1"]').click();
</script>

