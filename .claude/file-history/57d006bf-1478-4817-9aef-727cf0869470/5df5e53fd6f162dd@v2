// vsim's main RAM must cover QEMU's `virt`-machine RAM base (0x80000000) so
// the same ELF can be loaded at the same physical address in both halves of
// the hybrid handoff. The cap stays below NDS_HVM_BASE (0x90000000), which
// is the CPU's slave-port HVM region; further peripherals (ILM, ACM, AIA,
// SMU, UART) start at 0xA0000000+.

#include "platform/memory_map.h"

#define DOCTEST_CONFIG_IMPLEMENT_WITH_MAIN
#include <doctest.h>

#include <cstdint>

constexpr uint64_t kNdsHvmBase = 0x90000000ULL;

TEST_CASE("RAM region covers QEMU virt RAM base 0x80000000")
{
  CHECK(static_cast<uint64_t>(RAM_END) >= 0x80000000ULL);
}

TEST_CASE("RAM region does not collide with NDS_HVM_BASE")
{
  CHECK(static_cast<uint64_t>(RAM_END) < kNdsHvmBase);
}

TEST_CASE("RAM region does not collide with HART0 ILM peripheral")
{
  CHECK(static_cast<uint64_t>(RAM_END) < static_cast<uint64_t>(HART0_ILM_BASE));
}
