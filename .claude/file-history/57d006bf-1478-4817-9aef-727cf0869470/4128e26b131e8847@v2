// Bounded polls of a DMI status register. Shared by ResumeDriver
// (vsim resume from QEMU) and StateDrain (vsim drain to QEMU).

#pragma once

#include <cstdint>
#include <stdexcept>

namespace hybrid
{

struct DmiBus;

inline constexpr unsigned kDmiPollIterations = 1024;

template<typename Bus>
void poll_until_set(Bus& bus, uint8_t reg, uint32_t mask,
                    const char* label = "poll_until_set")
{
  for (unsigned i = 0; i < kDmiPollIterations; ++i)
    if ((bus.read(reg) & mask) == mask) return;
  throw std::runtime_error(std::string{label} + ": timed out");
}

template<typename Bus>
void poll_until_clear(Bus& bus, uint8_t reg, uint32_t mask,
                      const char* label = "poll_until_clear")
{
  for (unsigned i = 0; i < kDmiPollIterations; ++i)
    if ((bus.read(reg) & mask) == 0) return;
  throw std::runtime_error(std::string{label} + ": timed out");
}

}  // namespace hybrid
