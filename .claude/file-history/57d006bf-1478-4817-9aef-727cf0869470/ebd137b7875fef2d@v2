// Pure-logic tests for the GDB Remote Serial Protocol encoders/parsers.
// The TCP transport is exercised by the round-trip e2e test.

#include "hybrid/gdbstub_client.hpp"

#define DOCTEST_CONFIG_IMPLEMENT_WITH_MAIN
#include <doctest.h>

#include <cstdint>
#include <string>

TEST_CASE("compute_checksum: mod-256 sum of ASCII bytes")
{
  // 'O'=0x4F, 'K'=0x4B; sum = 0x9A.
  CHECK(hybrid::gdbstub::compute_checksum("OK") == 0x9Au);
  CHECK(hybrid::gdbstub::compute_checksum("") == 0x00u);
  // 'c'=0x63.
  CHECK(hybrid::gdbstub::compute_checksum("c") == 0x63u);
}

TEST_CASE("encode_packet wraps body with $...#cksum")
{
  CHECK(hybrid::gdbstub::encode_packet("OK") == "$OK#9a");
  CHECK(hybrid::gdbstub::encode_packet("c") == "$c#63");
}

TEST_CASE("encode_p_packet writes reg_num in lowercase hex, value little-endian")
{
  // x1 = 0 -> "P1=" + 16 zeros.
  // 'P'=0x50, '1'=0x31, '='=0x3D, '0'×16 = 16*0x30 = 0x300.
  // 0x50 + 0x31 + 0x3D + 0x300 = 0x3BE -> 0xBE mod 256.
  CHECK(hybrid::gdbstub::encode_p_packet(1, 0u)
        == "$P1=0000000000000000#be");
}

TEST_CASE("encode_p_packet emits little-endian byte order for 64-bit value")
{
  // 0xDEADBEEFCAFEBABE little-endian byte hex: be ba fe ca ef be ad de
  const auto pkt = hybrid::gdbstub::encode_p_packet(10, 0xDEADBEEFCAFEBABEULL);
  // Body looks like "Pa=bebafecaefbeadde"; just check the value substring.
  CHECK(pkt.find("Pa=bebafecaefbeadde") != std::string::npos);
  CHECK(pkt.starts_with("$"));
  CHECK(pkt.find("#") != std::string::npos);
}

TEST_CASE("encode_p_packet uses two-digit hex for reg_num >= 16")
{
  // x16 -> "P10" (hex 0x10).
  const auto pkt = hybrid::gdbstub::encode_p_packet(16, 0u);
  CHECK(pkt.find("P10=") != std::string::npos);
}

TEST_CASE("encode_continue is exactly $c#63")
{
  CHECK(hybrid::gdbstub::encode_continue() == "$c#63");
}

TEST_CASE("parse_packet extracts body from $body#cksum framing")
{
  CHECK(hybrid::gdbstub::parse_packet("$OK#9a") == "OK");
  CHECK(hybrid::gdbstub::parse_packet("$#00") == "");
}

TEST_CASE("parse_packet rejects malformed framing")
{
  CHECK_FALSE(hybrid::gdbstub::parse_packet("OK").has_value());
  CHECK_FALSE(hybrid::gdbstub::parse_packet("$OK").has_value());
  CHECK_FALSE(hybrid::gdbstub::parse_packet("$OK#").has_value());
}

TEST_CASE("parse_packet rejects mismatched checksum")
{
  CHECK_FALSE(hybrid::gdbstub::parse_packet("$OK#00").has_value());
}
