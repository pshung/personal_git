if(VSIM_ENABLE_HYBRID)
  if(NOT EXISTS "${VSIM_QEMU_ROOT}/include/qemu/qemu-plugin.h")
    message(WARNING
      "VSIM_ENABLE_HYBRID=ON but qemu-plugin.h not found under "
      "${VSIM_QEMU_ROOT}/include/qemu/. Build the TCG plugin out-of-tree via "
      "hybrid/qemu_plugin/Makefile on a host that has QEMU installed.")
  endif()
  message(STATUS "Hybrid mode: enabled (QEMU root: ${VSIM_QEMU_ROOT})")

  # Round-trip e2e test. Requires host-side QEMU + plugin + ELF that live
  # outside the build container; the script resolves them relative to its
  # own location and skips (return code 77) when any artifact is missing.
  # The path is relative so the same CTestTestfile works whether ctest is
  # invoked from the container's /work/build or from the host's build/.
  add_test(
    NAME test_roundtrip_e2e
    COMMAND bash ../tests/hybrid/roundtrip_e2e.sh
  )
  set_tests_properties(test_roundtrip_e2e PROPERTIES
    SKIP_RETURN_CODE 77
    LABELS "hybrid-e2e"
  )
endif()
