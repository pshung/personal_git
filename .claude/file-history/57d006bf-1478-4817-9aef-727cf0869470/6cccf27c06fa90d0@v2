// HandoffController glues CsrTrigger and StateDrain. Given a retired PC and
// a GPR probe, decides whether to drain state and returns the populated
// hybrid_state_v1 if so. Pure-logic; no SystemC.

#include "hybrid/abstract_command.hpp"
#include "hybrid/csr_trigger.hpp"
#include "hybrid/handoff_controller.hpp"
#include "hybrid/insn_match.h"
#include "hybrid/resume_driver.hpp"
#include "hybrid/state_abi.h"

#define DOCTEST_CONFIG_IMPLEMENT_WITH_MAIN
#include <doctest.h>

#include <array>
#include <cstdint>
#include <span>
#include <unordered_map>
#include <vector>

namespace {

constexpr uint8_t kDmstatus   = 0x11;
constexpr uint8_t kAbstractcs = 0x16;
constexpr uint8_t kCommand    = 0x17;
constexpr uint8_t kData0      = 0x04;
constexpr uint8_t kData1      = 0x05;
constexpr uint16_t kCsrDpc    = 0x7B1;

struct DmiOp
{
  enum class Kind
  {
    Write,
    Read,
  };
  Kind kind;
  uint8_t reg;
  uint32_t value;
};

struct RecordingBus final : hybrid::DmiBus
{
  std::vector<DmiOp> ops;
  uint32_t dmstatus_value   = 0;
  uint32_t abstractcs_value = 0;
  std::unordered_map<uint16_t, uint64_t> regfile;
  uint32_t pending_data0 = 0;
  uint32_t pending_data1 = 0;

  void write(uint8_t reg, uint32_t value) override
  {
    ops.push_back({DmiOp::Kind::Write, reg, value});
    if (reg == kCommand) {
      const uint16_t regno = value & 0xffffu;
      const bool is_write  = ((value >> 16) & 1u) != 0;
      if (!is_write) {
        const auto it = regfile.find(regno);
        const uint64_t v = (it == regfile.end()) ? 0 : it->second;
        pending_data0 = static_cast<uint32_t>(v & 0xffffffffu);
        pending_data1 = static_cast<uint32_t>((v >> 32) & 0xffffffffu);
      }
    }
  }

  auto read(uint8_t reg) -> uint32_t override
  {
    ops.push_back({DmiOp::Kind::Read, reg, 0});
    if (reg == kDmstatus)   return dmstatus_value;
    if (reg == kAbstractcs) return abstractcs_value;
    if (reg == kData0)      return pending_data0;
    if (reg == kData1)      return pending_data1;
    return 0;
  }
};

auto encode_csrrwi(uint32_t rd, uint32_t csr, uint32_t uimm) -> uint32_t
{
  return (csr << 20) | (uimm << 15) | (0b101u << 12) | (rd << 7) | 0x73u;
}

auto encode_csrrw(uint32_t rd, uint32_t csr, uint32_t rs1) -> uint32_t
{
  return (csr << 20) | (rs1 << 15) | (0b001u << 12) | (rd << 7) | 0x73u;
}

template<std::size_t N>
auto as_bytes(const std::array<uint32_t, N>& a) -> std::span<const uint8_t>
{
  return std::span{reinterpret_cast<const uint8_t*>(a.data()),
                   N * sizeof(uint32_t)};
}

}  // namespace

TEST_CASE("HandoffController: EXIT csrwi triggers drain and returns state")
{
  RecordingBus bus;
  bus.dmstatus_value = (1u << 9) | (1u << 17);
  bus.regfile[hybrid::regno_gpr(12)] = 3;
  bus.regfile[hybrid::regno_csr(kCsrDpc)] = 0x80000004;

  hybrid::CsrTrigger trigger;
  const std::array<uint32_t, 1> code{encode_csrrwi(0, 0x7C0, 1)};
  trigger.scan_buffer(as_bytes(code), /*base_pc=*/0x80000000);

  hybrid::HandoffController h(std::move(trigger), bus);
  const auto state = h.on_retire(0x80000000, [](uint8_t) { return 0u; });

  REQUIRE(state);
  CHECK(state->magic == HYBRID_STATE_MAGIC);
  CHECK(state->gpr[12] == 3);
  CHECK(state->pc == 0x80000004);
}

TEST_CASE("HandoffController: non-trigger PC returns nullopt without drain")
{
  RecordingBus bus;
  bus.dmstatus_value = (1u << 9) | (1u << 17);

  hybrid::CsrTrigger trigger;  // empty
  hybrid::HandoffController h(std::move(trigger), bus);

  const auto state = h.on_retire(0xDEADBEEF, [](uint8_t) { return 0u; });
  CHECK_FALSE(state.has_value());
  CHECK(bus.ops.empty());
}

TEST_CASE("HandoffController: ENTER csrwi never fires (vsim ignores entry)")
{
  RecordingBus bus;
  bus.dmstatus_value = (1u << 9) | (1u << 17);

  hybrid::CsrTrigger trigger;
  const std::array<uint32_t, 1> code{encode_csrrwi(0, 0x7C0, 0)};
  trigger.scan_buffer(as_bytes(code), /*base_pc=*/0x80000000);

  hybrid::HandoffController h(std::move(trigger), bus);
  const auto state = h.on_retire(0x80000000, [](uint8_t) { return 0u; });
  CHECK_FALSE(state.has_value());
  CHECK(bus.ops.empty());
}

TEST_CASE("HandoffController: RUNTIME fires only when probed GPR == 1")
{
  RecordingBus bus;
  bus.dmstatus_value = (1u << 9) | (1u << 17);

  hybrid::CsrTrigger trigger;
  const std::array<uint32_t, 1> code{encode_csrrw(0, 0x7C0, /*rs1=*/10)};
  trigger.scan_buffer(as_bytes(code), /*base_pc=*/0x80000000);

  hybrid::HandoffController h(std::move(trigger), bus);

  CHECK_FALSE(h.on_retire(0x80000000,
                          [](uint8_t r) { return r == 10 ? 0u : 0u; }));
  REQUIRE(h.on_retire(0x80000000,
                      [](uint8_t r) { return r == 10 ? 1u : 0u; }));
}
