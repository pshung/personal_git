#!/usr/bin/env bash
# Smoke test: drive vsim's Debug Module via OpenOCD over remote-bitbang.
# Halts the spinning fixture, reads/writes a GPR, resumes. If this passes,
# the AHB->DM path is good and SystemCDmiBus should work too.

set -euo pipefail

HERE=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
VSIM=${VSIM:-$HERE/../../build/sim_ax45mpv_premium}
ELF=${ELF:-$HERE/spin.elf}
PORT=${PORT:-9104}

if [[ ! -x "$VSIM" ]]; then
    echo "vsim binary not found at $VSIM" >&2
    exit 1
fi
if [[ ! -f "$ELF" ]]; then
    echo "spin.elf not found at $ELF (run: make -C $HERE)" >&2
    exit 1
fi

cleanup() {
    [[ -n "${VSIM_PID:-}" ]] && kill -9 "$VSIM_PID" 2>/dev/null || true
    wait 2>/dev/null || true
}
trap cleanup EXIT

echo "[smoke] launching vsim with --jtag-port $PORT ..."
"$VSIM" --jtag-port "$PORT" "$ELF" >"$HERE/vsim.log" 2>&1 &
VSIM_PID=$!

# vsim blocks waiting for an OpenOCD connection. Give it a moment to bind.
sleep 1
if ! kill -0 "$VSIM_PID" 2>/dev/null; then
    echo "[smoke] vsim exited early; log:" >&2
    cat "$HERE/vsim.log" >&2
    exit 1
fi

echo "[smoke] driving OpenOCD..."
openocd \
    -f "$HERE/vsim_openocd.cfg" \
    -c "halt" \
    -c "echo {== halted ==}" \
    -c "reg pc" \
    -c "reg a0" \
    -c "reg a1" \
    -c "reg a2" \
    -c "reg a2 0xdeadbeef" \
    -c "echo {== a2 written ==}" \
    -c "reg a2" \
    -c "resume" \
    -c "echo {== resumed ==}" \
    -c "shutdown" 2>&1 | tee "$HERE/openocd.log"

echo "[smoke] done. vsim.log + openocd.log in $HERE"
