# Tiny RV64 fixture for hybrid handoff smoke tests. Sets known register
# values, then spins. The test harness halts via the Debug Module, reads/
# writes registers, and resumes.

.section .text
.globl _start
_start:
    li      a0, 1
    li      a1, 2
    add     a2, a0, a1     # a2 = 3
1:  j       1b             # spin so the harness can halt us mid-run
