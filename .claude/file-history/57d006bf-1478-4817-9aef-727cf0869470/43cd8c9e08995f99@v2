// rt_abi_aliases.S
//
// Tier-1 fixture: ra/sp/gp/tp/fp survive QEMU1 -> vsim -> QEMU2 unchanged.
// These ABI-special GPRs are never touched by other Tier-1 fixtures.
//
// Phase A (QEMU1): seed each alias with a distinct page-aligned constant.
// Phase B (vsim):  no-op.
// Phase C (QEMU2): verify; exit code = first mismatching reg num, or 0.

.section .text
.globl _start
_start:
    li      ra, 0x80100000
    li      sp, 0x80200000
    li      gp, 0x80300000
    li      tp, 0x80400000
    li      fp, 0x80500000           // x8

    csrwi   0x7C0, 0                 // QEMU1 drains, exits

    csrwi   0x7C0, 1                 // vsim drains, exits 200

phase_c:
    li      t0, 0x80100000
    bne     ra, t0, fail_ra
    li      t0, 0x80200000
    bne     sp, t0, fail_sp
    li      t0, 0x80300000
    bne     gp, t0, fail_gp
    li      t0, 0x80400000
    bne     tp, t0, fail_tp
    li      t0, 0x80500000
    bne     fp, t0, fail_fp
    li      a2, 0
    j       exit_semihost

fail_ra: li a2, 1;  j exit_semihost
fail_sp: li a2, 2;  j exit_semihost
fail_gp: li a2, 3;  j exit_semihost
fail_tp: li a2, 4;  j exit_semihost
fail_fp: li a2, 8;  j exit_semihost

exit_semihost:
    li      t0, 0x80001000
    li      t1, 0x20026
    sd      t1, 0(t0)
    sd      a2, 8(t0)
    li      a0, 0x20
    mv      a1, t0
    .option push
    .option norvc
    slli    x0, x0, 0x1f
    ebreak
    srai    x0, x0, 0x7
    .option pop
1:  j       1b
