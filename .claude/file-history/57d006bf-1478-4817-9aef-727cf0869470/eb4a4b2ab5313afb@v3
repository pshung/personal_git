// rt_runtime_kind.S
//
// Tier-1 fixture (parked): exercises the HYBRID_HANDOFF_RUNTIME trigger
// path inside vsim's HandoffController via `csrrw x0, 0x7C0, a0` (funct3
// 0b001), which fires only when read_gpr(rs1)==1.
//
// PARKED on AX45MPV: the RTL retires `csrwi 0x7C0,*` cleanly but does not
// retire `csrrw x0, 0x7C0, rs1`, so vsim never reaches drain on this CPU
// configuration (kv_csr's existent_csr decode for MILMB likely gates the
// csrrw form differently from the csrrwi form). Kept in the tree for
// future RTL investigation; not registered with CTest.

#include "semihost_exit.inc"

.section .text
.globl _start
_start:
    csrwi   0x7C0, 0                 // QEMU1 drains, exits

    .option push
    .option norvc
    addi    a0, zero, 1              // 4B uncompressed
    csrrw   zero, 0x7C0, a0          // 4B; RUNTIME kind; should fire (a0==1)
    .option pop

phase_c:
    li      a2, 0
    SEMIHOST_EXIT a2
