// rt_sign_bits.S
//
// Tier-1 fixture: 64-bit width fidelity through DM Abstract Commands.
// A bug that truncates or sign-extends incorrectly between the 32-bit
// data0/data1 halves would corrupt the high bits.
//
// Phase A (QEMU1): seed x10..x14 with edge-case 64-bit constants.
// Phase B (vsim):  no-op (just bridges trigger entry/exit).
// Phase C (QEMU2): verify each value; exit code = first mismatching reg num,
//                  or 0 on full pass.

.section .text
.globl _start
_start:
    li      x10, 0
    li      x11, -1
    li      x12, 0x8000000000000000
    li      x13, 0x7FFFFFFFFFFFFFFF
    li      x14, 0x00000000FFFFFFFF

    csrwi   0x7C0, 0                 // QEMU1 drains, exits

    csrwi   0x7C0, 1                 // vsim drains, exits 200

phase_c:
    // Verify x10..x14. Order: x10, x11, x13, x14, x12 last (a2 sacrificed).
    bne     x10, x0, fail_x10
    li      t0, -1
    bne     x11, t0, fail_x11
    li      t0, 0x7FFFFFFFFFFFFFFF
    bne     x13, t0, fail_x13
    li      t0, 0x00000000FFFFFFFF
    bne     x14, t0, fail_x14
    li      t0, 0x8000000000000000
    bne     x12, t0, fail_x12
    li      a2, 0
    j       exit_semihost

fail_x10: li a2, 10; j exit_semihost
fail_x11: li a2, 11; j exit_semihost
fail_x12: li a2, 12; j exit_semihost
fail_x13: li a2, 13; j exit_semihost
fail_x14: li a2, 14; j exit_semihost

exit_semihost:
    li      t0, 0x80001000
    li      t1, 0x20026
    sd      t1, 0(t0)
    sd      a2, 8(t0)
    li      a0, 0x20
    mv      a1, t0
    .option push
    .option norvc
    slli    x0, x0, 0x1f
    ebreak
    srai    x0, x0, 0x7
    .option pop
1:  j       1b
