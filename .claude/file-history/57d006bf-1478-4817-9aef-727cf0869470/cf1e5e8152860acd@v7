# OpenOCD config that talks to vsim's in-process JTAG DTM via the remote
# bitbang protocol. The IDCODE/IR-length match jtag_dtm.hpp.

adapter driver remote_bitbang
remote_bitbang host localhost
remote_bitbang port 9104

set _CHIPNAME riscv
jtag newtap $_CHIPNAME cpu -irlen 5 -expected-id 0x1000563d

set _TARGETNAME $_CHIPNAME.cpu
target create $_TARGETNAME riscv -chain-position $_TARGETNAME

# Don't try to halt before init; let the user issue commands explicitly.
init
