// rt_runtime_kind.S
//
// Tier-1 fixture: exercises the HYBRID_HANDOFF_RUNTIME trigger path inside
// vsim's HandoffController. The exit instruction is `csrw 0x7C0, x10`
// (csrrw with rd=x0, funct3=0b001), which fires only when read_gpr(rs1)==1.
// This is the path that decode_csrrw_rs1 + read_gpr-by-rs1 must traverse.
//
// Phase A (QEMU1): seed a sentinel in t1; csrwi 0x7C0, 0 -> drain.
// Phase B (vsim):  li a0, 1; csrw 0x7C0, a0 -> RUNTIME-kind drain.
// Phase C (QEMU2): verify sentinel survived; exit 0 on PASS, 1 on FAIL.

.section .text
.globl _start
_start:
    li      t1, 0xCAFEBABE12345678   // sentinel that must survive vsim ROI

    csrwi   0x7C0, 0                 // QEMU1 drains, exits

    // Phase B: exit via RUNTIME-kind trigger.
    li      a0, 1                    // rs1 value selects fire (==1)
    csrw    0x7C0, a0                // csrrw x0, 0x7C0, a0  -> RUNTIME kind

phase_c:
    li      t2, 0xCAFEBABE12345678
    beq     t1, t2, pass
    li      a2, 1
    j       exit_semihost
pass:
    li      a2, 0

exit_semihost:
    li      t0, 0x80001000
    li      t1, 0x20026
    sd      t1, 0(t0)
    sd      a2, 8(t0)
    li      a0, 0x20
    mv      a1, t0
    .option push
    .option norvc
    slli    x0, x0, 0x1f
    ebreak
    srai    x0, x0, 0x7
    .option pop
1:  j       1b
