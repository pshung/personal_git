#pragma once

#include "hybrid/resume_driver.hpp"
#include "hybrid/state_loader.hpp"

#include <string>

namespace hybrid {

inline auto resume_from_qemu(const std::string& path, DmiBus& bus) -> void
{
  const auto state = load_state(path);
  ResumeDriver driver(bus);
  driver.resume(state);
}

}  // namespace hybrid
