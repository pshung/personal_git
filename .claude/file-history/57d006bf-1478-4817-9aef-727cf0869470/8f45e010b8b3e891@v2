// Phase 2 acceptance fixture: tiny RV64 program that triggers a QEMU->vsim
// handoff via the magic CSR, then exits via SIM_CONTROL with code = a2.
//
//   QEMU side: plugin sees csrwi 0x7C0, 0 -> drains state, exits.
//   vsim side: --resume-from-qemu loads state, CPU executes the body,
//              writes a2 (=3) to SIM_CONTROL, vsim exits 3.

.section .text
.globl _start
_start:
    csrwi   0x7C0, 0           // hybrid handoff trigger
    li      a0, 1
    li      a1, 2
    add     a2, a0, a1         // a2 = 3
    li      t0, 0xE0080000     // SIM_CONTROL_BASE
    sw      a2, 0(t0)          // exit code = a2 = 3
1:  j       1b                 // safety spin if sim_control didn't fire
