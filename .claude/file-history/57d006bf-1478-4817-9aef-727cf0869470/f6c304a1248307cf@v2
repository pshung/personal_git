#!/usr/bin/env python3
# Stub --qemu-binary for rt_gdbstub_timeout: parses `-gdb tcp::PORT` from
# argv, listens on PORT, accepts one connection, then sleeps. Never sends
# the `+` ack vsim's gdbstub session waits for, so the read-side timeout
# in Session::recv_byte must fire.

import socket
import sys
import time

port = None
for i, arg in enumerate(sys.argv):
    if arg == "-gdb" and i + 1 < len(sys.argv):
        spec = sys.argv[i + 1]
        if spec.startswith("tcp::"):
            port = int(spec[len("tcp::"):])
            break

if port is None:
    print("qemu_silent_stub: no -gdb tcp::PORT in argv", file=sys.stderr)
    sys.exit(2)

s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
s.bind(("127.0.0.1", port))
s.listen(1)
conn, _ = s.accept()
time.sleep(60)
