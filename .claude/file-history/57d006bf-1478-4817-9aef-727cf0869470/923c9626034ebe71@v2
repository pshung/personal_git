/* handoff.elf is run under qemu-riscv64 (linux-user) AND vsim. linux-user
   refuses to map below MMAP_MIN_ADDR (typically 0x10000), so the program
   is linked above that. vsim's RAM (0x0..0x7FFFFFFF) covers it. */

ENTRY(_start)

SECTIONS {
    . = 0x10000;
    .text : { *(.text*) }
    /DISCARD/ : { *(.*) }
}
