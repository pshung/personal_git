
reset-and-hold
monitor nds icache invalidate
monitor nds dcache invalidate
lo

# L2_Disable='set *0xe0500008=0x0L'

# L2_with_Pretfetch='set *0xe0500008=0x79L'

# L2_no_Prefetch='set *0xe0500008=0x1L'

set *0xe0500008=0x79L

# Enable write-around with threshold=4 ([DC_WAROUND[14:13] in $mcache_ctl) and L1D-prefetch (bit[10] in $mcache_ctl) for A27

# L1_ONLY='set $mcache_ctl=0x80003L'

# L1_WA='set $mcache_ctl=0x82103L'

# L1_PF='set $mcache_ctl=0x80703L'

# L1_WA_PF='set $mcache_ctl=0x82703L'

# L1L2_WA_PF='set $mcache_ctl=0x8a703L'

set $mcache_ctl=0x8a703L


# Enable Non-blocking load store (bit[8] in $mmisc_ctl)

# NB='set $mmisc_ctl=0x148L'

# NO_NB='set $mmisc_ctl=0x48L'

set $mmisc_ctl=0x148L


# DDR40='set *0xf0100300=0x80000000L'

# DDR100='set *0xf0100300=0x80000003L'

# DDR160='set *0xf0100300=0x80000006L'

# DDR200='set *0xf0100300=0x80000008L'

# DDR300='set *0xf0100300=0x8000000dL'

set *0xf0100300=0x80000006L

