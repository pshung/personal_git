# QEMU TCG plugin libhybrid_handoff.so. Wraps qemu_plugin/Makefile, which
# links against the QEMU 9.x source tree under hybrid_qemu/ + glib-2.0 +
# the wire-ABI headers under ../include/hybrid/.

set(HYBRID_PLUGIN_DIR "${CMAKE_SOURCE_DIR}/qemu_plugin")
set(HYBRID_PLUGIN_SO  "${HYBRID_PLUGIN_DIR}/libhybrid_handoff.so")

set(HYBRID_PLUGIN_SRC
  "${HYBRID_PLUGIN_DIR}/hybrid_handoff.c"
  "${HYBRID_PLUGIN_DIR}/Makefile"
  "${CMAKE_SOURCE_DIR}/include/hybrid/state_abi.h"
  "${CMAKE_SOURCE_DIR}/include/hybrid/state_abi_check.h"
  "${CMAKE_SOURCE_DIR}/include/hybrid/insn_match.h"
  "${CMAKE_SOURCE_DIR}/include/hybrid/reg_names.h"
)

add_custom_command(
  OUTPUT "${HYBRID_PLUGIN_SO}"
  COMMAND $(MAKE) -C "${HYBRID_PLUGIN_DIR}"
                  QEMU_ROOT=${VSIM_QEMU_ROOT}
  DEPENDS ${HYBRID_PLUGIN_SRC}
  WORKING_DIRECTORY "${HYBRID_PLUGIN_DIR}"
  COMMENT "Building libhybrid_handoff.so (QEMU TCG plugin)"
  VERBATIM
)

add_custom_target(hybrid_handoff_plugin ALL DEPENDS "${HYBRID_PLUGIN_SO}")
