        q31_t     sum4 = ((q31_t)(*pBias++) << bias_lshift) + NN_ROUND(out_rshift);

        uint16_t  colCnt = size >> 2;
        pA = in_tmp_buf;

        while (colCnt)
        {
            long     inM11, inM12, inM13, inM14;
            long     inV;

            inV = *__SIMD32(pA)++;
            inM11 = *__SIMD32(pB)++;
            inM12 = NDS_DSP_SUNPKD831(inM11);
            inM11 = NDS_DSP_SUNPKD820(inM11);
#if !ENA_DSP_BE
            sum = NDS_DSP_KMADA(sum, inM11, inV);
            sum2 = NDS_DSP_KMADA(sum2, inM12, inV);
#else
            sum = NDS_DSP_KMADA(sum, inM12, inV);
            sum2 = NDS_DSP_KMADA(sum2, inM11, inV);
#endif

            inM13 = *__SIMD32(pB)++;
            inM14 = NDS_DSP_SUNPKD831(inM13);
            inM13 = NDS_DSP_SUNPKD820(inM13);
#if !ENA_DSP_BE
            sum3 = NDS_DSP_KMADA(sum3, inM13, inV);
            sum4 = NDS_DSP_KMADA(sum4, inM14, inV);
#else
            sum3 = NDS_DSP_KMADA(sum3, inM14, inV);
            sum4 = NDS_DSP_KMADA(sum4, inM13, inV);
#endif

            inV = *__SIMD32(pA)++;
            inM11 = *__SIMD32(pB)++;
            inM12 = NDS_DSP_SUNPKD831(inM11);
            inM11 = NDS_DSP_SUNPKD820(inM11);
#if !ENA_DSP_BE
            sum = NDS_DSP_KMADA(sum, inM11, inV);
            sum2 = NDS_DSP_KMADA(sum2, inM12, inV);
#else
            sum = NDS_DSP_KMADA(sum, inM12, inV);
            sum2 = NDS_DSP_KMADA(sum2, inM11, inV);
#endif

            inM13 = *__SIMD32(pB)++;
            inM14 = NDS_DSP_SUNPKD831(inM13);
            inM13 = NDS_DSP_SUNPKD820(inM13);
#if !ENA_DSP_BE
            sum3 = NDS_DSP_KMADA(sum3, inM13, inV);
            sum4 = NDS_DSP_KMADA(sum4, inM14, inV);
#else
            sum3 = NDS_DSP_KMADA(sum3, inM14, inV);
            sum4 = NDS_DSP_KMADA(sum4, inM13, inV);
#endif
            colCnt--;
        }

        colCnt = size & 0x3;
        while (colCnt)
        {
            q15_t     inV = *pA++;
            q7_t      inM = *pB++;
            q7_t      inM2 = *pB++;
            q7_t      inM3 = *pB++;
            q7_t      inM4 = *pB++;

            sum += inV * inM;
            sum2 += inV * inM2;
            sum3 += inV * inM3;
            sum4 += inV * inM4;
            colCnt--;
        }                       /* while over colCnt */

        *pO++ = (q7_t) (NDS_DSP_SATS((sum >> out_rshift), 8));
        *pO++ = (q7_t) (NDS_DSP_SATS((sum2 >> out_rshift), 8));
        *pO++ = (q7_t) (NDS_DSP_SATS((sum3 >> out_rshift), 8));
        *pO++ = (q7_t) (NDS_DSP_SATS((sum4 >> out_rshift), 8));

        /* adjust the pointers and counters */
        rowCnt--;
    }

    /* left-over part of the rows */
    rowCnt = wt_row_num & 0x3;

    while (rowCnt)
    {
        q31_t     sum = ((q31_t)(*pBias++) << bias_lshift) + NN_ROUND(out_rshift);
        uint16_t  colCnt = size >> 2;

        pA = in_tmp_buf;

        while (colCnt)
        {
            q31_t     inV1, inV2, inM11, inM12;

            pB = (q7_t *) read_and_pad_reordered((void *)pB, &inM11, &inM12);

            inV1 = *__SIMD32(pA)++;
            sum = NDS_DSP_KMADA(sum, inV1, inM11);

            inV2 = *__SIMD32(pA)++;
            sum = NDS_DSP_KMADA(sum, inV2, inM12);

            colCnt--;
        }

        /* left-over of the vector */
        colCnt = size & 0x3;
        while (colCnt)
        {
            q15_t     inV = *pA++;
            q7_t      inM = *pB++;
            sum += inV * inM;
            colCnt--;
        }

        *pO++ = (q7_t) (NDS_DSP_SATS((sum >> out_rshift), 8));

        rowCnt--;
    }
#else // general
    uint16_t  rowCnt = wt_row_num >> 2;
    const q7_t *pB = wt_mat;
    const q7_t *pA;
    q7_t     *pO = out_vec;
    const q7_t *pBias = bias;

    while (rowCnt)
    {
        q31_t     sum =  ((q31_t)(*pBias++) << bias_lshift) + NN_ROUND(out_rshift);
        q31_t     sum2 = ((q31_t)(*pBias++) << bias_lshift) + NN_ROUND(out_rshift);
        q31_t     sum3 = ((q31_t)(*pBias++) << bias_lshift) + NN_ROUND(out_rshift);
        q31_t     sum4 = ((q31_t)(*pBias++) << bias_lshift) + NN_ROUND(out_rshift);

        uint16_t  colCnt = size >> 2;

        pA = in_vec;

        while (colCnt)
        {
            q7_t      inA1 = *pA++;
            q7_t      inA3 = *pA++;
            q7_t      inA2 = *pA++;
            q7_t      inA4 = *pA++;

            q7_t      inB1 = *pB++;
            q7_t      inB3 = *pB++;
            q7_t      inB2 = *pB++;
            q7_t      inB4 = *pB++;

            sum += inA1 * inB1 + inA2 * inB2;
            sum2 += inA1 * inB3 + inA2 * inB4;

            inB1 = *pB++;
            inB3 = *pB++;
            inB2 = *pB++;
            inB4 = *pB++;

            sum3 += inA1 * inB1 + inA2 * inB2;
            sum4 += inA1 * inB3 + inA2 * inB4;

            inB1 = *pB++;
            inB3 = *pB++;
            inB2 = *pB++;
            inB4 = *pB++;

            sum += inA3 * inB1 + inA4 * inB2;
            sum2 += inA3 * inB3 + inA4 * inB4;

            inB1 = *pB++;
            inB3 = *pB++;
            inB2 = *pB++;
            inB4 = *pB++;

            sum3 += inA3 * inB1 + inA4 * inB2;
            sum4 += inA3 * inB3 + inA4 * inB4;

            colCnt--;
        }
        colCnt = size & 0x3;
        while (colCnt)
        {
            q7_t      inA = *pA++;
            q7_t      inB = *pB++;
            sum += inA * inB;
            inB = *pB++;
            sum2 += inA * inB;
            inB = *pB++;
            sum3 += inA * inB;
            inB = *pB++;
            sum4 += inA * inB;

            colCnt--;
        }
        *pO++ = (q7_t) NDS_ISA_SATS((sum >> out_rshift), 8);
        *pO++ = (q7_t) NDS_ISA_SATS((sum2 >> out_rshift), 8);
        *pO++ = (q7_t) NDS_ISA_SATS((sum3 >> out_rshift), 8);
        *pO++ = (q7_t) NDS_ISA_SATS((sum4 >> out_rshift), 8);

        rowCnt--;
    }

    rowCnt = wt_row_num & 0x3;

    while (rowCnt)
    {
        int ip_out = ((q31_t)(*pBias++) << bias_lshift) + NN_ROUND(out_rshift);
        int j;

        pA = in_vec;
        for (j = 0; j < size; j++)
        {
            q7_t      inA = *pA++;
            q7_t      inB = *pB++;
            ip_out += inA * inB;
        }
        *pO++ = (q7_t) NDS_ISA_SATS((ip_out >> out_rshift), 8);

        rowCnt--;
    }

#endif                          /* ENA_DSP_ISA */

    return 0;
}
