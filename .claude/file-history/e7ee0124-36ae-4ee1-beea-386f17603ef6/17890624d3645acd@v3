/*
 * test-fmax-fmin.c -- fmax/fmin and fmaxf/fminf
 */
#include "test-common.h"

int main(void)
{
    /* fmax */
    P_D2(fmax, 1.0, 2.0);
    P_D2(fmax, 2.0, 1.0);
    P_D2(fmax, -1.0, -2.0);
    P_D2(fmax, 0.0, -0.0);
    P_D2(fmax, -0.0, 0.0);
    P_D2(fmax, NAN, 1.0);
    P_D2(fmax, 1.0, NAN);
    P_D2(fmax, NAN, NAN);
    P_D2(fmax, INFINITY, 1.0);
    P_D2(fmax, -INFINITY, 1.0);

    /* fmin */
    P_D2(fmin, 1.0, 2.0);
    P_D2(fmin, 2.0, 1.0);
    P_D2(fmin, -1.0, -2.0);
    P_D2(fmin, 0.0, -0.0);
    P_D2(fmin, -0.0, 0.0);
    P_D2(fmin, NAN, 1.0);
    P_D2(fmin, 1.0, NAN);
    P_D2(fmin, NAN, NAN);
    P_D2(fmin, -INFINITY, 1.0);

    /* fmaxf */
    P_F2(fmaxf, 1.0f, 2.0f);
    P_F2(fmaxf, -1.0f, -2.0f);
    P_F2(fmaxf, 0.0f, -0.0f);
    P_F2(fmaxf, NAN, 1.0f);
    P_F2(fmaxf, 1.0f, NAN);
    P_F2(fmaxf, NAN, NAN);

    /* fminf */
    P_F2(fminf, 1.0f, 2.0f);
    P_F2(fminf, -1.0f, -2.0f);
    P_F2(fminf, NAN, 1.0f);
    P_F2(fminf, 1.0f, NAN);
    P_F2(fminf, NAN, NAN);

    return 0;
}
