/*
 * test-classify.c -- finite, isinf, isnan, fpclassify
 */
#include "test-common.h"

int main(void)
{
    /* finite (double) */
    P_D1B(finite, 0.0);
    P_D1B(finite, -0.0);
    P_D1B(finite, 1.0);
    P_D1B(finite, -1.0);
    P_D1B(finite, 5e-324);
    P_D1B(finite, 1e308);
    P_D1B(finite, INFINITY);
    P_D1B(finite, -INFINITY);
    P_D1B(finite, NAN);

    /* finitef (float) */
    P_F1B(finitef, 0.0f);
    P_F1B(finitef, 1.0f);
    P_F1B(finitef, 1.4e-45f);
    P_F1B(finitef, INFINITY);
    P_F1B(finitef, -INFINITY);
    P_F1B(finitef, NAN);

    /* isinf (double) */
    P_D1B(isinf, 0.0);
    P_D1B(isinf, 1.0);
    P_D1B(isinf, INFINITY);
    P_D1B(isinf, -INFINITY);
    P_D1B(isinf, NAN);
    P_D1B(isinf, 5e-324);

    /* isinff (float) */
    P_F1B(isinff, 0.0f);
    P_F1B(isinff, 1.0f);
    P_F1B(isinff, INFINITY);
    P_F1B(isinff, -INFINITY);
    P_F1B(isinff, NAN);

    /* isnan (double) */
    P_D1B(isnan, 0.0);
    P_D1B(isnan, 1.0);
    P_D1B(isnan, INFINITY);
    P_D1B(isnan, -INFINITY);
    P_D1B(isnan, NAN);
    P_D1B(isnan, 5e-324);

    /* isnanf (float) */
    P_F1B(isnanf, 0.0f);
    P_F1B(isnanf, INFINITY);
    P_F1B(isnanf, NAN);

    /* fpclassify (double) */
    P_FPCL_D(0.0);
    P_FPCL_D(-0.0);
    P_FPCL_D(1.0);
    P_FPCL_D(-1.0);
    P_FPCL_D(5e-324);
    P_FPCL_D(INFINITY);
    P_FPCL_D(-INFINITY);
    P_FPCL_D(NAN);

    /* fpclassify (float) */
    P_FPCL_F(0.0f);
    P_FPCL_F(1.0f);
    P_FPCL_F(1.4e-45f);
    P_FPCL_F(INFINITY);
    P_FPCL_F(NAN);

    return 0;
}
