/*
 * test-exp.c -- Accuracy test for expf()
 *
 * Only expf is overridden on riscv64; we test it at float precision.
 */
#include "test-common.h"
#include "golden-values.h"

static void test_expf_golden(void)
{
    for (unsigned i = 0; i < GOLDEN_EXPF_COUNT; i++) {
        char buf[64];
        snprintf(buf, sizeof(buf), "%.9g", (double)golden_expf[i].input);
        CHECK_FLOAT("expf", expf(golden_expf[i].input), buf,
                    golden_expf[i].expected, golden_expf[i].max_ulp);
    }
}

static void test_expf_special(void)
{
    CHECK_FLOAT("expf", expf(0.0f), "0.0f", 1.0f, 0);
    CHECK_FLOAT("expf", expf(-0.0f), "-0.0f", 1.0f, 0);
    CHECK_FLOAT_INF("expf", expf(INFINITY), "Inf", +1);
    CHECK_FLOAT("expf", expf(-INFINITY), "-Inf", 0.0f, 0);
    CHECK_FLOAT_NAN("expf", expf(NAN), "NaN");
    /* Overflow: expf(89) should be +Inf */
    CHECK_FLOAT_INF("expf", expf(89.0f), "89.0f", +1);
    /* Underflow: expf(-104) should be 0 */
    CHECK_FLOAT("expf", expf(-104.0f), "-104.0f", 0.0f, 0);
}

int main(void)
{
    printf("=== expf accuracy test ===\n");

    test_expf_golden();
    test_expf_special();

    TEST_SUMMARY("expf");
}
