/*
 * test-atan.c -- Accuracy test for atan() and atanf()
 */
#include "test-common.h"
#include "golden-values.h"

static void test_atan_golden(void)
{
    for (unsigned i = 0; i < GOLDEN_ATAN_COUNT; i++) {
        char buf[64];
        snprintf(buf, sizeof(buf), "%.17g", golden_atan[i].input);
        CHECK_DOUBLE("atan", atan(golden_atan[i].input), buf,
                     golden_atan[i].expected, golden_atan[i].max_ulp);
    }
}

static void test_atan_special(void)
{
    CHECK_DOUBLE("atan", atan(0.0), "0.0", 0.0, 0);
    CHECK_DOUBLE("atan", atan(-0.0), "-0.0", -0.0, 0);
    /* atan(+Inf) = +pi/2 */
    CHECK_DOUBLE("atan", atan(INFINITY), "Inf", PI_2_D, 0);
    /* atan(-Inf) = -pi/2 */
    CHECK_DOUBLE("atan", atan(-INFINITY), "-Inf", -PI_2_D, 0);
    CHECK_DOUBLE_NAN("atan", atan(NAN), "NaN");
}

static void test_atanf_golden(void)
{
    for (unsigned i = 0; i < GOLDEN_ATANF_COUNT; i++) {
        char buf[64];
        snprintf(buf, sizeof(buf), "%.9g", (double)golden_atanf[i].input);
        CHECK_FLOAT("atanf", atanf(golden_atanf[i].input), buf,
                    golden_atanf[i].expected, golden_atanf[i].max_ulp);
    }
}

static void test_atanf_special(void)
{
    CHECK_FLOAT("atanf", atanf(0.0f), "0.0f", 0.0f, 0);
    CHECK_FLOAT("atanf", atanf(-0.0f), "-0.0f", -0.0f, 0);
    CHECK_FLOAT("atanf", atanf(INFINITY), "Inf", PI_2_F, 1);
    CHECK_FLOAT("atanf", atanf(-INFINITY), "-Inf", -PI_2_F, 1);
    CHECK_FLOAT_NAN("atanf", atanf(NAN), "NaN");
}

int main(void)
{
    printf("=== atan/atanf accuracy test ===\n");

    test_atan_golden();
    test_atan_special();
    test_atanf_golden();
    test_atanf_special();

    TEST_SUMMARY("atan/atanf");
}
