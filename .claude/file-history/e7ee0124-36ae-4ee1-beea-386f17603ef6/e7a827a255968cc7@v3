/*
 * test-round.c -- lrint, llrint, lround, llround (double and float)
 */
#include "test-common.h"

int main(void)
{
    /* lrint (double) -- round-to-nearest-even by default */
    P_D1I(lrint, 0.0);
    P_D1I(lrint, -0.0);
    P_D1I(lrint, 1.0);
    P_D1I(lrint, -1.0);
    P_D1I(lrint, 1.4);
    P_D1I(lrint, 1.5);
    P_D1I(lrint, 2.5);
    P_D1I(lrint, 1.6);
    P_D1I(lrint, -1.5);
    P_D1I(lrint, -2.5);
    P_D1I(lrint, 100.0);
    P_D1I(lrint, 0.49999999999999994);
    P_D1I(lrint, 3.5);
    P_D1I(lrint, 4.5);

    /* lrintf (float) */
    P_F1I(lrintf, 0.0f);
    P_F1I(lrintf, 1.0f);
    P_F1I(lrintf, 1.4f);
    P_F1I(lrintf, 1.5f);
    P_F1I(lrintf, 2.5f);
    P_F1I(lrintf, -1.5f);
    P_F1I(lrintf, 100.0f);

    /* llrint (double) */
    P_D1I(llrint, 0.0);
    P_D1I(llrint, 1.0);
    P_D1I(llrint, 1.5);
    P_D1I(llrint, 2.5);
    P_D1I(llrint, -1.5);
    P_D1I(llrint, 1e15);

    /* llrintf (float) */
    P_F1I(llrintf, 0.0f);
    P_F1I(llrintf, 1.5f);
    P_F1I(llrintf, 2.5f);

    /* lround (double) -- ties away from zero */
    P_D1I(lround, 0.0);
    P_D1I(lround, 1.0);
    P_D1I(lround, -1.0);
    P_D1I(lround, 1.4);
    P_D1I(lround, 1.5);
    P_D1I(lround, 2.5);
    P_D1I(lround, -1.5);
    P_D1I(lround, -2.5);
    P_D1I(lround, 1.6);

    /* lroundf (float) */
    P_F1I(lroundf, 0.0f);
    P_F1I(lroundf, 1.5f);
    P_F1I(lroundf, 2.5f);
    P_F1I(lroundf, -1.5f);

    /* llround (double) */
    P_D1I(llround, 0.0);
    P_D1I(llround, 1.5);
    P_D1I(llround, 2.5);
    P_D1I(llround, -1.5);
    P_D1I(llround, 1e15);

    /* llroundf (float) */
    P_F1I(llroundf, 0.0f);
    P_F1I(llroundf, 1.5f);
    P_F1I(llroundf, 2.5f);

    return 0;
}
