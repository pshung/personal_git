/*
 * test-fabs.c -- fabs() and fabsf()
 */
#include "test-common.h"

int main(void)
{
    P_D1(fabs, 0.0);
    P_D1(fabs, -0.0);
    P_D1(fabs, 1.0);
    P_D1(fabs, -1.0);
    P_D1(fabs, 3.14);
    P_D1(fabs, -3.14);
    P_D1(fabs, 1e300);
    P_D1(fabs, -1e300);
    P_D1(fabs, 5e-324);
    P_D1(fabs, -5e-324);
    P_D1(fabs, INFINITY);
    P_D1(fabs, -INFINITY);
    P_D1(fabs, NAN);

    P_F1(fabsf, 0.0f);
    P_F1(fabsf, -0.0f);
    P_F1(fabsf, 1.0f);
    P_F1(fabsf, -1.0f);
    P_F1(fabsf, 3.14f);
    P_F1(fabsf, -3.14f);
    P_F1(fabsf, 1e38f);
    P_F1(fabsf, -1e38f);
    P_F1(fabsf, 1.4e-45f);
    P_F1(fabsf, -1.4e-45f);
    P_F1(fabsf, INFINITY);
    P_F1(fabsf, -INFINITY);
    P_F1(fabsf, NAN);

    return 0;
}
