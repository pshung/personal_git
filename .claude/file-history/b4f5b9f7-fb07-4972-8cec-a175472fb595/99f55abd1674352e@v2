/*
 * cstate -- QEMU TCG plugin: capture CPU state at first hit of a guest PC.
 *
 * Used by the hot-inner-kernel-extractor skill to replace the name-based
 * live-in init heuristic in emit_harness.py with real register/stack values
 * the original loop was actually entered with. This eliminates the failure
 * mode where computed bounds checks (e.g. bge a0, t1 with t1 = mulw a4,a5)
 * trivially exit the loop on iter 1 because heuristic-init values can't
 * satisfy the predicate.
 *
 * Args (passed via -plugin file=libcstate.so,arg=val,arg=val):
 *   capture_pc=0xNNNN   guest virtual address to snapshot at (required)
 *   out=/path/state.bin output blob path (required)
 *   frame_bytes=4096    bytes of stack to capture above sp (default 4096)
 *
 * Tier 1 scope: GPRs (x0..x31) + stack frame. Vector regfile / vtype /
 * vl / vstart capture is Tier 2 -- the blob format reserves space for
 * them now (num_vreg=0, vlen_bits=0 means "absent") so loaders can
 * stay forward-compatible.
 *
 * Blob format (little-endian, fixed schema):
 *   0x000  char  magic[4]    = "CSTA"
 *   0x004  u32   version     = 1
 *   0x008  u64   capture_pc
 *   0x010  u32   xlen_bits   (64 for AX45MPV)
 *   0x014  u32   vlen_bits   (0 in T1; vector data length in bits in T2)
 *   0x018  u32   num_xreg    (32)
 *   0x01C  u32   num_vreg    (0 in T1)
 *   0x020  u32   stack_bytes
 *   0x024  u32   reserved
 *   0x028  u32   vtype       (0 in T1)
 *   0x02C  u32   vl          (0 in T1)
 *   0x030  u32   vstart      (0 in T1)
 *   0x034  u32   _pad
 *   0x040  u64   xreg[num_xreg]
 *   0x040 + 8*num_xreg : u8 vreg_data[num_vreg * (vlen_bits/8)]  (empty in T1)
 *   then  : u8 stack[stack_bytes]
 *
 * sp is xreg[2] per RISC-V ABI.
 */

#include <inttypes.h>
#include <stdint.h>
#include <stdlib.h>
#include <string.h>
#include <stdio.h>
#include <stdatomic.h>
#include <errno.h>

#include <glib.h>
#include <qemu-plugin.h>

QEMU_PLUGIN_EXPORT int qemu_plugin_version = QEMU_PLUGIN_VERSION;

/* ---------- args ---------- */
static uint64_t arg_capture_pc;
static char    *arg_out_path;
static uint32_t arg_frame_bytes = 4096;

/* ---------- blob ---------- */
#define CSTATE_MAGIC   "CSTA"
#define CSTATE_VERSION 1
#define NUM_XREG       32
#define HEADER_BYTES   0x40

typedef struct {
    char     magic[4];
    uint32_t version;
    uint64_t capture_pc;
    uint32_t xlen_bits;
    uint32_t vlen_bits;
    uint32_t num_xreg;
    uint32_t num_vreg;
    uint32_t stack_bytes;
    uint32_t reserved;
    uint32_t vtype;
    uint32_t vl;
    uint32_t vstart;
    uint32_t _pad[3];   /* pad header to 0x40 so xreg block starts cleanly */
} cstate_header_t;

_Static_assert(sizeof(cstate_header_t) == HEADER_BYTES, "header size");

/* ---------- per-vCPU register handle cache ---------- *
 * qemu_plugin_get_registers() must be called from the vCPU init callback
 * (it returns descriptors valid for the calling vCPU). We support a single
 * vCPU here -- libnn unit tests are single-threaded -- and stash the
 * resolved x0..x31 handles in a flat array.
 */
static struct qemu_plugin_register *xreg_handle[NUM_XREG];
static atomic_int captured;  /* one-shot guard */

/* RISC-V GPR names QEMU exposes via the GDB target XML. We try the canonical
 * x<N> form first, then ABI aliases as a fallback. (QEMU 9.2 typically uses
 * x<N>; other versions or targets may differ.) */
static const char *xreg_canonical[NUM_XREG] = {
    "x0","x1","x2","x3","x4","x5","x6","x7",
    "x8","x9","x10","x11","x12","x13","x14","x15",
    "x16","x17","x18","x19","x20","x21","x22","x23",
    "x24","x25","x26","x27","x28","x29","x30","x31",
};
static const char *xreg_abi[NUM_XREG] = {
    "zero","ra","sp","gp","tp","t0","t1","t2",
    "s0","s1","a0","a1","a2","a3","a4","a5",
    "a6","a7","s2","s3","s4","s5","s6","s7",
    "s8","s9","s10","s11","t3","t4","t5","t6",
};
/* QEMU's RISC-V gdb XML exposes x8 as "fp" (not "s0"); when the canonical
 * x<N> name and abi name both miss, try this third alias. Only x8 has a
 * conflict in practice. */
static const char *xreg_abi2[NUM_XREG] = {
    NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,
    "fp",NULL,NULL,NULL,NULL,NULL,NULL,NULL,
    NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,
    NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,
};

static struct qemu_plugin_register *find_reg(GArray *regs, const char *name)
{
    if (!regs) return NULL;
    for (guint i = 0; i < regs->len; i++) {
        qemu_plugin_reg_descriptor *d =
            &g_array_index(regs, qemu_plugin_reg_descriptor, i);
        if (d->name && g_strcmp0(d->name, name) == 0) {
            return d->handle;
        }
    }
    return NULL;
}

static void vcpu_init_cb(qemu_plugin_id_t id, unsigned int vcpu_index)
{
    if (vcpu_index != 0) return;  /* single-vCPU tests only */

    GArray *regs = qemu_plugin_get_registers();
    int missing = 0;

    for (int i = 0; i < NUM_XREG; i++) {
        struct qemu_plugin_register *h = find_reg(regs, xreg_canonical[i]);
        if (!h) {
            h = find_reg(regs, xreg_abi[i]);
        }
        if (!h && xreg_abi2[i]) {
            h = find_reg(regs, xreg_abi2[i]);
        }
        xreg_handle[i] = h;
        if (!h && i != 0) {
            /* x0 may not be exposed (always zero); ignore that case. */
            missing++;
            fprintf(stderr,
                    "cstate: warning: cannot resolve register %s/%s\n",
                    xreg_canonical[i], xreg_abi[i]);
        }
    }

    if (regs) {
        g_array_free(regs, TRUE);
    }
    if (missing) {
        fprintf(stderr,
                "cstate: %d GPRs missing from plugin register list -- "
                "captured blob may be incomplete\n", missing);
    }
}

/* Read a register's bytes, return a uint64_t in target byte order
 * (RISC-V is LE so target order == host order on x86 builds). */
static uint64_t read_xreg_u64(int idx)
{
    if (idx == 0 || !xreg_handle[idx]) return 0;
    /* qemu_plugin_read_register expects a GByteArray it may grow; pass a
     * heap-allocated one and free after. */
    GByteArray *gb = g_byte_array_sized_new(16);
    int n = qemu_plugin_read_register(xreg_handle[idx], gb);
    uint64_t val = 0;
    if (n > 0 && (size_t)n <= sizeof(val)) {
        memcpy(&val, gb->data, (size_t)n);
    }
    g_byte_array_free(gb, TRUE);
    return val;
}

static void write_blob(uint64_t pc, const uint64_t xreg[NUM_XREG],
                       const uint8_t *stack_bytes, uint32_t stack_len)
{
    FILE *fp = fopen(arg_out_path, "wb");
    if (!fp) {
        fprintf(stderr, "cstate: cannot open %s for write: %s\n",
                arg_out_path, strerror(errno));
        return;
    }

    cstate_header_t hdr;
    memset(&hdr, 0, sizeof(hdr));
    memcpy(hdr.magic, CSTATE_MAGIC, 4);
    hdr.version     = CSTATE_VERSION;
    hdr.capture_pc  = pc;
    hdr.xlen_bits   = 64;
    hdr.vlen_bits   = 0;          /* T1: no vector data */
    hdr.num_xreg    = NUM_XREG;
    hdr.num_vreg    = 0;
    hdr.stack_bytes = stack_len;

    fwrite(&hdr, 1, sizeof(hdr), fp);
    fwrite(xreg, sizeof(uint64_t), NUM_XREG, fp);
    /* No vector block in T1. */
    if (stack_bytes && stack_len > 0) {
        fwrite(stack_bytes, 1, stack_len, fp);
    }
    fclose(fp);

    fprintf(stderr,
            "cstate: captured pc=0x%" PRIx64 " sp=0x%" PRIx64
            " stack_bytes=%u -> %s\n",
            pc, xreg[2], stack_len, arg_out_path);
}

static void snap_cb(unsigned int cpu_index, void *udata)
{
    /* One-shot. atomic_exchange returns previous value; if it was already
     * 1, another thread / recurrence beat us. */
    if (atomic_exchange(&captured, 1) != 0) {
        return;
    }

    uint64_t xreg[NUM_XREG];
    for (int i = 0; i < NUM_XREG; i++) {
        xreg[i] = read_xreg_u64(i);
    }

    /* Read frame_bytes of stack at sp (xreg[2]). We capture [sp, sp+frame]
     * since that's where caller-saved spills and array buffers live (RISC-V
     * stack grows downward, so sp points at the lowest valid byte). */
    uint64_t sp = xreg[2];
    uint8_t *stack_buf = NULL;
    uint32_t stack_len = 0;
    if (sp != 0 && arg_frame_bytes > 0) {
        GByteArray *sb = g_byte_array_sized_new(arg_frame_bytes);
        if (qemu_plugin_read_memory_vaddr(sp, sb, arg_frame_bytes)) {
            stack_buf = g_memdup2(sb->data, sb->len);
            stack_len = sb->len;
        } else {
            fprintf(stderr,
                    "cstate: warning: stack read at sp=0x%" PRIx64
                    " for %u bytes failed; emitting zero stack\n",
                    sp, arg_frame_bytes);
            stack_len = arg_frame_bytes;
            stack_buf = g_malloc0(stack_len);
        }
        g_byte_array_free(sb, TRUE);
    }

    write_blob(arg_capture_pc, xreg, stack_buf, stack_len);
    g_free(stack_buf);
    (void)cpu_index; (void)udata;
}

static void vcpu_tb_trans(qemu_plugin_id_t id, struct qemu_plugin_tb *tb)
{
    /* Already captured? Skip register-reading callback overhead on
     * subsequent translations. */
    if (atomic_load(&captured)) {
        return;
    }
    size_t n = qemu_plugin_tb_n_insns(tb);
    for (size_t i = 0; i < n; i++) {
        struct qemu_plugin_insn *insn = qemu_plugin_tb_get_insn(tb, i);
        uint64_t vaddr = qemu_plugin_insn_vaddr(insn);
        if (vaddr == arg_capture_pc) {
            qemu_plugin_register_vcpu_insn_exec_cb(
                insn, snap_cb, QEMU_PLUGIN_CB_R_REGS, NULL);
        }
    }
}

static void plugin_exit(qemu_plugin_id_t id, void *p)
{
    if (!atomic_load(&captured)) {
        fprintf(stderr,
                "cstate: warning: capture_pc=0x%" PRIx64
                " was never reached; no blob written\n",
                arg_capture_pc);
    }
    g_free(arg_out_path);
}

static int parse_args(int argc, char **argv)
{
    for (int i = 0; i < argc; i++) {
        g_auto(GStrv) tokens = g_strsplit(argv[i], "=", 2);
        if (!tokens[0] || !tokens[1]) {
            fprintf(stderr, "cstate: bad arg '%s' (need key=value)\n", argv[i]);
            return -1;
        }
        if (g_strcmp0(tokens[0], "capture_pc") == 0) {
            arg_capture_pc = g_ascii_strtoull(tokens[1], NULL, 0);
        } else if (g_strcmp0(tokens[0], "out") == 0) {
            arg_out_path = g_strdup(tokens[1]);
        } else if (g_strcmp0(tokens[0], "frame_bytes") == 0) {
            arg_frame_bytes = (uint32_t)g_ascii_strtoull(tokens[1], NULL, 0);
        } else {
            fprintf(stderr, "cstate: unknown arg '%s'\n", tokens[0]);
            return -1;
        }
    }
    if (arg_capture_pc == 0) {
        fprintf(stderr, "cstate: capture_pc is required\n");
        return -1;
    }
    if (!arg_out_path) {
        fprintf(stderr, "cstate: out is required\n");
        return -1;
    }
    return 0;
}

QEMU_PLUGIN_EXPORT
int qemu_plugin_install(qemu_plugin_id_t id, const qemu_info_t *info,
                        int argc, char **argv)
{
    if (parse_args(argc, argv) < 0) {
        return -1;
    }
    atomic_store(&captured, 0);

    qemu_plugin_register_vcpu_init_cb(id, vcpu_init_cb);
    qemu_plugin_register_vcpu_tb_trans_cb(id, vcpu_tb_trans);
    qemu_plugin_register_atexit_cb(id, plugin_exit, NULL);
    return 0;
}
