# Build the cstate QEMU TCG plugin.
#
# Why a vendored Makefile (not QEMU's meson): the plugin lives in this
# skill's source tree so it can be checked in alongside the scripts that
# depend on it. We build the .so against /local/nick/qemu_v5's plugin
# header and link against the host glib (same setup QEMU itself uses).
#
# QEMU plugin .so naming: QEMU loads "lib<NAME>.so" when invoked as
# `-plugin file=libcstate.so`. We honor that convention even though the
# Makefile target name is just "cstate".
#
# Override QEMU_SRC to point at a different QEMU checkout if the path
# above moves.

QEMU_SRC ?= /local/nick/qemu_v5
PLUGIN_INC := $(QEMU_SRC)/include/qemu

GLIB_CFLAGS := $(shell pkg-config --cflags glib-2.0)
GLIB_LIBS   := $(shell pkg-config --libs   glib-2.0)

CFLAGS  ?= -O2 -g -Wall -Wextra -Wno-unused-parameter
CFLAGS  += -fPIC -std=gnu11
CFLAGS  += -I$(PLUGIN_INC) $(GLIB_CFLAGS)
LDFLAGS += -shared $(GLIB_LIBS)

TARGET := libcstate.so
SRC    := cstate.c

.PHONY: all clean
all: $(TARGET)

$(TARGET): $(SRC)
	$(CC) $(CFLAGS) $(SRC) -o $@ $(LDFLAGS)

clean:
	rm -f $(TARGET)
