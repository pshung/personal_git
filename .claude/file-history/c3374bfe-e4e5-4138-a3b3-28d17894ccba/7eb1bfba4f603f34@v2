/** @file*/

#include "internal_nn_math.h"

//// Convolution Functions
#if (NDS_VEC_RVV_VERSION >= 100)
q7_t *nn_mat_mul_kernel_u8_q7_bias_2sft_unroll4(const q7_t * src1,
                                                const u8_t * src2,
                                                const uint16_t out_tensor_ch,
                                                const uint16_t col_src1,
                                                const uint16_t pre_rshift,
                                                const uint16_t out_scale,
                                                const uint16_t post_rshift,
                                                const q31_t * bias,
                                                q7_t * out)
{
#if defined(ENA_NDS_V5_VEC_DOT_PROD) && (ENA_VEC_INTRINSIC)
    unsigned long vl;
    unsigned long rowCnt = out_tensor_ch >> 2;
    q7_t *pOut2 = out + out_tensor_ch;
    q7_t *pOut3 = out + out_tensor_ch * 2;
    q7_t *pOut4 = out + out_tensor_ch * 3;

    const q7_t *pA = src1;

    vl = __riscv_vsetvl_e32m1(1);
    vint32m1_t vZero = __riscv_vand(__riscv_vundefined_i32m1(), 0x0, vl);     //keep zero for redsum

    while(rowCnt > 0)
    {
        // setup pointers for A
        const q7_t *pA2 = pA + col_src1;
        const q7_t *pA3 = pA + col_src1 * 2;
        const q7_t *pA4 = pA + col_src1 * 3;
        // setup pointers for B
        const u8_t *pB = src2;
        const u8_t *pB2 = pB + col_src1;
        const u8_t *pB3 = pB + col_src1 * 2;
        const u8_t *pB4 = pB + col_src1 * 3;

        vl = __riscv_vsetvlmax_e32m8();

        //init
        //clear v8~v23 (keep multiplication results)
        vint32m8_t vZeroAcc0 = __riscv_vand(__riscv_vundefined_i32m8(), 0x0, vl);
        vint32m8_t vZeroAcc1 = __riscv_vand(__riscv_vundefined_i32m8(), 0x0, vl);

        vint32m1_t vAcc0 = __riscv_vget_i32m1(vZeroAcc0, 0);
        vint32m1_t vAcc1 = __riscv_vget_i32m1(vZeroAcc0, 1);
        vint32m1_t vAcc2 = __riscv_vget_i32m1(vZeroAcc0, 2);
        vint32m1_t vAcc3 = __riscv_vget_i32m1(vZeroAcc0, 3);
        vint32m1_t vAcc4 = __riscv_vget_i32m1(vZeroAcc0, 4);
        vint32m1_t vAcc5 = __riscv_vget_i32m1(vZeroAcc0, 5);
        vint32m1_t vAcc6 = __riscv_vget_i32m1(vZeroAcc0, 6);
        vint32m1_t vAcc7 = __riscv_vget_i32m1(vZeroAcc0, 7);

        vint32m1_t vAcc8 = __riscv_vget_i32m1(vZeroAcc1, 0);
        vint32m1_t vAcc9 = __riscv_vget_i32m1(vZeroAcc1, 1);
        vint32m1_t vAcc10 = __riscv_vget_i32m1(vZeroAcc1, 2);
        vint32m1_t vAcc11 = __riscv_vget_i32m1(vZeroAcc1, 3);
        vint32m1_t vAcc12 = __riscv_vget_i32m1(vZeroAcc1, 4);
        vint32m1_t vAcc13 = __riscv_vget_i32m1(vZeroAcc1, 5);
        vint32m1_t vAcc14 = __riscv_vget_i32m1(vZeroAcc1, 6);
        vint32m1_t vAcc15 = __riscv_vget_i32m1(vZeroAcc1, 7);

        unsigned long colCnt = col_src1;
        while(colCnt > 0)
        {
            vl = __riscv_vsetvl_e8m1(colCnt);
            //load src1 and src2
            vint8m1_t vpA_i8m1 = __riscv_vle8_v_i8m1(pA, vl);
            vint8m1_t vpA2_i8m1 = __riscv_vle8_v_i8m1(pA2, vl);
            vint8m1_t vpA3_i8m1 = __riscv_vle8_v_i8m1(pA3, vl);
            vint8m1_t vpA4_i8m1 = __riscv_vle8_v_i8m1(pA4, vl);

            vuint8m1_t vpB_u8m1 = __riscv_vle8_v_u8m1(pB, vl);
            vuint8m1_t vpB2_u8m1 = __riscv_vle8_v_u8m1(pB2, vl);
            vuint8m1_t vpB3_u8m1 = __riscv_vle8_v_u8m1(pB3, vl);
            vuint8m1_t vpB4_u8m1 = __riscv_vle8_v_u8m1(pB4, vl);

            //bump pointers and update loop counter
            colCnt -= vl;
            pA += vl;
            pA2 += vl;
            pA3 += vl;
            pA4 += vl;
            pB += vl;
            pB2 += vl;
            pB3 += vl;
            pB4 += vl;

            //set the proper avl/SEW/LMUL values for vd4dot
            vl >>= 2;
            vl = __riscv_vsetvl_e32m1(vl);

            //acc += src1 * src2
            vAcc0 = __riscv_vd4dotsu_vv_i32m1(vAcc0, vpA_i8m1, vpB_u8m1, vl);
            vAcc1 = __riscv_vd4dotsu_vv_i32m1(vAcc1, vpA2_i8m1, vpB_u8m1, vl);
            vAcc2 = __riscv_vd4dotsu_vv_i32m1(vAcc2, vpA3_i8m1, vpB_u8m1, vl);
            vAcc3 = __riscv_vd4dotsu_vv_i32m1(vAcc3, vpA4_i8m1, vpB_u8m1, vl);

            vAcc4 = __riscv_vd4dotsu_vv_i32m1(vAcc4, vpA_i8m1, vpB2_u8m1, vl);
            vAcc5 = __riscv_vd4dotsu_vv_i32m1(vAcc5, vpA2_i8m1, vpB2_u8m1, vl);
            vAcc6 = __riscv_vd4dotsu_vv_i32m1(vAcc6, vpA3_i8m1, vpB2_u8m1, vl);
            vAcc7 = __riscv_vd4dotsu_vv_i32m1(vAcc7, vpA4_i8m1, vpB2_u8m1, vl);

            vAcc8 = __riscv_vd4dotsu_vv_i32m1(vAcc8, vpA_i8m1, vpB3_u8m1, vl);
            vAcc9 = __riscv_vd4dotsu_vv_i32m1(vAcc9, vpA2_i8m1, vpB3_u8m1, vl);
            vAcc10 = __riscv_vd4dotsu_vv_i32m1(vAcc10, vpA3_i8m1, vpB3_u8m1, vl);
            vAcc11 = __riscv_vd4dotsu_vv_i32m1(vAcc11, vpA4_i8m1, vpB3_u8m1, vl);

            vAcc12 = __riscv_vd4dotsu_vv_i32m1(vAcc12, vpA_i8m1, vpB4_u8m1, vl);
            vAcc13 = __riscv_vd4dotsu_vv_i32m1(vAcc13, vpA2_i8m1, vpB4_u8m1, vl);
            vAcc14 = __riscv_vd4dotsu_vv_i32m1(vAcc14, vpA3_i8m1, vpB4_u8m1, vl);
            vAcc15 = __riscv_vd4dotsu_vv_i32m1(vAcc15, vpA4_i8m1, vpB4_u8m1, vl);
        }
        pA = pA4;

        vl = __riscv_vsetvl_e32m1(col_src1);;    //note the avl here
        vint32m1_t vSum0 = __riscv_vredsum(vAcc0, vZero, vl);
        vint32m1_t vSum1 = __riscv_vredsum(vAcc1, vZero, vl);
        vint32m1_t vSum2 = __riscv_vredsum(vAcc2, vZero, vl);
        vint32m1_t vSum3 = __riscv_vredsum(vAcc3, vZero, vl);

        vint32m1_t vSum4 = __riscv_vredsum(vAcc4, vZero, vl);
        vint32m1_t vSum5 = __riscv_vredsum(vAcc5, vZero, vl);
        vint32m1_t vSum6 = __riscv_vredsum(vAcc6, vZero, vl);
        vint32m1_t vSum7 = __riscv_vredsum(vAcc7, vZero, vl);

        vint32m1_t vSum8 = __riscv_vredsum(vAcc8, vZero, vl);
        vint32m1_t vSum9 = __riscv_vredsum(vAcc9, vZero, vl);
        vint32m1_t vSum10 = __riscv_vredsum(vAcc10, vZero, vl);
        vint32m1_t vSum11 = __riscv_vredsum(vAcc11, vZero, vl);

        vint32m1_t vSum12 = __riscv_vredsum(vAcc12, vZero, vl);
        vint32m1_t vSum13 = __riscv_vredsum(vAcc13, vZero, vl);
        vint32m1_t vSum14 = __riscv_vredsum(vAcc14, vZero, vl);
        vint32m1_t vSum15 = __riscv_vredsum(vAcc15, vZero, vl);

        vl = __riscv_vsetvl_e32m1(4);     //4: 4 acc
        vSum0 = __riscv_vslideup(vSum0, vSum1, 1, vl);
        vSum0 = __riscv_vslideup(vSum0, vSum2, 2, vl);
        vSum0 = __riscv_vslideup(vSum0, vSum3, 3, vl);

        vSum4 = __riscv_vslideup(vSum4, vSum5, 1, vl);
        vSum4 = __riscv_vslideup(vSum4, vSum6, 2, vl);
        vSum4 = __riscv_vslideup(vSum4, vSum7, 3, vl);

        vSum8 = __riscv_vslideup(vSum8, vSum9, 1, vl);
        vSum8 = __riscv_vslideup(vSum8, vSum10, 2, vl);
        vSum8 = __riscv_vslideup(vSum8, vSum11, 3, vl);

        vSum12 = __riscv_vslideup(vSum12, vSum13, 1, vl);
        vSum12 = __riscv_vslideup(vSum12, vSum14, 2, vl);
        vSum12 = __riscv_vslideup(vSum12, vSum15, 3, vl);

        //load bias
        vint32m1_t vBias = __riscv_vle32_v_i32m1(bias, vl);
        bias += vl;

        //add bias to acc
        vSum0 = __riscv_vadd(vSum0, vBias, vl);
        vSum4 = __riscv_vadd(vSum4, vBias, vl);
        vSum8 = __riscv_vadd(vSum8, vBias, vl);
        vSum12 = __riscv_vadd(vSum12, vBias, vl);

        //1st shift of 2-stage shift
        vSum0 = __riscv_vsra(vSum0, pre_rshift, vl);
        vSum4 = __riscv_vsra(vSum4, pre_rshift, vl);
        vSum8 = __riscv_vsra(vSum8, pre_rshift, vl);
        vSum12 = __riscv_vsra(vSum12, pre_rshift, vl);

        vSum0 = __riscv_vmul(vSum0, out_scale, vl);
        vSum4 = __riscv_vmul(vSum4, out_scale, vl);
        vSum8 = __riscv_vmul(vSum8, out_scale, vl);
        vSum12 = __riscv_vmul(vSum12, out_scale, vl);

        vSum0 = __riscv_vadd(vSum0, NN_ROUND(post_rshift), vl);
        vSum4 = __riscv_vadd(vSum4, NN_ROUND(post_rshift), vl);
        vSum8 = __riscv_vadd(vSum8, NN_ROUND(post_rshift), vl);
        vSum12 = __riscv_vadd(vSum12, NN_ROUND(post_rshift), vl);

        //saturate into 8-bits
        vl = __riscv_vsetvl_e16mf2(4);     //4: 4 acc
        vint16mf2_t vSum0_i16mf2 = __riscv_vnsra(vSum0, post_rshift, vl);
        vint16mf2_t vSum4_i16mf2 = __riscv_vnsra(vSum4, post_rshift, vl);
        vint16mf2_t vSum8_i16mf2 = __riscv_vnsra(vSum8, post_rshift, vl);
        vint16mf2_t vSum12_i16mf2 = __riscv_vnsra(vSum12, post_rshift, vl);
        vl = __riscv_vsetvl_e8mf4(4);     //4: 4 acc
        vint8mf4_t vSum0_i8mf4 = __riscv_vnclip(vSum0_i16mf2, 0, __RISCV_VXRM_RNU, vl);
        vint8mf4_t vSum4_i8mf4 = __riscv_vnclip(vSum4_i16mf2, 0, __RISCV_VXRM_RNU, vl);
        vint8mf4_t vSum8_i8mf4 = __riscv_vnclip(vSum8_i16mf2, 0, __RISCV_VXRM_RNU, vl);
        vint8mf4_t vSum12_i8mf4 = __riscv_vnclip(vSum12_i16mf2, 0, __RISCV_VXRM_RNU, vl);

        //store the results
        __riscv_vse8(out, vSum0_i8mf4, vl);
        __riscv_vse8(pOut2, vSum4_i8mf4, vl);
        __riscv_vse8(pOut3, vSum8_i8mf4, vl);
        __riscv_vse8(pOut4, vSum12_i8mf4, vl);
        out += vl;
        pOut2 += vl;
        pOut3 += vl;
        pOut4 += vl;

        rowCnt--;
    }

    //reset rows (as out_tensor_ch is 4n+2)
    if(out_tensor_ch & 0x2)
    {
        // setup pointers for A
        const q7_t *pA2 = pA + col_src1;
        // setup pointers for B
        const u8_t *pB = src2;
        const u8_t *pB2 = pB + col_src1;
        const u8_t *pB3 = pB + col_src1 * 2;
        const u8_t *pB4 = pB + col_src1 * 3;

        vl = __riscv_vsetvlmax_e32m8();

        //init
        //clear v0~v15 (keep multiplication results)
        vint32m8_t vZeroAcc0 = __riscv_vand(__riscv_vundefined_i32m8(), 0x0, vl);
        vint32m8_t vZeroAcc1 = __riscv_vand(__riscv_vundefined_i32m8(), 0x0, vl);

        vint32m2_t vAcc0 = __riscv_vget_i32m2(vZeroAcc0, 0);
        vint32m2_t vAcc1 = __riscv_vget_i32m2(vZeroAcc0, 1);
        vint32m2_t vAcc2 = __riscv_vget_i32m2(vZeroAcc0, 2);
        vint32m2_t vAcc3 = __riscv_vget_i32m2(vZeroAcc0, 3);

        vint32m2_t vAcc4 = __riscv_vget_i32m2(vZeroAcc1, 0);
        vint32m2_t vAcc5 = __riscv_vget_i32m2(vZeroAcc1, 1);
        vint32m2_t vAcc6 = __riscv_vget_i32m2(vZeroAcc1, 2);
        vint32m2_t vAcc7 = __riscv_vget_i32m2(vZeroAcc1, 3);

        unsigned long colCnt = col_src1;
        while(colCnt > 0)
        {
            vl = __riscv_vsetvl_e8m2(colCnt);
            //load src1
            vint8m2_t vpA_i8m2 = __riscv_vle8_v_i8m2(pA, vl);
            vint8m2_t vpA2_i8m2 = __riscv_vle8_v_i8m2(pA2, vl);
            //load src2
            vuint8m2_t vpB_u8m2 = __riscv_vle8_v_u8m2(pB, vl);
            vuint8m2_t vpB2_u8m2 = __riscv_vle8_v_u8m2(pB2, vl);
            vuint8m2_t vpB3_u8m2 = __riscv_vle8_v_u8m2(pB3, vl);
            vuint8m2_t vpB4_u8m2 = __riscv_vle8_v_u8m2(pB4, vl);

            //bump pointers and update loop counter
            colCnt -= vl;
            pA += vl;
            pA2 += vl;
            pB += vl;
            pB2 += vl;
            pB3 += vl;
            pB4 += vl;

            //set the proper avl/SEW/LMUL values for vd4dot
            vl >>= 2;
            vl = __riscv_vsetvl_e32m2(vl);

            //acc += src1 * src2
            vAcc0 = __riscv_vd4dotsu_vv_i32m2(vAcc0, vpA_i8m2, vpB_u8m2, vl);
            vAcc1 = __riscv_vd4dotsu_vv_i32m2(vAcc1, vpA2_i8m2, vpB_u8m2, vl);
            vAcc2 = __riscv_vd4dotsu_vv_i32m2(vAcc2, vpA_i8m2, vpB2_u8m2, vl);
            vAcc3 = __riscv_vd4dotsu_vv_i32m2(vAcc3, vpA2_i8m2, vpB2_u8m2, vl);
            vAcc4 = __riscv_vd4dotsu_vv_i32m2(vAcc4, vpA_i8m2, vpB3_u8m2, vl);
            vAcc5 = __riscv_vd4dotsu_vv_i32m2(vAcc5, vpA2_i8m2, vpB3_u8m2, vl);
            vAcc6 = __riscv_vd4dotsu_vv_i32m2(vAcc6, vpA_i8m2, vpB4_u8m2, vl);
            vAcc7 = __riscv_vd4dotsu_vv_i32m2(vAcc7, vpA2_i8m2, vpB4_u8m2, vl);
        }

        vl = __riscv_vsetvl_e32m2(col_src1);    //note the avl here
        vint32m1_t vSum0 = __riscv_vredsum(vAcc0, vZero, vl);
        vint32m1_t vSum1 = __riscv_vredsum(vAcc1, vZero, vl);
        vint32m1_t vSum2 = __riscv_vredsum(vAcc2, vZero, vl);
        vint32m1_t vSum3 = __riscv_vredsum(vAcc3, vZero, vl);
        vint32m1_t vSum4 = __riscv_vredsum(vAcc4, vZero, vl);
        vint32m1_t vSum5 = __riscv_vredsum(vAcc5, vZero, vl);
        vint32m1_t vSum6 = __riscv_vredsum(vAcc6, vZero, vl);
        vint32m1_t vSum7 = __riscv_vredsum(vAcc7, vZero, vl);

        vl = __riscv_vsetvl_e32m1(2);     //2: 2 acc
        vSum0 = __riscv_vslideup(vSum0, vSum1, 1, vl);
        vSum2 = __riscv_vslideup(vSum2, vSum3, 1, vl);
        vSum4 = __riscv_vslideup(vSum4, vSum5, 1, vl);
        vSum6 = __riscv_vslideup(vSum6, vSum7, 1, vl);

        //load bias
        vint32m1_t vBias = __riscv_vle32_v_i32m1(bias, vl);
        bias += vl;

        //add bias to acc
        vSum0 = __riscv_vadd(vSum0, vBias, vl);
        vSum2 = __riscv_vadd(vSum2, vBias, vl);
        vSum4 = __riscv_vadd(vSum4, vBias, vl);
        vSum6 = __riscv_vadd(vSum6, vBias, vl);

        //1st shift of 2-stage shift
        vSum0 = __riscv_vsra(vSum0, pre_rshift, vl);
        vSum2 = __riscv_vsra(vSum2, pre_rshift, vl);
        vSum4 = __riscv_vsra(vSum4, pre_rshift, vl);
        vSum6 = __riscv_vsra(vSum6, pre_rshift, vl);

        vSum0 = __riscv_vmul(vSum0, out_scale, vl);
        vSum2 = __riscv_vmul(vSum2, out_scale, vl);
        vSum4 = __riscv_vmul(vSum4, out_scale, vl);
        vSum6 = __riscv_vmul(vSum6, out_scale, vl);

        vSum0 = __riscv_vadd(vSum0, NN_ROUND(post_rshift), vl);
        vSum2 = __riscv_vadd(vSum2, NN_ROUND(post_rshift), vl);
        vSum4 = __riscv_vadd(vSum4, NN_ROUND(post_rshift), vl);
        vSum6 = __riscv_vadd(vSum6, NN_ROUND(post_rshift), vl);

        //saturate into 8-bits
        vl = __riscv_vsetvl_e16mf2(2);     //2: 2 acc
        vint16mf2_t vSum0_i16mf2 = __riscv_vnsra(vSum0, post_rshift, vl);
        vint16mf2_t vSum2_i16mf2 = __riscv_vnsra(vSum2, post_rshift, vl);
        vint16mf2_t vSum4_i16mf2 = __riscv_vnsra(vSum4, post_rshift, vl);
        vint16mf2_t vSum6_i16mf2 = __riscv_vnsra(vSum6, post_rshift, vl);
        vl = __riscv_vsetvl_e8mf4(2);     //2: 2 acc
        vint8mf4_t vSum0_i8mf4 = __riscv_vnclip(vSum0_i16mf2, 0, __RISCV_VXRM_RNU, vl);
        vint8mf4_t vSum2_i8mf4 = __riscv_vnclip(vSum2_i16mf2, 0, __RISCV_VXRM_RNU, vl);
        vint8mf4_t vSum4_i8mf4 = __riscv_vnclip(vSum4_i16mf2, 0, __RISCV_VXRM_RNU, vl);
        vint8mf4_t vSum6_i8mf4 = __riscv_vnclip(vSum6_i16mf2, 0, __RISCV_VXRM_RNU, vl);

        //store the results
        __riscv_vse8(out, vSum0_i8mf4, vl);
        __riscv_vse8(pOut2, vSum2_i8mf4, vl);
        __riscv_vse8(pOut3, vSum4_i8mf4, vl);
        __riscv_vse8(pOut4, vSum6_i8mf4, vl);
        out += vl;
        pOut2 += vl;
        pOut3 += vl;
        pOut4 += vl;
    }

    out += out_tensor_ch * 3;

    return out;
#elif defined(ENA_NDS_V5_VEC_DOT_PROD)
    unsigned long vl;
    unsigned long rowCnt = out_tensor_ch >> 2;
    q7_t *pOut2 = out + out_tensor_ch;
    q7_t *pOut3 = out + out_tensor_ch * 2;
    q7_t *pOut4 = out + out_tensor_ch * 3;

    const q7_t *pA = src1;

#if (__clang__)
    register const long zero asm ("x0") = 0;
#else
    register const long zero asm ("x0");
#endif
    NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);
    NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0x0);     //keep zero for redsum

