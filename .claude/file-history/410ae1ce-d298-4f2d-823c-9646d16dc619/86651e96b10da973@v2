#include "nds_math_types.h"

void nds_mul_q15(q15_t *src1, q15_t *src2, q15_t *dst, uint32_t size)
{
    for (uint32_t i = 0; i < size; i++) {
        int32_t v = ((int32_t) src1[i] * (int32_t) src2[i]) >> 15;
        if (v > 32767) v = 32767;
        else if (v < -32768) v = -32768;
        dst[i] = (q15_t) v;
    }
}

void nds_sub_q15(q15_t *src1, q15_t *src2, q15_t *dst, uint32_t size)
{
    for (uint32_t i = 0; i < size; i++) {
        int32_t v = (int32_t) src1[i] - (int32_t) src2[i];
        if (v > 32767) v = 32767;
        else if (v < -32768) v = -32768;
        dst[i] = (q15_t) v;
    }
}

void nds_offset_q15(q15_t *src, q15_t offset, q15_t *dst, uint32_t size)
{
    for (uint32_t i = 0; i < size; i++) {
        int32_t v = (int32_t) src[i] + (int32_t) offset;
        if (v > 32767) v = 32767;
        else if (v < -32768) v = -32768;
        dst[i] = (q15_t) v;
    }
}

void nds_dup_q15(q15_t *src, q15_t *dst, uint32_t size)
{
    for (uint32_t i = 0; i < size; i++) dst[i] = src[i];
}
