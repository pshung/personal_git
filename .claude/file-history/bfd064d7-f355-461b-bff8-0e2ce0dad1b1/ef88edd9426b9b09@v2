#include <stdio.h>
#include <riscv_vector.h>

int main(void) {
    int32_t a[] = {1, 2, 3, 4, 5, 6, 7, 8};
    int32_t b[] = {10, 20, 30, 40, 50, 60, 70, 80};
    int32_t c[8];
    size_t n = 8;

    size_t vl = __riscv_vsetvl_e32m1(n);
    printf("VLEN test: vl=%lu for n=%lu\n", (unsigned long)vl, (unsigned long)n);

    vint32m1_t va = __riscv_vle32_v_i32m1(a, vl);
    vint32m1_t vb = __riscv_vle32_v_i32m1(b, vl);
    vint32m1_t vc = __riscv_vadd_vv_i32m1(va, vb, vl);
    __riscv_vse32_v_i32m1(c, vc, vl);

    printf("a + b = [");
    for (size_t i = 0; i < vl; i++) {
        printf("%d%s", c[i], i < vl - 1 ? ", " : "");
    }
    printf("]\n");

    // Verify
    int pass = 1;
    for (size_t i = 0; i < vl; i++) {
        if (c[i] != a[i] + b[i]) { pass = 0; break; }
    }
    printf("Result: %s\n", pass ? "PASS" : "FAIL");
    return 0;
}
