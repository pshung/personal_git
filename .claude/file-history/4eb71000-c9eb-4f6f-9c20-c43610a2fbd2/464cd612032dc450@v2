class TestFeatureA:
    def test_feature_a_matmul_with_tile_config(self):
        """Matmul dispatch with fused tile_config: 18-dim, body op from tile_config."""
        group = {
            'op_name': 'linalg.matmul-1',
            'shape': [784, 256, 512],
            'configs': [{'lowering_config': [[0]*3]*6, 'cycles': 1.0}],
            'tile_config': TILE_CONFIG_MATMUL_FUSED,
        }
        fa = compute_feature_a(group)
        assert fa.shape == (FEATURE_A_DIM,)
        assert fa[0] == OP_TYPE_MAP['linalg.matmul-1']      # op_type
        assert fa[1] == 3                                     # num_dims (rank)
        assert fa[2] == 2                                     # num_parallel
        assert fa[3] == 1                                     # num_reduction
        assert fa[4] == 6                                     # num_levels
        assert fa[5] == 3                                     # num_ops_in_dispatch
        assert fa[6] == 1                                     # num_simple_ops (arith.addf)
        assert fa[7] == 0                                     # num_complex_ops
        # shape from iteration_space
        assert fa[8] == pytest.approx(math.log1p(784))        # shape_d0
        assert fa[9] == pytest.approx(math.log1p(256))        # shape_d1
        assert fa[10] == pytest.approx(math.log1p(512))       # shape_d2
        assert fa[11] == 0.0                                   # shape_d3 (padded)
        assert fa[15] == pytest.approx(math.log1p(784*256*512))  # log_total
        assert fa[16] == pytest.approx(2/3)                    # parallel_ratio
        assert fa[17] == pytest.approx(1/3)                    # reduction_ratio

    def test_feature_a_conv_with_tile_config(self):
        """Conv dispatch: 4 parallel, 2 reduction dims."""
        group = {
            'op_name': 'linalg.depthwise_conv_2d_nhwc_hwc-0',
            'shape': [1, 56, 56, 144, 3, 3],
            'configs': [{'lowering_config': [[0]*6]*4, 'cycles': 1.0}],
            'tile_config': TILE_CONFIG_CONV,
        }
        fa = compute_feature_a(group)
        assert fa[1] == 6   # num_dims
        assert fa[2] == 4   # num_parallel
        assert fa[3] == 2   # num_reduction
        assert fa[4] == 4   # num_levels
        assert fa[5] == 1   # single op dispatch
        assert fa[16] == pytest.approx(4/6)   # parallel_ratio
        assert fa[17] == pytest.approx(2/6)   # reduction_ratio

    def test_feature_a_generic_1d_with_tile_config(self):
        """1D generic: all parallel, arith ops counted."""
        group = {
            'op_name': 'linalg.generic-0',
            'shape': [150528],
            'configs': [{'lowering_config': [[0]]*4, 'cycles': 1.0}],
            'tile_config': TILE_CONFIG_GENERIC_1D,
        }
        fa = compute_feature_a(group)
        assert fa[1] == 1   # num_dims
        assert fa[2] == 1   # num_parallel
        assert fa[3] == 0   # num_reduction
        assert fa[4] == 4   # num_levels
        assert fa[6] == 2   # num_simple_ops: arith.mulf, arith.subf
        assert fa[7] == 0   # num_complex_ops
        assert fa[8] == pytest.approx(math.log1p(150528))
        assert fa[16] == pytest.approx(1.0)  # parallel_ratio
        assert fa[17] == pytest.approx(0.0)  # reduction_ratio

    def test_feature_a_math_ops_counted(self):
        """math.* ops counted as complex ops."""
        group = {
            'op_name': 'linalg.generic-0',
            'shape': [1024],
            'configs': [{'lowering_config': [[0]]*4, 'cycles': 1.0}],
            'tile_config': TILE_CONFIG_MATH_OPS,
        }
        fa = compute_feature_a(group)
        assert fa[6] == 1   # num_simple_ops: arith.addf
        assert fa[7] == 2   # num_complex_ops: math.exp, math.sqrt

    def test_feature_a_fallback_no_tile_config(self):
        """Without tile_config, falls back to CSV-only logic."""
        group = {
            'op_name': 'linalg.matmul-1',
            'shape': [64, 32, 16],
            'configs': [{'lowering_config': [[0]*3]*6, 'cycles': 1.0}],
        }
        fa = compute_feature_a(group)
        assert fa.shape == (FEATURE_A_DIM,)
        assert fa[0] == OP_TYPE_MAP['linalg.matmul-1']
        assert fa[1] == 3  # num_dims from shape
        # Fallback: parallel/reduction unknown -> 0
        assert fa[2] == 0   # num_parallel
        assert fa[3] == 0   # num_reduction
        assert fa[4] == 6   # num_levels from config
        assert fa[5] == 0   # num_ops_in_dispatch (unknown)
        assert fa[6] == 0   # num_simple_ops (unknown)
        assert fa[7] == 0   # num_complex_ops (unknown)
        # Shape still populated
        assert fa[8] == pytest.approx(math.log1p(64))
        assert fa[15] == pytest.approx(math.log1p(64*32*16))


