"""Tests for modelzoo_ranker.model — ModelzooRanker and loss."""
import torch

from modelzoo_ranker.model.ranker import ModelzooRanker
from modelzoo_ranker.model.loss import top_k_listmle_loss
from modelzoo_ranker.data.features import FEATURE_A_DIM, FEATURE_B_DIM


class TestModelzooRanker:
    def test_forward_output_shape(self):
        """Forward pass produces [B, S] scores."""
        model = ModelzooRanker()
        B, S = 4, 5
        fa = torch.randn(B, FEATURE_A_DIM)
        fb = torch.randn(B, S, FEATURE_B_DIM)
        mask = torch.ones(B, S, dtype=torch.bool)
        scores = model(fa, fb, mask)
        assert scores.shape == (B, S)

    def test_gradient_flow(self):
        """All parameters receive finite gradients after backward pass."""
        model = ModelzooRanker()
        B, S = 4, 3
        fa = torch.randn(B, FEATURE_A_DIM)
        fb = torch.randn(B, S, FEATURE_B_DIM)
        mask = torch.ones(B, S, dtype=torch.bool)
        scores = model(fa, fb, mask)
        loss = top_k_listmle_loss(scores, mask, k=3)
        loss.backward()
        for name, p in model.named_parameters():
            assert p.grad is not None, f'{name} has no gradient'
            assert torch.isfinite(p.grad).all(), f'{name} has non-finite gradient'


class TestLoss:
    def test_listmle_loss_finite(self):
        """Loss is a finite scalar."""
        B, S = 4, 5
        scores = torch.randn(B, S, requires_grad=True)
        mask = torch.ones(B, S, dtype=torch.bool)
        mask[:, -1] = False  # one padded position
        loss = top_k_listmle_loss(scores, mask, k=3)
        assert loss.dim() == 0  # scalar
        assert torch.isfinite(loss)
