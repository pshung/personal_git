/** @file*/

#include "internal_nn_math.h"
#include "riscv_nn_support.h"

//// Convolution Functions
int32_t riscv_nn_conv_HWC_u8_u8_s8_sym_fast_any(const u8_t * in_tensor,
        const uint16_t in_tensor_dim_x,
        const uint16_t in_tensor_dim_y,
        const uint16_t in_tensor_ch,
        const q7_t * ker_weight,
        const uint16_t out_tensor_ch,
        const uint16_t ker_dim_x,
        const uint16_t ker_dim_y,
        const uint16_t pad_x,
        const uint16_t pad_y,
        const uint16_t stride_x,
        const uint16_t stride_y,
        const uint16_t pre_rshift,
        const uint16_t out_scale,
        const uint16_t post_rshift,
        u8_t * out_tensor,
        const uint16_t out_tensor_dim_x,
        const uint16_t out_tensor_dim_y,
        q15_t * in_tmp_buf)
{
#ifdef ENA_EMPTY_FUN
    //empty body
#else
    if (in_tensor_ch % 4 != 0 || out_tensor_ch % 2 != 0)
    {
        /* check if the input dimension meets the constraints */
        return -1;
    }

#if defined(ENA_VEC_ISA) && defined(ENA_TILING)
    /* cache is 512KB, type is q7 */
    uint32_t tiling_size = 256;
    /* num of columnar */
    int col_counter = 0;
    int16_t    i_out_y, i_out_x, i_ker_y, i_ker_x;
    unsigned long addr_in_tmp_buf;

    /*
     *  Here we use in_tmp_buf as q15_t internally as computation are done with q15_t level
     *  im2col are done to output in q15_t format from u8_t input
     */
    const long align_byte = 64;
    u8_t *pBuffer = (u8_t*)in_tmp_buf;
    u8_t *pOut = out_tensor;
    q31_t *dst_q31;

    q7_t *src2 = (q7_t *)in_tmp_buf
                         + sizeof(*in_tensor) * tiling_size * in_tensor_ch * ker_dim_x * ker_dim_y; //matrix_A's memory space
    src2 = (q7_t*)nn_align((unsigned long)src2, align_byte);  // align the starting addresss
    addr_in_tmp_buf = (unsigned long)src2;
    addr_in_tmp_buf += sizeof(*ker_weight) * out_tensor_ch * in_tensor_ch * ker_dim_x * ker_dim_y;
    addr_in_tmp_buf = nn_align(addr_in_tmp_buf, align_byte);
    dst_q31 = (q31_t *)addr_in_tmp_buf;

    /* transpose the kernel_weight for matrix multiplication */
    const long row = out_tensor_ch;
    const long col = ker_dim_x * ker_dim_y * in_tensor_ch;
    nn_mat_mul_kernel_tiling_transpose_q7(ker_weight, src2, row, col);

    /* This part implements the im256col function */
    for (i_out_y = 0; i_out_y < out_tensor_dim_y; i_out_y++)
    {
        for (i_out_x = 0; i_out_x < out_tensor_dim_x; i_out_x++)
        {
            for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y; i_ker_y++)
            {
                for (i_ker_x = i_out_x * stride_x - pad_x; i_ker_x < i_out_x * stride_x - pad_x + ker_dim_x; i_ker_x++)
                {
                    if (i_ker_y < 0 || i_ker_y >= in_tensor_dim_y || i_ker_x < 0 || i_ker_x >= in_tensor_dim_x)
                    {
                        /* Filling 0 for out-of-bound paddings */
                        nn_set_zero_u8(pBuffer, sizeof(u8_t) * in_tensor_ch);
                    }
                    else
                    {
                        /* Copying the pixel data to column */
                        nn_dup_u8(in_tensor + (i_ker_y * in_tensor_dim_x + i_ker_x) * in_tensor_ch, pBuffer, in_tensor_ch);
                    }
                    pBuffer += in_tensor_ch;
                }
            }
            col_counter++;

            /* Computation is filed for [tiling_size] columns */
            if (col_counter == tiling_size)
            {
                pOut = nn_mat_mul_kernel_tiling_u8_u8_s8((u8_t *)in_tmp_buf,
                                                         src2,
                                                         dst_q31,
                                                         pOut,
                                                         col_counter,
                                                         in_tensor_ch * ker_dim_x * ker_dim_y,
                                                         out_tensor_ch,
                                                         pre_rshift,
                                                         out_scale,
                                                         post_rshift,
                                                         tiling_size);
                /* reset */
                col_counter = 0;
                pBuffer = (u8_t *)in_tmp_buf;
            }
        }
    }

    /* check if there is left-over for compute */
    pOut = nn_mat_mul_kernel_tiling_u8_u8_s8((u8_t *)in_tmp_buf,
                                             src2,
                                             dst_q31,
                                             pOut,
                                             col_counter,
                                             in_tensor_ch * ker_dim_x * ker_dim_y,
                                             out_tensor_ch,
                                             pre_rshift,
                                             out_scale,
                                             post_rshift,
                                             tiling_size);
#elif defined(ENA_VEC_ISA) || defined(ENA_DSP_ISA_V5)
    int i_out_y, i_out_x, i_ker_y, i_ker_x;

    /* -----------------------
     *  Here we use in_tmp_buf as q15_t internally as computation are done with q15_t level
     *  im2col are done to output in q15_t format from q7_t input
     */

    u8_t     *pBuffer = (u8_t*)in_tmp_buf;
    u8_t     *pOut = out_tensor;
    int bound_x_begin = (pad_x + stride_x - 1) / stride_x;
    int bound_x_end   = (in_tensor_dim_x + pad_x - ker_dim_x + stride_x) / stride_x;
    int bound_y_begin = (pad_y + stride_y - 1) / stride_y;
    int bound_y_end   = (in_tensor_dim_y + pad_y - ker_dim_y + stride_y) / stride_y;

    /*
     *  Here we split the entire matrix into three regions depending on the padding situation
     *    Top: i_out_y from 0 to padding - 1
     * Middle: i_out_y from padding to dim_im_out-padding-1
     * Bottom: i_out_y from dim_im_out-padding to dim_im_out-1
     */

    /* top part */
    for (i_out_y = 0; i_out_y < bound_y_begin; i_out_y++)
    {
        for (i_out_x = 0; i_out_x < out_tensor_dim_x; i_out_x++)
        {
            /* This part implements the im2col function */
            for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y; i_ker_y++)
            {
                for (i_ker_x = i_out_x * stride_x - pad_x; i_ker_x < i_out_x * stride_x - pad_x + ker_dim_x; i_ker_x++)
                {
                    if (i_ker_y < 0 || i_ker_y >= in_tensor_dim_y || i_ker_x < 0 || i_ker_x >= in_tensor_dim_x)
                    {
                        nn_set_zero_u8(pBuffer, sizeof(u8_t)*in_tensor_ch);
                    }
                    else
                    {
                        nn_dup_u8((u8_t *) in_tensor + (i_ker_y * in_tensor_dim_x + i_ker_x) * in_tensor_ch,
                                      pBuffer, in_tensor_ch);
                    }
                    pBuffer += in_tensor_ch;
                }
            }

            if (pBuffer == (u8_t*)in_tmp_buf + 2 * in_tensor_ch * ker_dim_x * ker_dim_y)
            {
                pOut = nn_mat_mul_kernel_u8_2sft(ker_weight,
                                                 (u8_t*)in_tmp_buf,
                                                 out_tensor_ch,
                                                 in_tensor_ch * ker_dim_x * ker_dim_y,
                                                 pre_rshift,
                                                 out_scale,
                                                 post_rshift,
                                                 pOut);
                /* counter reset */
                pBuffer = (u8_t *)in_tmp_buf;
            }
        }
    }

    /* middle part, here we also divide the x into left, mid and right */
    for (; i_out_y < bound_y_end; i_out_y++)
    {
        /* left part */
        for (i_out_x = 0; i_out_x < bound_x_begin; i_out_x++)
        {
            /* This part implements the im2col function */
            for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y;
                    i_ker_y++)
            {
                for (i_ker_x = i_out_x * stride_x - pad_x; i_ker_x < i_out_x * stride_x - pad_x + ker_dim_x;
                        i_ker_x++)
                {
                    if (i_ker_x < 0 || i_ker_x >= in_tensor_dim_x)
                    {
                        nn_set_zero_u8(pBuffer, sizeof(u8_t)*in_tensor_ch);
                    }
                    else
                    {
                        nn_dup_u8((u8_t *) in_tensor + (i_ker_y * in_tensor_dim_x + i_ker_x) * in_tensor_ch,
                                      pBuffer, in_tensor_ch);
                    }
                    pBuffer += in_tensor_ch;
                }
            }

            if (pBuffer == (u8_t*)in_tmp_buf + 2 * in_tensor_ch * ker_dim_x * ker_dim_y)
            {
                pOut = nn_mat_mul_kernel_u8_2sft(ker_weight,
                                                 (u8_t *)in_tmp_buf,
                                                 out_tensor_ch,
                                                 in_tensor_ch * ker_dim_x * ker_dim_y,
                                                 pre_rshift,
                                                 out_scale,
                                                 post_rshift,
                                                 pOut);
                /* counter reset */
                pBuffer = (u8_t*)in_tmp_buf;
            }
        }

        /* mid part */
        for (; i_out_x < bound_x_end; i_out_x++)
        {
            /* This part implements the im2col function */
            for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y;
                    i_ker_y++)
            {
                nn_dup_u8((u8_t *) in_tensor + (i_ker_y * in_tensor_dim_x + i_out_x * stride_x - pad_x) * in_tensor_ch,
                              pBuffer, in_tensor_ch * ker_dim_x);
                pBuffer += in_tensor_ch * ker_dim_x;
            }

            if (pBuffer == (u8_t*)in_tmp_buf + 2 * in_tensor_ch * ker_dim_x * ker_dim_y)
            {
                pOut = nn_mat_mul_kernel_u8_2sft(ker_weight,
                                                 (u8_t*)in_tmp_buf,
                                                 out_tensor_ch,
                                                 in_tensor_ch * ker_dim_x * ker_dim_y,
                                                 pre_rshift,
                                                 out_scale,
                                                 post_rshift,
                                                 pOut);
                /* counter reset */
                pBuffer = (u8_t*)in_tmp_buf;
            }
        }

        /* right part */
        for (; i_out_x < out_tensor_dim_x; i_out_x++)
        {
            /* This part implements the im2col function */
            for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y;
                    i_ker_y++)
            {
                for (i_ker_x = i_out_x * stride_x - pad_x; i_ker_x < i_out_x * stride_x - pad_x + ker_dim_x;
                        i_ker_x++)
                {
                    if (i_ker_x < 0 || i_ker_x >= in_tensor_dim_x)
                    {
                        nn_set_zero_u8(pBuffer, sizeof(u8_t)*in_tensor_ch);
                    }
                    else
                    {
                        nn_dup_u8((u8_t *) in_tensor + (i_ker_y * in_tensor_dim_x + i_ker_x) * in_tensor_ch,
                                      pBuffer, in_tensor_ch);
                    }
                    pBuffer += in_tensor_ch;
                }
            }

            if (pBuffer == (u8_t*)in_tmp_buf + 2 * in_tensor_ch * ker_dim_x * ker_dim_y)
            {
                pOut = nn_mat_mul_kernel_u8_2sft(ker_weight,
                                                 (u8_t*)in_tmp_buf,
                                                 out_tensor_ch,
                                                 in_tensor_ch * ker_dim_x * ker_dim_y,
                                                 pre_rshift,
                                                 out_scale,
                                                 post_rshift,
                                                 pOut);
                /* counter reset */
                pBuffer = (u8_t*)in_tmp_buf;
            }
        }
    }

    for (; i_out_y < out_tensor_dim_y; i_out_y++)
    {
        for (i_out_x = 0; i_out_x < out_tensor_dim_x; i_out_x++)
        {
            /* This part implements the im2col function */
            for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y;
                    i_ker_y++)
            {
                for (i_ker_x = i_out_x * stride_x - pad_x; i_ker_x < i_out_x * stride_x - pad_x + ker_dim_x;
                        i_ker_x++)
                {
                    if (i_ker_y < 0 || i_ker_y >= in_tensor_dim_y || i_ker_x < 0 || i_ker_x >= in_tensor_dim_x)
                    {
                        nn_set_zero_u8(pBuffer, sizeof(u8_t)*in_tensor_ch);
                    }
                    else
                    {
                        nn_dup_u8((u8_t *) in_tensor + (i_ker_y * in_tensor_dim_x + i_ker_x) * in_tensor_ch,
                                      pBuffer, in_tensor_ch);
                    }
                    pBuffer += in_tensor_ch;
                }
            }

            if (pBuffer == (u8_t*)in_tmp_buf + 2 * in_tensor_ch * ker_dim_x * ker_dim_y)
            {
                pOut = nn_mat_mul_kernel_u8_2sft(ker_weight,
                                                 (u8_t*)in_tmp_buf,
                                                 out_tensor_ch,
                                                 in_tensor_ch * ker_dim_x * ker_dim_y,
                                                 pre_rshift,
                                                 out_scale,
                                                 post_rshift,
                                                 pOut);
                /* counter reset */
                pBuffer = (u8_t*)in_tmp_buf;
            }
        }
    }

    /* check if there is left-over for compute */
#ifdef ENA_VEC_ISA
#if (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_NDS_V5_VEC_DOT_PROD) && defined(ENA_VEC_INTRINSIC)
   if (pBuffer != (u8_t *)in_tmp_buf)
    {
        unsigned vl;
        const q7_t *p_wt = ker_weight;
        int       i;
        uint16_t  colCnt = in_tensor_ch * ker_dim_x * ker_dim_y;

        vl = __riscv_vsetvl_e32m1(1);
        vint32m1_t vZero = __riscv_vand(__riscv_vundefined_i32m1(), 0x0, vl);     //const zero for redsum

        for (i = 0; i < out_tensor_ch; i++)
        {
            u8_t      *p_in = (u8_t*)in_tmp_buf;
            uint16_t colCnt2 = colCnt;

            //clear v0~v7
            vl = __riscv_vsetvl_e32m8(colCnt);
            vint32m8_t vAccumulator = __riscv_vand(__riscv_vundefined_i32m8(), 0x0, vl);

            while (colCnt2 > 0)
            {
                vl = __riscv_vsetvl_e8m8(colCnt2);
                //load src1
                vint8m8_t vP_wt_i8m8 = __riscv_vle8_v_i8m8(p_wt, vl);
                //load src2
                vuint8m8_t vP_in_u8m8 = __riscv_vle8_v_u8m8(p_in, vl);
                //bump pointers and update loop counter
                colCnt2 -= vl;
                p_wt += vl;
                p_in += vl;
                //set the proper avl/SEW/LMUL values for vd4dot
                vl >>= 2;
                vl = __riscv_vsetvl_e32m8(vl);
                //acc += src1 * src2
                vAccumulator = __riscv_vd4dotsu_vv_i32m8(vAccumulator, vP_wt_i8m8, vP_in_u8m8, vl);
            }

            vl = __riscv_vsetvl_e32m8(colCnt);  //note the avl here
            vint32m1_t vSum = __riscv_vredsum(vAccumulator, vZero, vl);

            //2-stage shift
            vl = __riscv_vsetvl_e32m1(1);
            vSum = __riscv_vsra(vSum, pre_rshift, vl);
            vSum = __riscv_vmul(vSum, out_scale, vl);
            vSum = __riscv_vadd(vSum, NN_ROUND(post_rshift), vl);

            //scale down, clip and store the results
            vSum = __riscv_vmax(vSum, 0, vl);
            vl = __riscv_vsetvl_e16mf2(1);
            vint16mf2_t vSum_i16mf2 = __riscv_vnsra(vSum, post_rshift, vl);
            vl = __riscv_vsetvl_e8mf4(1);
            vuint16mf2_t vSum_u16mf2 = __riscv_vreinterpret_u16mf2(vSum_i16mf2);
            vuint8mf4_t vpOut = __riscv_vnclipu(vSum_u16mf2, 0, __RISCV_VXRM_RNU, vl);
            __riscv_vse8(pOut, vpOut, vl);
            pOut += vl;
        }
    }
#elif (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_NDS_V5_VEC_DOT_PROD)
    if (pBuffer != (u8_t *)in_tmp_buf)
    {
        unsigned vl;
        const q7_t *p_wt = ker_weight;
        int       i;
        uint16_t  colCnt = in_tensor_ch * ker_dim_x * ker_dim_y;

        NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);
        NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0x0);     //const zero for redsum

        for (i = 0; i < out_tensor_ch; i++)
        {
            u8_t      *p_in = (u8_t*)in_tmp_buf;
            uint16_t colCnt2 = colCnt;

            //clear v0~v7
            NDS_VEC_VSETVLI(vl, colCnt, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);
            NDS_VEC_VAND_VI(NDS_VEC_V0, NDS_VEC_V0, 0x0);

            while (colCnt2 > 0)
            {
                NDS_VEC_VSETVLI(vl, colCnt2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);
                //load src1
                NDS_VEC_VLB_V(NDS_VEC_V8, p_wt);
                //load src2
                NDS_VEC_VLB_V(NDS_VEC_V16, p_in);
                //bump pointers and update loop counter
                colCnt2 -= vl;
                p_wt += vl;
                p_in += vl;
                //set the proper avl/SEW/LMUL values for vd4dot
                vl >>= 2;
                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);
                //acc += src1 * src2
                NDS_VEC_VD4DOTSU_VV(NDS_VEC_V0, NDS_VEC_V8, NDS_VEC_V16);
            }

            NDS_VEC_VSETVLI(vl, colCnt, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);  //note the avl here
            NDS_VEC_VREDSUM_VS(NDS_VEC_V8, NDS_VEC_V0, NDS_VEC_V31);

            //2-stage shift
            NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);
            NDS_VEC_VSRA_VX(NDS_VEC_V8, NDS_VEC_V8, pre_rshift);
            NDS_VEC_VMUL_VX(NDS_VEC_V8, NDS_VEC_V8, out_scale);
            NDS_VEC_VADD_VX(NDS_VEC_V8, NDS_VEC_V8, NN_ROUND(post_rshift));

            //scale down, clip and store the results
            NDS_VEC_VMAX_VX(NDS_VEC_V8, NDS_VEC_V8, 0);
            NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E16, NDS_VEC_VTYPE_LMUL_M1);
            NDS_VEC_VNSRA_WX(NDS_VEC_V8, NDS_VEC_V8, post_rshift);
            NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M1);
            NDS_VEC_VNCLIPU_WI(NDS_VEC_V8, NDS_VEC_V8, 0);
            NDS_VEC_VSB_V(NDS_VEC_V8, pOut);
            pOut += vl;
        }
    }
#elif (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_VEC_ISA_ZVQMAC) && (ENA_VEC_INTRINSIC)
    if (pBuffer != (u8_t*)in_tmp_buf)
    {
        int32_t vl;
        const q7_t *pA = ker_weight;
        int       i;
        uint16_t  colCnt = in_tensor_ch * ker_dim_x * ker_dim_y;

        //set SEW for 1st time VMV_S_X
        //LMUL=8 is just for clear v8~v15 (vmv ignores LMUL)
        vl = __riscv_vsetvl_e32m8(colCnt);

        for (i = 0; i < out_tensor_ch; i++)
        {
            q31_t     sum = 0;
            u8_t      *pB = (u8_t*)in_tmp_buf;
            uint16_t colCnt2 = colCnt;

            //init
            vint32m1_t vSum = __riscv_vmv_s_x_i32m1(sum, 1);
            //clear v8~v15
            vint32m8_t vAcc = __riscv_vand(__riscv_vundefined_i32m8(), 0x0, vl);

            while (colCnt2 > 0)
            {
                vl = __riscv_vsetvl_e8m2(colCnt2);
                //load src1
                vint8m2_t vpA = __riscv_vle8_v_i8m2(pA, vl);
                //load src2
                vuint8m2_t vpB = __riscv_vle8_v_u8m2(pB, vl);
                //acc += src1 * src2
                vAcc = __riscv_vqmaccsu(vAcc, vpA, vpB, vl);
                //bump pointers and update loop counter
                colCnt2 -= vl;
                pA += vl;
                pB += vl;
            }

            vl = __riscv_vsetvl_e32m8(colCnt);     //note the avl here
            vSum = __riscv_vredsum_tu(vSum, vAcc, vSum, vl);
            //move vr results to gpr
            sum = __riscv_vmv_x(vSum);

            sum = (sum >> pre_rshift) * out_scale + NN_ROUND(post_rshift);
            *pOut++ = NDS_ISA_SAT((sum >> post_rshift), 8);
        }
    }
#elif (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_VEC_ISA_ZVQMAC)
    if (pBuffer != (u8_t*)in_tmp_buf)
    {
        int32_t vl;
        const q7_t *pA = ker_weight;
        int       i;
        uint16_t  colCnt = in_tensor_ch * ker_dim_x * ker_dim_y;

        //set SEW for 1st time VMV_S_X
        //LMUL=8 is just for clear v8~v15 (vmv ignores LMUL)
        NDS_VEC_VSETVLI(vl, colCnt, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);

        for (i = 0; i < out_tensor_ch; i++)
        {
            q31_t     sum = 0;
            u8_t      *pB = (u8_t*)in_tmp_buf;
            uint16_t colCnt2 = colCnt;

            //init
            NDS_VEC_VMV_S_X(NDS_VEC_V0, sum);
            //clear v8~v15
            NDS_VEC_VAND_VI(NDS_VEC_V8, NDS_VEC_V8, 0x0);

            while (colCnt2 > 0)
            {
                NDS_VEC_VSETVLI(vl, colCnt2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M2);
                //load src1
                NDS_VEC_VLB_V(NDS_VEC_V2, pA);
                //load src2
                NDS_VEC_VLB_V(NDS_VEC_V4, pB);
                //acc += src1 * src2
                NDS_VEC_VQMACCSU_VV(NDS_VEC_V8, NDS_VEC_V2, NDS_VEC_V4);
                //bump pointers and update loop counter
                colCnt2 -= vl;
                pA += vl;
                pB += vl;
            }

            NDS_VEC_VSETVLI(vl, colCnt, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);      //note the avl here
            NDS_VEC_VREDSUM_VS(NDS_VEC_V0, NDS_VEC_V8, NDS_VEC_V0);
            //move vr results to gpr
            NDS_VEC_VMV_X_S(sum, NDS_VEC_V0);

            sum = (sum >> pre_rshift) * out_scale + NN_ROUND(post_rshift);
            *pOut++ = NDS_ISA_SAT((sum >> post_rshift), 8);
        }
    }
