#!/usr/bin/env python3
"""Tests for resolve_function.py"""

import os
import sys
import tempfile
import pytest

sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))
from resolve_function import find_matches


@pytest.fixture
def perf_dir(tmp_path):
    """Create a fake perf test directory with sample files."""
    names = [
        "t_pf_conv_dw_HWC_s8_s8_s8_asym_bias_any.c",
        "t_pf_conv_dw_HWC_s8_s8_s8_sym_bias_any.c",
        "t_pf_conv_dw_HWC_u8_u8_u8_asym_bias_any.c",
        "t_pf_conv_1x1_HWC_s8_s8_s8_asym_bias_fast_any.c",
        "t_pf_conv_HWC_s8_s8_s8_asym_bias_any.c",
        "t_pf_relu_s8.c",
        "t_pf_sigmoid_s8.c",
        "t_pf_avepool_HWC_s8_any.c",
    ]
    for name in names:
        (tmp_path / name).touch()
    return tmp_path


def test_exact_match(perf_dir):
    results = find_matches("relu_s8", perf_dir)
    assert results == ["relu_s8"]


def test_substring_single(perf_dir):
    results = find_matches("sigmoid", perf_dir)
    assert results == ["sigmoid_s8"]


def test_substring_multiple(perf_dir):
    results = find_matches("conv_dw", perf_dir)
    assert len(results) == 3
    assert "conv_dw_HWC_u8_u8_u8_asym_bias_any" in results


def test_multi_token_narrows(perf_dir):
    """Multiple tokens joined by wildcards narrow results."""
    results = find_matches("conv_dw u8", perf_dir)
    assert results == ["conv_dw_HWC_u8_u8_u8_asym_bias_any"]


def test_multi_token_order_matters(perf_dir):
    results = find_matches("conv 1x1 asym", perf_dir)
    assert results == ["conv_1x1_HWC_s8_s8_s8_asym_bias_fast_any"]


def test_no_match(perf_dir):
    results = find_matches("nonexistent", perf_dir)
    assert results == []


def test_case_insensitive(perf_dir):
    results = find_matches("RELU_S8", perf_dir)
    assert results == ["relu_s8"]
