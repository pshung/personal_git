/*
 * Benchmark a single libm function on RISC-V FPGA.
 *
 * Define BENCH_FUNC and BENCH_ARG at compile time:
 *   -DBENCH_FUNC=sin -DBENCH_ARG=1.0
 *   -DBENCH_FUNC=atan2 -DBENCH_ARG=1.0 -DBENCH_ARG2=1.0
 *   -DBENCH_FUNC=sinf -DBENCH_ARG=1.0f -DBENCH_FLOAT
 *
 * Build:
 *   riscv64-elf-gcc -Os -DBENCH_FUNC=sin -DBENCH_ARG=1.0 \
 *       --specs=picolibc.specs -T ae350.ld \
 *       -o bench-one.elf bench-one.c -lm
 */

#include <stdio.h>
#include <math.h>
#include <stdint.h>

/* ---------- CSR helpers ---------- */

#define CSR_MCYCLE          0xB00
#define CSR_MINSTRET        0xB02
#define CSR_MCOUNTINHIBIT   0x320
#if __riscv_xlen == 32
#define CSR_MCYCLEH         0xB80
#define CSR_MINSTRETH       0xB82
#endif

#define csr_write(csr, val) \
    __asm__ volatile("csrw %0, %1" :: "i"(csr), "r"(val))
#define csr_read(csr, val) \
    __asm__ volatile("csrr %0, %1" : "=r"(val) : "i"(csr))

static uint64_t pfm_cycle, pfm_inst;

static inline void startPFM(void)
{
    csr_write(CSR_MCOUNTINHIBIT, 0x7F);
#if __riscv_xlen == 32
    csr_write(CSR_MINSTRET, 0);
    csr_write(CSR_MINSTRETH, 0);
    csr_write(CSR_MCYCLE, 0);
    csr_write(CSR_MCYCLEH, 0);
#else
    csr_write(CSR_MINSTRET, 0);
    csr_write(CSR_MCYCLE, 0);
#endif
    csr_write(CSR_MCOUNTINHIBIT, 0);
}

static inline void stopPFM(void)
{
    csr_write(CSR_MCOUNTINHIBIT, 0x7F);
#if __riscv_xlen == 32
    uint32_t inst_lo, inst_hi, cycle_lo, cycle_hi;
    csr_read(CSR_MINSTRET, inst_lo);
    csr_read(CSR_MINSTRETH, inst_hi);
    csr_read(CSR_MCYCLE, cycle_lo);
    csr_read(CSR_MCYCLEH, cycle_hi);
    pfm_inst  = ((uint64_t)inst_hi << 32) | inst_lo;
    pfm_cycle = ((uint64_t)cycle_hi << 32) | cycle_lo;
#else
    csr_read(CSR_MINSTRET, pfm_inst);
    csr_read(CSR_MCYCLE, pfm_cycle);
#endif
    csr_write(CSR_MCOUNTINHIBIT, 0);
}

/* ---------- defaults ---------- */

#ifndef BENCH_FUNC
#error "Define BENCH_FUNC, e.g. -DBENCH_FUNC=sin"
#endif

#ifndef BENCH_ARG
#define BENCH_ARG 1.0
#endif

#ifndef NITER
#define NITER 1000
#endif

#define _STR(x) #x
#define STR(x) _STR(x)

int main(void)
{
#ifdef BENCH_ARG2
    /* Two-argument function (atan2, pow, hypot, ...) */
#ifdef BENCH_FLOAT
    volatile float a1 = (float)(BENCH_ARG), a2 = (float)(BENCH_ARG2);
    startPFM();
    for (int n = 0; n < NITER; n++) {
        volatile float r = BENCH_FUNC(a1, a2);
        (void)r;
    }
#else
    volatile double a1 = (double)(BENCH_ARG), a2 = (double)(BENCH_ARG2);
    startPFM();
    for (int n = 0; n < NITER; n++) {
        volatile double r = BENCH_FUNC(a1, a2);
        (void)r;
    }
#endif
#else
    /* One-argument function */
#ifdef BENCH_FLOAT
    volatile float a = (float)(BENCH_ARG);
    startPFM();
    for (int n = 0; n < NITER; n++) {
        volatile float r = BENCH_FUNC(a);
        (void)r;
    }
#else
    volatile double a = (double)(BENCH_ARG);
    startPFM();
    for (int n = 0; n < NITER; n++) {
        volatile double r = BENCH_FUNC(a);
        (void)r;
    }
#endif
#endif
    stopPFM();

    printf("%s,%llu,%llu,%d\n",
           STR(BENCH_FUNC),
           (unsigned long long)pfm_cycle,
           (unsigned long long)pfm_inst,
           NITER);

    return 0;
}
