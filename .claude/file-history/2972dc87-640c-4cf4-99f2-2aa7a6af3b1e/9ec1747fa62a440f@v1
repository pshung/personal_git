uint64_t handle_fstat(uint64_t a0 __attribute__((unused)),
                      uint64_t a1 __attribute__((unused)),
                      uint64_t a2 __attribute__((unused)),
                      uint64_t a3 __attribute__((unused)),
                      uint64_t a4 __attribute__((unused)),
                      uint64_t a5 __attribute__((unused)),
                      uint64_t a6 __attribute__((unused)))
{
  struct pico_stat* stat = (struct pico_stat*) (data_region.data.data() + a1);
  struct stat temp_stat;
  int ret = fstat(a0, &temp_stat);
  if (ret == -1) {
    spdlog::error("sys_call: fstat failed: fd={}: {}", a0,
                  std::strerror(errno));
  } else {
    stat->st_size = temp_stat.st_size;
    stat->st_mode = temp_stat.st_mode;
  }

  return ret;
};
