uint64_t handle_read(uint64_t a0 __attribute__((unused)),
                     uint64_t a1 __attribute__((unused)),
                     uint64_t a2 __attribute__((unused)),
                     uint64_t a3 __attribute__((unused)),
                     uint64_t a4 __attribute__((unused)),
                     uint64_t a5 __attribute__((unused)),
                     uint64_t a6 __attribute__((unused)))
{
  auto buf = guest_va_to_host<>(a1);
  ssize_t ret = read(a0, buf, a2);
  if (ret == -1) {
    spdlog::error("sys_call: read failed: fd={}, len={}: {}", a0, a2,
                  std::strerror(errno));
  }
  return ret;
};

uint64_t handle_write(uint64_t a0 __attribute__((unused)),
                      uint64_t a1 __attribute__((unused)),
                      uint64_t a2 __attribute__((unused)),
                      uint64_t a3 __attribute__((unused)),
                      uint64_t a4 __attribute__((unused)),
                      uint64_t a5 __attribute__((unused)),
                      uint64_t a6 __attribute__((unused)))
{
  auto data_start = guest_va_to_host<>(a1);
  std::vector<uint8_t> buf(a2, 0);
  std::copy(data_start, data_start + a2, buf.begin());
  ssize_t ret = write(a0, buf.data(), a2);
  if (ret == -1) {
    spdlog::error("sys_call: write failed: fd={}, len={}: {}", a0, a2,
                  std::strerror(errno));
  }
  return ret;
};

uint64_t handle_getcwd(uint64_t a0 __attribute__((unused)),
                       uint64_t a1 __attribute__((unused)),
                       uint64_t a2 __attribute__((unused)),
                       uint64_t a3 __attribute__((unused)),
                       uint64_t a4 __attribute__((unused)),
                       uint64_t a5 __attribute__((unused)),
                       uint64_t a6 __attribute__((unused)))
{
  auto data_start = guest_va_to_host<char>(a0);
  std::vector<char> buf(a1, 0);
  char* ret = getcwd(buf.data(), a1);
  if (ret == nullptr) {
    spdlog::error("sys_call: getcwd failed: size={}: {}", a1,
                  std::strerror(errno));
    return (uint64_t) nullptr;
  }
  std::copy(buf.begin(), buf.begin() + a1, data_start);
  return (uint64_t) ret;
};

