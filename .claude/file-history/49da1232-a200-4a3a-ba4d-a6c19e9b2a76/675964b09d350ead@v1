                sum = NDS_DSP_SMAQA_SU(sum, inA1, inB1);
                colCnt2--;
            }

            //sum up the high and low part results (SIMD results)
            sum = PADD_S32(sum);

            colCnt2 = colCnt & 0x7;
            while (colCnt2)
            {
                q7_t	inA1 = *pA++;
                u8_t	inB1 = *pB++;
                sum += inA1 * inB1;
                colCnt2--;
