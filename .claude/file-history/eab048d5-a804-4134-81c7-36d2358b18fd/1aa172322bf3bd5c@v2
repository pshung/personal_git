OUTPUT_ARCH(riscv)
ENTRY(_start)

MEMORY {
    RAM (rwx) : ORIGIN = 0x00000000, LENGTH = 0x10000000
}

SECTIONS {
    . = 0x00000000;
    .text : {
        KEEP(*(.text.init))
        *(.text*)
    } > RAM
    .rodata : { *(.rodata*) } > RAM
    .data   : { *(.data*)   } > RAM
    .bss    : {
        *(.bss*) *(COMMON)
    } > RAM
}
