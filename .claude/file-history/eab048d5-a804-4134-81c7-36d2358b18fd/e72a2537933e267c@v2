#include <stdint.h>

#define M 32
#define N 32
#define K 32

static int32_t A[M][K];
static int32_t B[K][N];
static int32_t C[M][N];

static void init(void) {
    for (int i = 0; i < M; i++)
        for (int k = 0; k < K; k++)
            A[i][k] = (i * 7 + k) & 0xf;
    for (int k = 0; k < K; k++)
        for (int j = 0; j < N; j++)
            B[k][j] = (k * 3 + j) & 0xf;
    for (int i = 0; i < M; i++)
        for (int j = 0; j < N; j++)
            C[i][j] = 0;
}

__attribute__((noinline))
static void gemm(void) {
    for (int i = 0; i < M; i++) {
        for (int j = 0; j < N; j++) {
            int32_t acc = 0;
            for (int k = 0; k < K; k++) {
                acc += A[i][k] * B[k][j];
            }
            C[i][j] = acc;
        }
    }
}

volatile int32_t sink;

int main(void) {
    init();
    for (int rep = 0; rep < 4; rep++) {
        gemm();
        sink = C[0][0];
    }
    return 0;
}
