"""Tests for v_outer=0 fallback bug in compute_v_outer_candidates.

When all v_outer candidates are filtered out (e.g., parity filter removes
v_outer=1 for even M dimensions), compute_v_outer_candidates returns [0].
v_outer=0 means "don't tile M" = full dimension, which can produce vectors
exceeding IREE's 65536-byte limit (e.g., vector<196x64xindex>).

The fix: return empty list [] instead of [0], so no config is generated
for that tier. The caller skips empty v_outer lists.
"""

import sys
import os

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', '..', 'script'))


class TestComputeVOuterCandidatesNoZeroFallback:
    """compute_v_outer_candidates must never return [0] as fallback."""

    def test_even_dim_max_vo_1_returns_empty(self):
        """When max_vo=1 and dim_M is even, parity filter removes 1.

        Previously returned [0] (full dim), causing vector<196x64xindex>
        compilation failure. Should return [] instead.
        """
        from dataset_generator.search_space import compute_v_outer_candidates
        result = compute_v_outer_candidates(1, 196)
        assert 0 not in result, (
            f"v_outer=0 (full dim) must not appear as fallback, got {result}"
        )

    def test_even_dim_large_max_vo_1_returns_empty(self):
        """Same bug with M=784."""
        from dataset_generator.search_space import compute_v_outer_candidates
        result = compute_v_outer_candidates(1, 784)
        assert 0 not in result, (
            f"v_outer=0 must not appear as fallback, got {result}"
        )

    def test_no_zero_in_any_result(self):
        """v_outer=0 should never appear in any compute_v_outer_candidates result."""
        from dataset_generator.search_space import compute_v_outer_candidates
        # Test various combinations that previously triggered [0] fallback
        for max_vo, dim_M in [(1, 196), (1, 784), (1, 100), (1, 2)]:
            result = compute_v_outer_candidates(max_vo, dim_M)
            assert 0 not in result, (
                f"compute_v_outer_candidates({max_vo}, {dim_M}) = {result} "
                f"contains 0 (full dim fallback)"
            )


class TestCallerSkipsEmptyVOuterList:
    """strategy_dist_vector must skip tiers with empty v_outer lists."""

    def test_no_configs_with_zero_v_outer_in_l3(self):
        """No generated config should have v_outer=0 in L3 second_inner dim.

        Reproduces the real failing case: M=196, N=2048, K=512, i8 matmul
        where MF2 tier (v_inner=64) has max_vo=1, parity filter removes 1.
        """
        from dataset_generator.search_space import is_valid_vector_config

        # This is the config that caused CompileFail:
        # L3 = [0, 64, 0] means M vec tile = 0 = full dim (196)
        failing_config = [
            [196, 2048, 0],  # L0
            [196, 2048, 0],  # L1
            [0, 0, 0],       # L2
            [0, 64, 0],      # L3: v_outer=0 (full M=196), v_inner=64
            [0, 0, 1],       # L4
            [0, 0, 0],       # L5
        ]
        dim_sizes = [196, 2048, 512]

        # The validator should reject this config because the actual vector
        # size with index type is 196 * 64 * 8 = 100352 bytes > 65536.
        # But even if the validator passes (it uses i32=4 bytes, not index=8),
        # the config should never be generated in the first place.
        #
        # Check: the vector size in bytes using index type (8 bytes on 64-bit)
        # 196 * 64 * 8 = 100352 > 65536
        m_effective = 196  # v_outer=0 means full dim
        n_effective = 64
        index_bytes = 8
        vector_bytes = m_effective * n_effective * index_bytes
        assert vector_bytes > 65536, "This config exceeds IREE vector limit"
