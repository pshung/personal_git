// probe_v_csr.S - minimal QEMU1-only fixture for testing V-CSR drain.
//
// Sets vxrm=1, vxsat=1 (vcsr=3) then triggers the QEMU1 handoff drain.
// Used by tests/hybrid/probe_vcsr_drain.sh to verify the plugin captures
// the new fields. Not a round-trip fixture (no vsim / QEMU2 phase).
//
// Expected state after drain: vxsat=1, vxrm=1, vcsr=3.

.section .text
.globl _start
_start:
    // Enable V extension: mstatus.VS = Initial (bit 9 of mstatus)
    li      t0, (1 << 9)
    csrs    mstatus, t0

    // Set vxrm = 1 (round toward +inf), vxsat = 1
    csrwi   vxrm,  1
    csrwi   vxsat, 1

    // Trigger QEMU1 drain (plugin drains state and exits QEMU)
.globl _hybrid_enter_pc
_hybrid_enter_pc:
    csrwi   0x7C0, 0

    // Should not reach here; spin in case plugin doesn't exit
1:  j 1b
