#!/bin/bash
ELF=/home/nick/work/hybrid_sim/hybrid_vsim/hybrid/test/rt_c_v_regs.elf
VSIM_BIN=/home/nick/work/hybrid_sim/hybrid_vsim/build/sim_ax45mpv_premium
VSIM_QEMU=/home/nick/work/hybrid_sim/build/qemu/qemu-system-riscv64
PLUGIN=/home/nick/work/hybrid_sim/qemu_plugin/libhybrid_handoff.so
SHM=$(mktemp -p /dev/shm vsim-rt-shared.XXXXXX); truncate -s $((128*1024*1024)) "$SHM"
STATE=$(mktemp); STATE2=$(mktemp)
"$VSIM_QEMU" -object "memory-backend-file,id=mem,share=on,mem-path=$SHM,size=$((128*1024*1024))" \
  -machine virt,memory-backend=mem -cpu andes-ax45mpv,vlen=512 -bios none -nographic \
  -kernel "$ELF" -plugin "$PLUGIN,outfile=$STATE" 2>/dev/null
timeout 60 "$VSIM_BIN" "$ELF" --resume-from-qemu "$STATE" --handoff-out "$STATE2" --shared-mem-path "$SHM" --shared-mem-size $((128*1024*1024)) 2>&1 | tail -3
echo === STATE2 metadata ===
ls -la "$STATE2"
echo flags: $(xxd -s 8 -l 4 "$STATE2" | awk '{print $2}')
echo pc:    $(xxd -s 16 -l 8 "$STATE2" | awk '{print $2, $3, $4, $5}')
echo vlenb: $(xxd -s 1312 -l 8 "$STATE2" | awk '{print $2, $3, $4, $5}')
echo "=== v0[0..31] ==="
xxd -s 1320 -l 32 "$STATE2"
echo "=== v8[0..31] (off=1832) ==="
xxd -s 1832 -l 32 "$STATE2"
echo "=== v9[0..31] (off=1896) ==="
xxd -s 1896 -l 32 "$STATE2"
rm -f "$SHM" "$STATE" "$STATE2"
