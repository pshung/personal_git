// rt_all_gprs.S
//
// Tier-1 fixture: full sweep of x1..x31 across QEMU1 -> vsim -> QEMU2.
// Each register survives the round-trip with its 64-bit value intact.
//
// Phase A (QEMU1):
//   x5 = 0x80002000 (also serves as Phase C spill base).
//   x_i = 0xA000_0000_0000_0000 + i for i in {1..4, 6..31}.
// Phase B (vsim):  no-op.
// Phase C (QEMU2):
//   Spill x6, x28, x29 (sacrificed below).
//   Verify x_i directly for i in {1..4, 7..27, 30..31, then 5}.
//   Verify spilled x6, x28, x29 against expected.
//   Exit code = first mismatching reg num, or 0 on full pass.

#include "semihost_exit.inc"

.section .text
.globl _start
_start:
    li      x6, 0xA000000000000000   // temp base for ADDI sweep
    addi    x1,  x6, 1
    addi    x2,  x6, 2
    addi    x3,  x6, 3
    addi    x4,  x6, 4
    addi    x7,  x6, 7
    addi    x8,  x6, 8
    addi    x9,  x6, 9
    addi    x10, x6, 10
    addi    x11, x6, 11
    addi    x12, x6, 12
    addi    x13, x6, 13
    addi    x14, x6, 14
    addi    x15, x6, 15
    addi    x16, x6, 16
    addi    x17, x6, 17
    addi    x18, x6, 18
    addi    x19, x6, 19
    addi    x20, x6, 20
    addi    x21, x6, 21
    addi    x22, x6, 22
    addi    x23, x6, 23
    addi    x24, x6, 24
    addi    x25, x6, 25
    addi    x26, x6, 26
    addi    x27, x6, 27
    addi    x28, x6, 28
    addi    x29, x6, 29
    addi    x30, x6, 30
    addi    x31, x6, 31
    addi    x6,  x6, 6               // x6 = 0xA000_..._6
    li      x5, 0x80002000           // x5 = spill base (also its expected value)

.globl _hybrid_enter_pc
_hybrid_enter_pc:
    csrwi   0x7C0, 0                 // QEMU1 drains, exits

.globl _hybrid_exit_pc
_hybrid_exit_pc:
    csrwi   0x7C0, 1                 // vsim drains, exits 200

phase_c:
    // Spill x6, x28, x29 to 0x80002000, +8, +16 before corrupting them.
    sd      x6,  0(x5)
    sd      x28, 8(x5)
    sd      x29, 16(x5)

    li      x6,  0xA000000000000000  // verification base
    li      x29, 0                   // result reg (0 = pass)

    .macro CHECK_BASE n
        bnez    x29, 99f
        addi    x28, x6, \n
        beq     x\n, x28, 99f
        addi    x29, x0, \n
    99:
    .endm

    CHECK_BASE 1
    CHECK_BASE 2
    CHECK_BASE 3
    CHECK_BASE 4
    CHECK_BASE 7
    CHECK_BASE 8
    CHECK_BASE 9
    CHECK_BASE 10
    CHECK_BASE 11
    CHECK_BASE 12
    CHECK_BASE 13
    CHECK_BASE 14
    CHECK_BASE 15
    CHECK_BASE 16
    CHECK_BASE 17
    CHECK_BASE 18
    CHECK_BASE 19
    CHECK_BASE 20
    CHECK_BASE 21
    CHECK_BASE 22
    CHECK_BASE 23
    CHECK_BASE 24
    CHECK_BASE 25
    CHECK_BASE 26
    CHECK_BASE 27
    CHECK_BASE 30
    CHECK_BASE 31

    // Verify x5 directly (still holds 0x80002000).
    bnez    x29, check_spilled
    li      x28, 0x80002000
    beq     x5, x28, check_spilled
    addi    x29, x0, 5

check_spilled:
    // Verify spilled x6 (expected = 0xA000_..._6).
    bnez    x29, check_x28
    ld      x28, 0(x5)
    li      x6, 0xA000000000000000
    addi    x6, x6, 6
    beq     x28, x6, check_x28
    addi    x29, x0, 6

check_x28:
    // Verify spilled x28 (expected = 0xA000_..._28).
    bnez    x29, check_x29
    ld      x28, 8(x5)
    li      x6, 0xA000000000000000
    addi    x6, x6, 28
    beq     x28, x6, check_x29
    addi    x29, x0, 28

check_x29:
    // Verify spilled x29 (expected = 0xA000_..._29).
    // Note: x29 is the result reg; if non-zero, skip but keep prior fail.
    bnez    x29, exit_build
    ld      x28, 16(x5)
    li      x6, 0xA000000000000000
    addi    x6, x6, 29
    beq     x28, x6, exit_build
    addi    x29, x0, 29

exit_build:
    mv      a2, x29
    SEMIHOST_EXIT a2
