\")\n   176→        echo \"\"\n   177→        echo \"RESULT: PASS (${PASS_COUNT} sub-test(s) passed)\"\n   178→        exit 0\n   179→    elif echo \"${OUTPUT}\" | grep -q \"accuracy checking fail\"; then\n   180→        echo \"\"\n   181→        echo \"RESULT: FAIL\"\n   182→        exit 1\n   183→    else\n   184→        echo \"\"\n   185→        echo \"WARNING: No output from QEMU. Try --strace mode.\"\n   186→        exit 2\n   187→    fi\n   188→fi\n   189→"}]},"uuid":"2ec3ce01-0d7c-4e19-b18a-3d1a4e69cd5d","timestamp":"2026-03-20T22:54:19.357Z","toolUseResult":{"type":"text","file":{"filePath":"/home/nick/work/libnn/qemu-validate/run_qemu_test.sh","content":"#!/usr/bin/env bash\n################################################################################\n# QEMU Validation Runner for libnn\n#\n# Compiles a single unit test against the existing libnn.a and runs it on QEMU\n# to verify correctness against golden data.\n#\n# Prerequisites: Run build_libnn.sh first to produce libnn.a\n#\n# Usage:\n#   ./run_qemu_test.sh <test_name> [options]\n#\n# Examples:\n#   ./run_qemu_test.sh conv_HWC_s8_s8_s8_asym_bias_any\n#   ./run_qemu_test.sh conv_HWC_s8_s8_s8_asym_bias_any --vlen 1024\n#   ./run_qemu_test.sh conv_HWC_s8_s8_s8_asym_bias_any --strace\n#   ./run_qemu_test.sh conv_HWC_s8_s8_s8_asym_bias_any --perf\n#\n# Environment:\n#   TOOLCHAIN_PATH  - Path to Andes toolchain bin/ (default: /local/nick/SW_Release_cp/ast530/nds64le-elf-newlib-v5d/bin)\n#   QEMU_SYS_RV64  - Path to QEMU binary (default: /local/nick/qemu_andes/build/qemu-system-riscv64)\n################################################################################\nset -euo pipefail\n\n#===== Defaults =====\nTOOLCHAIN_PATH=\"${TOOLCHAIN_PATH:-/local/nick/SW_Release_cp/ast530/nds64le-elf-newlib-v5d/bin}\"\nQEMU_SYS_RV64=\"${QEMU_SYS_RV64:-/local/nick/qemu_andes/build/qemu-system-riscv64}\"\nVLEN=512\nUSE_STRACE=0\nPERF_ONLY=0\nTIMEOUT=120\nVEC_CFG=\"zve64d\"\n\n#===== Parse arguments =====\nTEST_NAME=\"${1:-}\"\nif [ -z \"${TEST_NAME}\" ]; then\n    echo \"Usage: $0 <test_name> [--vlen N] [--strace] [--perf] [--timeout N]\"\n    echo \"\"\n    echo \"  test_name     Unit test name (without t_ prefix)\"\n    echo \"  --vlen N      Vector length: 128, 256, 512 (default), 1024\"\n    echo \"  --strace      Use strace to capture output (needed in some environments)\"\n    echo \"  --perf        Performance mode: run only the large test case\"\n    echo \"  --timeout N   QEMU timeout in seconds (default: 120)\"\n    exit 1\nfi\nshift\n\nwhile [[ $# -gt 0 ]]; do\n    case \"$1\" in\n        --vlen)    VLEN=\"$2\"; shift 2 ;;\n        --strace)  USE_STRACE=1; shift ;;\n        --perf)    PERF_ONLY=1; shift ;;\n        --timeout) TIMEOUT=\"$2\"; shift 2 ;;\n        *) echo \"Unknown option: $1\"; exit 1 ;;\n    esac\ndone\n\n#===== Resolve paths =====\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nLIB_ROOT=\"$(cd \"${SCRIPT_DIR}/..\" && pwd)\"\nPROJECT_DIR=\"${LIB_ROOT}/project/ax45mpv\"\nUNIT_TEST_DIR=\"${LIB_ROOT}/Examples/unit_func\"\nWORK_DIR=\"${SCRIPT_DIR}/work\"\n\nexport PATH=\"${TOOLCHAIN_PATH}:${LIB_ROOT}:${PATH}\"\nCC=\"riscv64-elf-gcc\"\n\n# Check libnn.a exists\nif [ ! -f \"${LIB_ROOT}/libnn.a\" ]; then\n    echo \"ERROR: libnn.a not found. Run build_libnn.sh first.\"\n    exit 1\nfi\n\n# Select QEMU wrapper based on VLEN\nQEMU_WRAPPER=\"${PROJECT_DIR}/riscv-qemu-wrapper-v${VLEN}_d${VLEN}_b512\"\nif [ ! -f \"${QEMU_WRAPPER}\" ]; then\n    QEMU_WRAPPER=\"${PROJECT_DIR}/riscv-qemu-wrapper-v${VLEN}_d$((VLEN/2))_b512\"\nfi\nif [ ! -f \"${QEMU_WRAPPER}\" ]; then\n    echo \"Error: No QEMU wrapper found for VLEN=${VLEN}\"\n    ls \"${PROJECT_DIR}\"/riscv-qemu-wrapper-* 2>/dev/null\n    exit 1\nfi\n\necho \"============================================\"\necho \"  QEMU Validation: t_${TEST_NAME}\"\necho \"============================================\"\necho \"  VLEN:    ${VLEN}\"\necho \"  Perf:    ${PERF_ONLY}\"\necho \"  Strace:  ${USE_STRACE}\"\necho \"  Wrapper: $(basename ${QEMU_WRAPPER})\"\necho \"============================================\"\n\n#===== Step 1: Compile test binary =====\necho \"\"\necho \"[1/2] Compiling test binary...\"\nmkdir -p \"${WORK_DIR}\"\n\nTEST_SRC=\"${UNIT_TEST_DIR}/t_${TEST_NAME}.c\"\nTEST_ADX=\"${WORK_DIR}/t_${TEST_NAME}_qemu.adx\"\n\nif [ ! -f \"${TEST_SRC}\" ]; then\n    echo \"  ERROR: Test source not found: ${TEST_SRC}\"\n    exit 1\nfi\n\n${CC} -mvh \\\n    -Wall -Werror -O3 \\\n    -mtune=andes-45-series -mext-vector=${VEC_CFG} -DNDS_VEC_RVV_VERSION=1000 \\\n    -ffunction-sections -fdata-sections -DPF_COUNTER \\\n    -Wl,-gc-sections -DENA_FS_VS -mzfh \\\n    -DFAST_VERSION -DFUNCTION_PF_ANALYZE \\\n    -DENA_DUMP_GOLDEN=0 -DENA_MEASURE_PERF=${PERF_ONLY} -DENA_RANDOM_INPUT=0 \\\n    -DENA_FAST_ALGO -DENA_CACHEABLE_ENV_SETUP -DENA_VL4 \\\n    -I\"${LIB_ROOT}/Include/\" \\\n    -I\"${LIB_ROOT}/libhvm-project/libhvm/include/\" \\\n    -I\"${UNIT_TEST_DIR}/include/\" \\\n    -o \"${TEST_ADX}\" \\\n    \"${TEST_SRC}\" \\\n    \"${LIB_ROOT}/libnn.a\" -lm 2>&1\n\nif [ $? -ne 0 ]; then\n    echo \"  FAILED: Compilation error\"\n    exit 1\nfi\necho \"  OK: $(basename ${TEST_ADX})\"\n\n#===== Step 2: Run on QEMU =====\necho \"\"\necho \"[2/2] Running on QEMU (timeout=${TIMEOUT}s)...\"\n\nexport QEMU_SYS_RV64\nexport VEC_CFG\n\ncd \"${UNIT_TEST_DIR}\"\n\nif [ ${USE_STRACE} -eq 1 ]; then\n    # Strace mode: captures semihosting output written to non-stdout fd.\n    # Needed when QEMU's chardev fd isn't connected to the terminal (e.g. in\n    # sandboxed environments like Claude Code).\n    STRACE_LOG=\"${WORK_DIR}/qemu_strace_${TEST_NAME}.txt\"\n    strace -f -e trace=write -o \"${STRACE_LOG}\" \\\n        timeout ${TIMEOUT} \"${QEMU_WRAPPER}\" \"${TEST_ADX}\" 2>&1 || true\n\n    # Extract semihosting output (writes to high fd numbers, skip internal eventfd on fd 8)\n    echo \"\"\n    echo \"--- QEMU Output (via strace) ---\"\n    grep 'write([0-9]' \"${STRACE_LOG}\" | grep -v 'write(8,' | \\\n        sed -n 's/.*write([0-9]*, \"\\(.*\\)\", [0-9]*).*/\\1/p' | \\\n        while IFS= read -r line; do\n            echo -e \"${line}\"\n        done\n    echo \"--- End ---\"\n\n    if grep -q '\"accuracy checking pass' \"${STRACE_LOG}\"; then\n        PASS_COUNT=$(grep -c '\"accuracy checking pass' \"${STRACE_LOG}\")\n        echo \"\"\n        echo \"RESULT: PASS (${PASS_COUNT} sub-test(s) passed)\"\n        exit 0\n    elif grep -q '\"accuracy checking fail' \"${STRACE_LOG}\"; then\n        echo \"\"\n        echo \"RESULT: FAIL\"\n        exit 1\n    else\n        echo \"\"\n        echo \"RESULT: UNKNOWN (no pass/fail found)\"\n        exit 2\n    fi\nelse\n    # Direct mode: works when the terminal properly connects QEMU chardev to stdout\n    OUTPUT=$(timeout ${TIMEOUT} \"${QEMU_WRAPPER}\" \"${TEST_ADX}\" 2>&1) || true\n    echo \"${OUTPUT}\"\n\n    if echo \"${OUTPUT}\" | grep -q \"accuracy checking pass\"; then\n        PASS_COUNT=$(echo \"${OUTPUT}\" | grep -c \"accuracy checking pass\")\n        echo \"\"\n        echo \"RESULT: PASS (${PASS_COUNT} sub-test(s) passed)\"\n        exit 0\n    elif echo \"${OUTPUT}\" | grep -q \"accuracy checking fail\"; then\n        echo \"\"\n        echo \"RESULT: FAIL\"\n        exit 1\n    else\n        echo \"\"\n        echo \"WARNING: No output from QEMU. Try --strace mode.\"\n        exit 2\n    fi\nfi\n","numLines":189,"startLine":1,"totalLines":189}},"sourceToolAssistantUUID":"7b5f98c8-19bb-4968-9330-50943f47c360"}
