y = cur_out_y * stride_y - pad_y; cur_ker_y < cur_out_y * stride_y - pad_y + ker_dim_y; cur_ker_y++)\n                {\n                    for (long cur_ker_x = cur_out_x * stride_x - pad_x; cur_ker_x < cur_out_x * stride_x - pad_x + ker_dim_x; cur_ker_x++)\n                    {\n                        if (cur_ker_y < 0 || cur_ker_y >= in_tensor_dim_y || cur_ker_x < 0 || cur_ker_x >= in_tensor_dim_x)\n                        {\n                            nn_set_val_s8(two_column_buf2, -in_offset, in_tensor_ch);\n                        }\n                        else\n                        {\n                            nn_dup_s8(in_tensor + (cur_ker_y * in_tensor_dim_x + cur_ker_x) * in_tensor_ch, two_column_buf2, in_tensor_ch);\n                        }\n                        two_column_buf2 += in_tensor_ch;\n                    }\n                }\n\n                /* Computation is filed for every 2 columns */\n                if (two_column_buf2 == (int8_t *)two_column_buf + 2 * in_tensor_ch * ker_dim_y * ker_dim_x)\n                {\n                    out = nn_mat_mult_kernel_s8_offset_v2(ker_weight,\n                                                          two_column_buf,\n                                                          out_tensor_ch,\n                                                          out_shift,\n                                                          out_scale,\n                                                          in_offset,\n                                                          out_offset,\n                                                          act_min,\n                                                          act_max,\n                                                          rhs_cols,\n                                                          contri_buf,\n                                                          out);\n\n                    /* counter reset */\n                    two_column_buf2 = (int8_t *)two_column_buf;\n                }\n            }\n        }\n\n        /* left-over because odd number of output pixels */\n        if (two_column_buf2 != (int8_t *)two_column_buf)\n        {\n            uint32_t vl;\n            const int8_t *pWt = ker_weight;\n            const int32_t *pOut_scale = out_scale;\n            const int32_t *pOut_shift = out_shift;\n            int32_t *pContri_buf = contri_buf;\n\n            NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n            NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0);   // const zero for redsum\n\n            for (long i = 0; i < out_tensor_ch; i++)\n            {\n                uint32_t rhs_cols2 = rhs_cols;\n                const int8_t *pIn = (int8_t *)two_column_buf;\n\n                // init the accumulators\n                NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VAND_VI(NDS_VEC_V0, NDS_VEC_V0, 0x0);\n\n                while (rhs_cols2 >= maxvl_per_loop)\n                {\n                    NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                    NDS_VEC_VLE8_V(NDS_VEC_V8, pIn);\n                    NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                    rhs_cols2 -= vl;\n                    pIn += vl;\n                    pWt += vl;\n\n                    NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                    NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V8, NDS_VEC_V16);\n                }\n\n                // rest loop\n                if (rhs_cols2 > 0)\n                {\n                    //clean one of the dot product source\n                    long tmp_avl;\n                    tmp_avl = rhs_cols2 + 3;\n                    NDS_VEC_VSETVLI(vl, tmp_avl, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                    NDS_VEC_VAND_VI(NDS_VEC_V8, NDS_VEC_V8, 0);\n\n                    NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                    NDS_VEC_VLE8_V(NDS_VEC_V8, pIn);\n                    NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                    rhs_cols2 -= vl;\n                    pIn += vl;\n                    pWt += vl;\n\n                    vl = (vl + 3) >> 2;\n                    NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                    NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V8, NDS_VEC_V16);\n                }\n\n                NDS_VEC_VSETVLI(vl, rhs_cols, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);   //note the avl here\n                NDS_VEC_VREDSUM_VS(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V31);\n\n                NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n                //add extra contribution back\n                NDS_VEC_VLE32_V(NDS_VEC_V4, pContri_buf);\n                NDS_VEC_VADD_VV(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V4);\n\n                //===== Quantize down =====\n                NDS_VEC_VLE32_V(NDS_VEC_V2, pOut_shift);\n                NDS_VEC_VLE32_V(NDS_VEC_V3, pOut_scale);\n                NDS_VEC_VRSUB_VX(NDS_VEC_V2, NDS_VEC_V2, 30);\n\n                NDS_VEC_VWMUL_VV(NDS_VEC_V4, NDS_VEC_V0, NDS_VEC_V3);\n                NDS_VEC_VNSRA_WV(NDS_VEC_V4, NDS_VEC_V4, NDS_VEC_V2);\n                NDS_VEC_VSSRA_VI(NDS_VEC_V4, NDS_VEC_V4, 1);\n\n                // Add offset\n                NDS_VEC_VADD_VX(NDS_VEC_V4, NDS_VEC_V4, out_offset);\n\n                // Clamp the result\n                NDS_VEC_VMAX_VX(NDS_VEC_V4, NDS_VEC_V4, act_min);\n                NDS_VEC_VMIN_VX(NDS_VEC_V4, NDS_VEC_V4, act_max);\n\n                //narrowing and store the results\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E16, NDS_VEC_VTYPE_LMUL_M1);\n                NDS_VEC_VNSRA_VI(NDS_VEC_V4, NDS_VEC_V4, 0);\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M1);\n                NDS_VEC_VNSRA_VI(NDS_VEC_V4, NDS_VEC_V4, 0);\n                NDS_VEC_VSE8_V(NDS_VEC_V4, out);\n                out += vl;\n                pOut_scale += vl;\n                pOut_shift += vl;\n                pContri_buf += vl;\n            }\n        }\n\n        in_tensor += (in_tensor_dim_x * in_tensor_dim_y * in_tensor_ch);\n        out_tensor += (out_tensor_dim_x * out_tensor_dim_y * out_tensor_ch);\n    }\n#elif defined(ENA_VEC_ISA) && (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_VEC_ELEN64)\n    int i_batch;\n    for (i_batch = 0; i_batch < in_tensor_batch; i_batch++)\n    {\n        int32_t i_out_y, i_out_x, i_ker_y, i_ker_x;\n\n        /* Generate two columns from the input tensor a GEMM computation */\n        int8_t *two_column_buf = (int8_t *)in_tmp_buf;\n        int8_t *out = out_tensor;\n        long vl;\n\n        /* This part implements the im2col function */\n        for (i_out_y = 0; i_out_y < out_tensor_dim_y; i_out_y++)\n        {\n            for (i_out_x = 0; i_out_x < out_tensor_dim_x; i_out_x++)\n            {\n                for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y; i_ker_y++)\n                {\n                    for (i_ker_x = i_out_x * stride_x - pad_x; i_ker_x < i_out_x * stride_x - pad_x + ker_dim_x; i_ker_x++)\n                    {\n                        if (i_ker_y < 0 || i_ker_y >= in_tensor_dim_y || i_ker_x < 0 || i_ker_x >= in_tensor_dim_x)\n                        {\n                            nn_set_val_s8(two_column_buf, -in_offset, in_tensor_ch);\n                        }\n                        else\n                        {\n                            nn_dup_s8(in_tensor + (i_ker_y * in_tensor_dim_x + i_ker_x) * in_tensor_ch, two_column_buf, in_tensor_ch);\n                        }\n                        two_column_buf += in_tensor_ch;\n                    }\n                }\n\n                /* Computation is filed for every 2 columns */\n                if (two_column_buf == (int8_t *)in_tmp_buf + 2 * in_tensor_ch * ker_dim_y * ker_dim_x)\n                {\n                    out = nn_mat_mult_kernel_s8_offset(ker_weight,\n                                                       (int8_t *)in_tmp_buf,\n                                                       out_tensor_ch,\n                                                       out_shift,\n                                                       out_scale,\n                                                       in_offset,\n                                                       out_offset,\n                                                       act_min,\n                                                       act_max,\n                                                       in_tensor_ch * ker_dim_y * ker_dim_x,\n                                                       bias,\n                                                       out);\n\n                    /* counter reset */\n                    two_column_buf = (int8_t *)in_tmp_buf;\n                }\n            }\n        }\n\n        /* left-over because odd number of output pixels */\n        if (two_column_buf != (int8_t *)in_tmp_buf)\n        {\n            const int8_t *ptr_wt = ker_weight;\n            int i;\n            uint32_t col_count = (in_tensor_ch * ker_dim_y * ker_dim_x);\n            const long in_offset2 = -in_offset;\n\n            NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n            NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0);   //const zero for redsum\n            NDS_VEC_VSETVLI(vl, col_count, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n\n            for (i = 0; i < out_tensor_ch; i++)\n            {\n                int32_t sum = 0;\n\n                /* Point to the beginning of the im2col buffer where the input is available as a rearranged column */\n                const int8_t *ptr_in = (int8_t *)in_tmp_buf;\n                uint32_t col_count2 = col_count;\n\n                //clear v0~v7\n                NDS_VEC_VAND_VI(NDS_VEC_V0, NDS_VEC_V0, 0x0);\n\n                while (col_count2)\n                {\n                    NDS_VEC_VSETVLI(vl, col_count2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M2);\n                    NDS_VEC_VLB_V(NDS_VEC_V8, ptr_wt);\n                    NDS_VEC_VLB_V(NDS_VEC_V10, ptr_in);\n                    NDS_VEC_VWSUB_VX(NDS_VEC_V12, NDS_VEC_V10, in_offset2);\n                    NDS_VEC_VSETVLI(vl, col_count2, NDS_VEC_VTYPE_SEW_E16, NDS_VEC_VTYPE_LMUL_M4);\n                    NDS_VEC_VSEXT_VF2(NDS_VEC_V16, NDS_VEC_V8);\n                    NDS_VEC_VWMACC_VV(NDS_VEC_V0, NDS_VEC_V16, NDS_VEC_V12);\n                    col_count2 -= vl;\n                    ptr_wt += vl;\n                    ptr_in += vl;\n                }\n\n                NDS_VEC_VSETVLI(vl, col_count, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);   //note the avl here\n                NDS_VEC_VREDSUM_VS(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V31);\n                //move vr results to gpr\n                NDS_VEC_VMV_X_S(sum, NDS_VEC_V0);\n\n                //add bias back\n                if (bias)\n                {\n                    sum += bias[i];\n                }\n\n                sum = nn_requantize(sum, out_scale[i], out_shift[i]);\n                sum += out_offset;\n                sum = MAX(sum, act_min);\n                sum = MIN(sum, act_max);\n                *out++ = (int8_t)sum;\n            }\n        }\n\n        in_tensor += (in_tensor_dim_x * in_tensor_dim_y * in_tensor_ch);\n        out_tensor += (out_tensor_dim_x * out_tensor_dim_y * out_tensor_ch);\n    }\n#elif defined(ENA_VEC_ISA) && (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_VEC_ISA_ZVQMAC) && defined(ENA_VEC_ELEN64)\n    int i_batch;\n    for (i_batch = 0; i_batch < in_tensor_batch; i_batch++)\n    {\n        int32_t i_out_y, i_out_x, i_ker_y, i_ker_x;\n\n        /* Generate two columns from the input tensor a GEMM computation */\n        int8_t *two_column_buf = (int8_t *)in_tmp_buf;\n        int8_t *out = out_tensor;\n        long vl;\n\n        /* This part implements the im2col function */\n        for (i_out_y = 0; i_out_y < out_tensor_dim_y; i_out_y++)\n        {\n            for (i_out_x = 0; i_out_x < out_tensor_dim_x; i_out_x++)\n            {\n                for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y; i_ker_y++)\n                {\n                    for (i_ker_x = i_out_x * stride_x - pad_x; i_ker_x < i_out_x * stride_x - pad_x + ker_dim_x; i_ker_x++)\n                    {\n                        if (i_ker_y < 0 || i_ker_y >= in_tensor_dim_y || i_ker_x < 0 || i_ker_x >= in_tensor_dim_x)\n                        {\n                            nn_set_val_s8(two_column_buf, -in_offset, in_tensor_ch);\n                        }\n                        else\n                        {\n                            nn_dup_s8(in_tensor + (i_ker_y * in_tensor_dim_x + i_ker_x) * in_tensor_ch, two_column_buf, in_tensor_ch);\n                        }\n                        two_column_buf += in_tensor_ch;\n                    }\n                }\n\n                /* Computation is filed for every 2 columns */\n                if (two_column_buf == (int8_t *)in_tmp_buf + 2 * in_tensor_ch * ker_dim_y * ker_dim_x)\n                {\n                    out = nn_mat_mult_kernel_s8_offset(ker_weight,\n                                                       (int8_t *)in_tmp_buf,\n                                                       out_tensor_ch,\n                                                       out_shift,\n                                                       out_scale,\n                                                       in_offset,\n                                                       out_offset,\n                                                       act_min,\n                                                       act_max,\n                                                       in_tensor_ch * ker_dim_y * ker_dim_x,\n                                                       bias,\n                                                       out);\n\n                    /* counter reset */\n                    two_column_buf = (int8_t *)in_tmp_buf;\n                }\n            }\n        }\n\n        /* left-over because odd number of output pixels */\n        if (two_column_buf != (int8_t *)in_tmp_buf)\n        {\n            const int8_t *ker_a = ker_weight;\n            int i;\n            uint32_t col_count = (in_tensor_ch * ker_dim_y * ker_dim_x);\n\n            //set SEW for 1st time VMV_S_X\n            //LMUL=2 is just for clear v2~v3 (vmv ignores LMUL)\n            NDS_VEC_VSETVLI_E32_M4(vl, col_count);\n\n            for (i = 0; i < out_tensor_ch; i++)\n            {\n                /* Load the accumulator with bias first */\n                int32_t sum = 0;\n                if (bias)\n                {\n                    sum = bias[i];\n                }\n\n                /* Point to the beginning of the im2col buffer where the input is available as a rearranged column */\n                const int8_t *ip_as_col = (int8_t *)in_tmp_buf;\n                uint32_t col_count2 = col_count;\n                int32_t sum_ker_a = 0;\n\n                //init\n                NDS_VEC_VMV_S_X(NDS_VEC_V0, sum);\n                NDS_VEC_VMV_S_X(NDS_VEC_V3, sum_ker_a);\n                //clear v2~v3\n                NDS_VEC_VAND_VI(NDS_VEC_V4, NDS_VEC_V4, 0x0);\n                NDS_VEC_VAND_VI(NDS_VEC_V12, NDS_VEC_V12, 0x0);\n\n                while (col_count2)\n                {\n                    NDS_VEC_VSETVLI_E8(vl, col_count2);\n                    NDS_VEC_VLB_V(NDS_VEC_V1, ker_a);\n                    NDS_VEC_VLB_V(NDS_VEC_V2, ip_as_col);\n                    NDS_VEC_VQMACC_VV(NDS_VEC_V4, NDS_VEC_V1, NDS_VEC_V2);\n\n                    NDS_VEC_VQMACC_VX(NDS_VEC_V12, 0x1, NDS_VEC_V1);\n\n                    col_count2 -= vl;\n                    ker_a += vl;\n                    ip_as_col += vl;\n                }\n\n                NDS_VEC_VSETVLI_E32_M4(vl, col_count);     //note the avl here\n                NDS_VEC_VREDSUM_VS(NDS_VEC_V0, NDS_VEC_V4, NDS_VEC_V0);\n                NDS_VEC_VREDSUM_VS(NDS_VEC_V3, NDS_VEC_V12, NDS_VEC_V3);\n                //move vr results to gpr\n                NDS_VEC_VMV_X_S(sum, NDS_VEC_V0);\n                NDS_VEC_VMV_X_S(sum_ker_a, NDS_VEC_V3);\n\n                //add offset back\n                sum += in_offset * sum_ker_a;\n\n                sum = nn_requantize(sum, out_scale[i], out_shift[i]);\n                sum += out_offset;\n                sum = MAX(sum, act_min);\n                sum = MIN(sum, act_max);\n                *out++ = (int8_t)sum;\n            }\n        }\n\n        in_tensor += (in_tensor_dim_x * in_tensor_dim_y * in_tensor_ch);\n        out_tensor += (out_tensor_dim_x * out_tensor_dim_y * out_tensor_ch);\n    }\n#elif defined(ENA_DSP_ISA_64)\n    const uint32_t rhs_cols = ker_dim_y * ker_dim_x * in_tensor_ch;\n\n    //--- calculate the buffer address ---\n    const long align_byte = sizeof(long);\n    // buffer-1\n    int8_t *two_column_buf = (int8_t*)in_tmp_buf;\n    two_column_buf = (int8_t*)nn_align((unsigned long)two_column_buf, align_byte);  // align the starting addresss\n    // buffer-2\n    long two_column_buf_size = 2 * in_tensor_ch * ker_dim_x * ker_dim_y * sizeof(*in_tensor);\n    int32_t *contri_buf = (int32_t*)(two_column_buf + two_column_buf_size);\n    contri_buf = (int32_t*)nn_align((unsigned long)contri_buf, align_byte);         // align the starting addresss\n\n    // calculate the weight contribution\n    const int8_t *pWt = ker_weight;\n    const long cst_one = 0x0101010101010101;\n\n    for (long cur_out_ch = 0; cur_out_ch < out_tensor_ch; cur_out_ch++)\n    {\n        long sum = 0;\n        long rhs_cols2 = rhs_cols;\n\n        while (rhs_cols2 >= SIMD_NUM_Q7)\n        {\n            suni_t wt_s8 = simd_load_8((s8_t*