YPC:-sw-boards.andestech.com}\"\nexport MYPORT=\"${MYPORT:-1116}\"\nPERF_ONLY=0\nTAG=\"\"\n\n#===== Parse arguments =====\nTEST_NAME=\"${1:-}\"\nif [ -z \"${TEST_NAME}\" ]; then\n    echo \"Usage: $0 <test_name> [--port N] [--host H] [--perf] [--tag NAME]\"\n    echo \"\"\n    echo \"  test_name     Unit test name (without t_ prefix)\"\n    echo \"  --port N      FPGA board port (default: 1116)\"\n    echo \"  --host H      FPGA board host (default: sw-boards.andestech.com)\"\n    echo \"  --perf        Performance mode: ENA_MEASURE_PERF=1, large test case only\"\n    echo \"  --tag NAME    Tag for log file naming (e.g. 'baseline', 'optimized')\"\n    exit 1\nfi\nshift\n\nwhile [[ $# -gt 0 ]]; do\n    case \"$1\" in\n        --port) export MYPORT=\"$2\"; shift 2 ;;\n        --host) export MYPC=\"$2\"; shift 2 ;;\n        --perf) PERF_ONLY=1; shift ;;\n        --tag)  TAG=\"$2\"; shift 2 ;;\n        *) echo \"Unknown option: $1\"; exit 1 ;;\n    esac\ndone\n\n#===== Resolve paths =====\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nLIB_ROOT=\"$(cd \"${SCRIPT_DIR}/..\" && pwd)\"\nPROJECT_DIR=\"${LIB_ROOT}/project/ax45mpv\"\nUNIT_TEST_DIR=\"${LIB_ROOT}/Examples/unit_func\"\nWORK_DIR=\"${SCRIPT_DIR}/work\"\nBOARD_WRAPPER=\"${PROJECT_DIR}/riscv64-sim-wrapper-on-board\"\n\nexport PATH=\"${TOOLCHAIN_PATH}:${LIB_ROOT}:${PATH}\"\nCC=\"riscv64-elf-gcc\"\n\n# Check libnn.a exists\nif [ ! -f \"${LIB_ROOT}/libnn.a\" ]; then\n    echo \"ERROR: libnn.a not found. Run build_libnn.sh first.\"\n    exit 1\nfi\n\n# Build output filename\nif [ -n \"${TAG}\" ]; then\n    ADX_NAME=\"t_${TEST_NAME}_${TAG}.adx\"\n    LOG_NAME=\"${TEST_NAME}_${TAG}.log\"\nelse\n    ADX_NAME=\"t_${TEST_NAME}_fpga.adx\"\n    LOG_NAME=\"${TEST_NAME}.log\"\nfi\n\necho \"============================================\"\necho \"  FPGA Benchmark: t_${TEST_NAME}\"\necho \"============================================\"\necho \"  Board:  ${MYPC}:${MYPORT}\"\necho \"  Perf:   ${PERF_ONLY}\"\necho \"  Tag:    ${TAG:-<none>}\"\necho \"============================================\"\n\n#===== Step 1: Compile test binary =====\necho \"\"\necho \"[1/2] Compiling test binary...\"\nmkdir -p \"${WORK_DIR}\"\n\nTEST_SRC=\"${UNIT_TEST_DIR}/t_${TEST_NAME}.c\"\nTEST_ADX=\"${WORK_DIR}/${ADX_NAME}\"\n\nif [ ! -f \"${TEST_SRC}\" ]; then\n    echo \"  ERROR: Test source not found: ${TEST_SRC}\"\n    exit 1\nfi\n\n# Key FPGA flags:\n#   -mvh                   : semihosting — GDB handles file I/O on host side\n#   -DGETENV_TESTDIR=...   : absolute path so binary finds bin/*.bin golden data\n#   -DENA_RUN_TWICE        : run function twice, measure warm-cache second run\n${CC} -mvh \\\n    -Wall -Werror -O3 \\\n    -mtune=andes-45-series -mext-vector -DNDS_VEC_RVV_VERSION=1000 \\\n    -ffunction-sections -fdata-sections -DPF_COUNTER \\\n    -Wl,-gc-sections -DENA_FS_VS -mzfh \\\n    -DFAST_VERSION -DFUNCTION_PF_ANALYZE \\\n    -DENA_DUMP_GOLDEN=0 \\\n    -DENA_MEASURE_PERF=${PERF_ONLY} \\\n    -DENA_RANDOM_INPUT=0 \\\n    -DENA_FAST_ALGO -DENA_CACHEABLE_ENV_SETUP \\\n    -DENA_RUN_TWICE -DENA_VL4 \\\n    -DGETENV_TESTDIR=\"${UNIT_TEST_DIR}\" \\\n    -I\"${LIB_ROOT}/Include/\" \\\n    -I\"${LIB_ROOT}/libhvm-project/libhvm/include/\" \\\n    -I\"${UNIT_TEST_DIR}/include/\" \\\n    -o \"${TEST_ADX}\" \\\n    \"${TEST_SRC}\" \\\n    \"${LIB_ROOT}/libnn.a\" -lm 2>&1\n\nif [ $? -ne 0 ]; then\n    echo \"  FAILED: Compilation error\"\n    exit 1\nfi\necho \"  OK: ${ADX_NAME}\"\n\n#===== Step 2: Run on FPGA board =====\necho \"\"\necho \"[2/2] Running on FPGA board ${MYPC}:${MYPORT}...\"\n\n# Clear first-reset flag so GDB script initializes the board properly\nrm -f \"${PROJECT_DIR}/First_Reset_done\"\n\ncd \"${WORK_DIR}\"\nOUTPUT=$(\"${BOARD_WRAPPER}\" \"${TEST_ADX}\" 2>&1)\nEXIT_CODE=$?\n\n# Parse and display results\necho \"\"\necho \"--- Board Output ---\"\necho \"${OUTPUT}\" | grep -E \"inst count|cycle count|accuracy checking|Error\" || true\necho \"--- End ---\"\n\n# Extract final cycle/inst counts (last occurrence = warm-cache second run)\nINST=$(echo \"${OUTPUT}\" | grep \"inst count\" | tail -1 | grep -oE '[0-9]+' | tail -1)\nCYCLES=$(echo \"${OUTPUT}\" | grep \"cycle count\" | tail -1 | grep -oE '[0-9]+' | tail -1)\n\n# Save result to log\nLOG_FILE=\"${WORK_DIR}/${LOG_NAME}\"\n{\n    echo \"test:   ${TEST_NAME}\"\n    echo \"tag:    ${TAG:-none}\"\n    echo \"date:   $(date -Iseconds)\"\n    echo \"board:  ${MYPC}:${MYPORT}\"\n    echo \"inst:   ${INST:-N/A}\"\n    echo \"cycles: ${CYCLES:-N/A}\"\n    if echo \"${OUTPUT}\" | grep -q \"accuracy checking pass\"; then\n        echo \"result: PASS\"\n    elif echo \"${OUTPUT}\" | grep -q \"accuracy checking fail\"; then\n        echo \"result: FAIL\"\n    else\n        echo \"result: UNKNOWN\"\n    fi\n} > \"${LOG_FILE}\"\n\necho \"\"\ncat \"${LOG_FILE}\"\necho \"\"\necho \"Log saved to: ${LOG_FILE}\"\n\n# Final status\nif echo \"${OUTPUT}\" | grep -q \"accuracy checking pass\"; then\n    echo \"\"\n    echo \"RESULT: PASS  inst=${INST}  cycles=${CYCLES}\"\n    exit 0\nelif echo \"${OUTPUT}\" | grep -q \"accuracy checking fail\"; then\n    echo \"\"\n    echo \"RESULT: FAIL  inst=${INST}  cycles=${CYCLES}\"\n    exit 1\nelse\n    echo \"\"\n    echo \"RESULT: ERROR (board connection or execution failure)\"\n    echo \"${OUTPUT}\" | tail -10\n    exit 2\nfi\n","structuredPatch":[{"oldStart":106,"oldLines":7,"newStart":106,"newLines":7,"lines":[" #   -DENA_RUN_TWICE        : run function twice, measure warm-cache second run"," ${CC} -mvh \\","     -Wall -Werror -O3 \\","-    -mtune=andes-45-series -mext-vector -DNDS_VEC_RVV_VERSION=1000 \\","+    -mtune=andes-45-series -mext-vector=zve64d -DNDS_VEC_RVV_VERSION=1000 \\","     -ffunction-sections -fdata-sections -DPF_COUNTER \\","     -Wl,-gc-sections -DENA_FS_VS -mzfh \\","     -DFAST_VERSION -DFUNCTION_PF_ANALYZE \\"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"817fa0b3-eec1-4873-b12e-7c8c47481dbc"}
