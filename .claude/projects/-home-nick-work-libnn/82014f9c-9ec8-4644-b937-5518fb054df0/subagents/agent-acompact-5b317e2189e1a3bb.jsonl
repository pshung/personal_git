  const int32_t out_offset,    //value is in the range of [-128, 127]\n                                                 const int32_t in_offset,     //value is in the range of [-127, 128]\n                                                 const int32_t act_min,\n                                                 const int32_t act_max,\n                                                 const uint16_t out_tensor_dim_x,\n                                                 const uint16_t out_tensor_dim_y,\n                                                 int16_t * in_tmp_buf)\n{\n#ifdef ENA_EMPTY_FUN\n    //empty body\n#elif defined(ENA_VEC_ISA) && (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_NDS_V5_VEC_DOT_PROD) && defined(ENA_VEC_ELEN64) && defined(ENA_VEC_INTRINSIC)\n    int i_batch;\n    for (i_batch = 0; i_batch < in_tensor_batch; i_batch++)\n    {\n        int32_t i_out_y, i_out_x, i_ker_y, i_ker_x;\n\n        /* Generate two columns from the input tensor a GEMM computation */\n        int8_t *two_column_buf = (int8_t *)in_tmp_buf;\n        int8_t *out = out_tensor;\n        long vl;\n\n        /* This part implements the im2col function */\n        for (i_out_y = 0; i_out_y < out_tensor_dim_y; i_out_y++)\n        {\n            for (i_out_x = 0; i_out_x < out_tensor_dim_x; i_out_x++)\n            {\n                for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y; i_ker_y++)\n                {\n                    for (i_ker_x = i_out_x * stride_x - pad_x; i_ker_x < i_out_x * stride_x - pad_x + ker_dim_x; i_ker_x++)\n                    {\n                        if (i_ker_y < 0 || i_ker_y >= in_tensor_dim_y || i_ker_x < 0 || i_ker_x >= in_tensor_dim_x)\n                        {\n                            nn_set_val_s8(two_column_buf, -in_offset, in_tensor_ch);\n                        }\n                        else\n                        {\n                            nn_dup_s8(in_tensor + (i_ker_y * in_tensor_dim_x + i_ker_x) * in_tensor_ch, two_column_buf, in_tensor_ch);\n                        }\n                        two_column_buf += in_tensor_ch;\n                    }\n                }\n\n                /* Computation is filed for every 2 columns */\n                if (two_column_buf == (int8_t *)in_tmp_buf + 2 * in_tensor_ch * ker_dim_y * ker_dim_x)\n                {\n                    out = nn_mat_mult_kernel_s8_offset(ker_weight,\n                                                       (int8_t *)in_tmp_buf,\n                                                       out_tensor_ch,\n                                                       out_shift,\n                                                       out_scale,\n                                                       in_offset,\n                                                       out_offset,\n                                                       act_min,\n                                                       act_max,\n                                                       in_tensor_ch * ker_dim_y * ker_dim_x,\n                                                       bias,\n                                                       out);\n\n                    /* counter reset */\n                    two_column_buf = (int8_t *)in_tmp_buf;\n                }\n            }\n        }\n\n        /* left-over because odd number of output pixels */\n        if (two_column_buf != (int8_t *)in_tmp_buf)\n        {\n            const int8_t *ker_a = ker_weight;\n            int i;\n            long col_count = (in_tensor_ch * ker_dim_y * ker_dim_x);\n            long vlenb = NDS_VEC_CSR_GET_VLENB();\n\n            vl = __riscv_vsetvl_e8m4(col_count);\n            vint8m4_t vOne = __riscv_vmv_v_x_i8m4(1, vl);                   //const one for vd4dot\n\n            //set SEW for 1st time VMV_S_X\n            vl = __riscv_vsetvl_e32m4(col_count);\n\n            for (i = 0; i < out_tensor_ch; i++)\n            {\n                int32_t sum = 0;\n                if (bias)\n                {\n                    sum = bias[i];\n                }\n\n                /* Point to the beginning of the im2col buffer where the input is available as a rearranged column */\n                const int8_t *ip_as_col = (int8_t *)in_tmp_buf;\n                long col_count2 = col_count;\n                int32_t sum_ker_a = 0;\n\n                //init\n                vint32m1_t vSum_e0 = __riscv_vmv_s_x_i32m1(sum, 1);\n                vint32m1_t vSum_ker_a_e0 = __riscv_vmv_s_x_i32m1(sum_ker_a, 1);\n\n                //clear the accumulator\n                vint32m4_t vAcc0 = __riscv_vand(__riscv_vundefined_i32m4(), 0, vl);\n                vint32m4_t vAcc1 = __riscv_vand(__riscv_vundefined_i32m4(), 0, vl);\n\n                while (col_count2 >= (vlenb * NDS_VEC_VTYPE_LMUL_ID_M4))\n                {\n                    vint8m4_t vWt_i8, vIn_i8;\n                    vl = __riscv_vsetvl_e8m4(col_count2);\n                    vWt_i8 = __riscv_vle8_v_i8m4(ker_a, vl);\n                    vIn_i8 = __riscv_vle8_v_i8m4(ip_as_col, vl);\n                    col_count2 -= vl;\n                    ker_a += vl;\n                    ip_as_col += vl;\n\n                    vl = __riscv_vsetvl_e32m4(vl);\n                    vAcc0 = __riscv_vd4dots_vv_i32m4_tu(vAcc0, vWt_i8, vIn_i8, vl);\n                    vAcc1 = __riscv_vd4dots_vv_i32m4_tu(vAcc1, vWt_i8, vOne, vl);\n                }\n\n                if(col_count2 > 0)\n                {\n                    vint8m4_t vWt_i8, vIn_i8;\n                    vl = __riscv_vsetvl_e8m4(col_count+3);\n                    vWt_i8 = __riscv_vand(__riscv_vundefined_i8m4(), 0, vl);\n\n                    vl = __riscv_vsetvl_e8m4(col_count2);\n                    vWt_i8 = __riscv_vle8_v_i8m4_tu(vWt_i8, ker_a, vl);\n                    vIn_i8 = __riscv_vle8_v_i8m4(ip_as_col, vl);\n                    col_count2 -= vl;\n                    ker_a += vl;\n                    ip_as_col += vl;\n\n                    vl = (vl + 3) >> 2;\n                    vl = __riscv_vsetvl_e32m4(vl);\n                    vAcc0 = __riscv_vd4dots_vv_i32m4_tu(vAcc0, vWt_i8, vIn_i8, vl);\n                    vAcc1 = __riscv_vd4dots_vv_i32m4_tu(vAcc1, vWt_i8, vOne, vl);\n                }\n\n                vl = __riscv_vsetvl_e32m4(col_count);       //note the avl here\n                vSum_e0 = __riscv_vredsum_tu(vSum_e0, vAcc0, vSum_e0, vl);\n                vSum_ker_a_e0 = __riscv_vredsum_tu(vSum_ker_a_e0, vAcc1, vSum_ker_a_e0, vl);\n\n                //move vr results to gpr\n                sum = __riscv_vmv_x(vSum_e0);\n                sum_ker_a = __riscv_vmv_x(vSum_ker_a_e0);\n\n                //add offset back\n                sum += in_offset * sum_ker_a;\n\n                sum = nn_requantize(sum, out_scale[i], out_shift[i]);\n                sum += out_offset;\n                sum = MAX(sum, act_min);\n                sum = MIN(sum, act_max);\n                *out++ = (int8_t)sum;\n            }\n        }\n        in_tensor += (in_tensor_dim_x * in_tensor_dim_y * in_tensor_ch);\n        out_tensor += (out_tensor_dim_x * out_tensor_dim_y * out_tensor_ch);\n    }\n#elif defined(ENA_VEC_ISA) && (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_VEC_ELEN64) && defined(ENA_VEC_INTRINSIC)\n    int i_batch;\n    for (i_batch = 0; i_batch < in_tensor_batch; i_batch++)\n    {\n        int32_t i_out_y, i_out_x, i_ker_y, i_ker_x;\n\n        /* Generate two columns from the input tensor a GEMM computation */\n        int8_t *two_column_buf = (int8_t *)in_tmp_buf;\n        int8_t *out = out_tensor;\n        long vl;\n\n        /* This part implements the im2col function */\n        for (i_out_y = 0; i_out_y < out_tensor_dim_y; i_out_y++)\n        {\n            for (i_out_x = 0; i_out_x < out_tensor_dim_x; i_out_x++)\n            {\n                for (i_ker_y = i_out_y * stride_y - pad_y; i_ker_y < i_out_y * stride_y - pad_y + ker_dim_y; i_ker_y++)\n                {\n                    for (i_ker_x = i_out_x * stride_x - pad_x; i_ker_x < i_out_x * stride_x - pad_x + ker_dim_x; i_ker_x++)\n                    {\n                        if (i_ker_y < 0 || i_ker_y >= in_tensor_dim_y || i_ker_x < 0 || i_ker_x >= in_tensor_dim_x)\n                        {\n                            nn_set_val_s8(two_column_buf, -in_offset, in_tensor_ch);\n                        }\n                        else\n                        {\n                            nn_dup_s8(in_tensor + (i_ker_y * in_tensor_dim_x + i_ker_x) * in_tensor_ch, two_column_buf, in_tensor_ch);\n                        }\n                        two_column_buf += in_tensor_ch;\n                    }\n                }\n\n                /* Computation is filed for every 2 columns */\n                if (two_column_buf == (int8_t *)in_tmp_buf + 2 * in_tensor_ch * ker_dim_y * ker_dim_x)\n                {\n                    out = nn_mat_mult_kernel_s8_offset(ker_weight,\n                                                       (int8_t *)in_tmp_buf,\n                                                       out_tensor_ch,\n                                                       out_shift,\n                                                       out_scale,\n                                                       in_offset,\n                                                       out_offset,\n                                                       act_min,\n                                                       act_max,\n                                                       in_tensor_ch * ker_dim_y * ker_dim_x,\n                                                       bias,\n                                                       out);\n\n                    /* counter reset */\n                    two_column_buf = (int8_t *)in_tmp_buf;\n                }\n            }\n        }\n\n        /* left-over because odd number of output pixels */\n        if (two_column_buf != (int8_t *)in_tmp_buf)\n        {\n            const int8_t *ptr_wt = ker_weight;\n            int i;\n            long col_count = (in_tensor_ch * ker_dim_y * ker_dim_x);\n            const long in_offset2 = -in_offset;\n\n            vl = __riscv_vsetvl_e32m1(1);\n            vint32m1_t vzero = __riscv_vand(__riscv_vundefined_i32m1(), 0, vl);   //const zero for redsum\n\n            vl = __riscv_vsetvl_e32m8(col_count);\n\n            for (i = 0; i < out_tensor_ch; i++)\n            {\n                int32_t sum = 0;\n\n                /* Point to the beginning of the im2col buffer where the input is available as a rearranged column */\n                const int8_t *ptr_in = (int8_t *)in_tmp_buf;\n                long col_count2 = col_count;\n\n                //clear v0~v7\n                vint32m8_t vaccumulator = __riscv_vand(__riscv_vundefined_i32m8(), 0x0, vl);\n\n                while (col_count2)\n                {\n                    vl = __riscv_vsetvl_e8m2(col_count2);\n                    vint8m2_t vptr_wt = __riscv_vle8_v_i8m2(ptr_wt, vl);\n                    vint8m2_t vptr_in = __riscv_vle8_v_i8m2(ptr_in, vl);\n                    vint16m4_t vptr_in_i16m4 = __riscv_vwsub_vx_i16m4(vptr_in, in_offset2, vl);\n                    vl = __riscv_vsetvl_e16m4(col_count2);\n                    vint16m4_t vptr_wt_i16m4 = __riscv_vsext_vf2(vptr_wt, vl);\n                    vaccumulator = __riscv_vwmacc(vaccumulator, vptr_wt_i16m4, vptr_in_i16m4, vl);\n                    col_count2 -= vl;\n                    ptr_wt += vl;\n                    ptr_in += vl;\n                }\n\n                vl = __riscv_vsetvl_e32m8(col_count);   //note the avl here\n                vint32m1_t vsum = __riscv_vredsum(vaccumulator, vzero, vl);\n                //move vr results to gpr\n                sum = __riscv_vmv_x(vsum);\n\n                //add bias back\n                if (bias)\n                {\n                    sum += bias[i];\n                }\n\n                sum = nn_requantize(sum, out_scale[i], out_shift[i]);\n                sum += out_offset;\n                sum = MAX(sum, act_min);\n                sum = MIN(sum, act_max);\n                *out++ = (int8_t)sum;\n            }\n        }\n        in_tensor += (in_tensor_dim_x * in_tensor_dim_y * in_tensor_ch);\n        out_tensor += (out_tensor_dim_x * out_tensor_dim_y * out_tensor_ch);\n    }\n#elif defined(ENA_VEC_ISA) && (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_NDS_V5_VEC_DOT_PROD) && defined(ENA_TILING)\n    const uint32_t col = ker_dim_y * ker_dim_x * in_tensor_ch;\n    const uint32_t tiling_size = 256;\n    long maxvl_per_loop;\n\n    //--- calculate the buffer address ---\n    const long align_byte = 64;\n    // buf_A\n    int8_t *src1 = (int8_t*)in_tmp_buf;\n    src1 = (int8_t*)nn_align((unsigned long)src1, align_byte);                  // align the starting addresss\n    // buf_B: converted src2\n    long src1_size = tiling_size * in_tensor_ch * ker_dim_x * ker_dim_y;\n    int8_t *src2 = (int8_t*)(src1 + src1_size);\n    src2 = (int8_t*)nn_align((unsigned long)src2, align_byte);                  // align the starting addresss\n    // buf_C: temp buffer for int32_t tiling accumulator\n    long src2_size = out_tensor_ch * in_tensor_ch * ker_dim_x * ker_dim_y;\n    int32_t *dst_i32 = (int32_t*)(src2 + src2_size);\n    dst_i32 = (int32_t*)nn_align((unsigned long)dst_i32, align_byte);           // align the starting addresss\n    // buf_contri\n    long dst_i32_size = tiling_size * out_tensor_ch;\n    int32_t *contri_buf = (int32_t*)(dst_i32 + dst_i32_size);\n    contri_buf = (int32_t*)nn_align((unsigned long)contri_buf, align_byte);     // align the starting addresss\n\n    // calculate the weight contribution\n    const int8_t *pWt = ker_weight;\n    int32_t *pContri_buf = contri_buf;\n    const int32_t *pBias = bias;\n    NDS_VEC_VSETVLI(maxvl_per_loop, reg_x0, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n    if (bias != NULL)\n    {\n        long out_tensor_ch2 = out_tensor_ch;\n        long vl;\n        NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n        NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0);   // const zero for redsum\n\n        while (out_tensor_ch2 > 0)\n        {\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VAND_VI(NDS_VEC_V0, NDS_VEC_V0, 0);\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VMV_V_I(NDS_VEC_V8, 1);     // const one for vd4dot\n\n            long rhs_cols2 = col;\n            while (rhs_cols2 >= maxvl_per_loop)\n            {\n                NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                pWt += vl;\n                rhs_cols2 -= vl;\n\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V16, NDS_VEC_V8);\n            }\n\n            //clean one of the dot product source\n            long tmp_avl;\n            tmp_avl = rhs_cols2 + 3;\n            NDS_VEC_VSETVLI(vl, tmp_avl, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VAND_VI(NDS_VEC_V8, NDS_VEC_V8, 0);\n            NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VADD_VI(NDS_VEC_V8, NDS_VEC_V8, 1);     // const one for vd4dot\n\n            // remain loop\n            while (rhs_cols2 > 0)\n            {\n                NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                pWt += vl;\n                rhs_cols2 -= vl;\n\n                vl = (vl + 3) >> 2;\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V16, NDS_VEC_V8);\n            }\n\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);   //note the avl here\n            NDS_VEC_VREDSUM_VS(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V31);\n\n            NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n            NDS_VEC_VLE32_V(NDS_VEC_V1, pBias);\n            NDS_VEC_VMUL_VX(NDS_VEC_V0, NDS_VEC_V0, in_offset);     // add input_offset contribution\n            NDS_VEC_VADD_VV(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V1);    // add bias\n            NDS_VEC_VSE32_V(NDS_VEC_V0, pContri_buf);\n            pBias += vl;\n            pContri_buf += vl;\n            out_tensor_ch2--;\n        }\n    }\n    else\n    {\n        long out_tensor_ch2 = out_tensor_ch;\n        long vl;\n        NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n        NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0);   // const zero for redsum\n\n        while (out_tensor_ch2 > 0)\n        {\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VAND_VI(NDS_VEC_V0, NDS_VEC_V0, 0);\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VMV_V_I(NDS_VEC_V8, 1);     // const one for vd4dot\n\n            long rhs_cols2 = col;\n            while (rhs_cols2 >= maxvl_per_loop)\n            {\n                NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                pWt += vl;\n                rhs_cols2 -= vl;\n\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V16, NDS_VEC_V8);\n            }\n\n            //clean one of the dot product source\n            long tmp_avl;\n            tmp_avl = rhs_cols2 + 3;\n            NDS_VEC_VSETVLI(vl, tmp_avl, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VAND_VI(NDS_VEC_V8, NDS_VEC_V8, 0);\n            NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VADD_VI(NDS_VEC_V8, NDS_VEC_V8, 1);     // const one for vd4dot\n\n            // remain loop\n            while (rhs_cols2 > 0)\n            {\n                NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                pWt += vl;\n                rhs_cols2 -= vl;\n\n                vl = (vl + 3) >> 2;\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V16, NDS_VEC_V8);\n            }\n\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);   //note the avl here\n            NDS_VEC_VREDSUM_VS(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V31);\n\n            NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n            NDS_VEC_VMUL_VX(NDS_VEC_V0, NDS_VEC_V0, in_offset);\n            NDS_VEC_VSE32_V(NDS_VEC_V0, pContri_buf);\n            pContri_buf++;\n            out_tensor_ch2--;\n        }\n    }\n\n    /* When out_tensor_ch is small, the tiling GEMM (vqmacc vectorizing across\n     * out_tensor_ch) severely underutilizes vector width.  Switch to vd4dots\n     * which vectorizes along the reduction dimension (col) instead — giving\n     * up to 32x better vector utilization for small channel counts. */\n    if (out_tensor_ch <= 64)\n    {\n        /* Reuse src1 area as the 2-column im2col buffer (tiling buffer is\n         * much larger than what 2-column batching needs). */\n        int8_t *two_column_buf = src1;\n\n        for (long cur_batch = 0; cur_batch < in_tensor_batch; cur_batch++)\n        {\n            int8_t *two_col_ptr = two_column_buf;\n            int8_t *out = out_tensor;\n\n            for (long cur_out_y = 0; cur_out_y < out_tensor_dim_y; cur_out_y++)\n            {\n                for (long cur_out_x = 0; cur_out_x < out_tensor_dim_x; cur_out_x++)\n                {\n                    for (long cur_ker_y = cur_out_y * stride_y - pad_y; cur_ker_y < cur_out_y * stride_y - pad_y + ker_dim_y; cur_ker_y++)\n                    {\n                        for (long cur_ker_x = cur_out_x * stride_x - pad_x; cur_ker_x < cur_out_x * stride_x - pad_x + ker_dim_x; cur_ker_x++)\n                        {\n                            if (cur_ker_y < 0 || cur_ker_y >= in_tensor_dim_y || cur_ker_x < 0 || cur_ker_x >= in_tensor_dim_x)\n                            {\n                                nn_set_val_s8(two_col_ptr, -in_offset, in_tensor_ch);\n                            }\n                            else\n                            {\n                                nn_dup_s8(in_tensor + (cur_ker_y * in_tensor_dim_x + cur_ker_x) * in_tensor_ch, two_col_ptr, in_tensor_ch);\n                            }\n                            two_col_ptr += in_tensor_ch;\n                        }\n                    }\n\n                    /* Computation is filed for every 2 columns */\n                    if (two_col_ptr == two_column_buf + 2 * col)\n                    {\n                        out = nn_mat_mult_kernel_s8_offset_v2(ker_weight,\n                                                              two_column_buf,\n                                                              out_tensor_ch,\n                                                              out_shift,\n                                                              out_scale,\n                                                              in_offset,\n                                                              out_offset,\n                                                              act_min,\n                                                              act_max,\n                                                              col,\n                                                              contri_buf,\n                                                              out);\n\n                        /* counter reset */\n                        two_col_ptr = two_column_buf;\n                    }\n                }\n            }\n\n            /* left-over because odd number of output pixels */\n            if (two_col_ptr != two_column_buf)\n            {\n                uint32_t vl;\n                const int8_t *pWt = ker_weight;\n                const int32_t *pOut_scale = out_scale;\n                const int32_t *pOut_shift = out_shift;\n                int32_t *pContri_buf2 = contri_buf;\n\n                NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n                NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0);\n\n                for (long i = 0; i < out_tensor_ch; i++)\n                {\n                    uint32_t rhs_cols2 = col;\n                    const int8_t *pIn = two_column_buf;\n\n                    NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                    NDS_VEC_VAND_VI(NDS_VEC_V0, NDS_VEC_V0, 0x0);\n\n                    while (rhs_cols2 >= maxvl_per_loop)\n                    {\n                        NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                        NDS_VEC_VLE8_V(NDS_VEC_V8, pIn);\n                        NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                        rhs_cols2 -= vl;\n                        pIn += vl;\n                        pWt += vl;\n\n                        NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                        NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V8, NDS_VEC_V16);\n                    }\n\n                    if (rhs_cols2 > 0)\n                    {\n                        long tmp_avl = rhs_cols2 + 3;\n                        NDS_VEC_VSETVLI(vl, tmp_avl, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                        NDS_VEC_VAND_VI(NDS_VEC_V8, NDS_VEC_V8, 0);\n\n                        NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                        NDS_VEC_VLE8_V(NDS_VEC_V8, pIn);\n                        NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                        pWt += vl;\n\n                        vl = (vl + 3) >> 2;\n                        NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                        NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V8, NDS_VEC_V16);\n                    }\n                    else\n                    {\n                        pWt += 0;   /* advance past this channel's weights (already done in loop) */\n                    }\n\n                    NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                    NDS_VEC_VREDSUM_VS(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V31);\n\n                    NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n                    NDS_VEC_VLE32_V(NDS_VEC_V4, pContri_buf2);\n                    NDS_VEC_VADD_VV(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V4);\n\n                    NDS_VEC_VLE32_V(NDS_VEC_V2, pOut_shift);\n                    NDS_VEC_VLE32_V(NDS_VEC_V3, pOut_scale);\n                    NDS_VEC_VRSUB_VX(NDS_VEC_V2, NDS_VEC_V2, 30);\n\n                    NDS_VEC_VWMUL_VV(NDS_VEC_V4, NDS_VEC_V0, NDS_VEC_V3);\n                    NDS_VEC_VNSRA_WV(NDS_VEC_V4, NDS_VEC_V4, NDS_VEC_V2);\n                    NDS_VEC_VSSRA_VI(NDS_VEC_V4, NDS_VEC_V4, 1);\n\n                    NDS_VEC_VADD_VX(NDS_VEC_V4, NDS_VEC_V4, out_offset);\n                    NDS_VEC_VMAX_VX(NDS_VEC_V4, NDS_VEC_V4, act_min);\n                    NDS_VEC_VMIN_VX(NDS_VEC_V4, NDS_VEC_V4, act_max);\n\n                    NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E16, NDS_VEC_VTYPE_LMUL_M1);\n                    NDS_VEC_VNSRA_VI(NDS_VEC_V4, NDS_VEC_V4, 0);\n                    NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M1);\n                    NDS_VEC_VNSRA_VI(NDS_VEC_V4, NDS_VEC_V4, 0);\n                    NDS_VEC_VSE8_V(NDS_VEC_V4, out);\n                    out += vl;\n                    pOut_scale += vl;\n                    pOut_shift += vl;\n                    pContri_buf2 += vl;\n                }\n            }\n\n            in_tensor += (in_tensor_dim_x * in_tensor_dim_y * in_tensor_ch);\n            out_tensor += (out_tensor_dim_x * out_tensor_dim_y * out_tensor_ch);\n        }\n    }\n    else\n    {\n    //transpose the kernel_weight for matrix multiplication\n    nn_mat_mul_kernel_tiling_transpose_q7(ker_weight, src2, out_tensor_ch, in_tensor_ch * ker_dim_x * ker_dim_y);\n\n    int8_t *out = out_tensor;\n    for (long cur_batch = 0; cur_batch < in_tensor_batch; cur_batch++)\n    {\n        int8_t *src1_buf = src1;\n        int col_counter = 0;\n\n        /* This part implements the im256col function */\n        for (long cur_out_y = 0; cur_out_y < out_tensor_dim_y; cur_out_y++)\n        {\n            for (long cur_out_x = 0; cur_out_x < out_tensor_dim_x; cur_out_x++)\n            {\n                for (long cur_ker_y = cur_out_y * stride_y - pad_y; cur_ker_y < cur_out_y * stride_y - pad_y + ker_dim_y; cur_ker_y++)\n                {\n                    for (long cur_ker_x = cur_out_x * stride_x - pad_x; cur_ker_x < cur_out_x * stride_x - pad_x + ker_dim_x; cur_ker_x++)\n                    {\n                        if (cur_ker_y < 0 || cur_ker_y >= in_tensor_dim_y || cur_ker_x < 0 || cur_ker_x >= in_tensor_dim_x)\n                        {\n                            nn_set_val_s8(src1_buf, -in_offset, in_tensor_ch);\n                        }\n                        else\n                        {\n                            nn_dup_s8(in_tensor + (cur_ker_y * in_tensor_dim_x + cur_ker_x) * in_tensor_ch, src1_buf, in_tensor_ch);\n                        }\n                        src1_buf += in_tensor_ch;\n                    }\n                }\n                col_counter++;\n\n                /* Computation is filed for every 256 columns */\n                if (col_counter == tiling_size)\n                {\n                    out = nn_mat_mul_kernel_tiling_asym_s8_s8_s8(src1,\n                                                                 src2,\n                                                                 dst_i32,\n                                                                 out,\n                                                                 out_scale,\n                                                                 out_shift,\n                                                                 col_counter,\n                                                                 in_tensor_ch * ker_dim_x * ker_dim_y,\n                                                                 out_tensor_ch,\n                                                                 out_offset,\n                                                                 act_min,\n                                                                 act_max,\n                                                                 contri_buf,\n                                                                 tiling_size);\n\n                    /* counter reset */\n                    col_counter = 0;\n                    src1_buf = src1;\n                }\n            }\n        }\n\n        /* check if there is left-over for compute */\n        out = nn_mat_mul_kernel_tiling_asym_s8_s8_s8(src1,\n                                                     src2,\n                                                     dst_i32,\n                                                     out,\n                                                     out_scale,\n                                                     out_shift,\n                                                     col_counter,\n                                                     in_tensor_ch * ker_dim_x * ker_dim_y,\n                                                     out_tensor_ch,\n                                                     out_offset,\n                                                     act_min,\n                                                     act_max,\n                                                     contri_buf,\n                                                     tiling_size);\n        /* next in_tensor batch offset */\n        in_tensor += (in_tensor_dim_x * in_tensor_dim_y * in_tensor_ch);\n    }\n    }\n#elif defined(ENA_VEC_ISA) && (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_NDS_V5_VEC_DOT_PROD) && defined(ENA_VEC_ELEN64)\n    const uint32_t rhs_cols = ker_dim_y * ker_dim_x * in_tensor_ch;\n    long maxvl_per_loop;\n\n    //--- calculate the buffer address ---\n    const long align_byte = sizeof(long);\n    // buffer-1\n    int8_t *two_column_buf = (int8_t*)in_tmp_buf;\n    two_column_buf = (int8_t*)nn_align((unsigned long)two_column_buf, align_byte);  // align the starting addresss\n    // buffer-2\n    long two_column_buf_size = 2 * in_tensor_ch * ker_dim_x * ker_dim_y * sizeof(*in_tensor);\n    int32_t *contri_buf = (int32_t*)(two_column_buf + two_column_buf_size);\n    contri_buf = (int32_t*)nn_align((unsigned long)contri_buf, align_byte);         // align the starting addresss\n\n    // calculate the weight contribution\n    const int8_t *pWt = ker_weight;\n    int32_t *pContri_buf = contri_buf;\n    const int32_t *pBias = bias;\n    NDS_VEC_VSETVLI(maxvl_per_loop, reg_x0, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n    if (bias != NULL)\n    {\n        long out_tensor_ch2 = out_tensor_ch;\n        long vl;\n        NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n        NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0);   // const zero for redsum\n\n        while (out_tensor_ch2 > 0)\n        {\n            NDS_VEC_VSETVLI(vl, rhs_cols, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VAND_VI(NDS_VEC_V0, NDS_VEC_V0, 0);\n            NDS_VEC_VSETVLI(vl, rhs_cols, NDS_VE