                                     out_tensor_ch,\n                                                       out_shift,\n                                                       out_scale,\n                                                       in_offset,\n                                                       out_offset,\n                                                       act_min,\n                                                       act_max,\n                                                       in_tensor_ch * ker_dim_y * ker_dim_x,\n                                                       bias,\n                                                       out);\n\n                    /* counter reset */\n                    two_column_buf = (int8_t *)in_tmp_buf;\n                }\n            }\n        }\n\n        /* left-over because odd number of output pixels */\n        if (two_column_buf != (int8_t *)in_tmp_buf)\n        {\n            const int8_t *ptr_wt = ker_weight;\n            int i;\n            long col_count = (in_tensor_ch * ker_dim_y * ker_dim_x);\n            const long in_offset2 = -in_offset;\n\n            vl = __riscv_vsetvl_e32m1(1);\n            vint32m1_t vzero = __riscv_vand(__riscv_vundefined_i32m1(), 0, vl);   //const zero for redsum\n\n            vl = __riscv_vsetvl_e32m8(col_count);\n\n            for (i = 0; i < out_tensor_ch; i++)\n            {\n                int32_t sum = 0;\n\n                /* Point to the beginning of the im2col buffer where the input is available as a rearranged column */\n                const int8_t *ptr_in = (int8_t *)in_tmp_buf;\n                long col_count2 = col_count;\n\n                //clear v0~v7\n                vint32m8_t vaccumulator = __riscv_vand(__riscv_vundefined_i32m8(), 0x0, vl);\n\n                while (col_count2)\n                {\n                    vl = __riscv_vsetvl_e8m2(col_count2);\n                    vint8m2_t vptr_wt = __riscv_vle8_v_i8m2(ptr_wt, vl);\n                    vint8m2_t vptr_in = __riscv_vle8_v_i8m2(ptr_in, vl);\n                    vint16m4_t vptr_in_i16m4 = __riscv_vwsub_vx_i16m4(vptr_in, in_offset2, vl);\n                    vl = __riscv_vsetvl_e16m4(col_count2);\n                    vint16m4_t vptr_wt_i16m4 = __riscv_vsext_vf2(vptr_wt, vl);\n                    vaccumulator = __riscv_vwmacc(vaccumulator, vptr_wt_i16m4, vptr_in_i16m4, vl);\n                    col_count2 -= vl;\n                    ptr_wt += vl;\n                    ptr_in += vl;\n                }\n\n                vl = __riscv_vsetvl_e32m8(col_count);   //note the avl here\n                vint32m1_t vsum = __riscv_vredsum(vaccumulator, vzero, vl);\n                //move vr results to gpr\n                sum = __riscv_vmv_x(vsum);\n\n                //add bias back\n                if (bias)\n                {\n                    sum += bias[i];\n                }\n\n                sum = nn_requantize(sum, out_scale[i], out_shift[i]);\n                sum += out_offset;\n                sum = MAX(sum, act_min);\n                sum = MIN(sum, act_max);\n                *out++ = (int8_t)sum;\n            }\n        }\n        in_tensor += (in_tensor_dim_x * in_tensor_dim_y * in_tensor_ch);\n        out_tensor += (out_tensor_dim_x * out_tensor_dim_y * out_tensor_ch);\n    }\n#elif defined(ENA_VEC_ISA) && (NDS_VEC_RVV_VERSION >= 100) && defined(ENA_NDS_V5_VEC_DOT_PROD) && defined(ENA_TILING)\n    const uint32_t col = ker_dim_y * ker_dim_x * in_tensor_ch;\n    const uint32_t tiling_size = 256;\n    long maxvl_per_loop;\n\n    //--- calculate the buffer address ---\n    const long align_byte = 64;\n    // buf_A\n    int8_t *src1 = (int8_t*)in_tmp_buf;\n    src1 = (int8_t*)nn_align((unsigned long)src1, align_byte);                  // align the starting addresss\n    // buf_B: converted src2\n    long src1_size = tiling_size * in_tensor_ch * ker_dim_x * ker_dim_y;\n    int8_t *src2 = (int8_t*)(src1 + src1_size);\n    src2 = (int8_t*)nn_align((unsigned long)src2, align_byte);                  // align the starting addresss\n    // buf_C: temp buffer for int32_t tiling accumulator\n    long src2_size = out_tensor_ch * in_tensor_ch * ker_dim_x * ker_dim_y;\n    int32_t *dst_i32 = (int32_t*)(src2 + src2_size);\n    dst_i32 = (int32_t*)nn_align((unsigned long)dst_i32, align_byte);           // align the starting addresss\n    // buf_contri\n    long dst_i32_size = tiling_size * out_tensor_ch;\n    int32_t *contri_buf = (int32_t*)(dst_i32 + dst_i32_size);\n    contri_buf = (int32_t*)nn_align((unsigned long)contri_buf, align_byte);     // align the starting addresss\n\n    // calculate the weight contribution\n    const int8_t *pWt = ker_weight;\n    int32_t *pContri_buf = contri_buf;\n    const int32_t *pBias = bias;\n    NDS_VEC_VSETVLI(maxvl_per_loop, reg_x0, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n    if (bias != NULL)\n    {\n        long out_tensor_ch2 = out_tensor_ch;\n        long vl;\n        NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n        NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0);   // const zero for redsum\n\n        while (out_tensor_ch2 > 0)\n        {\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VAND_VI(NDS_VEC_V0, NDS_VEC_V0, 0);\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VMV_V_I(NDS_VEC_V8, 1);     // const one for vd4dot\n\n            long rhs_cols2 = col;\n            while (rhs_cols2 >= maxvl_per_loop)\n            {\n                NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                pWt += vl;\n                rhs_cols2 -= vl;\n\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V16, NDS_VEC_V8);\n            }\n\n            //clean one of the dot product source\n            long tmp_avl;\n            tmp_avl = rhs_cols2 + 3;\n            NDS_VEC_VSETVLI(vl, tmp_avl, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VAND_VI(NDS_VEC_V8, NDS_VEC_V8, 0);\n            NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VADD_VI(NDS_VEC_V8, NDS_VEC_V8, 1);     // const one for vd4dot\n\n            // remain loop\n            while (rhs_cols2 > 0)\n            {\n                NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                pWt += vl;\n                rhs_cols2 -= vl;\n\n                vl = (vl + 3) >> 2;\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V16, NDS_VEC_V8);\n            }\n\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);   //note the avl here\n            NDS_VEC_VREDSUM_VS(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V31);\n\n            NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n            NDS_VEC_VLE32_V(NDS_VEC_V1, pBias);\n            NDS_VEC_VMUL_VX(NDS_VEC_V0, NDS_VEC_V0, in_offset);     // add input_offset contribution\n            NDS_VEC_VADD_VV(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V1);    // add bias\n            NDS_VEC_VSE32_V(NDS_VEC_V0, pContri_buf);\n            pBias += vl;\n            pContri_buf += vl;\n            out_tensor_ch2--;\n        }\n    }\n    else\n    {\n        long out_tensor_ch2 = out_tensor_ch;\n        long vl;\n        NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n        NDS_VEC_VAND_VI(NDS_VEC_V31, NDS_VEC_V31, 0);   // const zero for redsum\n\n        while (out_tensor_ch2 > 0)\n        {\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VAND_VI(NDS_VEC_V0, NDS_VEC_V0, 0);\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VMV_V_I(NDS_VEC_V8, 1);     // const one for vd4dot\n\n            long rhs_cols2 = col;\n            while (rhs_cols2 >= maxvl_per_loop)\n            {\n                NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                pWt += vl;\n                rhs_cols2 -= vl;\n\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V16, NDS_VEC_V8);\n            }\n\n            //clean one of the dot product source\n            long tmp_avl;\n            tmp_avl = rhs_cols2 + 3;\n            NDS_VEC_VSETVLI(vl, tmp_avl, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VAND_VI(NDS_VEC_V8, NDS_VEC_V8, 0);\n            NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n            NDS_VEC_VADD_VI(NDS_VEC_V8, NDS_VEC_V8, 1);     // const one for vd4dot\n\n            // remain loop\n            while (rhs_cols2 > 0)\n            {\n                NDS_VEC_VSETVLI(vl, rhs_cols2, NDS_VEC_VTYPE_SEW_E8, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VLE8_V(NDS_VEC_V16, pWt);\n                pWt += vl;\n                rhs_cols2 -= vl;\n\n                vl = (vl + 3) >> 2;\n                NDS_VEC_VSETVLI(vl, vl, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);\n                NDS_VEC_VD4DOTS_VV(NDS_VEC_V0, NDS_VEC_V16, NDS_VEC_V8);\n            }\n\n            NDS_VEC_VSETVLI(vl, col, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M8);   //note the avl here\n            NDS_VEC_VREDSUM_VS(NDS_VEC_V0, NDS_VEC_V0, NDS_VEC_V31);\n\n            NDS_VEC_VSETVLI(vl, 1, NDS_VEC_VTYPE_SEW_E32, NDS_VEC_VTYPE_LMUL_M1);\n            NDS_VEC_VMUL_VX(NDS_VEC_V0, NDS_VEC_V0, in_offset);\n            NDS_VEC_VSE32_V(NDS_VEC_V0, pContri_buf);\n            pContri_buf++;\n            out_tensor_ch2--;\n        }\n    }\n\n    /* When out_tensor_ch is small, the tiling GEMM (vqmacc vectorizing across\n     * out_tensor_ch) severely underutilizes vector width.  Switch to vd4dots\n     * which vectorizes along the reduction dimension (col) instead — giving\n     * up to 32x better vector utilization for small channel counts. */\n    if (out_tensor_ch <= 64)\n    {\n        /* Reuse src1 area as the 2-column im2col buffer (tiling buffer is\n         * much larger than what 2-column batching needs). */\n        int8_t *two_column_buf = src1;\n\n        for (long cur_batch = 0; cur_batch < in_tensor_batch; cur_batch++)\n        {\n            int8_t *two_col_ptr = two_column_buf;\n            int8_t *out = out_tensor;\n\n            for (long cur_out_y = 0; cur_out_y < out_tensor_dim_y; cur_out_y++)\n            {\n                for (long cur_out_x = 0; cur_out_x < out_tensor_dim_x; cur_out_x++)\n                {\n                    for (long cur_ker_y = cur_out_y * stride_y - pad_y; cur_ker_y < cur_out_y * stride_y - pad_y + ker_dim_y; cur_ker_y++)\n                    {\n                        for (long cur_ker_x = cur_out_x * stride_x - pad_x; cur_ker_x < cur_out_x * stride_x - pad_x + ker_dim_x; cur_ker_x++)\n                        {\n                            if (cur_ker_y < 0 || cur_ker_y >= in_tensor_dim_y || cur_ker_x < 0 || cur_ker_x >= in_tensor_dim_x)\n                            {\n                                nn_set_val_s8(two_col_ptr, -in_offset, in_tensor_ch);\n                            }\n                            else\n                            {\n                                nn_dup_s8(in_tensor + (cur_ker_y * in_tensor_dim_x + cur_ker_x) * in_tensor_ch, two_col_ptr, in_tensor_ch);\n                            }\n                            two_col_ptr += in_tensor_ch;\n                        }\n                    }\n\n                    /* Computation is filed for every 2 columns */\n                    if (t