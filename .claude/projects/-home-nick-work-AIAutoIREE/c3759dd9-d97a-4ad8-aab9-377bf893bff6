int function_do_write ( const char * mode );
    
int function_do_read( const char * mode ){
    int i;
    char *pchar;
    char readline[MAX_PRINTED];
    FILE *stream;

    stream = fopen( "cval01.dat", mode );
    if( stream == NULL ) {
        return 0;
    } 

    for( i=0; i<N_ELEM; i++ ){
        pchar = fgets( readline, MAX_PRINTED, stream );
        CVAL_VERIFY( pchar == readline );
        CVAL_VERIFY( cval_strlen(  readline ) == (size_t) csee[i].ret );
        CVAL_VERIFY( cval_strcmp(  readline, csee[i].printed ) == 0 );
    }

    /* EOF */
    CVAL_VERIFY( fgetc( stream ) == EOF );
    CVAL_VERIFY( feof(  stream ) );

    fclose( stream );
    return 1;
}

MAIN{

    /* CVAL_HEADER( "| T | printf() | Conversion Specifiers | e | E |" ); */

    CVAL_VERIFY( function_do_write( "w" ) );
    CVAL_VERIFY( function_do_read(  "r" ) );

}


int function_do_write( const char * mode ){
    int i;
    int res;

    /* Redirect stdout */
    FILE *reopen = freopen( "cval01.dat", mode, stdout );
    if( reopen == NULL ) {
        return 0;
    } 

    for( i=0; i<N_ELEM; i++ ){
        res = printf( csee[i].format, csee[i].num );
        CVAL_VERIFY( res == csee[i].ret );
        CVAL_VERIFY( res <  MAX_PRINTED );
    }

    /* Close stdout */
    CVAL_VERIFY( fclose( stdout ) == 0 );

    return 1;
}
