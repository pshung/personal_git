#include "def.h"

/* Compatibility: Preprocessor condition intended */
#if defined( CVAL_STDC )
#include <stdio.h>
#include <stdarg.h>
#else
#include <cstdio>
#include <cstdarg>
#endif

const char string[] = "test string\n";

int do_scan(const char *str, const char form[], ...) {
    int ret;
    va_list ap;
    va_start(ap, form);

    ret = vsscanf(str, form, ap);

    va_end(ap);
    return ret;
}

MAIN
{
    int res = 0;
    char str1[15];
    char c;
    
    CVAL_HEADER("The vsscanf function, ordinary character directive");
    res = do_scan("test c", "test %c", &c);
    CVAL_VERIFY(res == 1);
    CVAL_VERIFY(c == 'c'); 
    res = do_scan("string ", "%s%c", str1, &c);
    CVAL_VERIFY(res == 2);
    CVAL_VERIFY(c == ' '); 
    CVAL_VERIFY(cval_strcmp(str1, "string") == 0);
}
