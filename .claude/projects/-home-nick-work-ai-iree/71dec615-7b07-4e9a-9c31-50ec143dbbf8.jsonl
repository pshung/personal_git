XHAUSTIVE:\n   304→        candidates = set(range(1, effective_max + 1)) if effective_max >= 1 else set()\n   305→    else:\n   306→        candidates = set()\n   307→        candidates.add(effective_max)\n   308→        # Find max divisor of dim_M that fits within max_v_outer\n   309→        for d in range(effective_max, 0, -1):\n   310→            if dim_M % d == 0:\n   311→                candidates.add(d)\n   312→                break\n   313→\n   314→    # Apply filters\n   315→    if _config.REQUIRE_V_OUTER_DIVIDES_M:\n   316→        candidates = {v for v in candidates if dim_M % v == 0}\n   317→\n   318→    # Parity matching: odd dim_M → odd v_outer, even dim_M → even v_outer\n   319→    parity = dim_M % 2\n   320→    candidates = {v for v in candidates if v % 2 == parity}\n   321→\n   322→    if _config.V_OUTER_EXCLUDE:\n   323→        candidates = {v for v in candidates if v not in _config.V_OUTER_EXCLUDE}\n   324→\n   325→    if _config.V_OUTER_MIN > 1:\n   326→        candidates = {v for v in candidates if v >= _config.V_OUTER_MIN}\n   327→\n   328→    return sorted(candidates) if candidates else [0]\n   329→\n   330→\n   331→def _is_prime(n):\n   332→    \"\"\"Return True if n is a prime number.\"\"\"\n   333→    if n < 2:\n   334→        return False\n   335→    if n < 4:\n   336→        return True\n   337→    if n % 2 == 0 or n % 3 == 0:\n   338→        return False\n   339→    i = 5\n   340→    while i * i <= n:\n   341→        if n % i == 0 or n % (i + 2) == 0:\n   342→            return False\n   343→        i += 6\n   344→    return True\n   345→\n   346→\n   347→def generate_distribution_configs(\n   348→    v_inner: int,\n   349→    v_outer: int,"}]},"uuid":"cba92992-b34d-4164-9587-d4b4948fbad5","timestamp":"2026-03-20T02:58:30.171Z","toolUseResult":{"type":"text","file":{"filePath":"/home/nick/work/ai_iree/script/dataset_generator/search_space.py","content":"        _I8_LABELS = ['MF4', 'MF2', 'LMUL1', 'LMUL2']\n        for idx, (vi, _) in enumerate(_config.LMUL_TIERS_I8_WIDENING):\n            if vi == v_inner:\n                return _I8_LABELS[idx] if idx < len(_I8_LABELS) else f\"V={v_inner}\"\n    # f32 tiers (LMUL1..LMUL8)\n    for idx, (vi, _) in enumerate(_config.LMUL_TIERS_F32):\n        if vi == v_inner:\n            return f\"LMUL{1 << idx}\"\n    return f\"V={v_inner}\"\n\n\ndef compute_v_outer_candidates(max_v_outer: int, dim_M: int) -> List[int]:\n    \"\"\"Compute V_outer candidates with optional filtering.\n\n    Default: 2 candidates (max_v_outer + max divisor of M <= max_v_outer).\n    Exhaustive (V_OUTER_EXHAUSTIVE=True): all values 1..effective_max.\n\n    Filtering options (applied after candidate generation):\n    - REQUIRE_V_OUTER_DIVIDES_M: Only keep divisors of dim_M\n    - Parity matching: odd dim_M keeps only odd v_outer, even dim_M keeps only even v_outer\n    - V_OUTER_EXCLUDE: Remove explicitly excluded values\n    - V_OUTER_MIN: Remove values below minimum\n\n    Args:\n        max_v_outer: Maximum non-spilling V_outer from probe stage.\n        dim_M: Size of the outer parallel dimension (M).\n\n    Returns:\n        Sorted list of unique candidates after filtering.\n    \"\"\"\n    effective_max = min(max_v_outer, dim_M)\n\n    # Generate base candidates\n    if _config.V_OUTER_EXHAUSTIVE:\n        candidates = set(range(1, effective_max + 1)) if effective_max >= 1 else set()\n    else:\n        candidates = set()\n        candidates.add(effective_max)\n        # Find max divisor of dim_M that fits within max_v_outer\n        for d in range(effective_max, 0, -1):\n            if dim_M % d == 0:\n                candidates.add(d)\n                break\n\n    # Apply filters\n    if _config.REQUIRE_V_OUTER_DIVIDES_M:\n        candidates = {v for v in candidates if dim_M % v == 0}\n\n    # Parity matching: odd dim_M → odd v_outer, even dim_M → even v_outer\n    parity = dim_M % 2\n    candidates = {v for v in candidates if v % 2 == parity}\n\n    if _config.V_OUTER_EXCLUDE:\n        candidates = {v for v in candidates if v not in _config.V_OUTER_EXCLUDE}\n\n    if _config.V_OUTER_MIN > 1:\n        candidates = {v for v in candidates if v >= _config.V_OUTER_MIN}\n\n    return sorted(candidates) if candidates else [0]\n\n\ndef _is_prime(n):\n    \"\"\"Return True if n is a prime number.\"\"\"\n    if n < 2:\n        return False\n    if n < 4:\n        return True\n    if n % 2 == 0 or n % 3 == 0:\n        return False\n    i = 5\n    while i * i <= n:\n        if n % i == 0 or n % (i + 2) == 0:\n            return False\n        i += 6\n    return True\n\n\ndef generate_distribution_configs(\n    v_inner: int,\n    v_outer: int,","numLines":80,"startLine":270,"totalLines":1624}},"sourceToolAssistantUUID":"89a4a4f4-c56c-4567-aa40-4d1b3f054dda"}
