{"parentUuid":"0ff66120-4875-4291-9866-ab246f0105a3","isSidechain":false,"userType":"external","cwd":"/home/nick/work/ai_iree","sessionId":"71dec615-7b07-4e9a-9c31-50ec143dbbf8","version":"2.1.72","gitBranch":"master","slug":"purrfect-wandering-puppy","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016yCHW52rcv3fM2F2Srcsvf","type":"tool_result","content":"The file /home/nick/work/ai_iree/script/dataset_generator/search_space.py has been updated successfully."}]},"uuid":"b8218a51-800a-44c9-a67e-65cf4085a058","timestamp":"2026-03-20T03:01:00.589Z","toolUseResult":{"filePath":"/home/nick/work/ai_iree/script/dataset_generator/search_space.py","oldString":"    return sorted(candidates) if candidates else [0]","newString":"    return sorted(candidates) if candidates else []","originalFile":"\"\"\"Tiling configuration search space generation.\"\"\"\n\nimport os\nimport json\nimport math\nfrom typing import Dict, List, Tuple, Optional, Any\nfrom itertools import product\n\nfrom . import config as _config\nfrom .config import (\n    DTYPE_BYTES,\n    ACCUMULATOR_DTYPE,\n    SIX_LEVEL_OPS,\n)\n\n\nclass TilingStrategy:\n    \"\"\"Base class for tiling search space generation strategies.\"\"\"\n\n    name: str = \"\"\n\n    def generate_configs(\n        self,\n        iterator_types: List[str],\n        dim_sizes: List[int],\n        output_dtype: str,\n        max_configs: int,\n        op_name: str,\n        num_operands: int,\n        input_dtype: str,\n    ) -> List[List[List[int]]]:\n        \"\"\"Generate tiling configurations for one pattern.\"\"\"\n        raise NotImplementedError\n\n    def get_num_levels(self, op_name: str) -> int:\n        \"\"\"Return the number of tiling levels (4 or 6).\"\"\"\n        raise NotImplementedError\n\n    def format_header(\n        self,\n        op_name: str,\n        iterator_types: List[str],\n        dim_sizes: List[int],\n        input_dtype: str,\n        num_levels: int,\n    ) -> str:\n        \"\"\"Generate the # comment header block for a search space file.\"\"\"\n        raise NotImplementedError\n\n\n\ndef get_lmul_vector_tiles(\n    dim_size: int,\n    input_dtype: str = 'f32',\n) -> List[Tuple[int, int]]:\n    \"\"\"\n    Get LMUL-based (V_inner, V_outer_max) tiers up to the ceiling tier.\n\n    Walks through LMUL tiers in ascending V_inner order, including all tiers\n    up to and including the first tier where V_inner >= dim_size (the ceiling).\n    If no tier reaches dim_size, all tiers are included.\n\n    Tier table selection:\n    - f32 and non-widening types: LMUL_TIERS_F32 (LMUL1..LMUL8)\n    - i8→i32 widening (input_dtype in i8/si8/ui8): LMUL_TIERS_I8_WIDENING\n      v_inner = VLEN/8 × LMUL (MF4, MF2, LMUL1, LMUL2 — LMUL4/LMUL8 excluded)\n\n    If REQUIRE_V_INNER_DIVIDES_N=True, substitutes V_inner values that don't\n    divide dim_size evenly with the largest divisor of dim_size that is ≤ V_inner.\n\n    Args:\n        dim_size: Size of the inner-most parallel dimension.\n        input_dtype: Input data type string (e.g., 'f32', 'i8').\n\n    Returns:\n        List of (V_inner, V_outer_max) tuples.\n    \"\"\"\n    # Select tier table based on widening: i8/si8/ui8 → i32 uses widening tiers\n    is_widening = input_dtype in ('i8', 'si8', 'ui8')\n    if is_widening and _config.LMUL_TIERS_I8_WIDENING:\n        tiers = _config.LMUL_TIERS_I8_WIDENING\n    else:\n        tiers = _config.LMUL_TIERS_F32\n\n    result = []\n    for vi, vo_max in tiers:\n        # Apply divisibility substitution\n        if _config.REQUIRE_V_INNER_DIVIDES_N and dim_size % vi != 0:\n            # Find largest divisor of dim_size that is ≤ vi\n            substitute_vi = None\n            for d in range(min(vi, dim_size), 0, -1):\n                if dim_size % d == 0:\n                    substitute_vi = d\n                    break\n            if substitute_vi:\n                result.append((substitute_vi, vo_max))\n        else:\n            result.append((vi, vo_max))\n\n        # Stop at ceiling tier (first tier where vi >= dim_size)\n        if vi >= dim_size:\n            break\n    return result\n\n\ndef remap_probe_bounds_for_substitution(\n    probe_bounds: Dict[int, int],\n    dim_size: int\n) -> tuple[Dict[int, int], Dict[int, int]]:\n    \"\"\"Remap probe bounds when v_inner values are substituted.\n\n    When get_lmul_vector_tiles substitutes v_inner values (e.g., 128→96),\n    the probe bounds need to be updated to use the substituted keys.\n\n    Args:\n        probe_bounds: Original bounds {v_inner: max_v_outer} from probing\n        dim_size: Size of inner parallel dimension\n\n    Returns:\n        Tuple of (remapped_bounds, substitution_map) where:\n        - remapped_bounds: {substituted_v_inner: max_v_outer}\n        - substitution_map: {substituted_v_inner: original_v_inner} for tracking\n    \"\"\"\n    if not _config.REQUIRE_V_INNER_DIVIDES_N or not probe_bounds:\n        return probe_bounds, {}\n\n    remapped = {}\n    substitution_map = {}\n    for vi, vo_max in probe_bounds.items():\n        if dim_size % vi != 0:\n            # Find substituted value (largest divisor ≤ vi)\n            for d in range(min(vi, dim_size), 0, -1):\n                if dim_size % d == 0:\n                    remapped[d] = vo_max  # Use original bounds\n                    substitution_map[d] = vi  # Track substitution\n                    break\n        else:\n            remapped[vi] = vo_max\n\n    return remapped, substitution_map\n\n\ndef get_lmul_tier_capacity(v_inner: int) -> Tuple[int, str]:\n    \"\"\"Find the enclosing LMUL tier capacity for a given v_inner value.\n\n    Maps any v_inner (including substituted values) to the smallest LMUL tier\n    whose capacity >= v_inner. This determines the actual hardware vector\n    register capacity being used, regardless of how much of it v_inner fills.\n\n    Args:\n        v_inner: The vector inner tile size from a tile configuration.\n\n    Returns:\n        Tuple of (tier_capacity, lmul_label) where tier_capacity is the\n        LMUL tier's V_inner and lmul_label is e.g. \"LMUL1\", \"LMUL4\".\n    \"\"\"\n    for idx, (vi, _) in enumerate(_config.LMUL_TIERS_F32):\n        if vi >= v_inner:\n            return vi, f\"LMUL{1 << idx}\"\n    # Beyond all tiers — use the largest\n    last_vi, _ = _config.LMUL_TIERS_F32[-1]\n    return last_vi, f\"LMUL{1 << (len(_config.LMUL_TIERS_F32) - 1)}\"\n\n\ndef check_vector_utilization(\n    tile_config_path: str,\n    threshold: float = 0.5,\n) -> Dict[str, Any]:\n    \"\"\"Analyze vector utilization in a tile config search space file.\n\n    Extracts v_inner from generated configs and compares to the enclosing\n    LMUL tier capacity. Flags configs where utilization\n    (v_inner / tier_capacity) < threshold.\n\n    Args:\n        tile_config_path: Path to a search space .json file.\n        threshold: Utilization ratio below which to flag (default 0.5 = 50%).\n\n    Returns:\n        Dict with:\n            'file': basename of the file,\n            'total_configs': count of non-baseline configs,\n            'low_utilization': list of per-config dicts with v_inner,\n                tier_capacity, lmul_label, utilization.\n    \"\"\"\n    import ast\n    import re\n\n    iterator_types = None\n    num_levels = None\n    dim_inner = None\n    configs = []\n\n    with open(tile_config_path) as f:\n        for line in f:\n            line = line.strip()\n            if line.startswith('# Iterator types:'):\n                iterator_types = ast.literal_eval(line.split(':', 1)[1].strip())\n            elif line.startswith('# Dim sizes:'):\n                m = re.search(r'N\\(inner\\)=(\\d+)', line)\n                if m:\n                    dim_inner = int(m.group(1))\n            elif line.startswith('# Format:'):\n                num_levels = 6 if 'L5' in line else 4\n            elif line and not line.startswith('#'):\n                # Strip optional index prefix (e.g., \"42: [[...]]\")\n                if not line.startswith('['):\n                    line = line.split(': ', 1)[-1]\n                configs.append(json.loads(line))\n\n    basename = os.path.basename(tile_config_path)\n    empty = {'file': basename, 'total_configs': 0, 'low_utilization': [],\n             'dim_inner': dim_inner}\n\n    if not iterator_types or num_levels is None:\n        return empty\n\n    parallel_dims = [i for i, t in enumerate(iterator_types) if t == 'parallel']\n    if not parallel_dims:\n        return empty\n\n    inner_parallel = parallel_dims[-1]\n    vec_parallel_level = 3 if num_levels == 6 else 1\n\n    low_util = []\n    total_non_baseline = 0\n\n    for idx, config in enumerate(configs):\n        if len(config) <= vec_parallel_level:\n            continue\n        vec_parallel = config[vec_parallel_level]\n        if inner_parallel >= len(vec_parallel):\n            continue\n\n        v_inner = vec_parallel[inner_parallel]\n        if v_inner == 0:\n            continue\n\n        total_non_baseline += 1\n        tier_capacity, lmul_label = get_lmul_tier_capacity(v_inner)\n        utilization = v_inner / tier_capacity\n\n        if utilization < threshold:\n            low_util.append({\n                'config_idx': idx,\n                'v_inner': v_inner,\n                'tier_capacity': tier_capacity,\n                'lmul_label': lmul_label,\n                'utilization': utilization,\n            })\n\n    return {\n        'file': basename,\n        'total_configs': total_non_baseline,\n        'low_utilization': low_util,\n        'dim_inner': dim_inner,\n    }\n\n\ndef get_lmul_label(v_inner: int, input_dtype: str = 'f32') -> str:\n    \"\"\"Return a human-readable LMUL label for a V_inner value.\n\n    Uses the appropriate tier table based on input_dtype.\n    i8 widening tiers: MF4, MF2, LMUL1, LMUL2.\n    f32 tiers: LMUL1, LMUL2, LMUL4, LMUL8.\n    Falls back to 'V=<v_inner>' for unknown values.\n    \"\"\"\n    is_widening = input_dtype in ('i8', 'si8', 'ui8')\n    if is_widening and _config.LMUL_TIERS_I8_WIDENING:\n        _I8_LABELS = ['MF4', 'MF2', 'LMUL1', 'LMUL2']\n        for idx, (vi, _) in enumerate(_config.LMUL_TIERS_I8_WIDENING):\n            if vi == v_inner:\n                return _I8_LABELS[idx] if idx < len(_I8_LABELS) else f\"V={v_inner}\"\n    # f32 tiers (LMUL1..LMUL8)\n    for idx, (vi, _) in enumerate(_config.LMUL_TIERS_F32):\n        if vi == v_inner:\n            return f\"LMUL{1 << idx}\"\n    return f\"V={v_inner}\"\n\n\ndef compute_v_outer_candidates(max_v_outer: int, dim_M: int) -> List[int]:\n    \"\"\"Compute V_outer candidates with optional filtering.\n\n    Default: 2 candidates (max_v_outer + max divisor of M <= max_v_outer).\n    Exhaustive (V_OUTER_EXHAUSTIVE=True): all values 1..effective_max.\n\n    Filtering options (applied after candidate generation):\n    - REQUIRE_V_OUTER_DIVIDES_M: Only keep divisors of dim_M\n    - Parity matching: odd dim_M keeps only odd v_outer, even dim_M keeps only even v_outer\n    - V_OUTER_EXCLUDE: Remove explicitly excluded values\n    - V_OUTER_MIN: Remove values below minimum\n\n    Args:\n        max_v_outer: Maximum non-spilling V_outer from probe stage.\n        dim_M: Size of the outer parallel dimension (M).\n\n    Returns:\n        Sorted list of unique candidates after filtering.\n    \"\"\"\n    effective_max = min(max_v_outer, dim_M)\n\n    # Generate base candidates\n    if _config.V_OUTER_EXHAUSTIVE:\n        candidates = set(range(1, effective_max + 1)) if effective_max >= 1 else set()\n    else:\n        candidates = set()\n        candidates.add(effective_max)\n        # Find max divisor of dim_M that fits within max_v_outer\n        for d in range(effective_max, 0, -1):\n            if dim_M % d == 0:\n                candidates.add(d)\n                break\n\n    # Apply filters\n    if _config.REQUIRE_V_OUTER_DIVIDES_M:\n        candidates = {v for v in candidates if dim_M % v == 0}\n\n    # Parity matching: odd dim_M → odd v_outer, even dim_M → even v_outer\n    parity = dim_M % 2\n    candidates = {v for v in candidates if v % 2 == parity}\n\n    if _config.V_OUTER_EXCLUDE:\n        candidates = {v for v in candidates if v not in _config.V_OUTER_EXCLUDE}\n\n    if _config.V_OUTER_MIN > 1:\n        candidates = {v for v in candidates if v >= _config.V_OUTER_MIN}\n\n    return sorted(candidates) if candidates else [0]\n\n\ndef _is_prime(n):\n    \"\"\"Return True if n is a prime number.\"\"\"\n    if n < 2:\n        return False\n    if n < 4:\n        return True\n    if n % 2 == 0 or n % 3 == 0:\n        return False\n    i = 5\n    while i * i <= n:\n        if n % i == 0 or n % (i + 2) == 0:\n            return False\n        i += 6\n    return True\n\n\ndef generate_distribution_configs(\n    v_inner: int,\n    v_outer: int,\n    dim_inner: int,\n    dim_outer: int,\n    output_element_bytes: int = 4,\n    l2_targets: Optional[List[int]] = None,\n) -> List[Tuple[int, int]]:\n    \"\"\"Generate (dist_outer, dist_inner) pairs: 1 per L2 target.\n\n    Strategy: maximize dist_inner (N dimension), reduce dist_outer (M) to fit\n    L2 budget, avoid prime dist_outer.\n\n    All values snapped to V_inner grid and <= dim size.\n    Deduplicated across L2 targets.\n\n    Args:\n        v_inner: Vector inner tile size.\n        v_outer: Vector outer tile size.\n        dim_inner: Inner parallel dimension size.\n        dim_outer: Outer parallel dimension size.\n        output_element_bytes: Bytes per output element (default 4 for f32/i32).\n        l2_targets: L2 utilization targets in bytes. Defaults to config.L2_TARGETS.\n\n    Returns:\n        List of (dist_outer, dist_inner) pairs.\n    \"\"\"\n    if l2_targets is None:\n        l2_targets = _config.L2_TARGETS\n\n    if v_inner <= 0 or v_outer <= 0:\n        return [(min(1, dim_outer), min(1, dim_inner))]\n\n    seen = set()\n    pairs = []\n\n    for l2_budget in l2_targets:\n        max_elements = l2_budget // output_element_bytes\n\n        # Maximize dist_inner (N dimension), snap to v_inner grid\n        d_inner_mult = min(dim_inner, max_elements) // v_inner\n        if d_inner_mult < 1:\n            d_inner_mult = 1\n        d_inner = min(v_inner * d_inner_mult, dim_inner)\n\n        # Reduce dist_outer (M dimension) to fit L2 budget\n        remaining = max_elements // d_inner if d_inner > 0 else 1\n        d_outer = min(remaining, dim_outer)\n        # Avoid prime dist_outer: if prime and >2, decrement to nearest even\n        if d_outer > 2 and _is_prime(d_outer):\n            d_outer -= 1\n\n        key = (d_outer, d_inner)\n        if key not in seen:\n            seen.add(key)\n            pairs.append(key)\n\n    if not pairs:\n        return [(min(v_outer, dim_outer), min(v_inner, dim_inner))]\n\n    return pairs\n\n\ndef snap_to_grid(target: int, v_step: int) -> int:\n    \"\"\"\n    Snap a target value to the nearest multiple of v_step.\n\n    Mult = max(1, round(target / v_step)), return v_step * Mult.\n    \"\"\"\n    mult = max(1, round(target / v_step))\n    return v_step * mult\n\n\ndef calculate_vector_size_bytes(\n    tile_sizes: List[int],\n    dim_sizes: List[int],\n    dtype: str = 'f32',\n    iterator_types: Optional[List[str]] = None\n) -> int:\n    \"\"\"\n    Calculate effective vector size in bytes for a vector-level tiling config.\n\n    At the vector level, tile_size=0 means \"use full dimension\" (not tiled),\n    which uses the actual dimension size for the calculation.\n\n    For integer types (i8, i16) with reduction dimensions, uses accumulator\n    type (i32) for size calculation since reductions accumulate to wider types.\n    Element-wise ops (no reduction) use the original dtype.\n\n    Args:\n        tile_sizes: Tile sizes for each dimension (0 means use full dim_size)\n        dim_sizes: Actual dimension sizes\n        dtype: Data type string (e.g., 'f32', 'i8')\n        iterator_types: Optional list of iterator types ('parallel' or 'reduction')\n\n    Returns:\n        Vector size in bytes\n    \"\"\"\n    if len(tile_sizes) != len(dim_sizes):\n        return 0\n\n    # Check if there are reduction dimensions (need accumulator type for integers)\n    has_reduction = False\n    if iterator_types:\n        has_reduction = any(t == 'reduction' for t in iterator_types)\n\n    # Use accumulator type for small integers only when there are reductions\n    if has_reduction:\n        acc_dtype = ACCUMULATOR_DTYPE.get(dtype, dtype)\n    else:\n        acc_dtype = dtype\n    element_bytes = DTYPE_BYTES.get(acc_dtype, 4)\n\n    num_elements = 1\n    for tile, dim in zip(tile_sizes, dim_sizes):\n        # tile=0 means use full dimension size\n        effective_tile = tile if tile > 0 else dim\n        num_elements *= effective_tile\n\n    return num_elements * element_bytes\n\n\ndef is_valid_vector_config(\n    config: List[List[int]],\n    dim_sizes: List[int],\n    dtype: str = 'f32',\n    max_vector_bytes: int = None,\n    iterator_types: Optional[List[str]] = None\n) -> bool:\n    \"\"\"\n    Check if a tiling configuration produces valid vector sizes.\n\n    Validates that the vector-level tiles don't exceed IREE's maximum\n    allowed vector size (65536 bytes by default).\n\n    Checks BOTH vector parallel and vector reduction levels:\n    - 4-level: L1 (vector parallel) + L2 (vector reduction)\n    - 6-level: L3 (vector outer) + L4 (vector reduction)\n\n    Args:\n        config: List of tile size lists for each level\n        dim_sizes: Actual dimension sizes\n        dtype: Data type string\n        max_vector_bytes: Maximum allowed vector size in bytes\n        iterator_types: Optional list of iterator types ('parallel' or 'reduction')\n\n    Returns:\n        True if configuration is valid, False otherwise\n    \"\"\"\n    if max_vector_bytes is None:\n        max_vector_bytes = _config.IREE_MAX_VECTOR_BYTES\n    num_levels = len(config)\n\n    # Vector parallel level: L1 for 4-level, L3 for 6-level\n    # Vector reduction level: L2 for 4-level, L4 for 6-level\n    if num_levels == 4:\n        vec_parallel_level, vec_reduction_level = 1, 2\n    elif num_levels == 6:\n        vec_parallel_level, vec_reduction_level = 3, 4\n    else:\n        return True\n\n    if vec_reduction_level >= num_levels:\n        return True\n\n    vec_parallel = config[vec_parallel_level]\n    vec_reduction = config[vec_reduction_level]\n\n    # Combine tiles: parallel dims from vec_parallel, reduction dims from vec_reduction\n    # For each dim, one level has the tile value, the other has 0\n    # Take the non-zero value (or 0 if both are 0, which means full dim)\n    combined_tiles = []\n    for p, r in zip(vec_parallel, vec_reduction):\n        # Use whichever is non-zero; if both 0, stay 0 (will use full dim)\n        combined_tiles.append(p if p > 0 else r)\n\n    vector_bytes = calculate_vector_size_bytes(combined_tiles, dim_sizes, dtype, iterator_types)\n\n    return vector_bytes < max_vector_bytes\n\n\ndef get_divisors(n: int, max_val: int = None) -> List[int]:\n    \"\"\"Get all divisors of n, optionally limited by max_val.\"\"\"\n    if n <= 0:\n        return []\n    divisors = set()\n    for i in range(1, int(math.sqrt(n)) + 1):\n        if n % i == 0:\n            divisors.add(i)\n            divisors.add(n // i)\n    if max_val:\n        divisors = {d for d in divisors if d <= max_val}\n    return sorted(divisors)\n\n\ndef is_valid_vector_parallel_tiling(\n    vector_parallel_level: List[int],\n    parallel_dims: List[int]\n) -> bool:\n    \"\"\"\n    Check if vector parallel tiling is valid.\n\n    Remove configs where inner-most parallel dimension is 1 unless all other\n    parallel dimensions are also 1.\n    e.g., [2, 1] => invalid (remove), [1, 1] => valid (keep), [2, 4] => valid\n    \"\"\"\n    if not parallel_dims:\n        return True\n\n    # Get the parallel dimension values from the tiling level\n    parallel_values = [vector_parallel_level[i] for i in parallel_dims]\n\n    # Inner-most parallel dimension is the last one\n    inner_most_value = parallel_values[-1]\n    other_values = parallel_values[:-1]\n\n    # If inner-most is 1, check if all others are also 1\n    if inner_most_value == 1 and other_values:\n        # If any other value is not 1, this config is invalid\n        if any(v != 1 for v in other_values):\n            return False\n\n    return True\n\n\ndef generate_l0_distribution_options(\n    iterator_types: List[str],\n    dim_sizes: List[int],\n    num_operands: int = 2,\n) -> List[List[int]]:\n    \"\"\"\n    Generate L0 distribution level tiling options (cache-aware).\n\n    All parallel dimensions share the same tile size T chosen from multiples\n    of 64 that fit in cache. For dimensions where T doesn't divide evenly,\n    use the largest factor of D below T instead.\n\n    Cache constraint: T^num_parallel_dims * element_size * num_operands <= CACHE_SIZE_BYTES\n    Element size is always 4 bytes (f32, or i32 accumulator for i8->i32 quantized).\n\n    Rules per parallel dimension D:\n    - D < 64: candidates = {D}\n    - D >= 64: candidates = {multiples of 64 that divide D} filtered to <= D\n      If no multiple of 64 divides D: use largest factor of D below 64\n      Always include D itself\n\n    All parallel dims use the same T; if T doesn't divide D, that dim uses\n    the largest factor of D that is <= T.\n\n    Returns:\n        List of L0 tile size lists (one per option).\n    \"\"\"\n    ndims = len(iterator_types)\n    parallel_dims = [i for i, t in enumerate(iterator_types) if t == 'parallel']\n\n    if not parallel_dims:\n        return [[0] * ndims]\n\n    # Always use 4 bytes: f32 or i32 accumulator for i8->i32 quantized ops\n    element_size = 4\n    num_parallel = len(parallel_dims)\n\n    # Compute max T that fits in cache: T^num_parallel * element_size * num_operands <= cache\n    num_operands = max(num_operands, 1)\n    max_tile_elements = _config.CACHE_SIZE_BYTES / (element_size * num_operands)\n    max_T = int(max_tile_elements ** (1.0 / num_parallel)) if num_parallel > 0 else 2048\n\n    # Parallel dimension sizes\n    parallel_sizes = [dim_sizes[i] for i in parallel_dims]\n    min_parallel_size = min(parallel_sizes)\n\n    # Cap T to min parallel dim size and cache limit\n    T_cap = min(min_parallel_size, max_T)\n\n    # Collect shared T candidates from multiples of 64\n    shared_T_candidates = set()\n    for m64 in _config.DIST_MULTIPLES_OF_64:\n        if m64 <= T_cap:\n            shared_T_candidates.add(m64)\n\n    l0_options = []\n\n    # For each shared T, compute per-dimension tile sizes\n    for T in sorted(shared_T_candidates):\n        l0 = [0] * ndims\n        for idx in parallel_dims:\n            D = dim_sizes[idx]\n            if D % T == 0:\n                l0[idx] = T\n            else:\n                # Find largest factor of D that is <= T\n                factors = get_divisors(D, max_val=T)\n                l0[idx] = factors[-1] if factors else T\n        l0_options.append(l0)\n\n    # If no multiple of 64 divides min_parallel_size and min_parallel_size >= 64,\n    # add fallback: largest factor of each dim below 64\n    has_exact_m64 = any(min_parallel_size % m64 == 0 for m64 in _config.DIST_MULTIPLES_OF_64\n                        if m64 <= min_parallel_size)\n    if not has_exact_m64 and min_parallel_size >= 64:\n        l0 = [0] * ndims\n        for idx in parallel_dims:\n            D = dim_sizes[idx]\n            factors_below_64 = [f for f in get_divisors(D) if f < 64]\n            l0[idx] = max(factors_below_64) if factors_below_64 else D\n        l0_options.append(l0)\n\n    # Always add D itself for each parallel dim (max tile = full dimension)\n    l0_full = [0] * ndims\n    for idx in parallel_dims:\n        l0_full[idx] = dim_sizes[idx]\n    l0_options.append(l0_full)\n\n    # Deduplicate\n    seen = set()\n    unique_options = []\n    for l0 in l0_options:\n        key = tuple(l0)\n        if key not in seen:\n            seen.add(key)\n            unique_options.append(l0)\n\n    return unique_options\n\n\ndef is_6level_op(op_name: str) -> bool:\n    \"\"\"Check if an operation uses 6-level tiling.\"\"\"\n    return op_name in SIX_LEVEL_OPS\n\n\ndef get_num_levels(op_name: str) -> int:\n    \"\"\"Get the number of tiling levels for an operation.\"\"\"\n    return 6 if is_6level_op(op_name) else 4\n\n\ndef is_valid_conv_config(config: List[List[int]], op_name: str,\n                         dim_sizes: List[int] = None) -> bool:\n    \"\"\"\n    Check if a tiling configuration is valid for convolution decomposition.\n\n    IREE's CPUConvTileAndDecomposeExpert requires that after applying all\n    tiling levels, at least one spatial dimension (H or W) has BOTH the\n    kernel size AND output size reduced to 1, so the conv can be decomposed\n    into a simpler operation (e.g., matmul).\n\n    Additionally, the innermost parallel dimension (output channels C) must\n    have a tile size > 1 at the vector level to enable vectorization.\n\n    Args:\n        config: 4-level tiling configuration\n        op_name: Name of the operation (e.g., 'linalg.conv_2d_nhwc_hwcf')\n        dim_sizes: Original dimension sizes for the operation\n\n    Returns:\n        True if the configuration is valid for conv decomposition\n    \"\"\"\n    op_lower = op_name.lower()\n    if 'conv' not in op_lower and 'pooling' not in op_lower:\n        return True\n\n    # For conv ops, check L1 (vector parallel level)\n    # The innermost parallel dimension (typically position 3 for NHWC - channels)\n    # needs a tile size > 1 to enable vectorization\n    l1 = config[1]  # Vector parallel level\n    if 'conv' in op_lower:\n        if len(l1) >= 4:\n            innermost_parallel = l1[3]  # C dimension for NHWC formats\n            if innermost_parallel <= 1:\n                return False\n\n    # Simulate IREE's verifyConvTileAndDecomposeExpertConfig:\n    # Apply all tiling levels to the original shape, then check that at least\n    # one spatial dim has both kernel and output reduced to 1.\n    if dim_sizes is None:\n        return True\n\n    shape = list(dim_sizes)\n    for level in config:\n        for i, size in enumerate(level):\n            if i >= len(shape):\n                break\n            if size == 1:\n                shape[i] = 1\n            if shape[i] == -1 or size == 0:\n                continue\n            if shape[i] % size != 0:\n                shape[i] = -1\n            else:\n                shape[i] = size\n\n    # Determine KH, KW, OH, OW indices based on operation type\n    if 'conv_2d_nhwc_hwcf' in op_lower or 'depthwise_conv_2d_nhwc_hwc' in op_lower:\n        # Dims: [N, OH, OW, OC, KH, KW, (IC)]\n        if len(shape) >= 6:\n            oh, ow = shape[1], shape[2]\n            kh, kw = shape[4], shape[5]\n            remove_h = (kh == 1 and oh == 1)\n            remove_w = (kw == 1 and ow == 1)\n            if not remove_h and not remove_w:\n                return False\n    elif 'conv_2d_nchw_fchw' in op_lower:\n        # Dims: [N, OC, OH, OW, (IC), KH, KW]\n        if len(shape) >= 7:\n            oh, ow = shape[2], shape[3]\n            kh, kw = shape[5], shape[6]\n            remove_h = (kh == 1 and oh == 1)\n            remove_w = (kw == 1 and ow == 1)\n            if not remove_h and not remove_w:\n                return False\n    elif 'pooling_nhwc' in op_lower:\n        # Dims: [N, OH, OW, OC, KH, KW]\n        if len(shape) >= 6:\n            oh, ow = shape[1], shape[2]\n            kh, kw = shape[4], shape[5]\n            remove_h = (kh == 1 and oh == 1)\n            remove_w = (kw == 1 and ow == 1)\n            if not remove_h and not remove_w:\n                return False\n    elif 'pooling_nchw' in op_lower:\n        # Dims: [N, OC, OH, OW, KH, KW]\n        if len(shape) >= 6:\n            oh, ow = shape[2], shape[3]\n            kh, kw = shape[4], shape[5]\n            remove_h = (kh == 1 and oh == 1)\n            remove_w = (kw == 1 and ow == 1)\n            if not remove_h and not remove_w:\n                return False\n\n    return True\n\n\ndef generate_configs_4level(\n    iterator_types: List[str],\n    dim_sizes: List[int],\n    output_dtype: str = 'f32',\n    max_configs: int = 100000,\n    op_name: str = '',\n    num_operands: int = 2,\n    input_dtype: str = 'f32',\n) -> List[List[List[int]]]:\n    \"\"\"\n    Generate valid 4-level tiling configurations using LMUL-based pruning.\n\n    4-Level Structure:\n    - L0: Distribution (L2 targets x 3 aspect ratios)\n    - L1: Vector parallel (LMUL-based V_inner/V_outer)\n    - L2: Vector reduction (K-peeling)\n    - L3: All zeros (inner)\n    \"\"\"\n    ndims = len(iterator_types)\n    parallel_dims = [i for i, t in enumerate(iterator_types) if t == 'parallel']\n    reduction_dims = [i for i, t in enumerate(iterator_types) if t == 'reduction']\n\n    if not parallel_dims:\n        return [[[0] * ndims, [0] * ndims, [0] * ndims, [0] * ndims]]\n\n    inner_parallel = parallel_dims[-1]\n    second_inner = parallel_dims[-2] if len(parallel_dims) > 1 else None\n\n    N = dim_sizes[inner_parallel]\n    lmul_tiers = get_lmul_vector_tiles(N, input_dtype)\n\n    # K-peel on inner-most reduction dim only\n    inner_reduction = reduction_dims[-1] if reduction_dims else None\n    if inner_reduction is not None:\n        base_k_peel = list(_config.K_PEEL_CANDIDATES)\n        if N < _config.SMALL_N_THRESHOLD:\n            base_k_peel = sorted(set(base_k_peel + [_config.SMALL_N_K_PEEL]))\n        k_peel_cands = [k for k in base_k_peel if k <= dim_sizes[inner_reduction]]\n        if not k_peel_cands:\n            k_peel_cands = [1]\n    else:\n        k_peel_cands = []\n\n    is_conv = 'conv' in op_name.lower() or 'pooling' in op_name.lower()\n\n    seen = set()\n    configs = []\n    l3 = [0] * ndims\n\n    for v_inner, v_outer_max in lmul_tiers:\n        # Use tier table max for 4-level (no per-dist probing for 4-level ops)\n        max_vo = v_outer_max\n\n        # Compute V_outer candidates\n        if second_inner is not None:\n            dim_M = dim_sizes[second_inner]\n            v_outer_list = compute_v_outer_candidates(max_vo, dim_M)\n        else:\n            v_outer_list = [1]\n\n        for v_outer in v_outer_list:\n            dim_inner = dim_sizes[inner_parallel]\n            dim_outer = dim_sizes[second_inner] if second_inner is not None else 1\n\n            dist_pairs = generate_distribution_configs(\n                v_inner, v_outer, dim_inner, dim_outer)\n\n            for dist_outer, dist_inner in dist_pairs:\n                # Build L0 (other parallel dims = 0)\n                l0 = [0] * ndims\n                l0[inner_parallel] = dist_inner\n                if second_inner is not None:\n                    l0[second_inner] = dist_outer\n\n                # Build L1 (vec parallel, other parallel dims = 1)\n                l1_base = [0] * ndims\n                l1_base[inner_parallel] = v_inner\n                if second_inner is not None:\n                    l1_base[second_inner] = v_outer\n                for idx in parallel_dims:\n                    if idx != inner_parallel and idx != second_inner:\n                        l1_base[idx] = 1\n\n                # K-peeling on inner-most reduction dim\n                if k_peel_cands:\n                    for k_val in k_peel_cands:\n                        l2 = [0] * ndims\n                        l2[inner_reduction] = k_val\n                        if is_conv:\n                            for r_idx in reduction_dims:\n                                if r_idx != inner_reduction:\n                                    l2[r_idx] = 1\n                        config = [l0[:], l1_base[:], l2, l3[:]]\n                        if (is_valid_vector_config(config, dim_sizes, output_dtype) and\n                                is_valid_conv_config(config, op_name, dim_sizes)):\n                            key = tuple(tuple(lev) for lev in config)\n                            if key not in seen:\n                                seen.add(key)\n                                configs.append(config)\n                                if len(configs) >= max_configs:\n                                    return configs\n                else:\n                    # No reduction dims (element-wise)\n                    l2 = [0] * ndims\n                    config = [l0[:], l1_base[:], l2, l3[:]]\n                    if (is_valid_vector_config(config, dim_sizes, output_dtype) and\n                            is_valid_conv_config(config, op_name, dim_sizes)):\n                        key = tuple(tuple(lev) for lev in config)\n                        if key not in seen:\n                            seen.add(key)\n                            configs.append(config)\n                            if len(configs) >= max_configs:\n                                return configs\n\n    return configs\n\n\ndef generate_configs_6level(\n    iterator_types: List[str],\n    dim_sizes: List[int],\n    output_dtype: str = 'f32',\n    max_configs: int = 100000,\n    num_operands: int = 2,\n    input_dtype: str = 'f32',\n) -> List[List[List[int]]]:\n    \"\"\"\n    Generate valid 6-level tiling configurations using LMUL-based pruning.\n\n    6-Level Structure:\n    - L0 = L1: Distribution (L2 targets x 3 aspect ratios)\n    - L2: All zeros (cache level)\n    - L3: Vector parallel (LMUL-based V_inner/V_outer)\n    - L4: Vector reduction (K-peeling)\n    - L5: All zeros (inner)\n    \"\"\"\n    ndims = len(iterator_types)\n    parallel_dims = [i for i, t in enumerate(iterator_types) if t == 'parallel']\n    reduction_dims = [i for i, t in enumerate(iterator_types) if t == 'reduction']\n\n    if not parallel_dims:\n        return [[[0] * ndims for _ in range(6)]]\n\n    inner_parallel = parallel_dims[-1]\n    second_inner = parallel_dims[-2] if len(parallel_dims) > 1 else None\n\n    N = dim_sizes[inner_parallel]\n    lmul_tiers = get_lmul_vector_tiles(N, input_dtype)\n\n    # K-peel on inner-most reduction dim only\n    inner_reduction = reduction_dims[-1] if reduction_dims else None\n    if inner_reduction is not None:\n        base_k_peel = list(_config.K_PEEL_CANDIDATES)\n        if N < _config.SMALL_N_THRESHOLD:\n            base_k_peel = sorted(set(base_k_peel + [_config.SMALL_N_K_PEEL]))\n        k_peel_cands = [k for k in base_k_peel if k <= dim_sizes[inner_reduction]]\n        if not k_peel_cands:\n            k_peel_cands = [1]\n    else:\n        k_peel_cands = []\n\n    seen = set()\n    configs = []\n    l2 = [0] * ndims\n    l5 = [0] * ndims\n\n    for v_inner, v_outer_max in lmul_tiers:\n        # Use tier table max for 4-level (no per-dist probing for 4-level ops)\n        max_vo = v_outer_max\n\n        # Compute V_outer candidates\n        if second_inner is not None:\n            dim_M = dim_sizes[second_inner]\n            v_outer_list = compute_v_outer_candidates(max_vo, dim_M)\n        else:\n            v_outer_list = [1]\n\n        for v_outer in v_outer_list:\n            dim_inner = dim_sizes[inner_parallel]\n            dim_outer = dim_sizes[second_inner] if second_inner is not None else 1\n\n            dist_pairs = generate_distribution_configs(\n                v_inner, v_outer, dim_inner, dim_outer)\n\n            for dist_outer, dist_inner in dist_pairs:\n                # Build L0 = L1 (other parallel dims = 0)\n                l0 = [0] * ndims\n                l0[inner_parallel] = dist_inner\n                if second_inner is not None:\n                    l0[second_inner] = dist_outer\n                l1 = l0[:]\n\n                # Build L3 (vec parallel, other parallel dims = 1)\n                l3_base = [0] * ndims\n                l3_base[inner_parallel] = v_inner\n                if second_inner is not None:\n                    l3_base[second_inner] = v_outer\n                for idx in parallel_dims:\n                    if idx != inner_parallel and idx != second_inner:\n                        l3_base[idx] = 1\n\n                # K-peeling on inner-most reduction dim only\n                if k_peel_cands:\n                    for k_val in k_peel_cands:\n                        l4 = [0] * ndims\n                        l4[inner_reduction] = k_val\n                        config = [l0[:], l1[:], l2[:], l3_base[:], l4, l5[:]]\n                        if is_valid_vector_config(config, dim_sizes, output_dtype):\n                            key = tuple(tuple(lev) for lev in config)\n                            if key not in seen:\n                                seen.add(key)\n                                configs.append(config)\n                                if len(configs) >= max_configs:\n                                    return configs\n                else:\n                    l4 = [0] * ndims\n                    config = [l0[:], l1[:], l2[:], l3_base[:], l4, l5[:]]\n                    if is_valid_vector_config(config, dim_sizes, output_dtype):\n                        key = tuple(tuple(lev) for lev in config)\n                        if key not in seen:\n                            seen.add(key)\n                            configs.append(config)\n                            if len(configs) >= max_configs:\n                                return configs\n\n    return configs\n\n\ndef get_dim_sizes_from_shape_pattern(\n    op_name: str,\n    iterator_types: List[str],\n    shape_pattern: Dict\n) -> List[int]:\n    \"\"\"Extract dimension sizes from shape pattern based on operation type.\"\"\"\n    inputs = shape_pattern.get('inputs', [])\n    outputs = shape_pattern.get('outputs', [])\n    all_dims = shape_pattern.get('all_dims', [])\n    ndims = len(iterator_types)\n\n    if 'conv_2d_nhwc_hwcf' in op_name:\n        if outputs:\n            out_shape = outputs[0]['shape']\n            kernel_shape = inputs[1]['shape'] if len(inputs) > 1 else [3, 3, 3, 64]\n            return [out_shape[0], out_shape[1], out_shape[2], out_shape[3],\n                    kernel_shape[0], kernel_shape[1], kernel_shape[2]]\n\n    elif 'depthwise_conv_2d_nhwc_hwc' in op_name:\n        if outputs:\n            out_shape = outputs[0]['shape']\n            kernel_shape = inputs[1]['shape'] if len(inputs) > 1 else [3, 3, 144]\n            return [out_shape[0], out_shape[1], out_shape[2], out_shape[3],\n                    kernel_shape[0], kernel_shape[1]]\n\n    elif 'pooling_nhwc' in op_name:\n        if outputs:\n            out_shape = outputs[0]['shape']\n            pool_shape = inputs[1]['shape'] if len(inputs) > 1 else [3, 3]\n            return [out_shape[0], out_shape[1], out_shape[2], out_shape[3],\n                    pool_shape[0], pool_shape[1]]\n\n    elif op_name == 'linalg.matmul':\n        if inputs and len(inputs) >= 2:\n            a_shape = inputs[0]['shape']\n            b_shape = inputs[1]['shape']\n            return [a_shape[0], b_shape[1], a_shape[1]]\n\n    elif op_name == 'linalg.batch_matmul':\n        if inputs and len(inputs) >= 2:\n            a_shape = inputs[0]['shape']\n            b_shape = inputs[1]['shape']\n            return [a_shape[0], a_shape[1], b_shape[2], a_shape[2]]\n\n    elif op_name == 'linalg.vecmat':\n        if inputs and len(inputs) >= 2:\n            a_shape = inputs[0]['shape']\n            b_shape = inputs[1]['shape']\n            return [b_shape[1], b_shape[0]]\n\n    elif op_name == 'linalg.matvec':\n        if inputs and len(inputs) >= 2:\n            a_shape = inputs[0]['shape']\n            b_shape = inputs[1]['shape']\n            return [a_shape[0], a_shape[1]]\n\n    # Fallback: use lowering_config tile_sizes dimensions\n    lowering_config = shape_pattern.get('lowering_config', {})\n    if lowering_config:\n        tile_sizes = lowering_config.get('tile_sizes', [[]])\n        if tile_sizes and tile_sizes[0]:\n            ndims_from_tiles = len(tile_sizes[0])\n            if ndims_from_tiles == ndims:\n                return [max(64, t * 4) if t > 0 else 64 for t in tile_sizes[0]]\n\n    # Last resort: use all_dims or generate defaults\n    if all_dims and len(all_dims) >= ndims:\n        return [d if d is not None and d > 0 else 64 for d in all_dims[:ndims]]\n\n    return [64] * ndims\n\n\ndef get_dtype_from_pattern(shape_pattern: Dict) -> Tuple[str, str]:\n    \"\"\"Extract input and output dtypes from shape pattern.\"\"\"\n    if shape_pattern is None:\n        return 'f32', 'f32'\n\n    inputs = shape_pattern.get('inputs', [])\n    outputs = shape_pattern.get('outputs', [])\n\n    input_dtype = 'f32'\n    output_dtype = 'f32'\n\n    if inputs and inputs[0]:\n        input_dtype = inputs[0].get('dtype', 'f32')\n    if outputs and outputs[0]:\n        output_dtype = outputs[0].get('dtype', 'f32')\n\n    return input_dtype, output_dtype\n\n\ndef create_pattern_id(shape_pattern: Dict, op_name: str) -> str:\n    \"\"\"Create a unique identifier for a shape pattern.\"\"\"\n    if shape_pattern is None:\n        return \"unknown\"\n\n    inputs = shape_pattern.get('inputs', [])\n    outputs = shape_pattern.get('outputs', [])\n\n    if outputs and outputs[0] and 'shape' in outputs[0]:\n        shape_str = 'x'.join(str(d) for d in outputs[0]['shape'])\n        dtype = outputs[0].get('dtype', 'f32')\n        return f\"{shape_str}_{dtype}\"\n    elif inputs and inputs[0] and 'shape' in inputs[0]:\n        shape_str = 'x'.join(str(d) for d in inputs[0]['shape'])\n        dtype = inputs[0].get('dtype', 'f32')\n        return f\"{shape_str}_{dtype}\"\n\n    return \"unknown\"\n\n\ndef _get_dim_label(idx: int, iterator_types: List[str]) -> str:\n    \"\"\"Return a role-based label for a dimension index.\n\n    For parallel dims: innermost='N(inner)', second-inner='M(outer)',\n    third='B(batch)'. For reduction dims: 'K(reduction)'.\n    Additional reduction dims get 'K2(reduction)', etc.\n    \"\"\"\n    parallel_dims = [i for i, t in enumerate(iterator_types) if t == 'parallel']\n    reduction_dims = [i for i, t in enumerate(iterator_types) if t == 'reduction']\n\n    if idx in parallel_dims:\n        rank = len(parallel_dims) - 1 - parallel_dims.index(idx)\n        if rank == 0:\n            return \"N(inner)\"\n        elif rank == 1:\n            return \"M(outer)\"\n        else:\n            return \"B(batch)\"\n    elif idx in reduction_dims:\n        r_rank = reduction_dims.index(idx)\n        if r_rank == 0 and len(reduction_dims) == 1:\n            return \"K(reduction)\"\n        else:\n            return f\"K{r_rank + 1}(reduction)\" if len(reduction_dims) > 1 else \"K(reduction)\"\n    return f\"d{idx}\"\n\n\ndef format_search_space_header(\n    op_name: str,\n    iterator_types: List[str],\n    dim_sizes: List[int],\n    input_dtype: str,\n    num_levels: int,\n) -> str:\n    \"\"\"\n    Generate a # comment header block for a search space file.\n\n    Includes op name, strategy, iterator types, labeled dimension sizes,\n    dtype, K-peel candidates, and level format description.\n    \"\"\"\n    strategy_name = \"dist_vector\"\n    dim_labels = []\n    for i, (it, ds) in enumerate(zip(iterator_types, dim_sizes)):\n        label = _get_dim_label(i, iterator_types)\n        dim_labels.append(f\"{label}={ds}\")\n\n    if num_levels == 6:\n        fmt = \"[L0:distribution, L1:distribution, L2:cache, L3:vec_parallel, L4:vec_reduction, L5:inner]\"\n    else:\n        fmt = \"[L0:distribution, L1:vec_parallel, L2:vec_reduction, L3:inner]\"\n\n    # Compute effective k_peel candidates (includes small-N extra value)\n    k_peel = list(_config.K_PEEL_CANDIDATES) if _config.K_PEEL_CANDIDATES else [1]\n    parallel_dims = [i for i, t in enumerate(iterator_types) if t == 'parallel']\n    if parallel_dims:\n        inner_parallel_idx = parallel_dims[-1]\n        N = dim_sizes[inner_parallel_idx]\n        if _config.SMALL_N_THRESHOLD and N < _config.SMALL_N_THRESHOLD and _config.SMALL_N_K_PEEL:\n            k_peel = sorted(set(k_peel + [_config.SMALL_N_K_PEEL]))\n\n    lines = [\n        f\"# Op: {op_name}\",\n        f\"# Strategy: {strategy_name}\",\n        f\"# Iterator types: {iterator_types}\",\n        f\"# Dim sizes: {', '.join(dim_labels)}\",\n        f\"# Input dtype: {input_dtype}\",\n        f\"# K-peel candidates: {k_peel}\",\n        f\"# Format: {fmt}\",\n        \"#\",\n    ]\n\n    return '\\n'.join(lines)\n\n\ndef _write_configs(f, configs, strategy):\n    \"\"\"Write configs to file, with optional dist group headers.\n\n    If the strategy has config_groups (from DistVectorStrategy), writes\n    group headers before each group's configs. Otherwise writes configs flat.\n    \"\"\"\n    config_groups = getattr(strategy, 'config_groups', None)\n\n    if config_groups:\n        from .strategy_dist_vector import format_dist_group_header\n        for group in config_groups:\n            f.write(format_dist_group_header(group) + '\\n')\n            for idx in range(group['start_idx'], group['end_idx']):\n                f.write(f\"{idx}: \" + json.dumps(configs[idx], separators=(',', ':')) + '\\n')\n        # Clean up config_groups after writing\n        strategy.config_groups = None\n    else:\n        for idx, config in enumerate(configs):\n            f.write(f\"{idx}: \" + json.dumps(config, separators=(',', ':')) + '\\n')\n\n\ndef _get_default_tile_config(pattern: Dict) -> Optional[List]:\n    \"\"\"Extract default tile config from pattern dict.\n\n    Looks for 'default_tile_config' (renamed by assign_pattern_ids) or\n    'lowering_config.tile_sizes' (original field from MLIR analysis).\n\n    Returns:\n        Tile config list, or None if not available.\n    \"\"\"\n    if 'default_tile_config' in pattern:\n        dtc = pattern['default_tile_config']\n        if isinstance(dtc, dict):\n            return dtc.get('tile_sizes')\n        return dtc\n    lc = pattern.get('lowering_config')\n    if lc and isinstance(lc, dict):\n        return lc.get('tile_sizes')\n    return None\n\n\ndef _generate_pattern_configs_worker(args):\n    \"\"\"Worker function: generate configs for a single pattern.\n\n    This function is designed to be serializable for multiprocessing.\n    The probe_fn is created inside the worker to avoid pickling issues.\n\n    Args:\n        args: Tuple of (op_name, pattern, pattern_idx, output_dir, iterator_types,\n              max_configs, probe_fn_factory, is_generic, verbose, template,\n              [is_fused, primary_op, extra_inputs_spec, fused_id])\n\n    Returns:\n        Dict with result info: op_name, pattern_idx, config_count, output_file, error\n    \"\"\"\n    from .strategy_dist_vector import DistVectorStrategy\n\n    # Unpack with backward-compatible defaults for fused fields\n    is_fused = False\n    primary_op = None\n    extra_inputs_spec = []\n    fused_id = None\n    if len(args) > 10:\n        (\n            op_name, pattern, pattern_idx, output_dir, iterator_types,\n            max_configs, probe_fn_factory, is_generic, verbose, template,\n            is_fused, primary_op, extra_inputs_spec, fused_id\n        ) = args\n    else:\n        (\n            op_name, pattern, pattern_idx, output_dir, iterator_types,\n            max_configs, probe_fn_factory, is_generic, verbose, template\n        ) = args\n\n    try:\n        # Extract pattern info\n        if is_generic:\n            # Generic ops use tile_sizes to infer dim_sizes\n            lowering_config = pattern.get('lowering_config', {}) or {}\n            tile_sizes = lowering_config.get('tile_sizes', [[]])\n\n            if tile_sizes and tile_sizes[0]:\n                dim_sizes = [max(64, t * 4) if t > 0 else 64 for t in tile_sizes[0]]\n            else:\n                dim_sizes = [64] * len(iterator_types)\n        elif is_fused:\n            # Fused ops use primary_op for dim extraction (same shapes)\n            dim_sizes = get_dim_sizes_from_shape_pattern(primary_op, iterator_types, pattern)\n        else:\n            # Named ops use shape pattern\n            dim_sizes = get_dim_sizes_from_shape_pattern(op_name, iterator_types, pattern)\n\n        input_dtype, output_dtype = get_dtype_from_pattern(pattern)\n        num_operands = len(pattern.get('inputs', [])) + len(pattern.get('outputs', []))\n        num_operands = max(num_operands, 2)\n\n        # Create strategy instance\n        strategy = DistVectorStrategy()\n\n        # Wire per-dist probe_fn if factory provided and template exists\n        if probe_fn_factory and template:\n            pattern_info = {\n                \"op_name\": primary_op if is_fused else op_name,\n                \"iterator_types\": iterator_types,\n                \"dim_sizes\": dim_sizes,\n                \"input_dtype\": input_dtype,\n                \"template\": template,\n                \"inputs\": pattern.get(\"inputs\", []),\n                \"outputs\": pattern.get(\"outputs\", []),\n            }\n            if is_fused:\n                pattern_info[\"is_fused\"] = True\n                pattern_info[\"extra_inputs_spec\"] = extra_inputs_spec\n                pattern_info[\"primary_op\"] = primary_op\n            strategy.probe_fn = probe_fn_factory(pattern_info)\n\n        # Generate configs — fused ops use primary_op for level/config logic\n        config_op_name = primary_op if is_fused else op_name\n        num_levels = strategy.get_num_levels(config_op_name)\n        configs = strategy.generate_configs(\n            iterator_types, dim_sizes, output_dtype, max_configs,\n            config_op_name, num_operands, input_dtype)\n\n        # Clean up probe_fn\n        if hasattr(strategy, 'probe_fn'):\n            strategy.probe_fn = None\n\n        # Write configs to file\n        from .mlir_file_ops import get_operator_subdirectory\n        subdir = get_operator_subdirectory(op_name, is_generic,\n                                           is_fused=is_fused, primary_op=primary_op)\n        op_output_dir = os.path.join(output_dir, subdir)\n        os.makedirs(op_output_dir, exist_ok=True)\n\n        if is_fused and primary_op:\n            safe_fp_key = op_name.replace('.', '_').replace(':', '_').replace('/', '_')\n            filename = f\"{safe_fp_key}_{pattern_idx}_search_space.json\"\n        else:\n            pattern_name = f\"generic_{op_name[:50]}\" if is_generic else op_name\n            safe_name = pattern_name.replace('.', '_').replace(':', '_').replace('/', '_')\n            filename = f\"{safe_name}_{pattern_idx}_search_space.json\"\n        filepath = os.path.join(op_output_dir, filename)\n\n        # Extract default tile config\n        default_tile_config = _get_default_tile_config(pattern)\n\n        with open(filepath, 'w') as f:\n            header = strategy.format_header(\n                config_op_name, iterator_types, dim_sizes,\n                input_dtype, num_levels)\n            f.write(header + '\\n')\n            if default_tile_config is not None:\n                f.write('# Default tile config:\\n')\n                f.write('# ' + json.dumps(default_tile_config, separators=(',', ':')) + '\\n')\n                f.write('#\\n')\n            _write_configs(f, configs, strategy)\n\n        return {\n            'op_name': op_name,\n            'pattern_idx': pattern_idx,\n            'config_count': len(configs),\n            'output_file': os.path.join(subdir, filename),\n            'error': None,\n            'is_generic': is_generic,\n            'is_fused': is_fused\n        }\n\n    except Exception as e:\n        return {\n            'op_name': op_name,\n            'pattern_idx': pattern_idx,\n            'config_count': 0,\n            'output_file': None,\n            'error': str(e),\n            'is_generic': is_generic,\n            'is_fused': is_fused\n        }\n\n\ndef _collect_work_items(stats_data, output_dir, max_configs, probe_fn_factory, verbose, result,\n                        pattern_idx_filter=None):\n    \"\"\"Collect work items from named_ops, generic_ops, and fused_ops.\n\n    Args:\n        stats_data: Statistics dict with 'named_ops', 'generic_ops', and 'fused_ops'.\n        output_dir: Directory for config files.\n        max_configs: Maximum configs per pattern.\n        probe_fn_factory: Probe factory callable.\n        verbose: Print progress.\n        result: Result dict to update with op type counts and errors.\n        pattern_idx_filter: Optional int to filter to a single pattern index.\n\n    Returns:\n        Tuple of (work_items, op_summary).\n    \"\"\"\n    op_summary = {}  # op_name -> {'patterns': int, 'configs': int}\n    work_items = []\n\n    for op_name, op_data in stats_data.get('named_ops', {}).items():\n        iterator_types = op_data.get('iterator_types', [])\n        shape_patterns = op_data.get('shape_patterns', [])\n\n        if not iterator_types or not shape_patterns:\n            continue\n\n        result['named_op_types'] += 1\n        if op_name not in op_summary:\n            op_summary[op_name] = {'patterns': 0, 'configs': 0}\n\n        template = op_data.get('template')\n        for idx, pattern in enumerate(shape_patterns):\n            if pattern_idx_filter is not None and idx != pattern_idx_filter:\n                continue\n            work_items.append((\n                op_name, pattern, idx, output_dir, iterator_types,\n                max_configs, probe_fn_factory, False, verbose, template\n            ))\n\n    for pattern_name, op_data in stats_data.get('generic_ops', {}).items():\n        iterator_types = op_data.get('iterator_types', [])\n        shape_patterns = op_data.get('shape_patterns', [])\n\n        if not iterator_types or not shape_patterns:\n            continue\n\n        result['generic_op_types'] += 1\n        template = op_data.get('template')\n\n        for idx, pattern in enumerate(shape_patterns):\n            if pattern_idx_filter is not None and idx != pattern_idx_filter:\n                continue\n            if pattern is None:\n                result['total_patterns'