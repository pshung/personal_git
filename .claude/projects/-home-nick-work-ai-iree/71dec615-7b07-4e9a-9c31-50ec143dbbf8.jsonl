    input_dtype_bytes=input_bytes,\n   230→            output_dtype_bytes=output_bytes,\n   231→            l2_targets=l2_targets,\n   232→        )\n   233→\n   234→        assert len(pairs) == 1\n   235→        dist_outer, dist_inner = pairs[0]\n   236→\n   237→        # Verify working set fits\n   238→        a_tile = dist_outer * K * input_bytes\n   239→        b_tile = K * dist_inner * input_bytes\n   240→        c_tile = dist_outer * dist_inner * output_bytes\n   241→        working_set = a_tile + b_tile + c_tile\n   242→\n   243→        assert working_set <= 1 * 1024 * 1024, \\\n   244→            f\"Working set {working_set} exceeds 1MB\"\n   245→\n   246→        # Should find smaller dist_inner\n   247→        assert dist_inner < N, \\\n   248→            f\"dist_inner should be < {N} when B_tile exceeds budget\"\n   249→\n   250→    def test_no_valid_tile_fallback(self):\n   251→        \"\"\"\n   252→        Test fallback to (1, 1) when no valid tile fits.\n   253→\n   254→        With very small L2 target, may need to fall back.\n   255→        \"\"\"\n   256→        M = 1024\n   257→        N = 1024\n   258→        K = 1024\n   259→        input_bytes = 4\n   260→        output_bytes = 4\n   261→        l2_targets = [100]  # 100 bytes (impossibly small)\n   262→\n   263→        pairs = generate_dist_first_candidates(\n   264→            dim_inner=N,\n   265→            dim_outer=M,\n   266→            dim_reduction=K,\n   267→            input_dtype_bytes=input_bytes,\n   268→            output_dtype_bytes=output_bytes,\n   269→            l2_targets=l2_targets,\n   270→        )\n   271→\n   272→        # Should still generate a pair (fallback to (1, 1))\n   273→        assert len(pairs) == 1\n   274→        dist_outer, dist_inner = pairs[0]\n   275→\n   276→        # With such a small budget, should get minimal tile\n   277→        assert dist_outer >= 1 and dist_inner >= 1, \\\n   278→            \"Should fall back to at least (1, 1)\"\n   279→\n   280→    def test_deduplication_across_targets(self):\n   281→        \"\"\"\n   282→        Test that duplicate tiles are deduplicated.\n   283→\n   284→        If multiple L2 targets produce the same tile, should only return once.\n   285→        \"\"\"\n   286→        M = 64\n   287→        N = 64\n   288→        K = 64\n   289→        input_bytes = 4\n   290→        output_bytes = 4\n   291→        # All these targets should produce the same (64, 64) tile\n   292→        l2_targets = [1 * 1024 * 1024, 4 * 1024 * 1024, 5 * 1024 * 1024, 6 * 1024 * 1024]\n   293→\n   294→        pairs = generate_dist_first_candidates(\n   295→            dim_inner=N,\n   296→            dim_outer=M,\n   297→            dim_reduction=K,\n   298→            input_dtype_bytes=input_bytes,\n   299→            output_dtype_bytes=output_bytes,\n   300→            l2_targets=l2_targets,\n   301→        )\n   302→\n   303→        # Should deduplicate to single pair\n   304→        assert len(pairs) == 1, f\"Should deduplicate to 1 pair, got {len(pairs)}\"\n   305→        assert pairs[0] == (M, N), f\"Should be ({M}, {N}), got {pairs[0]}\"\n   306→\n   307→    def test_default_l2_targets(self):\n   308→        \"\"\"Test that default L2_TARGETS from config are used when not specified.\"\"\"\n   309→        M = 1024\n   310→        N = 192\n   311→        K = 768\n   312→        input_bytes = 1\n   313→        output_bytes = 4\n   314→\n   315→        # Call without l2_targets parameter\n   316→        pairs = generate_dist_first_candidates(\n   317→            dim_inner=N,\n   318→            dim_outer=M,\n   319→            dim_reduction=K,\n   320→            input_dtype_bytes=input_bytes,\n   321→            output_dtype_bytes=output_bytes,\n   322→        )\n   323→\n   324→        # Should use default L2_TARGETS = [1MB, 4MB, 5MB, 6MB]\n   325→        # Should generate at least 1 pair\n   326→        assert len(pairs) >= 1, \"Should generate pairs using default L2_TARGETS\"\n   327→\n   3