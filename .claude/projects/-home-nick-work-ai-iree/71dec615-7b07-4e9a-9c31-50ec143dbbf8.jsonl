, dist_inner = pairs[0]\n    41→\n    42→        # Calculate actual working set\n    43→        a_tile = dist_outer * K * input_bytes\n    44→        b_tile = K * dist_inner * input_bytes\n    45→        c_tile = dist_outer * dist_inner * output_bytes\n    46→        working_set = a_tile + b_tile + c_tile\n    47→\n    48→        # Verify working set is within 1MB target\n    49→        assert working_set <= 1 * 1024 * 1024, \\\n    50→            f\"Working set {working_set} bytes exceeds 1MB target\"\n    51→\n    52→        # Verify N is maximized (should be full 192)\n    53→        assert dist_inner == N, \\\n    54→            f\"dist_inner should maximize N: expected {N}, got {dist_inner}\"\n    55→\n    56→        # Verify M is constrained to fit budget\n    57→        # With N=192, K=768, solving for M:\n    58→        # M × (768×1 + 192×4) ≤ (1048576 - 768×192×1)\n    59→        # M × 1536 ≤ 901120\n    60→        # M ≤ 586\n    61→        # Largest divisor of 1024 ≤ 586 is 512\n    62→        assert dist_outer == 512, \\\n    63→            f\"dist_outer should be 512 for 1MB target, got {dist_outer}\"\n    64→\n    65→    def test_matmul_i8_large_targets(self):\n    66→        \"\"\"\n    67→        Test with 4MB, 5MB, 6MB targets — should all generate full (1024, 192).\n    68→\n    69→        Full tile working set: 1024 × 768 × 1 + 768 × 192 × 1 + 1024 × 192 × 4\n    70→                              = 786432 + 147456 + 786432 = 1720320 bytes = 1.64MB\n    71→\n    72→        So 4MB/5MB/6MB targets should all allow full tile.\n    73→        \"\"\"\n    74→        M = 1024\n    75→        N = 192\n    76→        K = 768\n    77→        input_bytes = 1  # i8\n    78→        output_bytes = 4  # i32\n    79→        l2_targets = [4 * 1024 * 1024, 5 * 1024 * 1024, 6 * 1024 * 1024]\n    80→\n    81→        pairs = generate_dist_first_candidates(\n    82→            dim_inner=N,\n    83→            dim_outer=M,\n    84→            dim_reduction=K,\n    85→            input_dtype_bytes=input_bytes,\n    86→            output_dtype_bytes=output_bytes,\n    87→            l2_targets=l2_targets,\n    88→        )\n    89→\n    90→        # Should generate 3 pairs (may deduplicate to 1 if all produce same tile)\n    91→        assert len(pairs) >= 1, \"Should generate at least one pair\"\n    92→\n    93→        # All should allow full dimensions\n    94→        for dist_outer, dist_inner in pairs:\n    95→            assert dist_inner == N, f\"dist_inner should be {N}, got {dist_inner}\"\n    96→            assert dist_outer == M, f\"dist_outer should be {M}, got {dist_outer}\"\n    97→\n    98→    def test_small_problem_fits_in_all_targets(self):\n    99→        \"\"\"\n   100→        Test with small problem (M=128, N=64, K=256, f32).\n   101→\n   102→        Working set: 128 × 256 × 4 + 256 × 64 × 4 + 128 × 64 × 4\n   103→                   = 131072 + 65536 + 32768 = 229376 bytes ≈ 224KB\n   104→\n   105→        Should fit in all L2 targets (1MB, 4MB, 5MB, 6MB).\n   106→        \"\"\"\n   107→        M = 128\n   108→        N = 64\n   109→        K = 256\n   110→        input_bytes = 4  # f32\n   111→        output_bytes = 4  # f32\n   112→        l2_targets = [1 * 1024 * 1024, 4 * 1024 * 1024, 5 * 1024 * 1024, 6 * 1024 * 1024]\n   113→\n   114→        pairs = generate_dist_first_candidates(\n   115→            dim_inner=N,\n   116→            dim_outer=M,\n   117→            dim_reduction=K,\n   118→            input_dtype_bytes=input_bytes,\n   119→            output_dtype_bytes=output_bytes,\n   120→            l2_targets=l2_targets,\n   121→        )\n   122→\n   123→        # Should deduplicate to single pair (128, 64)\n   124→        assert len(pairs) == 1, f\"Small problem should deduplicate to 1 pair, got {len(pairs)}\"\n   125→        dist_outer, dist_inner = pairs[0]\n   126→\n   127→        assert dist_outer == M and dist_inner == N, \\\n   128→            f\"Should generate full tile ({M}, {N}), got ({dist_outer}, {dist_inner})\"\n   129→\n   130→    def test_element_wise_no_reduction(self):\n   131→        \"\"\"\n   132→        Test element-wise operation (no reduction dimension).\n   133→\n   134→        Should use simplified formula: C_tile = dist_outer × dist_inner × output_bytes\n   135→        \"\"\"\n   136→        M = 1024\n   137→        N = 512\n   138→        K = 0  # No reduction\n   139→        input_bytes = 4  # f32\n   140→        output_bytes = 4  # f32\n   141→        l2_targets = [1 * 1024 * 1024]  # 1MB\n   142→\n   143→        pairs = generate_dist_first_candidates(\n   144→            dim_inner=N,\n   145→            dim_outer=M,\n   146→            dim_reduction=K,\n   147→            input_dtype_bytes=input_bytes,\n   148→            output_dtype_bytes=output_bytes,\n   149→            l2_targets=l2_targets,\n   150→        )\n   151→\n   152→        assert len(pairs) == 1\n   153→        dist_outer, dist_inner = pairs[0]\n   154→\n   155→        # Calculate working set (C_tile only)\n   156→        working_set = dist_outer * dist_inner * output_bytes\n   157→\n   158→        assert working_set <= 1 * 1024 * 1024, \\\n   159→            f\"Working set {working_set} exceeds 1MB\"\n   160→\n   161→        # Verify N is maximized\n   162→        assert dist_inner == N, \\\n   163→            f\"dist_inner should maximize N: expected {N}, got {dist_inner}\"\n   164→\n   165→        # Max elements = 1MB / 4 bytes = 262144\n   166→        # With N=512, max M = 262144 / 512 = 512\n   167→        # Largest divisor of 1024 ≤ 512 is 512\n   168→        assert dist_outer == 512, \\\n   169→            f\"dist_outer should be 512, got {dist_outer}\"\n   170→\n   171→    def test_n_maximization_priority(self):\n   172→        \"\"\"\n   173→        Test that N (dist_inner) is maximized before M (dist_outer).\n   174→\n   175→        This ensures best RVV vectorization on the inner parallel dimension.\n   176→        \"\"\"\n   177→        M = 256\n   178→      