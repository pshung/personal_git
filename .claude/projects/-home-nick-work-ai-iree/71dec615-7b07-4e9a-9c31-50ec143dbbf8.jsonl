2_targets,\n        )\n\n        assert len(pairs) == 1, \"Should generate one pair for 1MB target\"\n        dist_outer, dist_inner = pairs[0]\n\n        # Calculate actual working set\n        a_tile = dist_outer * K * input_bytes\n        b_tile = K * dist_inner * input_bytes\n        c_tile = dist_outer * dist_inner * output_bytes\n        working_set = a_tile + b_tile + c_tile\n\n        # Verify working set is within 1MB target\n        assert working_set <= 1 * 1024 * 1024, \\\n            f\"Working set {working_set} bytes exceeds 1MB target\"\n\n        # Verify N is maximized (should be full 192)\n        assert dist_inner == N, \\\n            f\"dist_inner should maximize N: expected {N}, got {dist_inner}\"\n\n        # Verify M is constrained to fit budget\n        # With N=192, K=768, solving for M:\n        # M × (768×1 + 192×4) ≤ (1048576 - 768×192×1)\n        # M × 1536 ≤ 901120\n        # M ≤ 586\n        # Largest divisor of 1024 ≤ 586 is 512\n        assert dist_outer == 512, \\\n            f\"dist_outer should be 512 for 1MB target, got {dist_outer}\"\n\n    def test_matmul_i8_large_targets(self):\n        \"\"\"\n        Test with 4MB, 5MB, 6MB targets — should all generate full (1024, 192).\n\n        Full tile working set: 1024 × 768 × 1 + 768 × 192 × 1 + 1024 × 192 × 4\n                              = 786432 + 147456 + 786432 = 1720320 bytes = 1.64MB\n\n        So 4MB/5MB/6MB targets should all allow full tile.\n        \"\"\"\n        M = 1024\n        N = 192\n        K = 768\n        input_bytes = 1  # i8\n        output_bytes = 4  # i32\n        l2_targets = [4 * 1024 * 1024, 5 * 1024 * 1024, 6 * 1024 * 1024]\n\n        pairs = generate_dist_first_candidates(\n            dim_inner=N,\n            dim_outer=M,\n            dim_reduction=K,\n            input_dtype_bytes=input_bytes,\n            output_dtype_bytes=output_bytes,\n            l2_targets=l2_targets,\n        )\n\n        # Should generate 3 pairs (may deduplicate to 1 if all produce same tile)\n        assert len(pairs) >= 1, \"Should generate at least one pair\"\n\n        # All should allow full dimensions\n        for dist_outer, dist_inner in pairs:\n            assert dist_inner == N, f\"dist_inner should be {N}, got {dist_inner}\"\n            assert dist_outer == M, f\"dist_outer should be {M}, got {dist_outer}\"\n\n    def test_small_problem_fits_in_all_targets(self):\n        \"\"\"\n        Test with small problem (M=128, N=64, K=256, f32).\n\n        Working set: 128 × 256 × 4 + 256 × 64 × 4 + 128 × 64 × 4\n                   = 131072 + 65536 + 32768 = 229376 bytes ≈ 224KB\n\n        Should fit in all L2 targets (1MB, 4MB, 5MB, 6MB).\n        \"\"\"\n        M = 128\n        N = 64\n        K = 256\n        input_bytes = 4  # f32\n        output_bytes = 4  # f32\n        l2_targets = [1 * 1024 * 1024, 4 * 1024 * 1024, 5 * 1024 * 1024, 6 * 1024 * 1024]\n\n        pairs = generate_dist_first_candidates(\n            dim_inner=N,\n            dim_outer=M,\n            dim_reduction=K,\n            input_dtype_bytes=input_bytes,\n            output_dtype_bytes=output_bytes,\n            l2_targets=l2_targets,\n        )\n\n        # Should deduplicate to single pair (128, 64)\n        assert len(pairs) == 1, f\"Small problem should deduplicate to 1 pair, got {len(pairs)}\"\n        dist_outer, dist_inner = pairs[0]\n\n        assert dist_outer == M and dist_inner == N, \\\n            f\"Should generate full tile ({M}, {N}), got ({dist_outer}, {dist_inner})\"\n\n    def test_element_wise_no_reduction(self):\n        \"\"\"\n        Test element-wise operation (no reduction dimension).\n\n        Should use simplified formula: C_tile = dist_outer × dist_inner × output_bytes\n        \"\"\"\n        M = 1024\n        N = 512\n        K = 0  # No reduction\n        input_bytes = 4  # f32\n        output_bytes = 4  # f32\n        l2_targets = [1 * 1024 * 1024]  # 1MB\n\n        pairs = generate_dist_first_candidates(\n            