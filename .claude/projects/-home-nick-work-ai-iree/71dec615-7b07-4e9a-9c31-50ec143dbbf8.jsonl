tats_data, output_dir, result, op_summary, verbose):\n    \"\"\"Aggregate worker results and update stats_data with file paths.\n\n    Args:\n        results: List of worker result dicts from _generate_pattern_configs_worker.\n        stats_data: Statistics dict to update with search_space_filepath fields.\n        output_dir: Base directory for config files.\n        result: Summary result dict to update with counts and errors.\n        op_summary: Per-operator summary dict to update.\n        verbose: Print summary per operator.\n    \"\"\"\n    generic_patterns = 0\n    generic_configs = 0\n    fused_patterns = 0\n    fused_configs = 0\n\n    for idx, work_result in enumerate(results):\n        result['total_patterns'] += 1\n\n        if work_result['error'] is not None:\n            result['errors'].append({\n                'op': work_result['op_name'],\n                'pattern': work_result['pattern_idx'],\n                'error': work_result['error']\n            })\n            continue\n\n        result['total_configs'] += work_result['config_count']\n        result['files_written'].append(work_result['output_file'])\n\n        op_name = work_result['op_name']\n        pattern_idx = work_result['pattern_idx']\n        is_generic = work_result['is_generic']\n        is_fused = work_result.get('is_fused', False)\n\n        if is_fused:\n            fused_patterns += 1\n            fused_configs += work_result['config_count']\n            op_data = stats_data.get('fused_ops', {}).get(op_name)\n            if op_data:\n                shape_patterns = op_data.get('shape_patterns', [])\n                if pattern_idx < len(shape_patterns):\n                    filepath = os.path.join(output_dir, work_result['output_file'])\n                    shape_patterns[pattern_idx]['search_space_filepath'] = filepath\n        elif is_generic:\n            generic_patterns += 1\n            generic_configs += work_result['config_count']\n            op_data = stats_data.g