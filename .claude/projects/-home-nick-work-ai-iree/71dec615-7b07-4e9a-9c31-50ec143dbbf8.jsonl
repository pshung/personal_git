{"parentUuid":"e5c40632-edba-432d-a051-ae6c8eb825b9","isSidechain":false,"userType":"external","cwd":"/home/nick/work/ai_iree","sessionId":"71dec615-7b07-4e9a-9c31-50ec143dbbf8","version":"2.1.72","gitBranch":"master","slug":"purrfect-wandering-puppy","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AC54YGqUPxuatvHDSkk1Nx","type":"tool_result","content":"     1→\"\"\"Compile-and-run task: stream MLIR → .adx → board → record → delete.\n     2→\n     3→Generates one MLIR file at a time, compiles to .adx, runs on board via GDB,\n     4→records cycle count, and deletes both temporary files before proceeding.\n     5→At most N files exist on disk at once (one per board).\n     6→\"\"\"\n     7→\n     8→import queue\n     9→import shutil\n    10→import subprocess\n    11→import sys\n    12→import threading\n    13→import time\n    14→from datetime import datetime\n    15→from pathlib import Path\n    16→from argparse import Namespace\n    17→\n    18→from ...compiler import (\n    19→    load_configs_to_try,\n    20→    generate_one_fused_mlir,\n    21→    build_fused_work_items,\n    22→    parse_vector_spills,\n    23→    generate_pattern_compile_report,\n    24→)\n    25→from ...shape_source import build_stats_from_shape_source\n    26→from ..stats_filters import filter_stats_by_fused_ids\n    27→from ..validators import parse_fused_ids\n    28→from ._common import (\n    29→    _resolve_splits,\n    30→    print_task_mission,\n    31→    print_subtask_complete,\n    32→)\n    33→\n    34→# Lazy imports for adx_builder (lives outside the package in script/)\n    35→_adx_imports_done = False\n    36→\n    37→\n    38→def _ensure_adx_imports():\n    39→    global _adx_imports_done\n    40→    if _adx_imports_done:\n    41→        return\n    42→    script_dir = str(Path(__file__).parent.parent.parent.parent)\n    43→    if script_dir not in sys.path:\n    44→        sys.path.insert(0, script_dir)\n    45→    _adx_imports_done = True\n    46→\n    47→\n    48→def adx_load_config(toml_path):\n    49→    _ensure_adx_imports()\n    50→    from adx_builder import load_config\n    51→    return load_config(toml_path)\n    52→\n    53→\n    54→def load_boards(cfg):\n    55→    _ensure_adx_imports()\n    56→    from adx_builder import load_boards as _load_boards\n    57→    return _load_boards(cfg)\n    58→\n    59→\n    60→def compile_mlir_to_adx(mlir_file, output_dir, cfg):\n    61→    _ensure_adx_imports()\n    62→    from adx_builder import compile_mlir_to_adx as _compile\n    63→    return _compile(mlir_file, output_dir, cfg)\n    64→\n    65→\n    66→def stage4_run_gdb(adx_path, board, timeout=None):\n    67→    _ensure_adx_imports()\n    68→    from adx_builder import stage4_run_gdb as _run_gdb\n    69→    return _run_gdb(adx_path, board, timeout=timeout)\n    70→\n    71→\n    72→def _parse_cycle_count(gdb_output):\n    73→    _ensure_adx_imports()\n    74→    from adx_builder import _parse_cycle_count as _parse\n    75→    return _parse(gdb_output)\n    76→\n    77→\n    78→def _expand_work_items(fused_work_items):\n    79→    \"\"\"Expand fused work items with their tile configs.\n    80→\n    81→    Returns list of (fp_key, op_data, template, extra_inputs_spec,\n    82→    primary_op, pattern, pattern_idx, fused_id, config_idx,\n    83→    lowering_config, tile_sizes) tuples.\n    84→    \"\"\"\n    85→    expanded = []\n    86→    for (fp_key, op_data, template, extra_inputs_spec,\n    87→         primary_op, pattern, pattern_idx, fused_id) in fused_work_items:\n    88→        default_lc = pattern.get(\"default_tile_config\") or pattern.get(\"lowering_config\")\n    89→        search_space_fp = pattern.get(\"search_space_filepath\")\n    90→        configs = load_configs_to_try(\n    91→            default_lc, search_space_fp, f\"fused {fp_key}[{pattern_idx}]\"\n    92→        )\n    93→        for config_idx, lowering_config, tile_sizes in configs:\n    94→            expanded.append((\n    95→                fp_key, op_data, template, extra_inputs_spec,\n    96→                primary_op, pattern, pattern_idx, fused_id,\n    97→                config_idx, lowering_config, tile_sizes,\n    98→            ))\n    99→    return expanded\n   100→\n   101→\n   102→_TIMEOUT_MULTIPLIER = 1.5\n   103→_MIN_TIMEOUT_SECONDS = 10.0\n   104→# Column definitions: (name, width)\n   105→_TSV_COLUMNS = [\n   106→    (\"fp_key\",      40),\n   107→    (\"pattern_idx\",  4),\n   108→    (\"config_idx\",   8),\n   109→    (\"status\",      12),\n   110→    (\"cycles\",      12),\n   111→    (\"board\",       20),\n   112→]\n   113→\n   114→_TSV_HEADER = \"\\t\".join(name.ljust(w) for name, w in _TSV_COLUMNS)\n   115→\n   116→\n   117→_RETRYABLE_STATUSES = {\"RunFail\"}\n   118→\n   119→\n   120→def _parse_completed_keys(tsv_path):\n   121→    \"\"\"Parse a TSV file and return (completed_set, retryable_set).\n   122→\n   123→    Items with retryable statuses (RunFail) are excluded from completed\n   124→    so they get re-run.\n   125→    Returns:\n   126→        completed: set of (fp_key, pattern_idx, config_idx) to skip.\n   127→        retryable: set of (fp_key, pattern_idx, config_idx) to retry.\n   128→    \"\"\"\n   129→    completed = set()\n   130→    retryable = set()\n   131→    with open(tsv_path) as f:\n   132→        header = f.readline()  # skip header\n   133→        for line in f:\n   134→            line = line.strip()\n   135→            if not line:\n   136→                continue\n   137→            fields = [f.strip() for f in line.split(\"\\t\")]\n   138→            if len(fields) >= 4:\n   139→                key = (fields[0], fields[1], fields[2])\n   140→                status = fields[3]\n   141→                if status in _RETRYABLE_STATUSES:\n   142→                    retryable.add(key)\n   143→                else:\n   144→                    completed.add(key)\n   145→    return completed, retryable\n   146→\n   147→\n   148→def _format_tsv_row(r):\n   149→    \"\"\"Format a result dict as a TSV line with aligned columns.\"\"\"\n   150→    values = [\n   151→        str(r['fp_key']),\n   152→        str(r['pattern_idx']),\n   153→        str(r['config_idx']),\n   154→        str(r['status']),\n   155→        str(r['cycles'] or ''),\n   156→        str(r.get('board', '')),\n   157→    ]\n   158→    return \"\\t\".join(val.ljust(w) for val, (_, w) in zip(values, _TSV_COLUMNS))\n   159→\n   160→\n   161→def _process_one_item(item, board, board_label, adx_cfg, tmp_dir, timeout=None):\n   162→    \"\"\"Process a single work item: generate → compile → run → cleanup.\n   163→\n   164→    Returns (result_dict, elapsed_seconds).\n   165→    \"\"\"\n   166→    (fp_key, op_data, template, extra_inputs_spec,\n   167→     primary_op, pattern, pattern_idx, fused_id,\n   168→     config_idx, lowering_config, tile_sizes) = item\n   169→\n   170→    inputs = pattern.get(\"inputs\", [])\n   171→    outputs = pattern.get(\"outputs\", [])\n   172→    skip_counts = {'wrap_error': 0, 'write_error': 0}\n   173→\n   174→    # Step 1: Generate MLIR\n   175→    item_id = f\"{fp_key}_{pattern_idx}_{config_idx}\"\n   176→    mlir_dir = tmp_dir / f\"{board_label}_{item_id}\"\n   177→    mlir_dir.mkdir(parents=True, exist_ok=True)\n   178→    file_tuple = generate_one_fused_mlir(\n   179→        mlir_dir, skip_counts,\n   180→        fp_key, op_data, template, extra_inputs_spec,\n   181→        primary_op, pattern, pattern_idx,\n   182→        inputs, outputs, lowering_config, config_idx, tile_sizes,\n   183→        fused_id,\n   184→    )\n   185→\n   186→    if file_tuple is None:\n   187→        return {\n   188→            \"fp_key\": fp_key, \"pattern_idx\": pattern_idx,\n   189→            \"config_idx\": config_idx, \"tile_sizes\": tile_sizes,\n   190→            \"op_data\": op_data,\n   191→            \"status\": \"CompileFail\", \"error\": \"MLIR generation failed\",\n   192→            \"cycles\": None, \"spill_info\": None,\n   193→        }, 0.0\n   194→\n   195→    mlir_path = file_tuple[0]\n   196→\n   197→    # Step 2: Compile to .adx\n   198→    try:\n   199→        adx_path, compile_stderr = compile_mlir_to_adx(mlir_path, mlir_dir, adx_cfg)\n   200→        spill_info = parse_vector_spills(compile_stderr)\n   201→    except Exception as e:\n   202→        _cleanup(mlir_dir)\n   203→        return {\n   204→            \"fp_key\": fp_key, \"pattern_idx\": pattern_idx,\n   205→            \"config_idx\": config_idx, \"tile_sizes\": tile_sizes,\n   206→            \"op_data\": op_data,\n   207→            \"status\": \"CompileFail\", \"error\": str(e),\n   208→            \"cycles\": None, \"spill_info\": None,\n   209→        }, 0.0\n   210→\n   211→    # Step 3: Run on board (with optional timeout)\n   212→    t0 = time.monotonic()\n   213→    try:\n   214→        gdb_output = stage4_run_gdb(adx_path, board, timeout=timeout)\n   215→        elapsed = time.monotonic() - t0\n   216→        cycles = _parse_cycle_count(gdb_output)\n   217→        status = \"Pass\" if cycles else \"RunFail\"\n   218→        error = \"\" if status == \"Pass\" else gdb_output\n   219→    except subprocess.TimeoutExpired:\n   220→        elapsed = time.monotonic() - t0\n   221→        cycles = None\n   222→        status = \"Timeout\"\n   223→        error = f\"exceeded {timeout:.1f}s timeout\"\n   224→        gdb_output = error\n   225→    except Exception as e:\n   226→        elapsed = time.monotonic() - t0\n   227→        cycles = None\n   228→        status = \"RunFail\"\n   229→        error = str(e)\n   230→\n   231→    # Step 4: Cleanup\n   232→    _cleanup(mlir_dir)\n   233→    return {\n   234→        \"fp_key\": fp_key, \"pattern_idx\": pattern_idx,\n   235→        \"config_idx\": config_idx, \"tile_sizes\": tile_sizes,\n   236→        \"op_data\": op_data,\n   237→        \"status\": status, \"error\": error,\n   238→        \"cycles\": cycles, \"spill_info\": spill_info,\n   239→    }, elapsed\n   240→\n   241→\n   242→def _group_items(expanded, completed=None):\n   243→    \"\"\"Group expanded items by (fp_key, pattern_idx), baseline first in each group.\n   244→\n   245→    If completed is provided, filters out already-recorded items. Baselines\n   246→    are kept (for wall-clock timing) if any search config in the group still\n   247→    needs to run, but marked as timing-only so TSV write is skipped.\n   248→\n   249→    Returns list of (group, timing_only_baseline) tuples.\n   250→    timing_only_baseline is True when the baseline is only re-run for timing.\n   251→    \"\"\"\n   252→    groups = {}\n   253→    for item in expanded:\n   254→        key = (item[0], item[6])  # (fp_key, pattern_idx)\n   255→        groups.setdefault(key, []).append(item)\n   256→\n   257→    result = []\n   258→    for key, items in groups.items():\n   259→        items.sort(key=lambda x: (0 if x[8] == \"baseline\" else 1, x[8]))\n   260→\n   261→        if completed is None:\n   262→            result.append((items, False))\n   263→            continue\n   264→\n   265→        baseline = [x for x in items if x[8] == \"baseline\"]\n   266→        search = [x for x in items if x[8] != \"baseline\"]\n   267→\n   268→        # Filter out completed items\n   269→        pending_search = [\n   270→            x for x in search\n   271→            if (str(x[0]), str(x[6]), str(x[8])) not in completed\n   272→        ]\n   273→\n   274→        if not pending_search:\n   275→            # Everything done for this group\n   276→            continue\n   277→\n   278→        baseline_completed = baseline and (\n   279→            str(baseline[0][0]), str(baseline[0][6]), str(baseline[0][8])\n   280→        ) in completed\n   281→\n   282→        if baseline:\n   283→            # Always include baseline for timing; mark if timing-only\n   284→            result.append((baseline + pending_search, baseline_completed))\n   285→        else:\n   286→            result.append((pending_search, False))\n   287→\n   288→    return result\n   289→\n   290→\n   291→def _board_worker(board, work_queue, result_queue, adx_cfg, tmp_dir,\n   292→                  tsv_fh=None, tsv_lock=None, on_result=None):\n   293→    \"\"\"Worker thread: pull groups from queue, run baseline then search configs.\"\"\"\n   294→    board_label = board.get('name') or f\"{board.get('remote', '?')}:{board.get('port', '?')}\"\n   295→\n   296→    while True:\n   297→        try:\n   298→            group, timing_only_baseline = work_queue.get_nowait()\n   299→        except queue.Empty:\n   300→            break\n   301→\n   302→        baseline_elapsed = None\n   303→        group_results = []\n   304→\n   305→        for item in group:\n   306→            config_idx = item[8]\n   307→\n   308→            # Baseline runs untimed; search configs use 1.5x baseline wall-clock\n   309→            timeout = None\n   310→            if config_idx != \"baseline\" and baseline_elapsed is not None:\n   311→                timeout = max(baseline_elapsed * _TIMEOUT_MULTIPLIER,\n   312→                              _MIN_TIMEOUT_SECONDS)\n   313→\n   314→            result, elapsed = _process_one_item(\n   315→                item, board, board_label, adx_cfg, tmp_dir, timeout=timeout\n   316→            )\n   317→\n   318→            if config_idx == \"baseline\":\n   319→                baseline_elapsed = elapsed\n   320→\n   321→            # Skip TSV write for timing-only baselines (already recorded)\n   322→            if not (config_idx == \"baseline\" and timing_only_baseline):\n   323→                result['board'] = board_label\n   324→                group_results.append(result)\n   325→\n   326→        # Write all group results as a block (no interleaving with other groups)\n   327→        if tsv_fh is not None and tsv_lock is not None and group_results:\n   328→            with tsv_lock:\n   329→                for result in group_results:\n   330→                    tsv_fh.write(_format_tsv_row(result) + \"\\n\")\n   331→                    if on_result:\n   332→                        on_result(result)\n   333→                tsv_fh.flush()\n   334→\n   335→        if result_queue is not None:\n   336→            for result in group_results:\n   337→                result_queue.put(result)\n   338→\n   339→        work_queue.task_done()\n   340→\n   341→\n   342→def _cleanup(mlir_dir):\n   343→    \"\"\"Remove the entire per-item working directory.\"\"\"\n   344→    if mlir_dir and mlir_dir.exists():\n   345→        shutil.rmtree(mlir_dir, ignore_errors=True)\n   346→\n   347→\n   348→def run_compile_and_run_task(args: Namespace) -> int:\n   349→    \"\"\"Run compile-and-run task: stream generate → compile → run → delete.\n   350→\n   351→    For each tile configuration: generates MLIR, compiles to .adx, runs on\n   352→    board via GDB, records cycle count, and deletes temporary files.\n   353→    At most N files exist on disk at once (one per board).\n   354→    \"\"\"\n   355→    print_task_mission(\n   356→        \"COMPILE-AND-RUN\",\n   357→        \"Stream MLIR → .adx → board → record cycles → delete\"\n   358→    )\n   359→\n   360→    if not getattr(args, 'config', None):\n   361→        print(\"  ✗ Error: --config is required\", file=sys.stderr)\n   362→        return 1\n   363→\n   364→    # Load board config\n   365→    try:\n   366→        adx_cfg = adx_load_config(args.config)\n   367→    except Exception as e:\n   368→        print(f\"  ✗ Error loading config: {e}\", file=sys.stderr)\n   369→        return 1\n   370→\n   371→    boards = load_boards(adx_cfg)\n   372→    if not boards:\n   373→        print(\"  ✗ Error: no boards configured\", file=sys.stderr)\n   374→        return 1\n   375→\n   376→    print(f\"  Boards: {len(boards)}\")\n   377→\n   378→    input_dir = Path(args.input_dir)\n   379→    output_dir = Path(args.output) if getattr(args, 'output', None) else input_dir\n   380→\n   381→    # Find global patterns file\n   382→    patterns_file = input_dir / \"files\" / \"patterns.json\"\n   383→    if not patterns_file.exists():\n   384→        patterns_file = input_dir / \"patterns.json\"\n   385→\n   386→    split_list = _resolve_splits(\n   387→        input_dir, output_dir, getattr(args, 'pattern_split', None)\n   388→    )\n   389→\n   390→    total_pass = total_fail = 0\n   391→\n   392→    for split_name, split_dir, split_output in split_list:\n   393→        # Find shapes files\n   394→        split_files = split_dir / \"files\"\n   395→        if not split_files.exists():\n   396→            split_files = split_dir\n   397→        shapes_files = list(split_files.glob(\"*_shapes.txt\"))\n   398→        if not shapes_files:\n   399→            continue\n   400→\n   401→        print(f\"\\n{'─'*60}\")\n   402→        print(f\"  [{split_name}]\")\n   403→\n   404→        split_output.mkdir(parents=True, exist_ok=True)\n   405→\n   406→        for shapes_file in shapes_files:\n   407→            op_name = shapes_file.stem.replace(\"_shapes\", \"\")\n   408→\n   409→            try:\n   410→                stats = build_stats_from_shape_source(\n   411→                    str(shapes_file), str(patterns_file), op_name\n   412→                )\n   413→            except Exception as e:\n   414→                print(f\"  ✗ Error building stats: {e}\", file=sys.stderr)\n   415→                continue\n   416→\n   417→            fused_ids = parse_fused_ids(getattr(args, 'fused_ids', None))\n   418→            stats = filter_stats_by_fused_ids(stats, fused_ids)\n   419→\n   420→            # Link search space files (same logic as compile task)\n   421→            _link_search_spaces(stats, split_dir, op_name)\n   422→\n   423→            fused_work_items, _, _ = build_fused_work_items(\n   424→                stats,\n   425→                op_filter=None,\n   426→                pattern_idx_filter=getattr(args, 'pattern_idx_filter', None),\n   427→            )\n   428→\n   429→            if not fused_work_items:\n   430→                print(f\"  [{split_name}] No work items for {op_name}\")\n   431→                continue\n   432→\n   433→            expanded = _expand_work_items(fused_work_items)\n   434→            if getattr(args, 'limit', None):\n   435→                expanded = expanded[:args.limit]\n   436→\n   437→\n   438→\n   439→            # Resume: parse existing TSV and filter completed items\n   440→            resume_path = getattr(args, 'resume', None)\n   441→            completed = None\n   442→            retryable = set()\n   443→            if resume_path:\n   444→                resume_file = Path(resume_path)\n   445→                if resume_file.exists():\n   446→                    completed, retryable = _parse_completed_keys(resume_file)\n   447→                    print(f\"  [{split_name}] Resuming from {resume_file.name}\"\n   448→                          f\" ({len(completed)} done, {len(retryable)} RunFail to retry)\")\n   449→\n   450→            # Group items, filtering out completed ones\n   451→            groups = _group_items(expanded, completed=completed)\n   452→\n   453→            # Count pending items for progress, split into new vs retry\n   454→            pending_items = 0\n   455→            retry_items = 0\n   456→            for grp, tob in groups:\n   457→                for x in grp:\n   458→                    if x[8] == \"baseline\" and tob:\n   459→                        continue  # timing-only baseline\n   460→                    pending_items += 1\n   461→                    key = (str(x[0]), str(x[6]), str(x[8]))\n   462→                    if key in retryable:\n   463→                        retry_items += 1\n   464→            new_items = pending_items - retry_items\n   465→            if retry_items:\n   466→                print(f\"  [{split_name}] {pending_items} configs to run for {op_name}\"\n   467→                      f\" ({new_items} new + {retry_items} retry)\")\n   468→            else:\n   469→                print(f\"  [{split_name}] {pending_items} configs to run for {op_name}\")\n   470→\n   471→            if not groups:\n   472→                print(f\"  [{split_name}] All items already recorded, skipping\")\n   473→                continue\n   474→\n   475→            # Open TSV: append to existing or create new\n   476→            if resume_path and Path(resume_path).exists():\n   477→                result_file = Path(resume_path)\n   478→                # Remove RunFail lines before appending retried results\n   479→                if retryable:\n   480→                    with open(result_file) as f:\n   481→                        lines = f.readlines()\n   482→                    with open(result_file, 'w') as f:\n   483→                        for line in lines:\n   484→                            fields = [fld.strip() for fld in line.split(\"\\t\")]\n   485→                            if len(fields) >= 4 and fields[3] in _RETRYABLE_STATUSES:\n   486→                                continue\n   487→                            f.write(line)\n   488→                tsv_fh = open(result_file, 'a')\n   489→            else:\n   490→                timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n   491→                result_file = split_output / f\"compile_and_run_{op_name}_{timestamp}.tsv\"\n   492→                tsv_fh = open(result_file, 'w')\n   493→                tsv_fh.write(_TSV_HEADER + \"\\n\")\n   494→                tsv_fh.flush()\n   495→            print(f\"  → Results: {result_file.name}\")\n   496→\n   497→            tmp_dir = split_output / \".compile_and_run_tmp\"\n   498→            tmp_dir.mkdir(parents=True, exist_ok=True)\n   499→\n   500→            tsv_lock = threading.Lock()\n   501→            split_pass = split_fail = split_timeout = 0\n   502→\n   503→            def _on_result(r):\n   504→                nonlocal split_pass, split_fail, split_timeout\n   505→                if r[\"status\"] == \"Pass\":\n   506→                    split_pass += 1\n   507→                elif r[\"status\"] == \"Timeout\":\n   508→                    split_timeout += 1\n   509→                else:\n   510→                    split_fail += 1\n   511→                done = split_pass + split_fail + split_timeout\n   512→                pct = 100.0 * done / pending_items if pending_items else 100.0\n   513→                print(\n   514→                    f\"\\r  [{done}/{pending_items}] {pct:.1f}%\"\n   515→                    f\" Pass={split_pass} Fail={split_fail} Timeout={split_timeout}\",\n   516→                    end=\"\", file=sys.stderr,\n   517→                )\n   518→\n   519→            work_q = queue.Queue()\n   520→            for group in groups:\n   521→                work_q.put(group)\n   522→\n   523→            threads = []\n   524→            for board in boards:\n   525→                t = threading.Thread(\n   526→                    target=_board_worker,\n   527→                    args=(board, work_q, None, adx_cfg, tmp_dir),\n   528→                    kwargs={\n   529→                        \"tsv_fh\": tsv_fh,\n   530→                        \"tsv_lock\": tsv_lock,\n   531→                        \"on_result\": _on_result,\n   532→                    },\n   533→                    daemon=True,\n   534→                )\n   535→                t.start()\n   536→                threads.append(t)\n   537→            for t in threads:\n   538→                t.join()\n   539→\n   540→            # Final newline after progress bar\n   541→            print(file=sys.stderr)\n   542→            tsv_fh.close()\n   543→\n   544→            total_pass += split_pass\n   545→            total_fail += split_fail\n   546→\n   547→            # Clean up tmp dir\n   548→            shutil.rmtree(tmp_dir, ignore_errors=True)\n   549→\n   550→    # Summary\n   551→    total = total_pass + total_fail\n   552→    print(f\"\\n{'='*60}\")\n   553→    print(f\"COMPILE-AND-RUN COMPLETE\")\n   554→    print(f\"  Pass={total_pass}, Fail={total_fail}, Total={total}\")\n   555→    print(f\"{'='*60}\\n\")\n   556→\n   557→    return 0\n   558→\n   559→\n   560→def _link_search_spaces(stats, split_dir, op_name):\n   561→    \"\"\"Link fused ops to their search space files.\"\"\"\n   562→    tile_config_dir = split_dir / \"tile-configs\"\n   563→    if not tile_config_dir.exists():\n   564→        return\n   565→\n   566→    safe_primary = f\"linalg_{op_name}\"\n   567→    primary_short = op_name\n   568→    fused_ops = stats.get('fused_ops', {})\n   569→\n   570→    for fp_key, fused_data in fused_ops.items():\n   571→        safe_fp_key = fp_key.replace('.', '_').replace(':', '_').replace('/', '_')\n   572→        for idx, pattern in enumerate(fused_data.get('shape_patterns', [])):\n   573→            fused_filename = f\"{safe_fp_key}_{idx}_search_space.json\"\n   574→            fused_path = tile_config_dir / f\"{primary_short}_fused\" / fused_filename\n   575→            if fused_path.exists():\n   576→                pattern['search_space_filepath'] = str(fused_path)\n   577→            else:\n   578→                tc_filename = f\"{safe_primary}_{idx}_search_space.json\"\n   579→                tc_path = tile_config_dir / op_name / tc_filename\n   580→                if tc_path.exists():\n   581→                    pattern['search_space_filepath'] = str(tc_path)\n   582→"}]},"uuid":"a21592f5-e8e6-4dfc-9156-fa65969dca20","timestamp":"2026-03-20T02:54:13.977Z","toolUseResult":{"type":"text","file":{"filePath":"/home/nick/work/ai_iree/script/dataset_generator/cli/tasks/compile_and_run.py","content":"\"\"\"Compile-and-run task: stream MLIR → .adx → board → record → delete.\n\nGenerates one MLIR file at a time, compiles to .adx, runs on board via GDB,\nrecords cycle count, and deletes both temporary files before proceeding.\nAt most N files exist on disk at once (one per board).\n\"\"\"\n\nimport queue\nimport shutil\nimport subprocess\nimport sys\nimport threading\nimport time\nfrom datetime import datetime\nfrom pathlib import Path\nfrom argparse import Namespace\n\nfrom ...compiler import (\n    load_configs_to_try,\n    generate_one_fused_mlir,\n    build_fused_work_items,\n    parse_vector_spills,\n    generate_pattern_compile_report,\n)\nfrom ...shape_source import build_stats_from_shape_source\nfrom ..stats_filters import filter_stats_by_fused_ids\nfrom ..validators import parse_fused_ids\nfrom ._common import (\n    _resolve_splits,\n    print_task_mission,\n    print_subtask_complete,\n)\n\n# Lazy imports for adx_builder (lives outside the package in script/)\n_adx_imports_done = False\n\n\ndef _ensure_adx_imports():\n    global _adx_imports_done\n    if _adx_imports_done:\n        return\n    script_dir = str(Path(__file__).parent.parent.parent.parent)\n    if script_dir not in sys.path:\n        sys.path.insert(0, script_dir)\n    _adx_imports_done = True\n\n\ndef adx_load_config(toml_path):\n    _ensure_adx_imports()\n    from adx_builder import load_config\n    return load_config(toml_path)\n\n\ndef load_boards(cfg):\n    _ensure_adx_imports()\n    from adx_builder import load_boards as _load_boards\n    return _load_boards(cfg)\n\n\ndef compile_mlir_to_adx(mlir_file, output_dir, cfg):\n    _ensure_adx_imports()\n    from adx_builder import compile_mlir_to_adx as _compile\n    return _compile(mlir_file, output_dir, cfg)\n\n\ndef stage4_run_gdb(adx_path, board, timeout=None):\n    _ensure_adx_imports()\n    from adx_builder import stage4_run_gdb as _run_gdb\n    return _run_gdb(adx_path, board, timeout=timeout)\n\n\ndef _parse_cycle_count(gdb_output):\n    _ensure_adx_imports()\n    from adx_builder import _parse_cycle_count as _parse\n    return _parse(gdb_output)\n\n\ndef _expand_work_items(fused_work_items):\n    \"\"\"Expand fused work items with their tile configs.\n\n    Returns list of (fp_key, op_data, template, extra_inputs_spec,\n    primary_op, pattern, pattern_idx, fused_id, config_idx,\n    lowering_config, tile_sizes) tuples.\n    \"\"\"\n    expanded = []\n    for (fp_key, op_data, template, extra_inputs_spec,\n         primary_op, pattern, pattern_idx, fused_id) in fused_work_items:\n        default_lc = pattern.get(\"default_tile_config\") or pattern.get(\"lowering_config\")\n        search_space_fp = pattern.get(\"search_space_filepath\")\n        configs = load_configs_to_try(\n            default_lc, search_space_fp, f\"fused {fp_key}[{pattern_idx}]\"\n        )\n        for config_idx, lowering_config, tile_sizes in configs:\n            expanded.append((\n                fp_key, op_data, template, extra_inputs_spec,\n                primary_op, pattern, pattern_idx, fused_id,\n                config_idx, lowering_config, tile_sizes,\n            ))\n    return expanded\n\n\n_TIMEOUT_MULTIPLIER = 1.5\n_MIN_TIMEOUT_SECONDS = 10.0\n# Column definitions: (name, width)\n_TSV_COLUMNS = [\n    (\"fp_key\",      40),\n    (\"pattern_idx\",  4),\n    (\"config_idx\",   8),\n    (\"status\",      12),\n    (\"cycles\",      12),\n    (\"board\",       20),\n]\n\n_TSV_HEADER = \"\\t\".join(name.ljust(w) for name, w in _TSV_COLUMNS)\n\n\n_RETRYABLE_STATUSES = {\"RunFail\"}\n\n\ndef _parse_completed_keys(tsv_path):\n    \"\"\"Parse a TSV file and return (completed_set, retryable_set).\n\n    Items with retryable statuses (RunFail) are excluded from completed\n    so they get re-run.\n    Returns:\n        completed: set of (fp_key, pattern_idx, config_idx) to skip.\n        retryable: set of (fp_key, pattern_idx, config_idx) to retry.\n    \"\"\"\n    completed = set()\n    retryable = set()\n    with open(tsv_path) as f:\n        header = f.readline()  # skip header\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            fields = [f.strip() for f in line.split(\"\\t\")]\n            if len(fields) >= 4:\n                key = (fields[0], fields[1], fields[2])\n                status = fields[3]\n                if status in _RETRYABLE_STATUSES:\n                    retryable.add(key)\n                else:\n                    completed.add(key)\n    return completed, retryable\n\n\ndef _format_tsv_row(r):\n    \"\"\"Format a result dict as a TSV line with aligned columns.\"\"\"\n    values = [\n        str(r['fp_key']),\n        str(r['pattern_idx']),\n        str(r['config_idx']),\n        str(r['status']),\n        str(r['cycles'] or ''),\n        str(r.get('board', '')),\n    ]\n    return \"\\t\".join(val.ljust(w) for val, (_, w) in zip(values, _TSV_COLUMNS))\n\n\ndef _process_one_item(item, board, board_label, adx_cfg, tmp_dir, timeout=None):\n    \"\"\"Process a single work item: generate → compile → run → cleanup.\n\n    Returns (result_dict, elapsed_seconds).\n    \"\"\"\n    (fp_key, op_data, template, extra_inputs_spec,\n     primary_op, pattern, pattern_idx, fused_id,\n     config_idx, lowering_config, tile_sizes) = item\n\n    inputs = pattern.get(\"inputs\", [])\n    outputs = pattern.get(\"outputs\", [])\n    skip_counts = {'wrap_error': 0, 'write_error': 0}\n\n    # Step 1: Generate MLIR\n    item_id = f\"{fp_key}_{pattern_idx}_{config_idx}\"\n    mlir_dir = tmp_dir / f\"{board_label}_{item_id}\"\n    mlir_dir.mkdir(parents=True, exist_ok=True)\n    file_tuple = generate_one_fused_mlir(\n        mlir_dir, skip_counts,\n        fp_key, op_data, template, extra_inputs_spec,\n        primary_op, pattern, pattern_idx,\n        inputs, outputs, lowering_config, config_idx, tile_sizes,\n        fused_id,\n    )\n\n    if file_tuple is None:\n        return {\n            \"fp_key\": fp_key, \"pattern_idx\": pattern_idx,\n            \"config_idx\": config_idx, \"tile_sizes\": tile_sizes,\n            \"op_data\": op_data,\n            \"status\": \"CompileFail\", \"error\": \"MLIR generation failed\",\n            \"cycles\": None, \"spill_info\": None,\n        }, 0.0\n\n    mlir_path = file_tuple[0]\n\n    # Step 2: Compile to .adx\n    try:\n        adx_path, compile_stderr = compile_mlir_to_adx(mlir_path, mlir_dir, adx_cfg)\n        spill_info = parse_vector_spills(compile_stderr)\n    except Exception as e:\n        _cleanup(mlir_dir)\n        return {\n            \"fp_key\": fp_key, \"pattern_idx\": pattern_idx,\n            \"config_idx\": config_idx, \"tile_sizes\": tile_sizes,\n            \"op_data\": op_data,\n            \"status\": \"CompileFail\", \"error\": str(e),\n            \"cycles\": None, \"spill_info\": None,\n        }, 0.0\n\n    # Step 3: Run on board (with optional timeout)\n    t0 = time.monotonic()\n    try:\n        gdb_output = stage4_run_gdb(adx_path, board, timeout=timeout)\n        elapsed = time.monotonic() - t0\n        cycles = _parse_cycle_count(gdb_output)\n        status = \"Pass\" if cycles else \"RunFail\"\n        error = \"\" if status == \"Pass\" else gdb_output\n    except subprocess.TimeoutExpired:\n        elapsed = time.monotonic() - t0\n        cycles = None\n        status = \"Timeout\"\n        error = f\"exceeded {timeout:.1f}s timeout\"\n        gdb_output = error\n    except Exception as e:\n        elapsed = time.monotonic() - t0\n        cycles = None\n        status = \"RunFail\"\n        error = str(e)\n\n    # Step 4: Cleanup\n    _cleanup(mlir_dir)\n    return {\n        \"fp_key\": fp_key, \"pattern_idx\": pattern_idx,\n        \"config_idx\": config_idx, \"tile_sizes\": tile_sizes,\n        \"op_data\": op_data,\n        \"status\": status, \"error\": error,\n        \"cycles\": cycles, \"spill_info\": spill_info,\n    }, elapsed\n\n\ndef _group_items(expanded, completed=None):\n    \"\"\"Group expanded items by (fp_key, pattern_idx), baseline first in each group.\n\n    If completed is provided, filters out already-recorded items. Baselines\n    are kept (for wall-clock timing) if any search config in the group still\n    needs to run, but marked as timing-only so TSV write is skipped.\n\n    Returns list of (group, timing_only_baseline) tuples.\n    timing_only_baseline is True when the baseline is only re-run for timing.\n    \"\"\"\n    groups = {}\n    for item in expanded:\n        key = (item[0], item[6])  # (fp_key, pattern_idx)\n        groups.setdefault(key, []).append(item)\n\n    result = []\n    for key, items in groups.items():\n        items.sort(key=lambda x: (0 if x[8] == \"baseline\" else 1, x[8]))\n\n        if completed is None:\n            result.append((items, False))\n            continue\n\n        baseline = [x for x in items if x[8] == \"baseline\"]\n        search = [x for x in items if x[8] != \"baseline\"]\n\n        # Filter out completed items\n        pending_search = [\n            x for x in search\n            if (str(x[0]), str(x[6]), str(x[8])) not in completed\n        ]\n\n        if not pending_search:\n            # Everything done for this group\n            continue\n\n        baseline_completed = baseline and (\n            str(baseline[0][0]), str(baseline[0][6]), str(baseline[0][8])\n        ) in completed\n\n        if baseline:\n            # Always include baseline for timing; mark if timing-only\n            result.append((baseline + pending_search, baseline_completed))\n        else:\n            result.append((pending_search, False))\n\n    return result\n\n\ndef _board_worker(board, work_queue, result_queue, adx_cfg, tmp_dir,\n                  tsv_fh=None, tsv_lock=None, on_result=None):\n    \"\"\"Worker thread: pull groups from queue, run baseline then search configs.\"\"\"\n    board_label = board.get('name') or f\"{board.get('remote', '?')}:{board.get('port', '?')}\"\n\n    while True:\n        try:\n            group, timing_only_baseline = work_queue.get_nowait()\n        except queue.Empty:\n            break\n\n        baseline_elapsed = None\n        group_results = []\n\n        for item in group:\n            config_idx = item[8]\n\n            # Baseline runs untimed; search configs use 1.5x baseline wall-clock\n            timeout = None\n            if config_idx != \"baseline\" and baseline_elapsed is not None:\n                timeout = max(baseline_elapsed * _TIMEOUT_MULTIPLIER,\n                              _MIN_TIMEOUT_SECONDS)\n\n            result, elapsed = _process_one_item(\n                item, board, board_label, adx_cfg, tmp_dir, timeout=timeout\n            )\n\n            if config_idx == \"baseline\":\n                baseline_elapsed = elapsed\n\n            # Skip TSV write for timing-only baselines (already recorded)\n            if not (config_idx == \"baseline\" and timing_only_baseline):\n                result['board'] = board_label\n                group_results.append(result)\n\n        # Write all group results as a block (no interleaving with other groups)\n        if tsv_fh is not None and tsv_lock is not None and group_results:\n            with tsv_lock:\n                for result in group_results:\n                    tsv_fh.write(_format_tsv_row(result) + \"\\n\")\n                    if on_result:\n                        on_result(result)\n                tsv_fh.flush()\n\n        if result_queue is not None:\n            for result in group_results:\n                result_queue.put(result)\n\n        work_queue.task_done()\n\n\ndef _cleanup(mlir_dir):\n    \"\"\"Remove the entire per-item working directory.\"\"\"\n    if mlir_dir and mlir_dir.exists():\n        shutil.rmtree(mlir_dir, ignore_errors=True)\n\n\ndef run_compile_and_run_task(args: Namespace) -> int:\n    \"\"\"Run compile-and-run task: stream generate → compile → run → delete.\n\n    For each tile configuration: generates MLIR, compiles to .adx, runs on\n    board via GDB, records cycle count, and deletes temporary files.\n    At most N files exist on disk at once (one per board).\n    \"\"\"\n    print_task_mission(\n        \"COMPILE-AND-RUN\",\n        \"Stream MLIR → .adx → board → record cycles → delete\"\n    )\n\n    if not getattr(args, 'config', None):\n        print(\"  ✗ Error: --config is required\", file=sys.stderr)\n        return 1\n\n    # Load board config\n    try:\n        adx_cfg = adx_load_config(args.config)\n    except Exception as e:\n        print(f\"  ✗ Error loading config: {e}\", file=sys.stderr)\n        return 1\n\n    boards = load_boards(adx_cfg)\n    if not boards:\n        print(\"  ✗ Error: no boards configured\", file=sys.stderr)\n        return 1\n\n    print(f\"  Boards: {len(boards)}\")\n\n    input_dir = Path(args.input_dir)\n    output_dir = Path(args.output) if getattr(args, 'output', None) else input_dir\n\n    # Find global patterns file\n    patterns_file = input_dir / \"files\" / \"patterns.json\"\n    if not patterns_file.exists():\n        patterns_file = input_dir / \"patterns.json\"\n\n    split_list = _resolve_splits(\n        input_dir, output_dir, getattr(args, 'pattern_split', None)\n    )\n\n    total_pass = total_fail = 0\n\n    for split_name, split_dir, split_output in split_list:\n        # Find shapes files\n        split_files = split_dir / \"files\"\n        if not split_files.exists():\n            split_files = split_dir\n        shapes_files = list(split_files.glob(\"*_shapes.txt\"))\n        if not shapes_files:\n            continue\n\n        print(f\"\\n{'─'*60}\")\n        print(f\"  [{split_name}]\")\n\n        split_output.mkdir(parents=True, exist_ok=True)\n\n        for shapes_file in shapes_files:\n            op_name = shapes_file.stem.replace(\"_shapes\", \"\")\n\n            try:\n                stats = build_stats_from_shape_source(\n                    str(shapes_file), str(patterns_file), op_name\n                )\n            except Exception as e:\n                print(f\"  ✗ Error building stats: {e}\", file=sys.stderr)\n                continue\n\n            fused_ids = parse_fused_ids(getattr(args, 'fused_ids', None))\n            stats = filter_stats_by_fused_ids(stats, fused_ids)\n\n            # Link search space files (same logic as compile task)\n            _link_search_spaces(stats, split_dir, op_name)\n\n            fused_work_items, _, _ = build_fused_work_items(\n                stats,\n                op_filter=None,\n                pattern_idx_filter=getattr(args, 'pattern_idx_filter', None),\n            )\n\n            if not fused_work_items:\n                print(f\"  [{split_name}] No work items for {op_name}\")\n                continue\n\n            expanded = _expand_work_items(fused_work_items)\n            if getattr(args, 'limit', None):\n                expanded = expanded[:args.limit]\n\n\n\n            # Resume: parse existing TSV and filter completed items\n            resume_path = getattr(args, 'resume', None)\n            completed = None\n            retryable = set()\n            if resume_path:\n                resume_file = Path(resume_path)\n                if resume_file.exists():\n                    completed, retryable = _parse_completed_keys(resume_file)\n                    print(f\"  [{split_name}] Resuming from {resume_file.name}\"\n                          f\" ({len(completed)} done, {len(retryable)} RunFail to retry)\")\n\n            # Group items, filtering out completed ones\n            groups = _group_items(expanded, completed=completed)\n\n            # Count pending items for progress, split into new vs retry\n            pending_items = 0\n            retry_items = 0\n            for grp, tob in groups:\n                for x in grp:\n                    if x[8] == \"baseline\" and tob:\n                        continue  # timing-only baseline\n                    pending_items += 1\n                    key = (str(x[0]), str(x[6]), str(x[8]))\n                    if key in retryable:\n                        retry_items += 1\n            new_items = pending_items - retry_items\n            if retry_items:\n                print(f\"  [{split_name}] {pending_items} configs to run for {op_name}\"\n                      f\" ({new_items} new + {retry_items} retry)\")\n            else:\n                print(f\"  [{split_name}] {pending_items} configs to run for {op_name}\")\n\n            if not groups:\n                print(f\"  [{split_name}] All items already recorded, skipping\")\n                continue\n\n            # Open TSV: append to existing or create new\n            if resume_path and Path(resume_path).exists():\n                result_file = Path(resume_path)\n                # Remove RunFail lines before appending retried results\n                if retryable:\n                    with open(result_file) as f:\n                        lines = f.readlines()\n                    with open(result_file, 'w') as f:\n                        for line in lines:\n                            fields = [fld.strip() for fld in line.split(\"\\t\")]\n                            if len(fields) >= 4 and fields[3] in _RETRYABLE_STATUSES:\n                                continue\n                            f.write(line)\n                tsv_fh = open(result_file, 'a')\n            else:\n                timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n                result_file = split_output / f\"compile_and_run_{op_name}_{timestamp}.tsv\"\n                tsv_fh = open(result_file, 'w')\n                tsv_fh.write(_TSV_HEADER + \"\\n\")\n                tsv_fh.flush()\n            print(f\"  → Results: {result_file.name}\")\n\n            tmp_dir = split_output / \".compile_and_run_tmp\"\n            tmp_dir.mkdir(parents=True, exist_ok=True)\n\n            tsv_lock = threading.Lock()\n            split_pass = split_fail = split_timeout = 0\n\n            def _on_result(r):\n                nonlocal split_pass, split_fail, split_timeout\n                if r[\"status\"] == \"Pass\":\n                    split_pass += 1\n                elif r[\"status\"] == \"Timeout\":\n                    split_timeout += 1\n                else:\n                    split_fail += 1\n                done = split_pass + split_fail + split_timeout\n                pct = 100.0 * done / pending_items if pending_items else 100.0\n                print(\n                    f\"\\r  [{done}/{pending_items}] {pct:.1f}%\"\n                    f\" Pass={split_pass} Fail={split_fail} Timeout={split_timeout}\",\n                    end=\"\", file=sys.stderr,\n                )\n\n            work_q = queue.Queue()\n            for group in groups:\n                work_q.put(group)\n\n            threads = []\n            for board in boards:\n                t = threading.Thread(\n                    target=_board_worker,\n                    args=(board, work_q, None, adx_cfg, tmp_dir),\n                    kwargs={\n                        \"tsv_fh\": tsv_fh,\n                        \"tsv_lock\": tsv_lock,\n                        \"on_result\": _on_result,\n                    },\n                    daemon=True,\n                )\n                t.start()\n                threads.append(t)\n            for t in threads:\n                t.join()\n\n            # Final newline after progress bar\n            print(file=sys.stderr)\n            tsv_fh.close()\n\n            total_pass += split_pass\n            total_fail += split_fail\n\n            # Clean up tmp dir\n            shutil.rmtree(tmp_dir, ignore_errors=True)\n\n    # Summary\n    total = total_pass + total_fail\n    print(f\"\\n{'='*60}\")\n    print(f\"COMPILE-AND-RUN COMPLETE\")\n    print(f\"  Pass={total_pass}, Fail={total_fail}, Total={total}\")\n    print(f\"{'='*60}\\n\")\n\n    return 0\n\n\ndef _link_search_spaces(stats, split_dir, op_name):\n    \"\"\"Link fused ops to their search space files.\"\"\"\n    tile_config_dir = split_dir / \"tile-configs\"\n    if not tile_config_dir.exists():\n        return\n\n    safe_primary = f\"linalg_{op_name}\"\n    primary_short = op_name\n    fused_ops = stats.get('fused_ops', {})\n\n    for fp_key, fused_data in fused_ops.items():\n        safe_fp_key = fp_key.replace('.', '_').replace(':', '_').replace('/', '_')\n        for idx, pattern in enumerate(fused_data.get('shape_patterns', [])):\n            fused_filename = f\"{safe_fp_key}_{idx}_search_space.json\"\n            fused_path = tile_config_dir / f\"{primary_short}_fused\" / fused_filename\n            if fused_path.exists():\n                pattern['search_space_filepath'] = str(fused_path)\n            else:\n                tc_filename = f\"{safe_primary}_{idx}_search_space.json\"\n                tc_path = tile_config_dir / op_name / tc_filename\n                if tc_path.exists():\n                    pattern['search_space_filepath'] = str(tc_path)\n","numLines":582,"startLine":1,"totalLines":582}},"sourceToolAssistantUUID":"e5c40632-edba-432d-a051-ae6c8eb825b9"}
