{"parentUuid":"5d909944-b756-48ee-b377-59db77cb1da3","isSidechain":false,"userType":"external","cwd":"/home/nick/work/ai_iree","sessionId":"71dec615-7b07-4e9a-9c31-50ec143dbbf8","version":"2.1.72","gitBranch":"master","slug":"purrfect-wandering-puppy","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VwuoRL3WSjrrz4exfAyVkM","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"ADX builder: compile MLIR subgraph to bare-metal ELF via 4-stage pipeline.\n     3→\n     4→Pipeline:\n     5→  MLIR → [iree-compile --compile-to=executable-configurations] → benchmark subgraph MLIR\n     6→       → [iree-compile -compile-from=executable-sources --output-format=vm-c]\n     7→                                      → host-c.h + kernel.h + kernel.o\n     8→       → [clang dispatch_driver.c]   → entry.o\n     9→       → [clang++ static link]       → *.adx\n    10→       → [GDB]                       → bare-metal RISC-V (optional, --run)\n    11→\n    12→Usage:\n    13→  python3 script/adx_builder.py <mlir_file> -o <output_dir> --config config/AX45_1024.toml\n    14→  python3 script/adx_builder.py <mlir_file> -o <output_dir> --config config/AX45_1024.toml --run\n    15→\"\"\"\n    16→\n    17→import argparse\n    18→import os\n    19→import queue\n    20→import re\n    21→import shutil\n    22→import subprocess\n    23→import sys\n    24→import time\n    25→from concurrent.futures import ThreadPoolExecutor, as_completed\n    26→from pathlib import Path\n    27→\n    28→try:\n    29→    import tomllib\n    30→except ImportError:\n    31→    try:\n    32→        import tomli as tomllib\n    33→    except ImportError:\n    34→        tomllib = None\n    35→\n    36→REPO_ROOT = Path(__file__).parent.parent\n    37→IREE_COMPILE = Path(\"/home/nick/work/AIAutoIREE/third-party/iree-build/tools/iree-compile\")\n    38→BARE_METAL_SRC = REPO_ROOT / \"bare-metal\" / \"src\"\n    39→BARE_METAL_LD = REPO_ROOT / \"bare-metal\" / \"utility\" / \"ae350-NN-xip_x.ld\"\n    40→BARE_METAL_GDB_SCRIPT = REPO_ROOT / \"bare-metal\" / \"gdb\" / \"gdb_45.script\"\n    41→\n    42→\n    43→def load_config(toml_path: str) -> dict:\n    44→    \"\"\"Load and validate TOML config. Raises if required keys are missing.\"\"\"\n    45→    if tomllib is None:\n    46→        raise ImportError(\"tomllib (Python 3.11+) or tomli package required\")\n    47→    with open(toml_path, \"rb\") as f:\n    48→        cfg = tomllib.load(f)\n    49→    llvm = cfg.get(\"build\", {}).get(\"llvm\", {})\n    50→    for k in (\"triple\", \"cpu\", \"attr\", \"vlen\"):\n    51→        if k not in llvm:\n    52→            raise ValueError(f\"Missing config key: build.llvm.{k}\")\n    53→    runtime = cfg.get(\"runtime\", {})\n    54→    for k in (\"iree_src_dir\", \"iree_lib_dir\"):\n    55→        if k not in runtime:\n    56→            raise ValueError(f\"Missing config key: runtime.{k}\")\n    57→    return cfg\n    58→\n    59→\n    60→def _base_riscv_flags(cfg: dict) -> list[str]:\n    61→    \"\"\"Common RISC-V iree-compile flags shared by both compilation steps.\"\"\"\n    62→    llvm = cfg[\"build\"][\"llvm\"]\n    63→    triple = llvm[\"triple\"]\n    64→    cpu = llvm[\"cpu\"]\n    65→    attr = llvm[\"attr\"]\n    66→    vlen = int(llvm[\"vlen\"])\n    67→    return [\n    68→        \"-iree-input-type=auto\",\n    69→        \"--iree-llvmcpu-stack-allocation-limit=0x999999\",\n    70→        \"--iree-hal-target-device=local\",\n    71→        \"--iree-hal-local-target-device-backends=llvm-cpu\",\n    72→        f\"-iree-llvmcpu-target-triple={triple}\",\n    73→        f\"-iree-llvmcpu-target-cpu={cpu}\",\n    74→        f\"-iree-llvmcpu-target-cpu-features={attr}\",\n    75→        f\"-iree-llvmcpu-target-vector-width-in-bytes={vlen // 8}\",\n    76→        \"--iree-llvmcpu-loop-interleaving\",\n    77→        \"--iree-llvmcpu-loop-vectorization\",\n    78→        \"--iree-llvmcpu-loop-unrolling\",\n    79→        \"--iree-llvmcpu-slp-vectorization\",\n    80→        \"-riscv-v-fixed-length-vector-lmul-max=8\",\n    81→        f\"-riscv-v-vector-bits-min={vlen}\",\n    82→        \"--iree-global-opt-propagate-transposes=False\",\n    83→        \"-iree-llvmcpu-link-embedded=false\",\n    84→        \"-iree-llvmcpu-link-static\",\n    85→        \"--iree-llvmcpu-optimization-remarks=stack-frame-layout\",\n    86→    ]\n    87→\n    88→\n    89→def stage1_dump_benchmarks(mlir_file: Path, benchmarks_dir: Path, cfg: dict) -> Path:\n    90→    \"\"\"Stage 1a: compile to executable-configurations and dump benchmark MLIRs.\n    91→\n    92→    Returns: path to the first *_static_benchmark.mlir found.\n    93→    \"\"\"\n    94→    if not IREE_COMPILE.exists():\n    95→        raise FileNotFoundError(f\"iree-compile not found: {IREE_COMPILE}\")\n    96→\n    97→    benchmarks_dir.mkdir(parents=True, exist_ok=True)\n    98→\n    99→    cmd = [\n   100→        str(IREE_COMPILE),\n   101→        str(mlir_file),\n   102→        \"--compile-to=executable-configurations\",\n   103→        f\"--iree-hal-dump-executable-benchmarks-to={benchmarks_dir}\",\n   104→    ] + _base_riscv_flags(cfg) + [\n   105→        \"--output-format=vm-c\",\n   106→    ]\n   107→\n   108→    result = subprocess.run(cmd, capture_output=True, text=True)\n   109→    if result.returncode != 0:\n   110→        print(f\"iree-compile (dump) stderr:\\n{result.stderr}\", file=sys.stderr)\n   111→        raise subprocess.CalledProcessError(result.returncode, cmd)\n   112→\n   113→    benchmark_files = sorted(benchmarks_dir.glob(\"*_static_benchmark.mlir\"))\n   114→    if not benchmark_files:\n   115→        raise FileNotFoundError(\n   116→            f\"No *_static_benchmark.mlir found in {benchmarks_dir}\"\n   117→        )\n   118→    return benchmark_files[0]\n   119→\n   120→\n   121→def stage1_compile_vmc(\n   122→    benchmark_mlir: Path, temp_dir: Path, cfg: dict\n   123→) -> tuple[Path, Path, Path, str]:\n   124→    \"\"\"Stage 1b: compile benchmark MLIR from executable-sources to vm-c.\n   125→\n   126→    Returns: (host_c_h, kernel_h, kernel_o, stderr_text)\n   127→    \"\"\"\n   128→    host_c_h = temp_dir / \"host-c.h\"\n   129→    kernel_o = temp_dir / \"kernel.o\"\n   130→    kernel_h = temp_dir / \"kernel.h\"\n   131→\n   132→    cmd = [\n   133→        str(IREE_COMPILE),\n   134→        str(benchmark_mlir),\n   135→        \"-o\", str(host_c_h),\n   136→    ] + _base_riscv_flags(cfg) + [\n   137→        \"--output-format=vm-c\",\n   138→        \"-compile-from=executable-sources\",\n   139→        # Must be a relative path (iree-compile limitation); run cwd=temp_dir\n   140→        \"--iree-llvmcpu-static-library-output-path=kernel.o\",\n   141→    ]\n   142→\n   143→    result = subprocess.run(cmd, capture_output=True, text=True, cwd=str(temp_dir))\n   144→    if result.returncode != 0:\n   145→        print(f\"iree-compile (vm-c) stderr:\\n{result.stderr}\", file=sys.stderr)\n   146→        raise subprocess.CalledProcessError(result.returncode, cmd)\n   147→\n   148→    if not host_c_h.exists():\n   149→        raise FileNotFoundError(f\"Stage 1b output missing: {host_c_h}\")\n   150→\n   151→    # iree-compile may drop the stem and produce \".o\"/\".h\" instead of \"kernel.o\"/\"kernel.h\"\n   152→    if not kernel_o.exists():\n   153→        dotfile_o = temp_dir / \".o\"\n   154→        if dotfile_o.exists():\n   155→            dotfile_o.rename(kernel_o)\n   156→        else:\n   157→            raise FileNotFoundError(f\"Stage 1b output missing: {kernel_o}\")\n   158→    if not kernel_h.exists():\n   159→        dotfile_h = temp_dir / \".h\"\n   160→        if dotfile_h.exists():\n   161→            dotfile_h.rename(kernel_h)\n   162→        # kernel.h absence is non-fatal — entry func detection uses benchmark MLIR\n   163→\n   164→    return host_c_h, kernel_h, kernel_o, result.stderr or \"\"\n   165→\n   166→\n   167→def _detect_entry_func_from_benchmark(benchmark_mlir: Path) -> str:\n   168→    \"\"\"Extract entry function from benchmark MLIR as 'module.<func>'.\n   169→\n   170→    Looks for the public benchmark entry: util.func public @<name>(%arg0: i32)\n   171→    The module name defaults to 'module' when the top-level module is unnamed.\n   172→    \"\"\"\n   173→    content = benchmark_mlir.read_text()\n   174→    # Named module: module @name { ... }\n   175→    module_m = re.search(r'^module\\s+@(\\w+)', content, re.MULTILINE)\n   176→    module_name = module_m.group(1) if module_m else \"module\"\n   177→    # Public benchmark entry function takes i32 count\n   178→    func_m = re.search(r'util\\.func\\s+public\\s+@(\\w+)\\s*\\(\\s*%\\w+\\s*:\\s*i32\\s*\\)', content)\n   179→    if not func_m:\n   180→        raise ValueError(f\"Could not detect util.func public @name(i32) in {benchmark_mlir}\")\n   181→    return f\"{module_name}.{func_m.group(1)}\"\n   182→\n   183→\n   184→def _parse_query_name(kernel_h: Path) -> str:\n   185→    \"\"\"Extract HAL library query function name from kernel.h.\"\"\"\n   186→    lines = kernel_h.read_text().splitlines()\n   187→    for idx, line in enumerate(lines):\n   188→        if re.match(r'^const\\s+iree_hal_executable_library_header_t\\*\\*', line):\n   189→            for next_line in lines[idx + 1:]:\n   190→                if re.match(r'^\\s*$', next_line):\n   191→                    break\n   192→                words = next_line.strip().split()\n   193→                if words:\n   194→                    return words[0].replace('(', '')\n   195→            break\n   196→    raise ValueError(f\"Could not find HAL query function declaration in {kernel_h}\")\n   197→\n   198→\n   199→def stage2_compile_entry(\n   200→    kernel_h: Path, entry_func: str, temp_dir: Path, cfg: dict\n   201→) -> Path:\n   202→    \"\"\"Stage 2: compile dispatch_driver.c → entry.o.\"\"\"\n   203→    if not kernel_h.exists():\n   204→        raise FileNotFoundError(f\"kernel.h not found: {kernel_h}\")\n   205→\n   206→    query_name = _parse_query_name(kernel_h)\n   207→\n   208→    # Append libraries[] array declaration to kernel.h\n   209→    append_code = (\n   210→        \"\\nconst iree_hal_executable_library_query_fn_t libraries[] = {\\n\"\n   211→        f\"    {query_name},\\n\"\n   212→        \"};\\n\"\n   213→    )\n   214→    with open(kernel_h, \"a\") as f:\n   215→        f.write(append_code)\n   216→\n   217→    toolchain_bin = cfg[\"build\"][\"riscv_toolchain\"]\n   218→    iree_src_dir = cfg[\"runtime\"][\"iree_src_dir\"]\n   219→    clang = Path(toolchain_bin) / \"clang\"\n   220→    dispatch_driver_c = BARE_METAL_SRC / \"dispatch_driver.c\"\n   221→    entry_o = temp_dir / \"entry.o\"\n   222→\n   223→    cmd = [\n   224→        str(clang),\n   225→        str(dispatch_driver_c),\n   226→        \"-c\",\n   227→        \"-o\", str(entry_o),\n   228→        f\"-I{temp_dir}\",\n   229→        f\"-I{BARE_METAL_SRC}\",\n   230→        f\"-I{iree_src_dir}\",\n   231→        \"-mabi=lp64d\",\n   232→        \"-DIREE_PLATFORM_GENERIC=1\",\n   233→        \"-DEMITC_IMPLEMENTATION\",\n   234→        \"-DPF_COUNTER\",\n   235→        f\"-DQUERY={query_name}\",\n   236→        f'-D_FUNC=\"{entry_func}\"',\n   237→        \"-O3\",\n   238→    ]\n   239→\n   240→    result = subprocess.run(cmd, capture_output=True, text=True)\n   241→    if result.returncode != 0:\n   242→        print(f\"clang stderr:\\n{result.stderr}\", file=sys.stderr)\n   243→        raise subprocess.CalledProcessError(result.returncode, cmd)\n   244→\n   245→    return entry_o\n   246→\n   247→\n   248→def stage3_link_adx(entry_o: Path, kernel_o: Path, out_adx: Path, cfg: dict) -> Path:\n   249→    \"\"\"Stage 3: link entry.o + kernel.o + static libs → .adx ELF.\"\"\"\n   250→    toolchain_bin = cfg[\"build\"][\"riscv_toolchain\"]\n   251→    iree_lib_dir = cfg[\"runtime\"][\"iree_lib_dir\"]\n   252→    clangpp = Path(toolchain_bin) / \"clang++\"\n   253→\n   254→    lib_files = sorted(Path(iree_lib_dir).rglob(\"lib*.a\"))\n   255→    if not lib_files:\n   256→        raise FileNotFoundError(f\"No lib*.a found in {iree_lib_dir}\")\n   257→\n   258→    cmd = [\n   259→        str(clangpp),\n   260→        \"-o\", str(out_adx),\n   261→        \"-T\", str(BARE_METAL_LD),\n   262→        \"-mvh\",\n   263→        str(entry_o),\n   264→        str(kernel_o),\n   265→        \"-lm\",\n   266→        \"-Wl,--start-group\",\n   267→        *[str(f) for f in lib_files],\n   268→        \"-Wl,--end-group\",\n   269→    ]\n   270→\n   271→    result = subprocess.run(cmd, capture_output=True, text=True)\n   272→    if result.returncode != 0:\n   273→        print(f\"clang++ stderr:\\n{result.stderr}\", file=sys.stderr)\n   274→        raise subprocess.CalledProcessError(result.returncode, cmd)\n   275→\n   276→    return out_adx\n   277→\n   278→\n   279→def _boardfarm_get_iceman_port(remote: str, board_id: int, account: str, password: str) -> int | None:\n   280→    \"\"\"Query boardfarm API for the current iceman port of board_id.\n   281→\n   282→    Returns the port int if iceman is running, None if not running or board not found.\n   283→    \"\"\"\n   284→    try:\n   285→        import urllib.request\n   286→        import urllib.error\n   287→        import json\n   288→        import ssl\n   289→        import base64\n   290→\n   291→        url = f\"https://{remote}/api/v2/my_boards/\"\n   292→        token = base64.b64encode(f\"{account}:{password}\".encode()).decode()\n   293→        req = urllib.request.Request(url, headers={\"Authorization\": f\"Basic {token}\"})\n   294→        ctx = ssl.create_default_context()\n   295→        ctx.check_hostname = False\n   296→        ctx.verify_mode = ssl.CERT_NONE\n   297→        with urllib.request.urlopen(req, context=ctx, timeout=30) as resp:\n   298→            data = json.loads(resp.read())\n   299→        results = data.get(\"results\", [])\n   300→        for board in results:\n   301→            if board.get(\"id\") == board_id:\n   302→                port_str = board.get(\"iceman_port\")\n   303→                if port_str:\n   304→                    return int(port_str.split(\":\")[1])\n   305→                return None\n   306→        print(f\"  [boardfarm] warning: board_id={board_id} not found in results\", file=sys.stderr)\n   307→        return None\n   308→    except Exception as e:\n   309→        print(f\"  [boardfarm] GET my_boards failed: {e}\", file=sys.stderr)\n   310→        return None\n   311→\n   312→\n   313→def _boardfarm_launch_iceman(remote: str, board_id: int, port: int, account: str, password: str) -> bool:\n   314→    \"\"\"POST launch_iceman for board_id. Returns True on HTTP 200.\"\"\"\n   315→    try:\n   316→        import urllib.request\n   317→        import urllib.parse\n   318→        import ssl\n   319→        import base64\n   320→\n   321→        url = f\"https://{remote}/api/v2/my_boards/{board_id}/launch_iceman/\"\n   322→        token = base64.b64encode(f\"{account}:{password}\".encode()).decode()\n   323→        body = urllib.parse.urlencode({\"iceman_flag\": f\"-p {port} -D -Z v5\"}).encode()\n   324→        req = urllib.request.Request(url, data=body, headers={\n   325→            \"Authorization\": f\"Basic {token}\",\n   326→            \"Content-Type\": \"application/x-www-form-urlencoded\",\n   327→        })\n   328→        ctx = ssl.create_default_context()\n   329→        ctx.check_hostname = False\n   330→        ctx.verify_mode = ssl.CERT_NONE\n   331→        with urllib.request.urlopen(req, context=ctx, timeout=30) as resp:\n   332→            return resp.status == 200\n   333→    except Exception as e:\n   334→        print(f\"  [boardfarm] launch_iceman failed: {e}\", file=sys.stderr)\n   335→        return False\n   336→\n   337→\n   338→def _boardfarm_reconnect(remote: str, board_id: int, port: int, account: str, password: str,\n   339→                         max_attempts: int = 3) -> int | None:\n   340→    \"\"\"Try to recover iceman: query current port, or launch and poll.\n   341→\n   342→    Returns new port int on success, None on failure.\n   343→    \"\"\"\n   344→    print(f\"  [boardfarm] reconnecting board_id={board_id} on {remote} ...\", file=sys.stderr)\n   345→\n   346→    # Step 1: maybe iceman is already running on a different port\n   347→    new_port = _boardfarm_get_iceman_port(remote, board_id, account, password)\n   348→    if new_port is not None:\n   349→        print(f\"  [boardfarm] iceman already running on port {new_port}\", file=sys.stderr)\n   350→        return new_port\n   351→\n   352→    # Step 2: launch iceman, poll for port\n   353→    for attempt in range(1, max_attempts + 1):\n   354→        print(f\"  [boardfarm] launch_iceman attempt {attempt}/{max_attempts} ...\", file=sys.stderr)\n   355→        _boardfarm_launch_iceman(remote, board_id, port, account, password)\n   356→        time.sleep(60)\n   357→        new_port = _boardfarm_get_iceman_port(remote, board_id, account, password)\n   358→        if new_port is not None:\n   359→            print(f\"  [boardfarm] iceman started on port {new_port}\", file=sys.stderr)\n   360→            return new_port\n   361→\n   362→    print(f\"  [boardfarm] failed to start iceman after {max_attempts} attempts\", file=sys.stderr)\n   363→    return None\n   364→\n   365→\n   366→def _is_connection_error(output: str) -> bool:\n   367→    return (\n   368→        \"Connection timed out\" in output\n   369→        or \"Connection refused\" in output\n   370→        or \"Network is unreachable\" in output\n   371→        or \"could not connect\" in output\n   372→    )\n   373→\n   374→\n   375→def load_boards(cfg: dict) -> list[dict]:\n   376→    \"\"\"Return list of board configs from cfg.\n   377→\n   378→    Supports two TOML formats:\n   379→      - New:  [[target.boards]]  (array of board dicts); shared fields\n   380→              (gdb, boardfarm_account, boardfarm_password) may be placed\n   381→              in [target] and are inherited by each board unless overridden.\n   382→      - Old:  [target.gdb]       (single board, for backward compat)\n   383→    \"\"\"\n   384→    target = cfg.get(\"target\", {})\n   385→    boards = target.get(\"boards\")\n   386→    if boards:\n   387→        # Shared fields from [target] inherited by each board\n   388→        shared = {k: v for k, v in target.items()\n   389→                  if k not in (\"boards\", \"device\", \"gdb\") and not isinstance(v, (dict, list))}\n   390→        if \"gdb\" in target:\n   391→            shared[\"gdb\"] = target[\"gdb\"]\n   392→        return [{**shared, **board} for board in boards]\n   393→    # Fall back to legacy [target.gdb]\n   394→    gdb_cfg = target.get(\"gdb\", {})\n   395→    if gdb_cfg:\n   396→        return [gdb_cfg]\n   397→    return []\n   398→\n   399→\n   400→def stage4_run_gdb(adx_path: Path, cfg_or_board: dict, timeout: float | None = None) -> str:\n   401→    \"\"\"Stage 4: upload and execute via GDB. Returns stdout+stderr.\n   402→\n   403→    Accepts either a full cfg dict (uses first board) or a board dict directly.\n   404→    Automatically reconnects via boardfarm API on connection failure.\n   405→    Raises subprocess.TimeoutExpired if timeout (seconds) is exceeded.\n   406→    \"\"\"\n   407→    # Accept either full cfg or a board dict\n   408→    if \"target\" in cfg_or_board or \"build\" in cfg_or_board:\n   409→        boards = load_boards(cfg_or_board)\n   410→        board = boards[0] if boards else {}\n   411→    else:\n   412→        board = cfg_or_board\n   413→\n   414→    gdb = board.get(\"gdb\")\n   415→    remote = board.get(\"remote\", \"\")\n   416→    port = board.get(\"port\")\n   417→    board_id = board.get(\"board_id\", 0)\n   418→    account = board.get(\"boardfarm_account\") or os.environ.get(\"AUTOIREE_BOARDFARM_ACCOUNT\", \"\")\n   419→    password = board.get(\"boardfarm_password\") or os.environ.get(\"AUTOIREE_BOARDFARM_PASSWORD\", \"\")\n   420→\n   421→    boardfarm_enabled = bool(board_id) and \"boards.andestech.com\" in remote and account and password\n   422→\n   423→    max_retries = 3 if boardfarm_enabled else 1\n   424→    for attempt in range(max_retries):\n   425→        cmd = [\n   426→            gdb,\n   427→            str(adx_path),\n   428→            \"-batch\",\n   429→            \"-ex\", f\"target remote {remote}:{port}\",\n   430→            \"-x\", str(BARE_METAL_GDB_SCRIPT),\n   431→        ]\n   432→        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)\n   433→        output = result.stdout + result.stderr\n   434→\n   435→        if not _is_connection_error(output) or not boardfarm_enabled:\n   436→            return output\n   437→\n   438→        print(f\"  [gdb] connection error on attempt {attempt + 1}, trying boardfarm reconnect ...\",\n   439→              file=sys.stderr)\n   440→        new_port = _boardfarm_reconnect(remote, board_id, port, account, password)\n   441→        if new_port is None:\n   442→            return output\n   443→        port = new_port\n   444→\n   445→    return output\n   446→\n   447→\n   448→_WRITER_SENTINEL = None  # sentinel to stop writer thread\n   449→\n   450→\n   451→def run_adx_files_parallel(\n   452→    adx_files: list,\n   453→    cfg: dict,\n   454→    result_file: Path | None = None,\n   455→    on_result=None,\n   456→) -> list[tuple]:\n   457→    \"\"\"Run adx_files across all configured boards in parallel.\n   458→\n   459→    Distributes work via a shared work queue: each board runs one file at a\n   460→    time, picks the next from the queue when done.\n   461→\n   462→    Results (adx_path, output) are pushed to a result_queue consumed by a\n   463→    single dedicated writer thread — no lock needed on the file.\n   464→\n   465→    If result_file is given, the writer appends TSV rows:\n   466→        <adx_name>\\\\t<Pass|Timeout|Fail>\\\\t<cycles or \"\">\n   467→\n   468→    Returns list of (adx_path, output) tuples in completion order.\n   469→    \"\"\"\n   470→    import threading\n   471→\n   472→    boards = load_boards(cfg)\n   473→    if not boards:\n   474→        raise ValueError(\"No boards configured in [target.gdb] or [[target.boards]]\")\n   475→\n   476→    work_queue: queue.Queue = queue.Queue()\n   477→    for adx in adx_files:\n   478→        work_queue.put(adx)\n   479→\n   480→    result_queue: queue.Queue = queue.Queue()\n   481→    results: list[tuple] = []\n   482→\n   483→    def _status_and_cycles(output: str) -> tuple[str, str]:\n   484→        cycles = _parse_cycle_count(output)\n   485→        if cycles:\n   486→            return \"Pass\", cycles\n   487→        if \"timed out\" in output.lower() or \"timeout\" in output.lower():\n   488→            return \"Timeout\", \"\"\n   489→        return \"Fail\", \"\"\n   490→\n   491→    def _writer():\n   492→        \"\"\"Single thread that drains result_queue and writes to file.\"\"\"\n   493→        fh = open(result_file, \"a\") if result_file else None\n   494→        if fh:\n   495→            fh.write(\"adx_file\\tstatus\\tcycles\\n\")\n   496→        while True:\n   497→            item = result_queue.get()\n   498→            if item is _WRITER_SENTINEL:\n   499→                break\n   500→            adx, output, board = item\n   501→            results.append((adx, output))\n   502→            status, cycles = _status_and_cycles(output)\n   503→            if fh:\n   504→                fh.write(f\"{adx.name}\\t{status}\\t{cycles}\\n\")\n   505→                fh.flush()\n   506→            if on_result:\n   507→                on_result(adx, status, cycles, output, board)\n   508→        if fh:\n   509→            fh.close()\n   510→\n   511→    writer_thread = threading.Thread(target=_writer, daemon=True)\n   512→    writer_thread.start()\n   513→\n   514→    def worker(board: dict):\n   515→        while True:\n   516→            try:\n   517→                adx = work_queue.get_nowait()\n   518→            except queue.Empty:\n   519→                break\n   520→            output = stage4_run_gdb(adx, board)\n   521→            result_queue.put((adx, output, board))\n   522→            work_queue.task_done()\n   523→\n   524→    with ThreadPoolExecutor(max_workers=len(boards)) as executor:\n   525→        futures = [executor.submit(worker, board) for board in boards]\n   526→        for f in as_completed(futures):\n   527→            f.result()  # re-raise any exception\n   528→\n   529→    result_queue.put(_WRITER_SENTINEL)  # signal writer to stop\n   530→    writer_thread.join()\n   531→\n   532→    return results\n   533→\n   534→\n   535→def _parse_cycle_count(gdb_output: str) -> str | None:\n   536→    \"\"\"Extract cycle count from GDB stdout.\"\"\"\n   537→    m = re.search(r'The cycle count is (\\d+)', gdb_output)\n   538→    return m.group(1) if m else None\n   539→\n   540→\n   541→def compile_mlir_to_adx(mlir_file: Path, output_dir: Path, cfg: dict) -> tuple[Path, str]:\n   542→    \"\"\"Compile a single MLIR file to a bare-metal .adx ELF.\n   543→\n   544→    Returns: (adx_path, compile_stderr) where compile_stderr contains\n   545→    optimization remarks for spill detection.\n   546→    \"\"\"\n   547→    mlir_file = mlir_file.resolve()\n   548→    output_dir = Path(output_dir)\n   549→    output_dir.mkdir(parents=True, exist_ok=True)\n   550→\n   551→    stem = mlir_file.stem\n   552→    temp_dir = (output_dir / \"temp\" / stem).resolve()\n   553→    temp_dir.mkdir(parents=True, exist_ok=True)\n   554→    benchmarks_dir = temp_dir / \"benchmarks\"\n   555→\n   556→    benchmark_mlir = stage1_dump_benchmarks(mlir_file, benchmarks_dir, cfg)\n   557→    entry_func = _detect_entry_func_from_benchmark(benchmark_mlir)\n   558→    host_c_h, kernel_h, kernel_o, compile_stderr = stage1_compile_vmc(benchmark_mlir, temp_dir, cfg)\n   559→    entry_o = stage2_compile_entry(kernel_h, entry_func, temp_dir, cfg)\n   560→    out_adx = output_dir / f\"{stem}.adx\"\n   561→    stage3_link_adx(entry_o, kernel_o, out_adx, cfg)\n   562→    shutil.rmtree(temp_dir, ignore_errors=True)\n   563→    return out_adx, compile_stderr\n   564→\n   565→\n   566→def cmd_compile(args):\n   567→    mlir_file = args.mlir_file.resolve()\n   568→    if not mlir_file.exists():\n   569→        sys.exit(f\"Error: MLIR file not found: {mlir_file}\")\n   570→\n   571→    output_dir = args.output_dir.resolve()\n   572→    output_dir.mkdir(parents=True, exist_ok=True)\n   573→\n   574→    stem = mlir_file.stem\n   575→    temp_dir = (output_dir / \"temp\" / stem).resolve()\n   576→    temp_dir.mkdir(parents=True, exist_ok=True)\n   577→    benchmarks_dir = temp_dir / \"benchmarks\"\n   578→\n   579→    cfg = load_config(args.config)\n   580→\n   581→    print(\"Stage 1a: iree-compile → benchmark MLIR ...\")\n   582→    benchmark_mlir = stage1_dump_benchmarks(mlir_file, benchmarks_dir, cfg)\n   583→    print(f\"  benchmark: {benchmark_mlir.name}\")\n   584→\n   585→    entry_func = args.entry_func or _detect_entry_func_from_benchmark(benchmark_mlir)\n   586→    print(f\"  entry func: {entry_func}\")\n   587→\n   588→    print(\"Stage 1b: iree-compile → vm-c ...\")\n   589→    host_c_h, kernel_h, kernel_o, _stderr = stage1_compile_vmc(benchmark_mlir, temp_dir, cfg)\n   590→    print(f\"  host-c.h : {host_c_h.name}\")\n   591→    print(f\"  kernel.h : {kernel_h.name}\")\n   592→    print(f\"  kernel.o : {kernel_o.name}\")\n   593→\n   594→    print(\"Stage 2: clang dispatch_driver.c → entry.o ...\")\n   595→    entry_o = stage2_compile_entry(kernel_h, entry_func, temp_dir, cfg)\n   596→    print(f\"  entry.o  : {entry_o.name}\")\n   597→\n   598→    out_adx = output_dir / f\"{stem}.adx\"\n   599→    print(f\"Stage 3: clang++ link → {out_adx.name} ...\")\n   600→    stage3_link_adx(entry_o, kernel_o, out_adx, cfg)\n   601→\n   602→    shutil.rmtree(temp_dir, ignore_errors=True)\n   603→    print(f\"Done: {out_adx}\")\n   604→\n   605→\n   606→def cmd_run(args):\n   607→    cfg = load_config(args.config)\n   608→\n   609→    # Collect .adx files from file args or directory\n   610→    adx_files = []\n   611→    for path in args.adx_paths:\n   612→        p = Path(path).resolve()\n   613→        if p.is_dir():\n   614→            adx_files.extend(sorted(p.glob(\"*.adx\")))\n   615→        elif p.suffix == \".adx\":\n   616→            adx_files.append(p)\n   617→        else:\n   618→            sys.exit(f\"Error: expected .adx file or directory, got: {p}\")\n   619→\n   620→    if not adx_files:\n   621→        sys.exit(\"Error: no .adx files found\")\n   622→\n   623→    boards = load_boards(cfg)\n   624→    print(f\"Running {len(adx_files)} file(s) on {len(boards)} board(s) in parallel ...\\n\")\n   625→\n   626→    results = run_adx_files_parallel(adx_files, cfg)\n   627→    for adx, output in sorted(results, key=lambda x: x[0].name):\n   628→        cycles = _parse_cycle_count(output)\n   629→        if cycles:\n   630→            print(f\"  {adx.name}: cycles = {cycles}\")\n   631→        else:\n   632→            hint = next((l for l in output.splitlines() if l.strip()), \"no output\")\n   633→            print(f\"  {adx.name}: FAILED ({hint})\")\n   634→            print(output, file=sys.stderr)\n   635→\n   636→\n   637→def main():\n   638→    parser = argparse.ArgumentParser(\n   639→        description=\"ADX build and run pipeline for RISC-V bare-metal\"\n   640→    )\n   641→    sub = parser.add_subparsers(dest=\"task\", required=True)\n   642→\n   643→    # --- compile ---\n   644→    p_compile = sub.add_parser(\"compile\", help=\"Compile MLIR to .adx ELF\")\n   645→    p_compile.add_argument(\"mlir_file\", type=Path, help=\"Input MLIR file\")\n   646→    p_compile.add_argument(\"-o\", \"--output-dir\", type=Path, required=True,\n   647→                           help=\"Output directory for .adx file\")\n   648→    p_compile.add_argument(\"--config\", default=\"config/AX45_1024.toml\",\n   649→                           help=\"TOML config (default: config/AX45_1024.toml)\")\n   650→    p_compile.add_argument(\"--entry-func\", default=None,\n   651→                           help=\"Entry function name (overrides auto-detection)\")\n   652→\n   653→    # --- run ---\n   654→    p_run = sub.add_parser(\"run\", help=\"Run .adx file(s) via GDB\")\n   655→    p_run.add_argument(\"adx_paths\", nargs=\"+\",\n   656→                       help=\".adx file(s) or directory containing .adx files\")\n   657→    p_run.add_argument(\"--config\", default=\"config/AX45_1024.toml\",\n   658→                       help=\"TOML config (default: config/AX45_1024.toml)\")\n   659→\n   660→    args = parser.parse_args()\n   661→    if args.task == \"compile\":\n   662→        cmd_compile(args)\n   663→    elif args.task == \"run\":\n   664→        cmd_run(args)\n   665→\n   666→\n   667→if __name__ == \"__main__\":\n   668→    main()\n   669→"}]},"uuid":"adcd1c70-0a64-4fce-86ee-91c7de8fc3c9","timestamp":"2026-03-20T02:56:56.362Z","toolUseResult":{"type":"text","file":{"filePath":"/home/nick/work/ai_iree/script/adx_builder.py","content":"#!/usr/bin/env python3\n\"\"\"ADX builder: compile MLIR subgraph to bare-metal ELF via 4-stage pipeline.\n\nPipeline:\n  MLIR → [iree-compile --compile-to=executable-configurations] → benchmark subgraph MLIR\n       → [iree-compile -compile-from=executable-sources --output-format=vm-c]\n                                      → host-c.h + kernel.h + kernel.o\n       → [clang dispatch_driver.c]   → entry.o\n       → [clang++ static link]       → *.adx\n       → [GDB]                       → bare-metal RISC-V (optional, --run)\n\nUsage:\n  python3 script/adx_builder.py <mlir_file> -o <output_dir> --config config/AX45_1024.toml\n  python3 script/adx_builder.py <mlir_file> -o <output_dir> --config config/AX45_1024.toml --run\n\"\"\"\n\nimport argparse\nimport os\nimport queue\nimport re\nimport shutil\nimport subprocess\nimport sys\nimport time\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom pathlib import Path\n\ntry:\n    import tomllib\nexcept ImportError:\n    try:\n        import tomli as tomllib\n    except ImportError:\n        tomllib = None\n\nREPO_ROOT = Path(__file__).parent.parent\nIREE_COMPILE = Path(\"/home/nick/work/AIAutoIREE/third-party/iree-build/tools/iree-compile\")\nBARE_METAL_SRC = REPO_ROOT / \"bare-metal\" / \"src\"\nBARE_METAL_LD = REPO_ROOT / \"bare-metal\" / \"utility\" / \"ae350-NN-xip_x.ld\"\nBARE_METAL_GDB_SCRIPT = REPO_ROOT / \"bare-metal\" / \"gdb\" / \"gdb_45.script\"\n\n\ndef load_config(toml_path: str) -> dict:\n    \"\"\"Load and validate TOML config. Raises if required keys are missing.\"\"\"\n    if tomllib is None:\n        raise ImportError(\"tomllib (Python 3.11+) or tomli package required\")\n    with open(toml_path, \"rb\") as f:\n        cfg = tomllib.load(f)\n    llvm = cfg.get(\"build\", {}).get(\"llvm\", {})\n    for k in (\"triple\", \"cpu\", \"attr\", \"vlen\"):\n        if k not in llvm:\n            raise ValueError(f\"Missing config key: build.llvm.{k}\")\n    runtime = cfg.get(\"runtime\", {})\n    for k in (\"iree_src_dir\", \"iree_lib_dir\"):\n        if k not in runtime:\n            raise ValueError(f\"Missing config key: runtime.{k}\")\n    return cfg\n\n\ndef _base_riscv_flags(cfg: dict) -> list[str]:\n    \"\"\"Common RISC-V iree-compile flags shared by both compilation steps.\"\"\"\n    llvm = cfg[\"build\"][\"llvm\"]\n    triple = llvm[\"triple\"]\n    cpu = llvm[\"cpu\"]\n    attr = llvm[\"attr\"]\n    vlen = int(llvm[\"vlen\"])\n    return [\n        \"-iree-input-type=auto\",\n        \"--iree-llvmcpu-stack-allocation-limit=0x999999\",\n        \"--iree-hal-target-device=local\",\n        \"--iree-hal-local-target-device-backends=llvm-cpu\",\n        f\"-iree-llvmcpu-target-triple={triple}\",\n        f\"-iree-llvmcpu-target-cpu={cpu}\",\n        f\"-iree-llvmcpu-target-cpu-features={attr}\",\n        f\"-iree-llvmcpu-target-vector-width-in-bytes={vlen // 8}\",\n        \"--iree-llvmcpu-loop-interleaving\",\n        \"--iree-llvmcpu-loop-vectorization\",\n        \"--iree-llvmcpu-loop-unrolling\",\n        \"--iree-llvmcpu-slp-vectorization\",\n        \"-riscv-v-fixed-length-vector-lmul-max=8\",\n        f\"-riscv-v-vector-bits-min={vlen}\",\n        \"--iree-global-opt-propagate-transposes=False\",\n        \"-iree-llvmcpu-link-embedded=false\",\n        \"-iree-llvmcpu-link-static\",\n        \"--iree-llvmcpu-optimization-remarks=stack-frame-layout\",\n    ]\n\n\ndef stage1_dump_benchmarks(mlir_file: Path, benchmarks_dir: Path, cfg: dict) -> Path:\n    \"\"\"Stage 1a: compile to executable-configurations and dump benchmark MLIRs.\n\n    Returns: path to the first *_static_benchmark.mlir found.\n    \"\"\"\n    if not IREE_COMPILE.exists():\n        raise FileNotFoundError(f\"iree-compile not found: {IREE_COMPILE}\")\n\n    benchmarks_dir.mkdir(parents=True, exist_ok=True)\n\n    cmd = [\n        str(IREE_COMPILE),\n        str(mlir_file),\n        \"--compile-to=executable-configurations\",\n        f\"--iree-hal-dump-executable-benchmarks-to={benchmarks_dir}\",\n    ] + _base_riscv_flags(cfg) + [\n        \"--output-format=vm-c\",\n    ]\n\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    if result.returncode != 0:\n        print(f\"iree-compile (dump) stderr:\\n{result.stderr}\", file=sys.stderr)\n        raise subprocess.CalledProcessError(result.returncode, cmd)\n\n    benchmark_files = sorted(benchmarks_dir.glob(\"*_static_benchmark.mlir\"))\n    if not benchmark_files:\n        raise FileNotFoundError(\n            f\"No *_static_benchmark.mlir found in {benchmarks_dir}\"\n        )\n    return benchmark_files[0]\n\n\ndef stage1_compile_vmc(\n    benchmark_mlir: Path, temp_dir: Path, cfg: dict\n) -> tuple[Path, Path, Path, str]:\n    \"\"\"Stage 1b: compile benchmark MLIR from executable-sources to vm-c.\n\n    Returns: (host_c_h, kernel_h, kernel_o, stderr_text)\n    \"\"\"\n    host_c_h = temp_dir / \"host-c.h\"\n    kernel_o = temp_dir / \"kernel.o\"\n    kernel_h = temp_dir / \"kernel.h\"\n\n    cmd = [\n        str(IREE_COMPILE),\n        str(benchmark_mlir),\n        \"-o\", str(host_c_h),\n    ] + _base_riscv_flags(cfg) + [\n        \"--output-format=vm-c\",\n        \"-compile-from=executable-sources\",\n        # Must be a relative path (iree-compile limitation); run cwd=temp_dir\n        \"--iree-llvmcpu-static-library-output-path=kernel.o\",\n    ]\n\n    result = subprocess.run(cmd, capture_output=True, text=True, cwd=str(temp_dir))\n    if result.returncode != 0:\n        print(f\"iree-compile (vm-c) stderr:\\n{result.stderr}\", file=sys.stderr)\n        raise subprocess.CalledProcessError(result.returncode, cmd)\n\n    if not host_c_h.exists():\n        raise FileNotFoundError(f\"Stage 1b output missing: {host_c_h}\")\n\n    # iree-compile may drop the stem and produce \".o\"/\".h\" instead of \"kernel.o\"/\"kernel.h\"\n    if not kernel_o.exists():\n        dotfile_o = temp_dir / \".o\"\n        if dotfile_o.exists():\n            dotfile_o.rename(kernel_o)\n        else:\n            raise FileNotFoundError(f\"Stage 1b output missing: {kernel_o}\")\n    if not kernel_h.exists():\n        dotfile_h = temp_dir / \".h\"\n        if dotfile_h.exists():\n            dotfile_h.rename(kernel_h)\n        # kernel.h absence is non-fatal — entry func detection uses benchmark MLIR\n\n    return host_c_h, kernel_h, kernel_o, result.stderr or \"\"\n\n\ndef _detect_entry_func_from_benchmark(benchmark_mlir: Path) -> str:\n    \"\"\"Extract entry function from benchmark MLIR as 'module.<func>'.\n\n    Looks for the public benchmark entry: util.func public @<name>(%arg0: i32)\n    The module name defaults to 'module' when the top-level module is unnamed.\n    \"\"\"\n    content = benchmark_mlir.read_text()\n    # Named module: module @name { ... }\n    module_m = re.search(r'^module\\s+@(\\w+)', content, re.MULTILINE)\n    module_name = module_m.group(1) if module_m else \"module\"\n    # Public benchmark entry function takes i32 count\n    func_m = re.search(r'util\\.func\\s+public\\s+@(\\w+)\\s*\\(\\s*%\\w+\\s*:\\s*i32\\s*\\)', content)\n    if not func_m:\n        raise ValueError(f\"Could not detect util.func public @name(i32) in {benchmark_mlir}\")\n    return f\"{module_name}.{func_m.group(1)}\"\n\n\ndef _parse_query_name(kernel_h: Path) -> str:\n    \"\"\"Extract HAL library query function name from kernel.h.\"\"\"\n    lines = kernel_h.read_text().splitlines()\n    for idx, line in enumerate(lines):\n        if re.match(r'^const\\s+iree_hal_executable_library_header_t\\*\\*', line):\n            for next_line in lines[idx + 1:]:\n                if re.match(r'^\\s*$', next_line):\n                    break\n                words = next_line.strip().split()\n                if words:\n                    return words[0].replace('(', '')\n            break\n    raise ValueError(f\"Could not find HAL query function declaration in {kernel_h}\")\n\n\ndef stage2_compile_entry(\n    kernel_h: Path, entry_func: str, temp_dir: Path, cfg: dict\n) -> Path:\n    \"\"\"Stage 2: compile dispatch_driver.c → entry.o.\"\"\"\n    if not kernel_h.exists():\n        raise FileNotFoundError(f\"kernel.h not found: {kernel_h}\")\n\n    query_name = _parse_query_name(kernel_h)\n\n    # Append libraries[] array declaration to kernel.h\n    append_code = (\n        \"\\nconst iree_hal_executable_library_query_fn_t libraries[] = {\\n\"\n        f\"    {query_name},\\n\"\n        \"};\\n\"\n    )\n    with open(kernel_h, \"a\") as f:\n        f.write(append_code)\n\n    toolchain_bin = cfg[\"build\"][\"riscv_toolchain\"]\n    iree_src_dir = cfg[\"runtime\"][\"iree_src_dir\"]\n    clang = Path(toolchain_bin) / \"clang\"\n    dispatch_driver_c = BARE_METAL_SRC / \"dispatch_driver.c\"\n    entry_o = temp_dir / \"entry.o\"\n\n    cmd = [\n        str(clang),\n        str(dispatch_driver_c),\n        \"-c\",\n        \"-o\", str(entry_o),\n        f\"-I{temp_dir}\",\n        f\"-I{BARE_METAL_SRC}\",\n        f\"-I{iree_src_dir}\",\n        \"-mabi=lp64d\",\n        \"-DIREE_PLATFORM_GENERIC=1\",\n        \"-DEMITC_IMPLEMENTATION\",\n        \"-DPF_COUNTER\",\n        f\"-DQUERY={query_name}\",\n        f'-D_FUNC=\"{entry_func}\"',\n        \"-O3\",\n    ]\n\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    if result.returncode != 0:\n        print(f\"clang stderr:\\n{result.stderr}\", file=sys.stderr)\n        raise subprocess.CalledProcessError(result.returncode, cmd)\n\n    return entry_o\n\n\ndef stage3_link_adx(entry_o: Path, kernel_o: Path, out_adx: Path, cfg: dict) -> Path:\n    \"\"\"Stage 3: link entry.o + kernel.o + static libs → .adx ELF.\"\"\"\n    toolchain_bin = cfg[\"build\"][\"riscv_toolchain\"]\n    iree_lib_dir = cfg[\"runtime\"][\"iree_lib_dir\"]\n    clangpp = Path(toolchain_bin) / \"clang++\"\n\n    lib_files = sorted(Path(iree_lib_dir).rglob(\"lib*.a\"))\n    if not lib_files:\n        raise FileNotFoundError(f\"No lib*.a found in {iree_lib_dir}\")\n\n    cmd = [\n        str(clangpp),\n        \"-o\", str(out_adx),\n        \"-T\", str(BARE_METAL_LD),\n        \"-mvh\",\n        str(entry_o),\n        str(kernel_o),\n        \"-lm\",\n        \"-Wl,--start-group\",\n        *[str(f) for f in lib_files],\n        \"-Wl,--end-group\",\n    ]\n\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    if result.returncode != 0:\n        print(f\"clang++ stderr:\\n{result.stderr}\", file=sys.stderr)\n        raise subprocess.CalledProcessError(result.returncode, cmd)\n\n    return out_adx\n\n\ndef _boardfarm_get_iceman_port(remote: str, board_id: int, account: str, password: str) -> int | None:\n    \"\"\"Query boardfarm API for the current iceman port of board_id.\n\n    Returns the port int if iceman is running, None if not running or board not found.\n    \"\"\"\n    try:\n        import urllib.request\n        import urllib.error\n        import json\n        import ssl\n        import base64\n\n        url = f\"https://{remote}/api/v2/my_boards/\"\n        token = base64.b64encode(f\"{account}:{password}\".encode()).decode()\n        req = urllib.request.Request(url, headers={\"Authorization\": f\"Basic {token}\"})\n        ctx = ssl.create_default_context()\n        ctx.check_hostname = False\n        ctx.verify_mode = ssl.CERT_NONE\n        with urllib.request.urlopen(req, context=ctx, timeout=30) as resp:\n            data = json.loads(resp.read())\n        results = data.get(\"results\", [])\n        for board in results:\n            if board.get(\"id\") == board_id:\n                port_str = board.get(\"iceman_port\")\n                if port_str:\n                    return int(port_str.split(\":\")[1])\n                return None\n        print(f\"  [boardfarm] warning: board_id={board_id} not found in results\", file=sys.stderr)\n        return None\n    except Exception as e:\n        print(f\"  [boardfarm] GET my_boards failed: {e}\", file=sys.stderr)\n        return None\n\n\ndef _boardfarm_launch_iceman(remote: str, board_id: int, port: int, account: str, password: str) -> bool:\n    \"\"\"POST launch_iceman for board_id. Returns True on HTTP 200.\"\"\"\n    try:\n        import urllib.request\n        import urllib.parse\n        import ssl\n        import base64\n\n        url = f\"https://{remote}/api/v2/my_boards/{board_id}/launch_iceman/\"\n        token = base64.b64encode(f\"{account}:{password}\".encode()).decode()\n        body = urllib.parse.urlencode({\"iceman_flag\": f\"-p {port} -D -Z v5\"}).encode()\n        req = urllib.request.Request(url, data=body, headers={\n            \"Authorization\": f\"Basic {token}\",\n            \"Content-Type\": \"application/x-www-form-urlencoded\",\n        })\n        ctx = ssl.create_default_context()\n        ctx.check_hostname = False\n        ctx.verify_mode = ssl.CERT_NONE\n        with urllib.request.urlopen(req, context=ctx, timeout=30) as resp:\n            return resp.status == 200\n    except Exception as e:\n        print(f\"  [boardfarm] launch_iceman failed: {e}\", file=sys.stderr)\n        return False\n\n\ndef _boardfarm_reconnect(remote: str, board_id: int, port: int, account: str, password: str,\n                         max_attempts: int = 3) -> int | None:\n    \"\"\"Try to recover iceman: query current port, or launch and poll.\n\n    Returns new port int on success, None on failure.\n    \"\"\"\n    print(f\"  [boardfarm] reconnecting board_id={board_id} on {remote} ...\", file=sys.stderr)\n\n    # Step 1: maybe iceman is already running on a different port\n    new_port = _boardfarm_get_iceman_port(remote, board_id, account, password)\n    if new_port is not None:\n        print(f\"  [boardfarm] iceman already running on port {new_port}\", file=sys.stderr)\n        return new_port\n\n    # Step 2: launch iceman, poll for port\n    for attempt in range(1, max_attempts + 1):\n        print(f\"  [boardfarm] launch_iceman attempt {attempt}/{max_attempts} ...\", file=sys.stderr)\n        _boardfarm_launch_iceman(remote, board_id, port, account, password)\n        time.sleep(60)\n        new_port = _boardfarm_get_iceman_port(remote, board_id, account, password)\n        if new_port is not None:\n            print(f\"  [boardfarm] iceman started on port {new_port}\", file=sys.stderr)\n            return new_port\n\n    print(f\"  [boardfarm] failed to start iceman after {max_attempts} attempts\", file=sys.stderr)\n    return None\n\n\ndef _is_connection_error(output: str) -> bool:\n    return (\n        \"Connection timed out\" in output\n        or \"Connection refused\" in output\n        or \"Network is unreachable\" in output\n        or \"could not connect\" in output\n    )\n\n\ndef load_boards(cfg: dict) -> list[dict]:\n    \"\"\"Return list of board configs from cfg.\n\n    Supports two TOML formats:\n      - New:  [[target.boards]]  (array of board dicts); shared fields\n              (gdb, boardfarm_account, boardfarm_password) may be placed\n              in [target] and are inherited by each board unless overridden.\n      - Old:  [target.gdb]       (single board, for backward compat)\n    \"\"\"\n    target = cfg.get(\"target\", {})\n    boards = target.get(\"boards\")\n    if boards:\n        # Shared fields from [target] inherited by each board\n        shared = {k: v for k, v in target.items()\n                  if k not in (\"boards\", \"device\", \"gdb\") and not isinstance(v, (dict, list))}\n        if \"gdb\" in target:\n            shared[\"gdb\"] = target[\"gdb\"]\n        return [{**shared, **board} for board in boards]\n    # Fall back to legacy [target.gdb]\n    gdb_cfg = target.get(\"gdb\", {})\n    if gdb_cfg:\n        return [gdb_cfg]\n    return []\n\n\ndef stage4_run_gdb(adx_path: Path, cfg_or_board: dict, timeout: float | None = None) -> str:\n    \"\"\"Stage 4: upload and execute via GDB. Returns stdout+stderr.\n\n    Accepts either a full cfg dict (uses first board) or a board dict directly.\n    Automatically reconnects via boardfarm API on connection failure.\n    Raises subprocess.TimeoutExpired if timeout (seconds) is exceeded.\n    \"\"\"\n    # Accept either full cfg or a board dict\n    if \"target\" in cfg_or_board or \"build\" in cfg_or_board:\n        boards = load_boards(cfg_or_board)\n        board = boards[0] if boards else {}\n    else:\n        board = cfg_or_board\n\n    gdb = board.get(\"gdb\")\n    remote = board.get(\"remote\", \"\")\n    port = board.get(\"port\")\n    board_id = board.get(\"board_id\", 0)\n    account = board.get(\"boardfarm_account\") or os.environ.get(\"AUTOIREE_BOARDFARM_ACCOUNT\", \"\")\n    password = board.get(\"boardfarm_password\") or os.environ.get(\"AUTOIREE_BOARDFARM_PASSWORD\", \"\")\n\n    boardfarm_enabled = bool(board_id) and \"boards.andestech.com\" in remote and account and password\n\n    max_retries = 3 if boardfarm_enabled else 1\n    for attempt in range(max_retries):\n        cmd = [\n            gdb,\n            str(adx_path),\n            \"-batch\",\n            \"-ex\", f\"target remote {remote}:{port}\",\n            \"-x\", str(BARE_METAL_GDB_SCRIPT),\n        ]\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)\n        output = result.stdout + result.stderr\n\n        if not _is_connection_error(output) or not boardfarm_enabled:\n            return output\n\n        print(f\"  [gdb] connection error on attempt {attempt + 1}, trying boardfarm reconnect ...\",\n              file=sys.stderr)\n        new_port = _boardfarm_reconnect(remote, board_id, port, account, password)\n        if new_port is None:\n            return output\n        port = new_port\n\n    return output\n\n\n_WRITER_SENTINEL = None  # sentinel to stop writer thread\n\n\ndef run_adx_files_parallel(\n    adx_files: list,\n    cfg: dict,\n    result_file: Path | None = None,\n    on_result=None,\n) -> list[tuple]:\n    \"\"\"Run adx_files across all configured boards in parallel.\n\n    Distributes work via a shared work queue: each board runs one file at a\n    time, picks the next from the queue when done.\n\n    Results (adx_path, output) are pushed to a result_queue consumed by a\n    single dedicated writer thread — no lock needed on the file.\n\n    If result_file is given, the writer appends TSV rows:\n        <adx_name>\\\\t<Pass|Timeout|Fail>\\\\t<cycles or \"\">\n\n    Returns list of (adx_path, output) tuples in completion order.\n    \"\"\"\n    import threading\n\n    boards = load_boards(cfg)\n    if not boards:\n        raise ValueError(\"No boards configured in [target.gdb] or [[target.boards]]\")\n\n    work_queue: queue.Queue = queue.Queue()\n    for adx in adx_files:\n        work_queue.put(adx)\n\n    result_queue: queue.Queue = queue.Queue()\n    results: list[tuple] = []\n\n    def _status_and_cycles(output: str) -> tuple[str, str]:\n        cycles = _parse_cycle_count(output)\n        if cycles:\n            return \"Pass\", cycles\n        if \"timed out\" in output.lower() or \"timeout\" in output.lower():\n            return \"Timeout\", \"\"\n        return \"Fail\", \"\"\n\n    def _writer():\n        \"\"\"Single thread that drains result_queue and writes to file.\"\"\"\n        fh = open(result_file, \"a\") if result_file else None\n        if fh:\n            fh.write(\"adx_file\\tstatus\\tcycles\\n\")\n        while True:\n            item = result_queue.get()\n            if item is _WRITER_SENTINEL:\n                break\n            adx, output, board = item\n            results.append((adx, output))\n            status, cycles = _status_and_cycles(output)\n            if fh:\n                fh.write(f\"{adx.name}\\t{status}\\t{cycles}\\n\")\n                fh.flush()\n            if on_result:\n                on_result(adx, status, cycles, output, board)\n        if fh:\n            fh.close()\n\n    writer_thread = threading.Thread(target=_writer, daemon=True)\n    writer_thread.start()\n\n    def worker(board: dict):\n        while True:\n            try:\n                adx = work_queue.get_nowait()\n            except queue.Empty:\n                break\n            output = stage4_run_gdb(adx, board)\n            result_queue.put((adx, output, board))\n            work_queue.task_done()\n\n    with ThreadPoolExecutor(max_workers=len(boards)) as executor:\n        futures = [executor.submit(worker, board) for board in boards]\n        for f in as_completed(futures):\n            f.result()  # re-raise any exception\n\n    result_queue.put(_WRITER_SENTINEL)  # signal writer to stop\n    writer_thread.join()\n\n    return results\n\n\ndef _parse_cycle_count(gdb_output: str) -> str | None:\n    \"\"\"Extract cycle count from GDB stdout.\"\"\"\n    m = re.search(r'The cycle count is (\\d+)', gdb_output)\n    return m.group(1) if m else None\n\n\ndef compile_mlir_to_adx(mlir_file: Path, output_dir: Path, cfg: dict) -> tuple[Path, str]:\n    \"\"\"Compile a single MLIR file to a bare-metal .adx ELF.\n\n    Returns: (adx_path, compile_stderr) where compile_stderr contains\n    optimization remarks for spill detection.\n    \"\"\"\n    mlir_file = mlir_file.resolve()\n    output_dir = Path(output_dir)\n    output_dir.mkdir(parents=True, exist_ok=True)\n\n    stem = mlir_file.stem\n    temp_dir = (output_dir / \"temp\" / stem).resolve()\n    temp_dir.mkdir(parents=True, exist_ok=True)\n    benchmarks_dir = temp_dir / \"benchmarks\"\n\n    benchmark_mlir = stage1_dump_benchmarks(mlir_file, benchmarks_dir, cfg)\n    entry_func = _detect_entry_func_from_benchmark(benchmark_mlir)\n    host_c_h, kernel_h, kernel_o, compile_stderr = stage1_compile_vmc(benchmark_mlir, temp_dir, cfg)\n    entry_o = stage2_compile_entry(kernel_h, entry_func, temp_dir, cfg)\n    out_adx = output_dir / f\"{stem}.adx\"\n    stage3_link_adx(entry_o, kernel_o, out_adx, cfg)\n    shutil.rmtree(temp_dir, ignore_errors=True)\n    return out_adx, compile_stderr\n\n\ndef cmd_compile(args):\n    mlir_file = args.mlir_file.resolve()\n    if not mlir_file.exists():\n        sys.exit(f\"Error: MLIR file not found: {mlir_file}\")\n\n    output_dir = args.output_dir.resolve()\n    output_dir.mkdir(parents=True, exist_ok=True)\n\n    stem = mlir_file.stem\n    temp_dir = (output_dir / \"temp\" / stem).resolve()\n    temp_dir.mkdir(parents=True, exist_ok=True)\n    benchmarks_dir = temp_dir / \"benchmarks\"\n\n    cfg = load_config(args.config)\n\n    print(\"Stage 1a: iree-compile → benchmark MLIR ...\")\n    benchmark_mlir = stage1_dump_benchmarks(mlir_file, benchmarks_dir, cfg)\n    print(f\"  benchmark: {benchmark_mlir.name}\")\n\n    entry_func = args.entry_func or _detect_entry_func_from_benchmark(benchmark_mlir)\n    print(f\"  entry func: {entry_func}\")\n\n    print(\"Stage 1b: iree-compile → vm-c ...\")\n    host_c_h, kernel_h, kernel_o, _stderr = stage1_compile_vmc(benchmark_mlir, temp_dir, cfg)\n    print(f\"  host-c.h : {host_c_h.name}\")\n    print(f\"  kernel.h : {kernel_h.name}\")\n    print(f\"  kernel.o : {kernel_o.name}\")\n\n    print(\"Stage 2: clang dispatch_driver.c → entry.o ...\")\n    entry_o = stage2_compile_entry(kernel_h, entry_func, temp_dir, cfg)\n    print(f\"  entry.o  : {entry_o.name}\")\n\n    out_adx = output_dir / f\"{stem}.adx\"\n    print(f\"Stage 3: clang++ link → {out_adx.name} ...\")\n    stage3_link_adx(entry_o, kernel_o, out_adx, cfg)\n\n    shutil.rmtree(temp_dir, ignore_errors=True)\n    print(f\"Done: {out_adx}\")\n\n\ndef cmd_run(args):\n    cfg = load_config(args.config)\n\n    # Collect .adx files from file args or directory\n    adx_files = []\n    for path in args.adx_paths:\n        p = Path(path).resolve()\n        if p.is_dir():\n            adx_files.extend(sorted(p.glob(\"*.adx\")))\n        elif p.suffix == \".adx\":\n            adx_files.append(p)\n        else:\n            sys.exit(f\"Error: expected .adx file or directory, got: {p}\")\n\n    if not adx_files:\n        sys.exit(\"Error: no .adx files found\")\n\n    boards = load_boards(cfg)\n    print(f\"Running {len(adx_files)} file(s) on {len(boards)} board(s) in parallel ...\\n\")\n\n    results = run_adx_files_parallel(adx_files, cfg)\n    for adx, output in sorted(results, key=lambda x: x[0].name):\n        cycles = _parse_cycle_count(output)\n        if cycles:\n            print(f\"  {adx.name}: cycles = {cycles}\")\n        else:\n            hint = next((l for l in output.splitlines() if l.strip()), \"no output\")\n            print(f\"  {adx.name}: FAILED ({hint})\")\n            print(output, file=sys.stderr)\n\n\ndef main():\n    parser = argparse.ArgumentParser(\n        description=\"ADX build and run pipeline for RISC-V bare-metal\"\n    )\n    sub = parser.add_subparsers(dest=\"task\", required=True)\n\n    # --- compile ---\n    p_compile = sub.add_parser(\"compile\", help=\"Compile MLIR to .adx ELF\")\n    p_compile.add_argument(\"mlir_file\", type=Path, help=\"Input MLIR file\")\n    p_compile.add_argument(\"-o\", \"--output-dir\", type=Path, required=True,\n                           help=\"Output directory for .adx file\")\n    p_compile.add_argument(\"--config\", default=\"config/AX45_1024.toml\",\n                           help=\"TOML config (default: config/AX45_1024.toml)\")\n    p_compile.add_argument(\"--entry-func\", default=None,\n                           help=\"Entry function name (overrides auto-detection)\")\n\n    # --- run ---\n    p_run = sub.add_parser(\"run\", help=\"Run .adx file(s) via GDB\")\n    p_run.add_argument(\"adx_paths\", nargs=\"+\",\n                       help=\".adx file(s) or directory containing .adx files\")\n    p_run.add_argument(\"--config\", default=\"config/AX45_1024.toml\",\n                       help=\"TOML config (default: config/AX45_1024.toml)\")\n\n    args = parser.parse_args()\n    if args.task == \"compile\":\n        cmd_compile(args)\n    elif args.task == \"run\":\n        cmd_run(args)\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":669,"startLine":1,"totalLines":669}},"sourceToolAssistantUUID":"5d909944-b756-48ee-b377-59db77cb1da3"}
