{"parentUuid":"5a7d87b8-73ba-4bc3-9592-4acff5b93c50","isSidechain":false,"userType":"external","cwd":"/home/nick/work/ai_iree","sessionId":"71dec615-7b07-4e9a-9c31-50ec143dbbf8","version":"2.1.72","gitBranch":"master","slug":"purrfect-wandering-puppy","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HZ3unXYgBngus7cuaRUMq9","type":"tool_result","content":"     1→\"\"\"Tests for ProbeCache, cached probe_fn, and --skip-test-probe flag.\"\"\"\n     2→\n     3→import threading\n     4→from argparse import Namespace\n     5→from unittest.mock import patch, MagicMock\n     6→from dataset_generator.compiler import ProbeCache, make_dist_probe_fn\n     7→from dataset_generator.cli.tasks.search import should_skip_probe\n     8→\n     9→\n    10→class TestProbeCache:\n    11→    \"\"\"Tests for ProbeCache get/put and hit/miss tracking.\"\"\"\n    12→\n    13→    def test_get_returns_none_for_missing_key(self):\n    14→        cache = ProbeCache()\n    15→        assert cache.get((\"tmpl\", 4, 8)) is None\n    16→\n    17→    def test_put_then_get_returns_value(self):\n    18→        cache = ProbeCache()\n    19→        key = (\"tmpl\", 4, 8)\n    20→        value = {32: 16, 64: 8}\n    21→        cache.put(key, value)\n    22→        assert cache.get(key) == value\n    23→\n    24→    def test_hit_miss_counters(self):\n    25→        cache = ProbeCache()\n    26→        key = (\"tmpl\", 4, 8)\n    27→        cache.get(key)           # miss (returns None, no counter bump)\n    28→        cache.put(key, {32: 16}) # miss += 1\n    29→        cache.get(key)           # hit += 1\n    30→        cache.get(key)           # hit += 1\n    31→        assert cache.hits == 2\n    32→        assert cache.misses == 1\n    33→\n    34→    def test_thread_safety(self):\n    35→        cache = ProbeCache()\n    36→        errors = []\n    37→\n    38→        def writer(start):\n    39→            try:\n    40→                for i in range(100):\n    41→                    cache.put((\"t\", start + i, 0), i)\n    42→            except Exception as e:\n    43→                errors.append(e)\n    44→\n    45→        def reader(start):\n    46→            try:\n    47→                for i in range(100):\n    48→                    cache.get((\"t\", start + i, 0))\n    49→            except Exception as e:\n    50→                errors.append(e)\n    51→\n    52→        threads = []\n    53→        for t in range(4):\n    54→            threads.append(threading.Thread(target=writer, args=(t * 100,)))\n    55→            threads.append(threading.Thread(target=reader, args=(t * 100,)))\n    56→        for t in threads:\n    57→            t.start()\n    58→        for t in threads:\n    59→            t.join()\n    60→\n    61→        assert not errors\n    62→\n    63→\n    64→class TestMakeDistProbeFnWithCache:\n    65→    \"\"\"Test that make_dist_probe_fn uses cache when provided.\"\"\"\n    66→\n    67→    @patch(\"dataset_generator.compiler.probe_spill_bounds\")\n    68→    def test_cache_hit_skips_probe(self, mock_probe):\n    69→        \"\"\"Second call with same (template, dist_outer, dist_inner) returns cached result.\"\"\"\n    70→        mock_probe.return_value = {32: 8}\n    71→        pattern_info = {\"template\": \"func @main(%arg0: tensor<4x8xf32>)\"}\n    72→        cache = ProbeCache()\n    73→\n    74→        probe_fn = make_dist_probe_fn(\n    75→            pattern_info, [\"iree-compile\"], \"/tmp/probe\",\n    76→            timeout=10, workers=1, cache=cache,\n    77→        )\n    78→\n    79→        # First call — cache miss, calls probe_spill_bounds\n    80→        result1 = probe_fn((4, 8), {})\n    81→        assert result1 == {32: 8}\n    82→        assert mock_probe.call_count == 1\n    83→\n    84→        # Second call with same l0_tiles — cache hit\n    85→        result2 = probe_fn((4, 8), {})\n    86→        assert result2 == {32: 8}\n    87→        assert mock_probe.call_count == 1  # NOT called again\n    88→\n    89→        assert cache.hits == 1\n    90→        assert cache.misses == 1\n    91→\n    92→    @patch(\"dataset_generator.compiler.probe_spill_bounds\")\n    93→    def test_different_dist_pair_is_cache_miss(self, mock_probe):\n    94→        \"\"\"Different (dist_outer, dist_inner) causes a cache miss.\"\"\"\n    95→        mock_probe.return_value = {32: 8}\n    96→        pattern_info = {\"template\": \"func @main(%arg0: tensor<4x8xf32>)\"}\n    97→        cache = ProbeCache()\n    98→\n    99→        probe_fn = make_dist_probe_fn(\n   100→            pattern_info, [\"iree-compile\"], \"/tmp/probe\",\n   101→            timeout=10, workers=1, cache=cache,\n   102→        )\n   103→\n   104→        probe_fn((4, 8), {})\n   105→        probe_fn((4, 16), {})\n   106→        assert mock_probe.call_count == 2\n   107→        assert cache.misses == 2\n   108→\n   109→    @patch(\"dataset_generator.compiler.probe_spill_bounds\")\n   110→    def test_no_cache_calls_every_time(self, mock_probe):\n   111→        \"\"\"Without cache, every call invokes probe_spill_bounds.\"\"\"\n   112→        mock_probe.return_value = {32: 8}\n   113→        pattern_info = {\"template\": \"func @main(%arg0: tensor<4x8xf32>)\"}\n   114→\n   115→        probe_fn = make_dist_probe_fn(\n   116→            pattern_info, [\"iree-compile\"], \"/tmp/probe\",\n   117→            timeout=10, workers=1,\n   118→        )\n   119→\n   120→        probe_fn((4, 8), {})\n   121→        probe_fn((4, 8), {})\n   122→        assert mock_probe.call_count == 2\n   123→\n   124→    @patch(\"dataset_generator.compiler.probe_spill_bounds\")\n   125→    def test_different_templates_separate_cache_entries(self, mock_probe):\n   126→        \"\"\"Two probe_fns with different templates don't share cache entries.\"\"\"\n   127→        mock_probe.side_effect = lambda *a, **kw: {32: 8}\n   128→        cache = ProbeCache()\n   129→\n   130→        probe_fn_a = make_dist_probe_fn(\n   131→            {\"template\": \"template_A\"}, [\"iree-compile\"], \"/tmp/probe\",\n   132→            timeout=10, workers=1, cache=cache,\n   133→        )\n   134→        probe_fn_b = make_dist_probe_fn(\n   135→            {\"template\": \"template_B\"}, [\"iree-compile\"], \"/tmp/probe\",\n   136→            timeout=10, workers=1, cache=cache,\n   137→        )\n   138→\n   139→        probe_fn_a((4, 8), {})\n   140→        probe_fn_b((4, 8), {})\n   141→        # Both should miss — different templates\n   142→        assert mock_probe.call_count == 2\n   143→        assert cache.misses == 2\n   144→\n   145→\n   146→class TestShouldSkipProbe:\n   147→    \"\"\"Test should_skip_probe() for --skip-test-probe flag.\"\"\"\n   148→\n   149→    def test_skip_test_split_when_flag_set(self):\n   150→        args = Namespace(skip_test_probe=True)\n   151→        assert should_skip_probe(args, \"test\") is True\n   152→\n   153→    def test_no_skip_train_split_when_flag_set(self):\n   154→        args = Namespace(skip_test_probe=True)\n   155→        assert should_skip_probe(args, \"train\") is False\n   156→\n   157→    def test_no_skip_val_split_when_flag_set(self):\n   158→        args = Namespace(skip_test_probe=True)\n   159→        assert should_skip_probe(args, \"val\") is False\n   160→\n   161→    def test_no_skip_test_split_when_flag_not_set(self):\n   162→        args = Namespace(skip_test_probe=False)\n   163→        assert should_skip_probe(args, \"test\") is False\n   164→\n   165→    def test_no_skip_when_flag_missing(self):\n   166→        args = Namespace()\n   167→        assert should_skip_probe(args, \"test\") is False\n   168→"}]},"uuid":"24d9da01-7572-4f0f-9606-d585615fe566","timestamp":"2026-03-20T02:57:59.235Z"},"type":"agent_progress","prompt":"","agentId":"a8ddd474f8dda762a"},"toolUseID":"agent_msg_01KTMWet1JMio5kf8oDY87bs","parentToolUseID":"toolu_01WvKHvxmXK9T5pdyr67cNsK","uuid":"3d8bea12-527a-43bc-8d1e-4240cf2b1e5e","timestamp":"2026-03-20T02:57:59.236Z"}
