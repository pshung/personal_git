\n        # N should be maximized (algorithm tries largest N first)\n        # Verify dist_inner is as large as possible\n        assert dist_inner > 1, \"dist_inner should be > 1 with this budget\"\n\n    def test_b_tile_exceeds_budget(self):\n        \"\"\"\n        Test case where B_tile alone exceeds budget.\n\n        Should skip to smaller dist_inner values.\n        \"\"\"\n        M = 1024\n        N = 1024\n        K = 1024\n        input_bytes = 4\n        output_bytes = 4\n        l2_targets = [1 * 1024 * 1024]  # 1MB\n\n        # B_tile with full N = 1024 × 1024 × 4 = 4MB > 1MB budget\n        # Algorithm should try smaller N divisors\n\n        pairs = generate_dist_first_candidates(\n            dim_inner=N,\n            dim_outer=M,\n            dim_reduction=K,\n            input_dtype_bytes=input_bytes,\n            output_dtype_bytes=output_bytes,\n            l2_targets=l2_targets,\n        )\n\n        assert len(pairs) == 1\n        dist_outer, dist_inner = pairs[0]\n\n        # Verify working set fits\n        a_tile = dist_outer * K * input_bytes\n        b_tile = K * dist_inner * input_bytes\n        c_tile = dist_outer * dist_inner * output_bytes\n        working_set = a_tile + b_tile + c_tile\n\n        assert working_set <= 1 * 1024 * 1024, \\\n            f\"Working set {working_set} exceeds 1MB\"\n\n        # Should find smaller dist_inner\n        assert dist_inner < N, \\\n            f\"dist_inner should be < {N} when B_tile exceeds budget\"\n\n    def test_no_valid_tile_fallback(self):\n        \"\"\"\n        Test fallback to (1, 1) when no valid tile fits.\n\n        With very small L2 target, may need to fall back.\n        \"\"\"\n        M = 1024\n        N = 1024\n        K = 1024\n        input_bytes = 4\n        output_bytes = 4\n        l2_targets = [100]  # 100 bytes (impossibly small)\n\n        pairs = generate_dist_first_candidates(\n            dim_inner=N,\n            dim_outer=M,\n            dim_reduction=K,\n            input_dtype_bytes=input_bytes,\n            output_dtype_bytes=output_bytes,\n            l2_targets=l2_targets,\n        )\n\n        # Should still generate a pair (fallback to (1, 1))\n        assert len(pairs) == 1\n        dist_outer, dist_inner = pairs[0]\n\n        # With such a small budget, should get minimal tile\n        assert dist_outer >= 1 and dist_inner >= 1, \\\n            \"Should fall back to at least (1, 1)\"\n\n    def test_deduplication_across_targets(self):\n        \"\"\"\n        Test that duplicate tiles are deduplicated.\n\n        If multiple L2 targets produce the same tile, should only return once.\n        \"\"\"\n        M = 64\n        N = 64\n        K = 64\n        input_bytes = 4\n        output_bytes = 4\n        # All these targets should produce the same (64, 64) tile\n        l2_targets = [1 * 1024 * 1024, 4 * 1024 * 1024, 5 * 1024 * 1024, 6 * 1024 * 1024]\n\n        pairs = generate_dist_first_candidates(\n            dim_inner=N,\n            dim_outer=M,\n            dim_reduction=K,\n            input_dtype_bytes=input_bytes,\n            output_dtype_bytes=output_bytes,\n            l2_targets=l2_targets,\n        )\n\n        # Should deduplicate to single pair\n        assert len(pairs) == 1, f\"Should deduplicate to 1 pair, got {len(pairs)}\"\n        assert pairs[0] == (M, N), f\"Should be ({M}, {N}), got {pairs[0]}\"\n\n    def test_default_l2_targets(self):\n        \"\"\"Test that default L2_TARGETS from config are used when not specified.\"\"\"\n        M = 1024\n        N = 192\n        K = 768\n        input_bytes = 1\n        output_bytes = 4\n\n        # Call without l2_targets parameter\n        pairs = generate_dist_first_candidates(\n            dim_inner=N,\n            dim_outer=M,\n            dim_reduction=K,\n            input_dtype_bytes=input_bytes,\n            output_dtype_bytes=output_bytes,\n        )\n\n        # Should use default L2_TARGETS = [1MB, 4MB, 5MB, 6MB]\n        # Should generate at least 1 pair\n        assert len(pairs) >= 1, \"Should generate pairs using default L2_TARGETS\"\n\n        # Verify all working sets are valid\n        for dist_outer, dist_inner in pairs:\n            a_tile = dist_outer * K * input_bytes\n            b_tile = K * dist_inner * input_bytes\n            c_tile = dist_outer * dist_inner * output_bytes\n            working_set = a_tile + b_tile + c_tile\n            # Should fit within largest default target (6MB)\n            assert working_set <= 6 * 1024 * 1024, \\\n                f\"Working set {working_set} exceeds largest default target\"\n","numLines":337,"startLine":1,"totalLines":337}},"sourceToolAssistantUUID":"03d2656c-a49a-4336-9fc0-272d54ff51ce"}
